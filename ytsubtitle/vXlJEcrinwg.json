[
  {
    "startTime": 12.88,
    "endTime": 14.32,
    "text": "there are two"
  },
  {
    "startTime": 14.32,
    "endTime": 18.0,
    "text": "powerful phenomena unfolding on earth"
  },
  {
    "startTime": 18.0,
    "endTime": 20.16,
    "text": "the rise of global warming"
  },
  {
    "startTime": 20.16,
    "endTime": 23.519,
    "text": "and the rise of women and girls"
  },
  {
    "startTime": 23.519,
    "endTime": 25.519,
    "text": "the link between them is often"
  },
  {
    "startTime": 25.519,
    "endTime": 26.88,
    "text": "overlooked"
  },
  {
    "startTime": 26.88,
    "endTime": 30.24,
    "text": "but gender equity is a key answer to our"
  },
  {
    "startTime": 30.24,
    "endTime": 32.32,
    "text": "planetary challenge"
  },
  {
    "startTime": 32.32,
    "endTime": 34.719,
    "text": "let me explain"
  },
  {
    "startTime": 34.719,
    "endTime": 36.559,
    "text": "for the last few years i have been"
  },
  {
    "startTime": 36.559,
    "endTime": 38.719,
    "text": "working on an effort called project"
  },
  {
    "startTime": 38.719,
    "endTime": 40.16,
    "text": "drawdown"
  },
  {
    "startTime": 40.16,
    "endTime": 43.12,
    "text": "our team has scoured humanity's wisdom"
  },
  {
    "startTime": 43.12,
    "endTime": 46.0,
    "text": "for solutions to draw down"
  },
  {
    "startTime": 46.0,
    "endTime": 47.44,
    "text": "heat trapping"
  },
  {
    "startTime": 47.44,
    "endTime": 49.44,
    "text": "climate changing emissions in the"
  },
  {
    "startTime": 49.44,
    "endTime": 51.039,
    "text": "atmosphere"
  },
  {
    "startTime": 51.039,
    "endTime": 51.84,
    "text": "not"
  },
  {
    "startTime": 51.84,
    "endTime": 55.12,
    "text": "someday maybe if we're lucky solutions"
  },
  {
    "startTime": 55.12,
    "endTime": 58.64,
    "text": "the 80 best practices and technologies"
  },
  {
    "startTime": 58.64,
    "endTime": 60.719,
    "text": "already in hand"
  },
  {
    "startTime": 60.719,
    "endTime": 61.6,
    "text": "clean"
  },
  {
    "startTime": 61.6,
    "endTime": 63.199,
    "text": "renewable energy"
  },
  {
    "startTime": 63.199,
    "endTime": 64.72,
    "text": "including solar"
  },
  {
    "startTime": 64.72,
    "endTime": 66.479,
    "text": "and wind"
  },
  {
    "startTime": 66.479,
    "endTime": 67.92,
    "text": "green buildings"
  },
  {
    "startTime": 67.92,
    "endTime": 69.28,
    "text": "both new"
  },
  {
    "startTime": 69.28,
    "endTime": 71.439,
    "text": "and retrofitted"
  },
  {
    "startTime": 71.439,
    "endTime": 74.159,
    "text": "efficient transportation from brazil"
  },
  {
    "startTime": 74.159,
    "endTime": 75.76,
    "text": "to china"
  },
  {
    "startTime": 75.76,
    "endTime": 78.159,
    "text": "thriving ecosystems"
  },
  {
    "startTime": 78.159,
    "endTime": 79.6,
    "text": "through protection"
  },
  {
    "startTime": 79.6,
    "endTime": 81.36,
    "text": "and restoration"
  },
  {
    "startTime": 81.36,
    "endTime": 83.2,
    "text": "reducing waste"
  },
  {
    "startTime": 83.2,
    "endTime": 85.759,
    "text": "and reclaiming its value"
  },
  {
    "startTime": 85.759,
    "endTime": 88.479,
    "text": "growing food in good ways"
  },
  {
    "startTime": 88.479,
    "endTime": 91.04,
    "text": "that regenerate soil"
  },
  {
    "startTime": 91.04,
    "endTime": 92.64,
    "text": "shifting diets"
  },
  {
    "startTime": 92.64,
    "endTime": 94.64,
    "text": "to less meat"
  },
  {
    "startTime": 94.64,
    "endTime": 96.32,
    "text": "more plants"
  },
  {
    "startTime": 96.32,
    "endTime": 97.28,
    "text": "and"
  },
  {
    "startTime": 97.28,
    "endTime": 100.56,
    "text": "equity for women and girls"
  },
  {
    "startTime": 100.56,
    "endTime": 103.28,
    "text": "gender and climate are inextricably"
  },
  {
    "startTime": 103.28,
    "endTime": 104.799,
    "text": "linked"
  },
  {
    "startTime": 104.799,
    "endTime": 107.119,
    "text": "drawing down emissions"
  },
  {
    "startTime": 107.119,
    "endTime": 110.64,
    "text": "depends on rising up"
  },
  {
    "startTime": 110.799,
    "endTime": 113.28,
    "text": "first a bit of context"
  },
  {
    "startTime": 113.28,
    "endTime": 116.159,
    "text": "we are in a situation of urgency"
  },
  {
    "startTime": 116.159,
    "endTime": 117.92,
    "text": "severity and scope"
  },
  {
    "startTime": 117.92,
    "endTime": 121.28,
    "text": "never before faced by humankind"
  },
  {
    "startTime": 121.28,
    "endTime": 123.28,
    "text": "so far"
  },
  {
    "startTime": 123.28,
    "endTime": 125.36,
    "text": "our response isn't anywhere close to"
  },
  {
    "startTime": 125.36,
    "endTime": 127.6,
    "text": "adequate"
  },
  {
    "startTime": 127.6,
    "endTime": 130.08,
    "text": "but you already know that"
  },
  {
    "startTime": 130.08,
    "endTime": 132.4,
    "text": "you know it in your gut"
  },
  {
    "startTime": 132.4,
    "endTime": 134.959,
    "text": "in your bones"
  },
  {
    "startTime": 134.959,
    "endTime": 137.04,
    "text": "we are each part of the planet's living"
  },
  {
    "startTime": 137.04,
    "endTime": 138.16,
    "text": "systems"
  },
  {
    "startTime": 138.16,
    "endTime": 142.0,
    "text": "knitted together with almost 7.7 billion"
  },
  {
    "startTime": 142.0,
    "endTime": 143.36,
    "text": "human beings"
  },
  {
    "startTime": 143.36,
    "endTime": 147.76,
    "text": "and 1.8 million known species"
  },
  {
    "startTime": 147.76,
    "endTime": 151.599,
    "text": "we can feel the connections between us"
  },
  {
    "startTime": 151.599,
    "endTime": 153.68,
    "text": "we can feel the brokenness"
  },
  {
    "startTime": 153.68,
    "endTime": 156.959,
    "text": "and the closing window to heal it"
  },
  {
    "startTime": 156.959,
    "endTime": 158.8,
    "text": "this earth"
  },
  {
    "startTime": 158.8,
    "endTime": 160.48,
    "text": "our home"
  },
  {
    "startTime": 160.48,
    "endTime": 163.12,
    "text": "is telling us that a better way of being"
  },
  {
    "startTime": 163.12,
    "endTime": 166.56,
    "text": "must emerge and fast"
  },
  {
    "startTime": 167.36,
    "endTime": 170.4,
    "text": "in my experience to have eyes wide open"
  },
  {
    "startTime": 170.4,
    "endTime": 173.519,
    "text": "is to hold a broken heart every day"
  },
  {
    "startTime": 173.519,
    "endTime": 176.56,
    "text": "it's a grief that i rarely speak"
  },
  {
    "startTime": 176.56,
    "endTime": 179.36,
    "text": "though my work calls on the power of"
  },
  {
    "startTime": 179.36,
    "endTime": 181.76,
    "text": "voice"
  },
  {
    "startTime": 182.08,
    "endTime": 184.0,
    "text": "i remind myself that the heart can"
  },
  {
    "startTime": 184.0,
    "endTime": 185.599,
    "text": "simply break"
  },
  {
    "startTime": 185.599,
    "endTime": 188.56,
    "text": "or it can break open"
  },
  {
    "startTime": 188.56,
    "endTime": 191.44,
    "text": "a broken open heart is awake"
  },
  {
    "startTime": 191.44,
    "endTime": 194.64,
    "text": "and alive and calls for action"
  },
  {
    "startTime": 194.64,
    "endTime": 196.64,
    "text": "it is regenerative"
  },
  {
    "startTime": 196.64,
    "endTime": 198.56,
    "text": "like nature"
  },
  {
    "startTime": 198.56,
    "endTime": 202.319,
    "text": "reclaiming ruined ground growing anew"
  },
  {
    "startTime": 202.319,
    "endTime": 206.0,
    "text": "life moves inexorably toward more life"
  },
  {
    "startTime": 206.0,
    "endTime": 207.599,
    "text": "toward healing"
  },
  {
    "startTime": 207.599,
    "endTime": 209.599,
    "text": "toward wholeness"
  },
  {
    "startTime": 209.599,
    "endTime": 212.879,
    "text": "that's a fundamental ecological truth"
  },
  {
    "startTime": 212.879,
    "endTime": 214.319,
    "text": "and we"
  },
  {
    "startTime": 214.319,
    "endTime": 216.159,
    "text": "all of us"
  },
  {
    "startTime": 216.159,
    "endTime": 219.44,
    "text": "we are life force"
  },
  {
    "startTime": 219.68,
    "endTime": 221.519,
    "text": "on the face of it the primary link"
  },
  {
    "startTime": 221.519,
    "endTime": 224.0,
    "text": "between women girls and a warming world"
  },
  {
    "startTime": 224.0,
    "endTime": 226.72,
    "text": "is not life but death"
  },
  {
    "startTime": 226.72,
    "endTime": 228.879,
    "text": "awareness is growing that climate"
  },
  {
    "startTime": 228.879,
    "endTime": 231.599,
    "text": "impacts hit women and girls hardest"
  },
  {
    "startTime": 231.599,
    "endTime": 234.4,
    "text": "given existing vulnerabilities"
  },
  {
    "startTime": 234.4,
    "endTime": 237.04,
    "text": "there is greater risk of displacement"
  },
  {
    "startTime": 237.04,
    "endTime": 239.28,
    "text": "higher odds of being injured or killed"
  },
  {
    "startTime": 239.28,
    "endTime": 241.84,
    "text": "during a natural disaster"
  },
  {
    "startTime": 241.84,
    "endTime": 244.319,
    "text": "prolonged drought can precipitate early"
  },
  {
    "startTime": 244.319,
    "endTime": 246.48,
    "text": "marriage as families contend with"
  },
  {
    "startTime": 246.48,
    "endTime": 248.159,
    "text": "scarcity"
  },
  {
    "startTime": 248.159,
    "endTime": 249.92,
    "text": "floods can force last resort"
  },
  {
    "startTime": 249.92,
    "endTime": 251.36,
    "text": "prostitution"
  },
  {
    "startTime": 251.36,
    "endTime": 254.08,
    "text": "as women struggle to make ends meet the"
  },
  {
    "startTime": 254.08,
    "endTime": 257.12,
    "text": "list goes on and goes wide"
  },
  {
    "startTime": 257.12,
    "endTime": 259.04,
    "text": "these dynamics are most acute under"
  },
  {
    "startTime": 259.04,
    "endTime": 262.0,
    "text": "conditions of poverty from new orleans"
  },
  {
    "startTime": 262.0,
    "endTime": 264.72,
    "text": "to nairobi"
  },
  {
    "startTime": 264.72,
    "endTime": 267.04,
    "text": "too often the story ends here"
  },
  {
    "startTime": 267.04,
    "endTime": 269.04,
    "text": "but not today"
  },
  {
    "startTime": 269.04,
    "endTime": 272.16,
    "text": "another empowering truth begs to be seen"
  },
  {
    "startTime": 272.16,
    "endTime": 275.36,
    "text": "if we gain ground on gender equity"
  },
  {
    "startTime": 275.36,
    "endTime": 278.24,
    "text": "we also gain ground on addressing global"
  },
  {
    "startTime": 278.24,
    "endTime": 280.08,
    "text": "warming"
  },
  {
    "startTime": 280.08,
    "endTime": 282.24,
    "text": "this connection comes to light in three"
  },
  {
    "startTime": 282.24,
    "endTime": 283.84,
    "text": "key areas"
  },
  {
    "startTime": 283.84,
    "endTime": 286.08,
    "text": "three areas where we can secure the"
  },
  {
    "startTime": 286.08,
    "endTime": 288.08,
    "text": "rights of women and girls"
  },
  {
    "startTime": 288.08,
    "endTime": 290.96,
    "text": "shore up resilience and avert emissions"
  },
  {
    "startTime": 290.96,
    "endTime": 293.199,
    "text": "at the same time"
  },
  {
    "startTime": 293.199,
    "endTime": 294.56,
    "text": "women"
  },
  {
    "startTime": 294.56,
    "endTime": 297.28,
    "text": "are the primary farmers of the world"
  },
  {
    "startTime": 297.28,
    "endTime": 299.759,
    "text": "they produce 60 to 80 percent of food in"
  },
  {
    "startTime": 299.759,
    "endTime": 302.0,
    "text": "lower income countries often operating"
  },
  {
    "startTime": 302.0,
    "endTime": 304.16,
    "text": "on fewer than five acres"
  },
  {
    "startTime": 304.16,
    "endTime": 307.6,
    "text": "that's what the term smallholder means"
  },
  {
    "startTime": 307.6,
    "endTime": 309.28,
    "text": "compared with men"
  },
  {
    "startTime": 309.28,
    "endTime": 311.84,
    "text": "women smallholders have less access to"
  },
  {
    "startTime": 311.84,
    "endTime": 314.96,
    "text": "resources including land rights"
  },
  {
    "startTime": 314.96,
    "endTime": 317.36,
    "text": "credit and capital training"
  },
  {
    "startTime": 317.36,
    "endTime": 319.36,
    "text": "tools and technology"
  },
  {
    "startTime": 319.36,
    "endTime": 321.6,
    "text": "they farm as capably and efficiently as"
  },
  {
    "startTime": 321.6,
    "endTime": 322.88,
    "text": "men"
  },
  {
    "startTime": 322.88,
    "endTime": 325.039,
    "text": "but this well-documented disparity in"
  },
  {
    "startTime": 325.039,
    "endTime": 327.919,
    "text": "resources and rights means women produce"
  },
  {
    "startTime": 327.919,
    "endTime": 331.36,
    "text": "less food on the same amount of land"
  },
  {
    "startTime": 331.36,
    "endTime": 333.52,
    "text": "close those gaps"
  },
  {
    "startTime": 333.52,
    "endTime": 336.88,
    "text": "and farm yields rise by 20 to 30 percent"
  },
  {
    "startTime": 336.88,
    "endTime": 339.759,
    "text": "that means 20 to 30 percent more food"
  },
  {
    "startTime": 339.759,
    "endTime": 343.68,
    "text": "from the same garden or the same field"
  },
  {
    "startTime": 343.68,
    "endTime": 346.08,
    "text": "the implications for hunger for health"
  },
  {
    "startTime": 346.08,
    "endTime": 347.84,
    "text": "for household income"
  },
  {
    "startTime": 347.84,
    "endTime": 349.44,
    "text": "they're obvious"
  },
  {
    "startTime": 349.44,
    "endTime": 352.96,
    "text": "let's follow the thread to climate"
  },
  {
    "startTime": 352.96,
    "endTime": 356.72,
    "text": "we humans need land to grow food"
  },
  {
    "startTime": 356.72,
    "endTime": 359.28,
    "text": "unfortunately forests are often cleared"
  },
  {
    "startTime": 359.28,
    "endTime": 361.68,
    "text": "to supply it and that causes emissions"
  },
  {
    "startTime": 361.68,
    "endTime": 363.759,
    "text": "from deforestation"
  },
  {
    "startTime": 363.759,
    "endTime": 366.639,
    "text": "but if existing farms produce enough"
  },
  {
    "startTime": 366.639,
    "endTime": 367.84,
    "text": "food"
  },
  {
    "startTime": 367.84,
    "endTime": 370.479,
    "text": "forests are less likely to be lost so"
  },
  {
    "startTime": 370.479,
    "endTime": 372.72,
    "text": "there's a ripple effect"
  },
  {
    "startTime": 372.72,
    "endTime": 374.88,
    "text": "support women small holders"
  },
  {
    "startTime": 374.88,
    "endTime": 377.039,
    "text": "realize higher yields"
  },
  {
    "startTime": 377.039,
    "endTime": 380.08,
    "text": "avoid deforestation and sustain the"
  },
  {
    "startTime": 380.08,
    "endTime": 382.8,
    "text": "life-giving power of forests"
  },
  {
    "startTime": 382.8,
    "endTime": 384.319,
    "text": "project drawdown estimates that"
  },
  {
    "startTime": 384.319,
    "endTime": 386.639,
    "text": "addressing inequity in agriculture could"
  },
  {
    "startTime": 386.639,
    "endTime": 387.6,
    "text": "prevent"
  },
  {
    "startTime": 387.6,
    "endTime": 390.479,
    "text": "2 billion tons of emissions between now"
  },
  {
    "startTime": 390.479,
    "endTime": 392.24,
    "text": "and 2050."
  },
  {
    "startTime": 392.24,
    "endTime": 393.6,
    "text": "that's on par"
  },
  {
    "startTime": 393.6,
    "endTime": 395.52,
    "text": "with the impact household recycling can"
  },
  {
    "startTime": 395.52,
    "endTime": 397.68,
    "text": "have globally"
  },
  {
    "startTime": 397.68,
    "endTime": 399.68,
    "text": "addressing this inequity can also help"
  },
  {
    "startTime": 399.68,
    "endTime": 401.919,
    "text": "women cope with the challenges of"
  },
  {
    "startTime": 401.919,
    "endTime": 406.0,
    "text": "growing food as the climate changes"
  },
  {
    "startTime": 406.0,
    "endTime": 407.68,
    "text": "there is life force"
  },
  {
    "startTime": 407.68,
    "endTime": 409.84,
    "text": "in cultivation"
  },
  {
    "startTime": 409.84,
    "endTime": 411.44,
    "text": "at last count"
  },
  {
    "startTime": 411.44,
    "endTime": 414.56,
    "text": "130 million girls are still denied their"
  },
  {
    "startTime": 414.56,
    "endTime": 417.12,
    "text": "basic right to attend school"
  },
  {
    "startTime": 417.12,
    "endTime": 419.199,
    "text": "gaps are greatest in secondary school"
  },
  {
    "startTime": 419.199,
    "endTime": 420.88,
    "text": "classrooms"
  },
  {
    "startTime": 420.88,
    "endTime": 423.28,
    "text": "too many girls are missing a vital"
  },
  {
    "startTime": 423.28,
    "endTime": 425.44,
    "text": "foundation for life"
  },
  {
    "startTime": 425.44,
    "endTime": 428.319,
    "text": "education means better health for women"
  },
  {
    "startTime": 428.319,
    "endTime": 429.84,
    "text": "and their children"
  },
  {
    "startTime": 429.84,
    "endTime": 432.0,
    "text": "better financial security"
  },
  {
    "startTime": 432.0,
    "endTime": 434.84,
    "text": "greater agency at home and in"
  },
  {
    "startTime": 434.84,
    "endTime": 438.16,
    "text": "society more capacity to navigate a"
  },
  {
    "startTime": 438.16,
    "endTime": 440.479,
    "text": "climate changing world"
  },
  {
    "startTime": 440.479,
    "endTime": 443.44,
    "text": "education can mean options"
  },
  {
    "startTime": 443.44,
    "endTime": 446.0,
    "text": "adaptability strength"
  },
  {
    "startTime": 446.0,
    "endTime": 449.28,
    "text": "it can also mean lower emissions"
  },
  {
    "startTime": 449.28,
    "endTime": 451.919,
    "text": "for a variety of reasons when we have"
  },
  {
    "startTime": 451.919,
    "endTime": 453.759,
    "text": "more years of education"
  },
  {
    "startTime": 453.759,
    "endTime": 456.4,
    "text": "we typically choose to marry later"
  },
  {
    "startTime": 456.4,
    "endTime": 458.639,
    "text": "and to have fewer children so our"
  },
  {
    "startTime": 458.639,
    "endTime": 461.52,
    "text": "families end up being smaller"
  },
  {
    "startTime": 461.52,
    "endTime": 463.52,
    "text": "what happens at the individual level"
  },
