  },
  {
    "startTime": 390.08,
    "endTime": 391.199,
    "text": "research"
  },
  {
    "startTime": 391.199,
    "endTime": 393.199,
    "text": "and with months of frantically drafting"
  },
  {
    "startTime": 393.199,
    "endTime": 394.479,
    "text": "proposals"
  },
  {
    "startTime": 394.479,
    "endTime": 396.24,
    "text": "meticulously computing data in a"
  },
  {
    "startTime": 396.24,
    "endTime": 398.96,
    "text": "caffeinated days at 2am"
  },
  {
    "startTime": 398.96,
    "endTime": 401.52,
    "text": "i was able to finalize my results"
  },
  {
    "startTime": 401.52,
    "endTime": 403.36,
    "text": "and the results showed that habituation"
  },
  {
    "startTime": 403.36,
