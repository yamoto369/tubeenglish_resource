  },
  {
    "startTime": 178.16,
    "endTime": 180.16,
    "text": "like fear or guilt"
  },
  {
    "startTime": 180.16,
    "endTime": 181.76,
    "text": "i also thought because they would feel"
  },
  {
    "startTime": 181.76,
    "endTime": 183.8,
    "text": "less fearful and guilty this"
  },
  {
    "startTime": 183.8,
    "endTime": 186.0,
    "text": "desensitization will lead them to even"
  },
  {
    "startTime": 186.0,
    "endTime": 187.92,
    "text": "more risk-taking"
  },
  {
    "startTime": 187.92,
    "endTime": 190.0,
    "text": "in short i wanted to conduct a research"
  },
  {
    "startTime": 190.0,
    "endTime": 192.8,
    "text": "study to answer one big question"
  },
  {
    "startTime": 192.8,
    "endTime": 194.959,
    "text": "why do teens keep making outrageous"
  },
  {
    "startTime": 194.959,
    "endTime": 196.959,
    "text": "choices that are harmful to their health"
  },
  {
    "startTime": 196.959,
    "endTime": 199.2,
    "text": "and well-being"
  },
  {
    "startTime": 199.2,
    "endTime": 202.0,
    "text": "but there was one big obstacle in my way"
  },
  {
    "startTime": 202.0,
    "endTime": 203.92,
    "text": "to investigate this problem"
  },
  {
    "startTime": 203.92,
    "endTime": 206.8,
    "text": "i needed teenagers to experiment on"
  },
  {
    "startTime": 206.8,
    "endTime": 208.879,
    "text": "laboratories and devices to measure"
  },
  {
    "startTime": 208.879,
