  },
  {
    "startTime": 212.64,
    "endTime": 215.04,
    "text": "me and guide me along the way"
  },
  {
    "startTime": 215.04,
    "endTime": 217.28,
    "text": "i needed resources"
  },
  {
    "startTime": 217.28,
    "endTime": 219.599,
    "text": "but you see i attended a high school in"
  },
  {
    "startTime": 219.599,
