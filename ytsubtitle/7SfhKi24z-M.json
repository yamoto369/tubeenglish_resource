    "startTime": 1131.679,
    "endTime": 1134.559,
    "text": "into all of your identities"
  },
  {
    "startTime": 1134.559,
    "endTime": 1136.559,
    "text": "or do you want to continue"
  },
  {
    "startTime": 1136.559,
    "endTime": 1138.799,
    "text": "to cannibalize"
  },
  {
    "startTime": 1138.799,
    "endTime": 1141.84,
    "text": "your multiple identities and privilege"
  },
  {
    "startTime": 1141.84,
    "endTime": 1145.52,
    "text": "one identity over the other"
  },
  {
    "startTime": 1147.2,
    "endTime": 1152.24,
    "text": "do you want to join a long line"
  },
  {
    "startTime": 1152.24,
    "endTime": 1155.76,
    "text": "of generations of people"
  },
  {
    "startTime": 1155.76,
    "endTime": 1159.44,
    "text": "who believed in the promise of america"
  },
  {
    "startTime": 1159.44,
    "endTime": 1161.2,
    "text": "and had the faith"
  },
  {
    "startTime": 1161.2,
    "endTime": 1162.08,
    "text": "to"
  },
  {
    "startTime": 1162.08,
    "endTime": 1165.64,
    "text": "uphill democracy"
  },
  {
    "startTime": 1168.64,
    "endTime": 1171.76,
    "text": "do you want to live into the fullest of"
  },
  {
    "startTime": 1171.76,
    "endTime": 1173.36,
    "text": "your potential"
  },
  {
    "startTime": 1173.36,
    "endTime": 1179.16,
    "text": "i certainly do and i believe you do too"
  },
  {
    "startTime": 1179.84,
    "endTime": 1181.6,
    "text": "let me just say"
  },
  {
    "startTime": 1181.6,
    "endTime": 1184.0,
    "text": "quite seriously"
  },
  {
    "startTime": 1184.0,
    "endTime": 1187.039,
    "text": "i believe in you"
  },
  {
    "startTime": 1187.039,
    "endTime": 1189.919,
    "text": "and despite everything"
  },
  {
    "startTime": 1189.919,
    "endTime": 1195.36,
    "text": "i still believe in them in america"
  },
  {
    "startTime": 1195.679,
    "endTime": 1198.0,
    "text": "i hope that this offering that i've"
  },
  {
    "startTime": 1198.0,
    "endTime": 1199.84,
    "text": "given to you tonight that i've shared"
  },
  {
    "startTime": 1199.84,
    "endTime": 1201.76,
    "text": "with you tonight"
  },
  {
    "startTime": 1201.76,
    "endTime": 1205.6,
    "text": "will provide redemptive pathways"
  },
  {
    "startTime": 1205.6,
    "endTime": 1207.52,
    "text": "so that you might claim"
  },
  {
    "startTime": 1207.52,
    "endTime": 1210.16,
    "text": "the fullness of your identity"
  },
  {
    "startTime": 1210.16,
    "endTime": 1213.039,
    "text": "and become a major participant"
  },
  {
    "startTime": 1213.039,
    "endTime": 1214.72,
    "text": "in humanizing"
  },
  {
    "startTime": 1214.72,
    "endTime": 1217.28,
    "text": "not only the future for"
  },
  {
    "startTime": 1217.28,
    "endTime": 1222.42,
    "text": "yourselves but also for our democracy"
  },
  {
    "startTime": 1222.42,
    "endTime": 1228.019,
    "text": "[Applause]"
  }
]