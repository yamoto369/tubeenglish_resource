[
  {
    "startTime": 13.28,
    "endTime": 17.119,
    "text": "i want to share with you"
  },
  {
    "startTime": 17.119,
    "endTime": 20.4,
    "text": "a moment in my life"
  },
  {
    "startTime": 20.48,
    "endTime": 22.72,
    "text": "when the hurt"
  },
  {
    "startTime": 22.72,
    "endTime": 25.84,
    "text": "and wounds of racism"
  },
  {
    "startTime": 25.84,
    "endTime": 28.56,
    "text": "were both deadly"
  },
  {
    "startTime": 28.56,
    "endTime": 31.84,
    "text": "and paralyzing for me"
  },
  {
    "startTime": 32.16,
    "endTime": 35.12,
    "text": "and i think what i've learned"
  },
  {
    "startTime": 35.12,
    "endTime": 37.76,
    "text": "can be a source of healing"
  },
  {
    "startTime": 37.76,
    "endTime": 40.718,
    "text": "for all of us"
  },
  {
    "startTime": 41.28,
    "endTime": 44.84,
    "text": "when i was 17"
  },
  {
    "startTime": 45.04,
    "endTime": 47.6,
    "text": "years old"
  },
  {
    "startTime": 47.84,
    "endTime": 50.32,
    "text": "i was a college student"
  },
  {
    "startTime": 50.32,
    "endTime": 54.48,
    "text": "at tuskegee university"
  },
  {
    "startTime": 54.48,
    "endTime": 56.64,
    "text": "and i was a worker"
  },
  {
    "startTime": 56.64,
    "endTime": 59.359,
    "text": "in the southern freedom movement"
  },
  {
    "startTime": 59.359,
    "endTime": 63.68,
    "text": "which we call the civil rights movement"
  },
  {
    "startTime": 65.68,
    "endTime": 68.72,
    "text": "during this time"
  },
  {
    "startTime": 68.799,
    "endTime": 71.04,
    "text": "i met"
  },
  {
    "startTime": 71.04,
    "endTime": 73.92,
    "text": "another young 26 year old"
  },
  {
    "startTime": 73.92,
    "endTime": 76.96,
    "text": "white seminarian college student"
  },
  {
    "startTime": 76.96,
    "endTime": 79.119,
    "text": "named jonathan daniels"
  },
  {
    "startTime": 79.119,
    "endTime": 82.08,
    "text": "from cambridge massachusetts"
  },
  {
    "startTime": 82.08,
    "endTime": 84.479,
    "text": "he and i"
  },
  {
    "startTime": 84.479,
    "endTime": 86.64,
    "text": "were both part"
  },
  {
    "startTime": 86.64,
    "endTime": 89.439,
    "text": "of a generation of idealistic young"
  },
  {
    "startTime": 89.439,
    "endTime": 91.6,
    "text": "people"
  },
  {
    "startTime": 91.6,
    "endTime": 95.04,
    "text": "whose life has been ignited"
  },
  {
    "startTime": 95.04,
    "endTime": 97.439,
    "text": "by the freedom fire"
  },
  {
    "startTime": 97.439,
    "endTime": 100.96,
    "text": "the ordinary black people were spreading"
  },
  {
    "startTime": 100.96,
    "endTime": 102.56,
    "text": "around the nation"
  },
  {
    "startTime": 102.56,
    "endTime": 105.84,
    "text": "and throughout the south"
  },
  {
    "startTime": 106.399,
    "endTime": 110.079,
    "text": "we had come to lowndes county"
  },
  {
    "startTime": 110.079,
    "endTime": 113.04,
    "text": "to work in the movement"
  },
  {
    "startTime": 113.04,
    "endTime": 116.399,
    "text": "and it was a non-violent movement"
  },
  {
    "startTime": 116.399,
    "endTime": 120.799,
    "text": "to redeem the souls of america"
  },
  {
    "startTime": 120.799,
    "endTime": 122.399,
    "text": "we believe"
  },
  {
    "startTime": 122.399,
    "endTime": 124.399,
    "text": "that everyone"
  },
  {
    "startTime": 124.399,
    "endTime": 126.96,
    "text": "both black and white"
  },
  {
    "startTime": 126.96,
    "endTime": 129.84,
    "text": "people in the south"
  },
  {
    "startTime": 129.84,
    "endTime": 133.36,
    "text": "could find a redemptive pathway"
  },
  {
    "startTime": 133.36,
    "endTime": 136.56,
    "text": "out of the stranglehold of racism"
  },
  {
    "startTime": 136.56,
    "endTime": 139.36,
    "text": "that had gripped them for more than 400"
  },
  {
    "startTime": 139.36,
    "endTime": 142.36,
    "text": "years"
  },
  {
    "startTime": 144.8,
    "endTime": 146.319,
    "text": "and on a hot"
  },
  {
    "startTime": 146.319,
    "endTime": 149.76,
    "text": "summer day in august"
  },
  {
    "startTime": 149.76,
    "endTime": 153.68,
    "text": "jonathan and i joined a demonstration"
  },
  {
    "startTime": 153.68,
    "endTime": 156.4,
    "text": "of local young black people"
  },
  {
    "startTime": 156.4,
    "endTime": 158.319,
    "text": "who were protesting"
  },
  {
    "startTime": 158.319,
    "endTime": 160.959,
    "text": "the exploitation"
  },
  {
    "startTime": 160.959,
    "endTime": 162.239,
    "text": "by their"
  },
  {
    "startTime": 162.239,
    "endTime": 165.76,
    "text": "sharecroppers black sharecroppers"
  },
  {
    "startTime": 165.76,
    "endTime": 169.36,
    "text": "by richland landholders who cheated them"
  },
  {
    "startTime": 169.36,
    "endTime": 170.4,
    "text": "out of their"
  },
  {
    "startTime": 170.4,
    "endTime": 172.72,
    "text": "money"
  },
  {
    "startTime": 174.879,
    "endTime": 179.84,
    "text": "we decided to demonstrate alongside them"
  },
  {
    "startTime": 179.84,
    "endTime": 181.84,
    "text": "and on the morning that we showed up for"
  },
  {
    "startTime": 181.84,
    "endTime": 184.48,
    "text": "the demonstration"
  },
  {
    "startTime": 184.48,
    "endTime": 186.8,
    "text": "we were met with a mob"
  },
  {
    "startTime": 186.8,
    "endTime": 189.2,
    "text": "of howling white men"
  },
  {
    "startTime": 189.2,
    "endTime": 191.84,
    "text": "with baseball bats"
  },
  {
    "startTime": 191.84,
    "endTime": 194.8,
    "text": "shotguns"
  },
  {
    "startTime": 195.28,
    "endTime": 198.64,
    "text": "and any weapon that you could imagine"
  },
  {
    "startTime": 198.64,
    "endTime": 202.08,
    "text": "and they were threatening to kill us"
  },
  {
    "startTime": 202.08,
    "endTime": 204.72,
    "text": "and the sheriff"
  },
  {
    "startTime": 204.72,
    "endTime": 208.56,
    "text": "seeing the danger that we face"
  },
  {
    "startTime": 208.56,
    "endTime": 210.72,
    "text": "arrested us"
  },
  {
    "startTime": 210.72,
    "endTime": 213.68,
    "text": "and put us on a garbage truck"
  },
  {
    "startTime": 213.68,
    "endTime": 217.44,
    "text": "and took us to the local jail"
  },
  {
    "startTime": 217.44,
    "endTime": 219.36,
    "text": "where we were put"
  },
  {
    "startTime": 219.36,
    "endTime": 221.36,
    "text": "in cells"
  },
  {
    "startTime": 221.36,
    "endTime": 224.48,
    "text": "with the most inhumane conditions you"
  },
  {
    "startTime": 224.48,
    "endTime": 226.64,
    "text": "can imagine"
  },
  {
    "startTime": 226.64,
    "endTime": 229.2,
    "text": "and we were threatened"
  },
  {
    "startTime": 229.2,
    "endTime": 231.84,
    "text": "by the jailers"
  },
  {
    "startTime": 231.84,
    "endTime": 232.879,
    "text": "with"
  },
  {
    "startTime": 232.879,
    "endTime": 237.599,
    "text": "drinking water that came from toilets"
  },
  {
    "startTime": 239.76,
    "endTime": 242.319,
    "text": "we were finally released on the sixth"
  },
  {
    "startTime": 242.319,
    "endTime": 244.08,
    "text": "day"
  },
  {
    "startTime": 244.08,
    "endTime": 245.76,
    "text": "without our"
  },
  {
    "startTime": 245.76,
    "endTime": 247.92,
    "text": "without any knowledge without any"
  },
  {
    "startTime": 247.92,
    "endTime": 250.239,
    "text": "forewarning just out of the clear blue"
  },
  {
    "startTime": 250.239,
    "endTime": 251.76,
    "text": "sky"
  },
  {
    "startTime": 251.76,
    "endTime": 254.799,
    "text": "we were made to leave"
  },
  {
    "startTime": 254.799,
    "endTime": 256.16,
    "text": "and we knew"
  },
  {
    "startTime": 256.16,
    "endTime": 258.479,
    "text": "that this was a dangerous sign"
  },
  {
    "startTime": 258.479,
    "endTime": 261.919,
    "text": "because goodman schwerner and cheney"
  },
  {
    "startTime": 261.919,
    "endTime": 264.88,
    "text": "had also been forced to leave jail"
  },
  {
    "startTime": 264.88,
    "endTime": 267.12,
    "text": "and were murdered because no one knew"
  },
  {
    "startTime": 267.12,
    "endTime": 269.6,
    "text": "what had happened to them"
  },
  {
    "startTime": 269.6,
    "endTime": 270.639,
    "text": "and so"
  },
  {
    "startTime": 270.639,
    "endTime": 271.919,
    "text": "despite"
  },
  {
    "startTime": 271.919,
    "endTime": 275.44,
    "text": "our fervent resistance"
  },
  {
    "startTime": 275.44,
    "endTime": 278.32,
    "text": "the sheriff made us leave the jail"
  },
  {
    "startTime": 278.32,
    "endTime": 283.56,
    "text": "and of course nobody was waiting for us"
  },
  {
    "startTime": 284.0,
    "endTime": 287.199,
    "text": "it was hot"
  },
  {
    "startTime": 288.0,
    "endTime": 290.72,
    "text": "one of those sudden days"
  },
  {
    "startTime": 290.72,
    "endTime": 292.4,
    "text": "where you can literally feel the"
  },
  {
    "startTime": 292.4,
    "endTime": 295.04,
    "text": "pavement"
  },
  {
    "startTime": 295.04,
    "endTime": 298.0,
    "text": "seeping the vapor seeping out of the"
  },
  {
    "startTime": 298.0,
    "endTime": 300.72,
    "text": "pavement"
  },
  {
    "startTime": 300.72,
    "endTime": 302.0,
    "text": "and the group"
  },
  {
    "startTime": 302.0,
    "endTime": 305.52,
    "text": "of about 14 of us"
  },
  {
    "startTime": 305.84,
    "endTime": 309.84,
    "text": "selected jonathan daniels"
  },
  {
    "startTime": 309.84,
    "endTime": 312.08,
    "text": "marshall who has recently come to the"
  },
  {
    "startTime": 312.08,
    "endTime": 313.6,
    "text": "county"
  },
  {
    "startTime": 313.6,
    "endTime": 316.4,
    "text": "joyce bailey"
  },
  {
    "startTime": 316.4,
    "endTime": 319.36,
    "text": "a local 17 year old girl"
  },
  {
    "startTime": 319.36,
    "endTime": 323.12,
    "text": "and i to go and get the drinks"
  },
  {
    "startTime": 323.36,
    "endTime": 326.639,
    "text": "when we got to the door"
  },
  {
    "startTime": 326.639,
    "endTime": 328.72,
    "text": "a white man was standing in the door"
  },
  {
    "startTime": 328.72,
    "endTime": 330.639,
    "text": "waving a shotgun"
  },
  {
    "startTime": 330.639,
    "endTime": 333.28,
    "text": "and he said"
  },
  {
    "startTime": 333.28,
    "endTime": 336.56,
    "text": "i'll blow your brains out"
  },
  {
    "startTime": 336.56,
    "endTime": 340.08,
    "text": "and before i could even react before i"
  },
  {
    "startTime": 340.08,
    "endTime": 343.6,
    "text": "could even process what was going on"
  },
  {
    "startTime": 343.6,
    "endTime": 348.16,
    "text": "jonathan intentionally pulled my blouse"
  },
  {
    "startTime": 348.16,
    "endTime": 349.84,
    "text": "and i fell back"
  },
  {
    "startTime": 349.84,
    "endTime": 353.36,
    "text": "thinking that i was dead"
  },
  {
    "startTime": 353.36,
    "endTime": 356.639,
    "text": "and in that instant when i looked up"
  },
  {
    "startTime": 356.639,
    "endTime": 359.039,
    "text": "jonathan daniels had was standing in the"
  },
  {
    "startTime": 359.039,
    "endTime": 361.36,
    "text": "line of fire"
  },
  {
    "startTime": 361.36,
    "endTime": 364.719,
    "text": "and he took the blast"
  },
  {
    "startTime": 364.8,
    "endTime": 368.24,
    "text": "and he saved my life"
  },
  {
    "startTime": 375.039,
    "endTime": 376.96,
    "text": "i was so"
  },
  {
    "startTime": 376.96,
    "endTime": 379.759,
    "text": "traumatized"
  },
  {
    "startTime": 379.759,
    "endTime": 382.16,
    "text": "and paralyzed"
  },
  {
    "startTime": 382.16,
    "endTime": 384.639,
    "text": "by that event"
  },
  {
    "startTime": 384.639,
    "endTime": 387.52,
    "text": "where tom coleman"
  },
  {
    "startTime": 387.52,
    "endTime": 390.08,
    "text": "deliberately"
  },
  {
    "startTime": 390.08,
    "endTime": 393.28,
    "text": "with malicious intent"
  },
  {
    "startTime": 393.28,
    "endTime": 396.0,
    "text": "killed my beloved friend"
  },
  {
    "startTime": 396.0,
    "endTime": 402.0,
    "text": "and colleague jonathan myrick daniels"
  },
  {
    "startTime": 407.039,
    "endTime": 409.84,
    "text": "on that day"
  },
  {
    "startTime": 410.319,
    "endTime": 412.479,
    "text": "which was one of the most important days"
  },
  {
    "startTime": 412.479,
    "endTime": 414.8,
    "text": "in my life"
  },
  {
    "startTime": 414.8,
    "endTime": 418.72,
    "text": "i saw both love and hate"
  },
  {
    "startTime": 418.72,
    "endTime": 420.08,
    "text": "coming from"
  },
  {
    "startTime": 420.08,
    "endTime": 422.88,
    "text": "two very different white men"
  },
  {
    "startTime": 422.88,
    "endTime": 425.759,
    "text": "that represented the best"
  },
  {
    "startTime": 425.759,
    "endTime": 427.36,
    "text": "and the worst"
  },
  {
    "startTime": 427.36,
    "endTime": 430.478,
    "text": "of white america"
  },
  {
    "startTime": 430.8,
    "endTime": 433.599,
    "text": "so deep was my hurt as seeing tom"
  },
  {
    "startTime": 433.599,
    "endTime": 437.199,
    "text": "coleman murder jonathan before my eyes"
  },
  {
    "startTime": 437.199,
    "endTime": 440.16,
    "text": "that i became a silent person"
  },
  {
    "startTime": 440.16,
    "endTime": 443.599,
    "text": "and i did not speak"
  },
  {
    "startTime": 443.68,
    "endTime": 446.72,
    "text": "for six months"
  },
  {
    "startTime": 448.319,
    "endTime": 451.36,
    "text": "i finally learned to touch that hurt"
  },
  {
    "startTime": 451.36,
    "endTime": 452.96,
    "text": "in me"
  },
  {
    "startTime": 452.96,
    "endTime": 455.52,
    "text": "as i became older"
  },
  {
    "startTime": 455.52,
    "endTime": 458.08,
    "text": "and began to talk about the southern"
  },
  {
    "startTime": 458.08,
    "endTime": 459.919,
    "text": "freedom movement"
  },
  {
    "startTime": 459.919,
    "endTime": 462.72,
    "text": "and began to connect my stories"
  },
  {
    "startTime": 462.72,
    "endTime": 466.319,
    "text": "with the stories of my other colleagues"
  },
  {
    "startTime": 466.319,
    "endTime": 468.479,
    "text": "and freedom fighters"
  },
  {
    "startTime": 468.479,
    "endTime": 471.599,
    "text": "who had who like me had faced a deadly"
  },
  {
    "startTime": 471.599,
    "endTime": 472.639,
    "text": "trauma"
  },
  {
    "startTime": 472.639,
    "endTime": 474.08,
    "text": "of racism"
  },
  {
    "startTime": 474.08,
    "endTime": 477.44,
    "text": "and who had lost friends along the way"
  },
  {
    "startTime": 477.44,
    "endTime": 480.08,
    "text": "and who themselves have been beaten and"
  },
  {
    "startTime": 480.08,
    "endTime": 483.12,
    "text": "thrown in jail"
  },
  {
    "startTime": 487.12,
    "endTime": 491.879,
    "text": "it is 50 years later"
  },
  {
    "startTime": 493.28,
    "endTime": 494.24,
    "text": "many"
  },
  {
    "startTime": 494.24,
    "endTime": 495.52,
    "text": "people were"
  },
  {
    "startTime": 495.52,
    "endTime": 498.879,
    "text": "beaten and thrown in jail"
  },
  {
    "startTime": 498.879,
    "endTime": 500.8,
    "text": "others were murdered like jonathan"
  },
  {
    "startTime": 500.8,
    "endTime": 502.639,
    "text": "daniels"
  },
  {
    "startTime": 502.639,
    "endTime": 506.319,
    "text": "and yet we are still we're still as a"
  },
  {
    "startTime": 506.319,
    "endTime": 507.84,
    "text": "nation"
  },
  {
    "startTime": 507.84,
    "endTime": 510.72,
    "text": "marked down"
  },
  {
    "startTime": 510.72,
    "endTime": 514.64,
    "text": "in the quicksand of racism"
  },
  {
    "startTime": 518.479,
    "endTime": 522.08,
    "text": "and everywhere i go around the nation"
  },
  {
    "startTime": 522.08,
    "endTime": 524.24,
    "text": "i see"
  },
  {
    "startTime": 524.24,
    "endTime": 526.959,
    "text": "and hear the hurt"
  },
  {
    "startTime": 526.959,
    "endTime": 529.68,
    "text": "and i ask people everywhere"
  },
  {
    "startTime": 529.68,
    "endTime": 530.72,
    "text": "tell me"
  },
  {
    "startTime": 530.72,
    "endTime": 533.519,
    "text": "where does it hurt"
  },
  {
    "startTime": 533.519,
    "endTime": 536.959,
    "text": "do you see and feel the hurt"
  },
  {
    "startTime": 536.959,
    "endTime": 540.32,
    "text": "that i see and feel"
  },
  {
    "startTime": 541.279,
    "endTime": 545.04,
    "text": "i feel and see the hurt"
  },
  {
    "startTime": 545.04,
    "endTime": 546.839,
    "text": "and black and brown"
  },
  {
    "startTime": 546.839,
    "endTime": 552.48,
    "text": "people who every day feel the vicious"
  },
  {
    "startTime": 552.48,
    "endTime": 556.32,
    "text": "volley of racism"
  },
  {
    "startTime": 556.32,
    "endTime": 559.279,
    "text": "and who every day have their civil and"
  },
  {
    "startTime": 559.279,
    "endTime": 562.32,
    "text": "human rights stripped away and the"
  },
  {
    "startTime": 562.32,
    "endTime": 564.32,
    "text": "people who do this"
  },
  {
    "startTime": 564.32,
    "endTime": 567.12,
    "text": "use stereotypes and myths"
  },
  {
    "startTime": 567.12,
    "endTime": 571.04,
    "text": "to justify doing it"
  },
  {
    "startTime": 573.92,
    "endTime": 576.88,
    "text": "everywhere i go"
  },
  {
    "startTime": 576.88,
    "endTime": 579.519,
    "text": "i see"
  },
  {
    "startTime": 579.519,
    "endTime": 582.48,
    "text": "and hear women"
  },
  {
