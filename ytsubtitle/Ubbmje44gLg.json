    "startTime": 739.2,
    "endTime": 742.079,
    "text": "recording made by a prisoner"
  },
  {
    "startTime": 742.079,
    "endTime": 744.32,
    "text": "because it encapsulates the power of"
  },
  {
    "startTime": 744.32,
    "endTime": 746.639,
    "text": "what we do"
  },
  {
    "startTime": 746.639,
    "endTime": 748.48,
    "text": "the prisoner was an irish traveler who"
  },
  {
    "startTime": 748.48,
    "endTime": 751.04,
    "text": "couldn't read"
  },
  {
    "startTime": 751.04,
    "endTime": 753.04,
    "text": "and he wanted to send a story home to"
  },
  {
    "startTime": 753.04,
    "endTime": 756.399,
    "text": "his daughter for her birthday"
  },
  {
    "startTime": 756.399,
    "endTime": 758.0,
    "text": "with the help of a mentor and some"
  },
  {
    "startTime": 758.0,
    "endTime": 759.44,
    "text": "clever editing"
  },
  {
    "startTime": 759.44,
    "endTime": 762.399,
    "text": "something magical happened"
  },
  {
    "startTime": 762.399,
    "endTime": 764.0,
    "text": "this is an extract from the raw"
  },
  {
    "startTime": 764.0,
    "endTime": 766.16,
    "text": "recording where the prisoner is reading"
  },
  {
    "startTime": 766.16,
    "endTime": 768.24,
    "text": "the story by repeating it"
  },
  {
    "startTime": 768.24,
    "endTime": 771.42,
    "text": "phrase at a time"
  },
  {
    "startTime": 771.42,
    "endTime": 774.529,
    "text": "[Music]"
  },
  {
    "startTime": 776.399,
    "endTime": 778.72,
    "text": "then one day he ran away"
  },
  {
    "startTime": 778.72,
    "endTime": 782.32,
    "text": "he ran until he came to the great marsh"
  },
  {
    "startTime": 782.32,
    "endTime": 784.959,
    "text": "he ran until he come to the great marsh"
  },
  {
    "startTime": 784.959,
    "endTime": 787.36,
    "text": "where the wild ducks lived"
  },
  {
    "startTime": 787.36,
    "endTime": 790.8,
    "text": "where the wild dogs lived"
  },
  {
    "startTime": 790.959,
    "endTime": 792.0,
    "text": "and this"
  },
  {
    "startTime": 792.0,
    "endTime": 792.8,
    "text": "is"
  },
