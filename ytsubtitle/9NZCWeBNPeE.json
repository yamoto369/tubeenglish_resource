  {
    "startTime": 732.16,
    "endTime": 734.48,
    "text": "because you always do"
  },
  {
    "startTime": 734.48,
    "endTime": 735.76,
    "text": "and i watched my older daughter take a"
  },
  {
    "startTime": 735.76,
