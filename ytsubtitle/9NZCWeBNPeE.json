    "endTime": 666.16,
    "text": "can we go tubing on the river"
  },
  {
    "startTime": 666.16,
    "endTime": 667.68,
    "text": "and i said well you know i'd really wait"
  },
  {
    "startTime": 667.68,
    "endTime": 670.24,
