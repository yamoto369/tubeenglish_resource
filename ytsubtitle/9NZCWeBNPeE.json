  },
  {
    "startTime": 622.32,
    "endTime": 623.44,
    "text": "silence"
  },
  {
    "startTime": 623.44,
    "endTime": 625.76,
    "text": "and finally my youngest asked a single"
  },
  {
    "startTime": 625.76,
    "endTime": 628.079,
