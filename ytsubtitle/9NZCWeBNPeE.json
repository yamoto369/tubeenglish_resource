  },
  {
    "startTime": 745.12,
    "endTime": 747.44,
    "text": "of burdens and challenges"
  },
  {
    "startTime": 747.44,
    "endTime": 749.44,
    "text": "but i was certain that we were going to"
  },
  {
    "startTime": 749.44,
    "endTime": 752.639,
    "text": "see this through to redemption"
  },
  {
    "startTime": 752.639,
    "endTime": 754.72,
    "text": "i looked at my dad and i looked at my"
  },
  {
    "startTime": 754.72,
    "endTime": 756.639,
    "text": "girls who were dancing and you know"
  },
  {
    "startTime": 756.639,
    "endTime": 759.04,
    "text": "eating their donuts and i said aloud to"
  },
  {
    "startTime": 759.04,
    "endTime": 762.32,
    "text": "no one in particular i said this"
  },
  {
    "startTime": 762.32,
    "endTime": 765.92,
    "text": "this is how god sees my dad"
  },
  {
    "startTime": 765.92,
    "endTime": 768.88,
    "text": "my father was literally born again"
  },
  {
    "startTime": 768.88,
    "endTime": 770.839,
    "text": "and by choosing the narrow path of"
  },
  {
    "startTime": 770.839,
