  },
  {
    "startTime": 695.76,
    "endTime": 699.44,
    "text": "all the way to the light of dawn"
  },
  {
    "startTime": 699.44,
    "endTime": 701.279,
    "text": "have you ever noticed that a child who"
  },
  {
    "startTime": 701.279,
    "endTime": 703.6,
    "text": "is secure a child who knows love that"
  },
  {
    "startTime": 703.6,
    "endTime": 705.68,
    "text": "that child will dance"
  },
  {
    "startTime": 705.68,
    "endTime": 706.64,
    "text": "they"
  },
  {
    "startTime": 706.64,
    "endTime": 708.56,
