  {
    "startTime": 712.72,
    "endTime": 714.959,
    "text": "and unharmed and"
  },
  {
    "startTime": 714.959,
    "endTime": 717.279,
    "text": "holy loved"
  },
  {
    "startTime": 717.279,
    "endTime": 719.04,
    "text": "the day after my children met their"
  },
  {
    "startTime": 719.04,
    "endTime": 720.8,
    "text": "grandpa she took him to go get donuts"
  },
  {
    "startTime": 720.8,
    "endTime": 722.32,
    "text": "and i watched as they walked down the"
  },
  {
    "startTime": 722.32,
