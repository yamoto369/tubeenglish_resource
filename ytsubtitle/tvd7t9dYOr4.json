[
  {
    "startTime": 2.639,
    "endTime": 4.88,
    "text": "I'm Peppa Pig."
  },
  {
    "startTime": 4.88,
    "endTime": 7.759,
    "text": "This is my little brother, George. This"
  },
  {
    "startTime": 7.759,
    "endTime": 13.519,
    "text": "is Mommy Pig. And this is Daddy Pig."
  },
  {
    "startTime": 13.519,
    "endTime": 17.0,
    "text": "Peppa Pig."
  },
  {
    "startTime": 20.24,
    "endTime": 24.44,
    "text": "Mr. Dinosaur is lost."
  },
  {
    "startTime": 24.44,
    "endTime": 27.039,
    "text": "[Music]"
  },
  {
    "startTime": 27.039,
    "endTime": 30.64,
    "text": "George's favorite toy is Mr. Dinosaur."
  },
  {
    "startTime": 30.64,
    "endTime": 32.96,
    "text": "Dinosaur."
  },
  {
    "startTime": 32.96,
    "endTime": 37.079,
    "text": "George loves Mr. Dinosaur."
  },
  {
    "startTime": 37.6,
    "endTime": 39.6,
    "text": "Sometimes George likes to scare Peppa"
  },
  {
    "startTime": 39.6,
    "endTime": 42.719,
    "text": "with Mr. Dinosaur."
  },
  {
    "startTime": 42.719,
    "endTime": 46.04,
    "text": "Too scary."
  },
  {
    "startTime": 49.76,
    "endTime": 52.079,
    "text": "At supper time, Mr. Dinosaur sits next"
  },
  {
    "startTime": 52.079,
    "endTime": 53.84,
    "text": "to George."
  },
  {
    "startTime": 53.84,
    "endTime": 54.96,
    "text": "Uh,"
  },
  {
    "startTime": 54.96,
    "endTime": 58.0,
    "text": "I beg your pardon. Was that you, George,"
  },
  {
    "startTime": 58.0,
    "endTime": 60.16,
    "text": "or was it Mr. Dinosaur?"
  },
  {
    "startTime": 60.16,
    "endTime": 63.16,
    "text": "Dinosaur."
  },
  {
    "startTime": 65.439,
    "endTime": 67.52,
    "text": "At bath time, George shares his bath"
  },
  {
    "startTime": 67.52,
    "endTime": 70.92,
    "text": "with Mr. Dinosaur."
  },
  {
    "startTime": 73.68,
    "endTime": 75.36,
    "text": "Good night, Peppa."
  },
  {
    "startTime": 75.36,
    "endTime": 77.36,
    "text": "Good night, Bubby."
  },
  {
    "startTime": 77.36,
    "endTime": 79.6,
    "text": "Good night, George. And good night, Mr."
  },
  {
    "startTime": 79.6,
    "endTime": 82.32,
    "text": "Dinosaur."
  },
  {
    "startTime": 82.32,
    "endTime": 84.88,
    "text": "When George goes to bed, Mr. Dinosaur is"
  },
  {
    "startTime": 84.88,
    "endTime": 88.079,
    "text": "tucked up with him."
  },
  {
    "startTime": 90.44,
    "endTime": 91.68,
    "text": "[Music]"
  },
  {
    "startTime": 91.68,
    "endTime": 93.92,
    "text": "George's favorite game is throwing Mr."
  },
  {
    "startTime": 93.92,
    "endTime": 96.32,
    "text": "Dinosaur up in the air."
  },
  {
    "startTime": 96.32,
    "endTime": 98.079,
    "text": "And catching him when he falls back"
  },
  {
    "startTime": 98.079,
    "endTime": 99.9,
    "text": "down."
  },
  {
    "startTime": 99.9,
    "endTime": 106.96,
    "text": "[Music]"
  },
  {
    "startTime": 106.96,
    "endTime": 111.72,
    "text": "Peppa and Daddy Pig are playing drafts."
  },
  {
    "startTime": 112.0,
    "endTime": 118.32,
    "text": "I win, Daddy. Oh, well done, Peppa."
  },
  {
    "startTime": 118.32,
    "endTime": 119.8,
    "text": "George."
  },
  {
    "startTime": 119.8,
    "endTime": 121.92,
    "text": "[Music]"
  },
  {
    "startTime": 121.92,
    "endTime": 124.479,
    "text": "George, what's the matter?"
  },
  {
    "startTime": 124.479,
    "endTime": 126.159,
    "text": "I'm sore."
  },
  {
    "startTime": 126.159,
    "endTime": 130.8,
    "text": "George, have you lost Mr. Dinosaur?"
  },
  {
    "startTime": 130.8,
    "endTime": 133.599,
    "text": "George has lost Mr. Dinosaur."
  },
  {
    "startTime": 133.599,
    "endTime": 135.92,
    "text": "Don't worry, George. We'll find Mr."
  },
  {
    "startTime": 135.92,
    "endTime": 136.879,
    "text": "Dinosaur."
  },
  {
    "startTime": 136.879,
    "endTime": 139.44,
    "text": "It's a job for a detective."
  },
  {
    "startTime": 139.44,
    "endTime": 143.04,
    "text": "Daddy, what is a detective?"
  },
  {
    "startTime": 143.04,
    "endTime": 146.56,
    "text": "A detective is a very important person"
  },
  {
    "startTime": 146.56,
    "endTime": 148.879,
    "text": "who is good at finding things."
  },
  {
    "startTime": 148.879,
    "endTime": 152.4,
    "text": "Me, I'm good at finding things."
  },
  {
    "startTime": 152.4,
    "endTime": 156.0,
    "text": "All right. Peppa is the detective."
  },
  {
    "startTime": 156.0,
    "endTime": 159.2,
    "text": "George, I'm the detective."
  },
  {
    "startTime": 159.2,
    "endTime": 163.44,
    "text": "I will help you find Mr. Dinosaur."
  },
  {
    "startTime": 163.44,
    "endTime": 166.0,
    "text": "Maybe the detective should ask George"
  },
  {
    "startTime": 166.0,
    "endTime": 168.08,
    "text": "some simple questions."
  },
  {
    "startTime": 168.08,
    "endTime": 173.16,
    "text": "George, where's Mr. Dinosaur?"
  },
  {
    "startTime": 173.84,
    "endTime": 175.92,
    "text": "George does not know where Mr. Dinosaur"
  },
  {
    "startTime": 175.92,
    "endTime": 176.72,
    "text": "is."
  },
  {
    "startTime": 176.72,
    "endTime": 179.2,
    "text": "The detective could try and guess where"
  },
  {
    "startTime": 179.2,
    "endTime": 181.28,
    "text": "Mr. Dinosaur might be."
  },
  {
    "startTime": 181.28,
    "endTime": 185.959,
    "text": "I know. I know where he is."
  },
  {
    "startTime": 187.519,
    "endTime": 190.0,
    "text": "George always has Mr. Dinosaur with him"
  },
  {
    "startTime": 190.0,
    "endTime": 193.599,
    "text": "in the bath. So, Mr. Dinosaur is in the"
  },
  {
    "startTime": 193.599,
    "endTime": 194.56,
    "text": "bath."
  },
  {
    "startTime": 194.56,
    "endTime": 196.959,
    "text": "Mr. Dinosaur is not in the bath."
  },
  {
    "startTime": 196.959,
    "endTime": 200.8,
    "text": "Oh, I know. I know where Mr. dinosaur"
  },
  {
    "startTime": 200.8,
    "endTime": 202.64,
    "text": "is."
  },
  {
    "startTime": 202.64,
    "endTime": 205.68,
    "text": "George always has Mr. Dinosaur in his"
  },
  {
    "startTime": 205.68,
    "endTime": 209.84,
    "text": "bed at night. See, that's where he is."
  },
  {
    "startTime": 209.84,
    "endTime": 212.319,
    "text": "Mr. Dinosaur is not in George's bed."
  },
  {
    "startTime": 212.319,
    "endTime": 213.76,
    "text": "Oh,"
  },
  {
    "startTime": 213.76,
    "endTime": 216.64,
    "text": "maybe we should try the garden."
  },
  {
    "startTime": 216.64,
    "endTime": 219.76,
    "text": "Yes, the garden. I was going to say"
  },
  {
    "startTime": 219.76,
    "endTime": 221.36,
    "text": "that."
  },
  {
    "startTime": 221.36,
    "endTime": 225.28,
    "text": "[Music]"
  },
  {
    "startTime": 225.28,
    "endTime": 227.84,
    "text": "Where is Mr. Dinosaur?"
  },
  {
    "startTime": 227.84,
    "endTime": 232.159,
    "text": "Mr. Dinosaur is very hard to find."
  },
  {
    "startTime": 232.159,
    "endTime": 235.92,
    "text": "Mr. Dinosaur isn't anywhere."
  },
  {
    "startTime": 235.92,
    "endTime": 238.64,
    "text": "George, you do love to throw Mr."
  },
  {
    "startTime": 238.64,
    "endTime": 241.12,
    "text": "Dinosaur in the air."
  },
  {
    "startTime": 241.12,
    "endTime": 243.36,
    "text": "I wonder if this time you threw Mr."
  },
  {
    "startTime": 243.36,
    "endTime": 246.72,
    "text": "Dinosaur just a bit too high."
  },
  {
    "startTime": 246.72,
    "endTime": 249.28,
    "text": "There he is. There he is. I saw him"
  },
  {
    "startTime": 249.28,
    "endTime": 251.599,
    "text": "first."
  },
  {
    "startTime": 251.599,
    "endTime": 254.879,
    "text": "Well done, Peppa. You really are a very"
  },
  {
    "startTime": 254.879,
    "endTime": 258.2,
    "text": "good detective."
  },
  {
    "startTime": 261.44,
    "endTime": 263.22,
    "text": "I'm sore."
  },
  {
    "startTime": 263.22,
    "endTime": 265.199,
    "text": "[Music]"
  },
  {
    "startTime": 265.199,
    "endTime": 268.0,
    "text": "George is so happy to have Mr. Dinosaur"
  },
  {
    "startTime": 268.0,
    "endTime": 271.24,
    "text": "back again."
  },
  {
    "startTime": 272.56,
    "endTime": 275.12,
    "text": "Maybe it isn't a good idea to play with"
  },
  {
    "startTime": 275.12,
    "endTime": 279.08,
    "text": "dinosaurs near trees."
  },
  {
    "startTime": 282.479,
    "endTime": 285.4,
    "text": "Dinosaur."
  },
  {
    "startTime": 285.4,
    "endTime": 287.68,
    "text": "[Music]"
  },
  {
    "startTime": 287.68,
    "endTime": 291.639,
    "text": "Peppa Pig."
  },
  {
    "startTime": 292.4,
    "endTime": 296.28,
    "text": "Peppa Pig."
  },
  {
    "startTime": 296.56,
    "endTime": 300.52,
    "text": "Peppa Pig."
  },
  {
    "startTime": 301.97,
    "endTime": 305.139,
    "text": "[Music]"
  },
  {
    "startTime": 311.37,
    "endTime": 315.999,
    "text": "[Music]"
  }
]