[
  {
    "startTime": 13.12,
    "endTime": 15.519,
    "text": "it was a thursday"
  },
  {
    "startTime": 15.519,
    "endTime": 17.6,
    "text": "june the 23rd"
  },
  {
    "startTime": 17.6,
    "endTime": 20.6,
    "text": "1994"
  },
  {
    "startTime": 24.08,
    "endTime": 26.32,
    "text": "collect your belongings you are free to"
  },
  {
    "startTime": 26.32,
    "endTime": 28.64,
    "text": "go"
  },
  {
    "startTime": 28.72,
    "endTime": 31.439,
    "text": "when escorted outside go directly to"
  },
  {
    "startTime": 31.439,
    "endTime": 32.88,
    "text": "your car"
  },
  {
    "startTime": 32.88,
    "endTime": 36.88,
    "text": "do not talk to reporters"
  },
  {
    "startTime": 36.88,
    "endTime": 40.079,
    "text": "my head is spinning my heart is racing i"
  },
  {
    "startTime": 40.079,
    "endTime": 42.96,
    "text": "can't get a breath"
  },
  {
    "startTime": 42.96,
    "endTime": 46.32,
    "text": "i just want out of there"
  },
  {
    "startTime": 47.44,
    "endTime": 49.36,
    "text": "when i get to my car"
  },
  {
    "startTime": 49.36,
    "endTime": 52.32,
    "text": "i throw everything on the back"
  },
  {
    "startTime": 52.32,
    "endTime": 54.079,
    "text": "and i just collapse into the driver's"
  },
  {
    "startTime": 54.079,
    "endTime": 55.52,
    "text": "seat"
  },
  {
    "startTime": 55.52,
    "endTime": 57.28,
    "text": "i can't do this"
  },
  {
    "startTime": 57.28,
    "endTime": 59.76,
    "text": "i can't go home"
  },
  {
    "startTime": 59.76,
    "endTime": 62.079,
    "text": "to my family"
  },
  {
    "startTime": 62.079,
    "endTime": 64.0,
    "text": "that i haven't seen"
  },
  {
    "startTime": 64.0,
    "endTime": 66.32,
    "text": "in a week"
  },
  {
    "startTime": 66.32,
    "endTime": 69.76,
    "text": "and pretend to be happy"
  },
  {
    "startTime": 70.72,
    "endTime": 72.799,
    "text": "not even their love"
  },
  {
    "startTime": 72.799,
    "endTime": 75.28,
    "text": "and support could help me at this"
  },
  {
    "startTime": 75.28,
    "endTime": 78.32,
    "text": "particular time"
  },
  {
    "startTime": 79.52,
    "endTime": 84.84,
    "text": "we had just sentenced a man to death"
  },
  {
    "startTime": 86.159,
    "endTime": 88.799,
    "text": "now what"
  },
  {
    "startTime": 88.799,
    "endTime": 92.4,
    "text": "just go home and wash dishes"
  },
  {
    "startTime": 92.64,
    "endTime": 94.799,
    "text": "you see"
  },
  {
    "startTime": 94.799,
    "endTime": 97.2,
    "text": "in mississippi"
  },
  {
    "startTime": 97.2,
    "endTime": 99.439,
    "text": "the death penalty is like a part of our"
  },
  {
    "startTime": 99.439,
    "endTime": 102.64,
    "text": "unspoken culture"
  },
  {
    "startTime": 103.68,
    "endTime": 107.28,
    "text": "the basic logic is if you murder someone"
  },
  {
    "startTime": 107.28,
    "endTime": 109.2,
    "text": "then you're going to receive the death"
  },
  {
    "startTime": 109.2,
    "endTime": 111.68,
    "text": "penalty"
  },
  {
    "startTime": 111.759,
    "endTime": 113.36,
    "text": "so"
  },
  {
    "startTime": 113.36,
    "endTime": 115.759,
    "text": "when the jury selection process took"
  },
  {
    "startTime": 115.759,
    "endTime": 117.52,
    "text": "place"
  },
  {
    "startTime": 117.52,
    "endTime": 120.479,
    "text": "they asked me"
  },
  {
    "startTime": 121.6,
    "endTime": 123.36,
    "text": "could you"
  },
  {
    "startTime": 123.36,
    "endTime": 124.24,
    "text": "if"
  },
  {
    "startTime": 124.24,
    "endTime": 126.32,
    "text": "the evidence presented"
  },
  {
    "startTime": 126.32,
    "endTime": 128.879,
    "text": "justified the death penalty"
  },
  {
    "startTime": 128.879,
    "endTime": 131.36,
    "text": "could you deliver"
  },
  {
    "startTime": 131.36,
    "endTime": 134.0,
    "text": "rationally and without reservations a"
  },
  {
    "startTime": 134.0,
    "endTime": 136.959,
    "text": "penalty of death"
  },
  {
    "startTime": 137.52,
    "endTime": 141.52,
    "text": "my answer was an astounding yes"
  },
  {
    "startTime": 141.52,
    "endTime": 145.76,
    "text": "and i was selected as juror number two"
  },
  {
    "startTime": 146.239,
    "endTime": 148.4,
    "text": "the trial started"
  },
  {
    "startTime": 148.4,
    "endTime": 152.0,
    "text": "from the evidence being presented"
  },
  {
    "startTime": 152.0,
    "endTime": 154.879,
    "text": "and from the pictures of the victim"
  },
  {
    "startTime": 154.879,
    "endTime": 158.64,
    "text": "my first response was yes this man is a"
  },
  {
    "startTime": 158.64,
    "endTime": 159.84,
    "text": "monster"
  },
  {
    "startTime": 159.84,
    "endTime": 163.92,
    "text": "and he deserves the death penalty"
  },
  {
    "startTime": 164.0,
    "endTime": 165.76,
    "text": "for days"
  },
  {
    "startTime": 165.76,
    "endTime": 169.12,
    "text": "i sat and looked at his hands the ones"
  },
  {
    "startTime": 169.12,
    "endTime": 172.879,
    "text": "that yielded the knife"
  },
  {
    "startTime": 173.76,
    "endTime": 176.319,
    "text": "and his pasty uh well against his pasty"
  },
  {
    "startTime": 176.319,
    "endTime": 178.48,
    "text": "white skin"
  },
  {
    "startTime": 178.48,
    "endTime": 180.72,
    "text": "his eyes"
  },
  {
    "startTime": 180.72,
    "endTime": 184.08,
    "text": "well he spent endless days in his cell"
  },
  {
    "startTime": 184.08,
    "endTime": 185.599,
    "text": "no sunlight"
  },
  {
    "startTime": 185.599,
    "endTime": 188.159,
    "text": "so his eyes were as black as his hair"
  },
  {
    "startTime": 188.159,
    "endTime": 190.48,
    "text": "and his mustache"
  },
  {
    "startTime": 190.48,
    "endTime": 194.319,
    "text": "he was very intimidating"
  },
  {
    "startTime": 194.319,
    "endTime": 196.4,
    "text": "and there was absolutely"
  },
  {
    "startTime": 196.4,
    "endTime": 200.159,
    "text": "no doubt in his guilt"
  },
  {
    "startTime": 200.879,
    "endTime": 203.36,
    "text": "but regardless of his guilt"
  },
  {
    "startTime": 203.36,
    "endTime": 206.319,
    "text": "as the days passed"
  },
  {
    "startTime": 206.319,
    "endTime": 210.56,
    "text": "i began to see this monster"
  },
  {
    "startTime": 210.56,
    "endTime": 213.84,
    "text": "as a human being"
  },
  {
    "startTime": 214.0,
    "endTime": 216.0,
    "text": "something inside of me was changing that"
  },
  {
    "startTime": 216.0,
    "endTime": 216.799,
    "text": "i just"
  },
  {
    "startTime": 216.799,
    "endTime": 218.959,
    "text": "didn't understand"
  },
  {
    "startTime": 218.959,
    "endTime": 221.76,
    "text": "i was beginning to question myself as to"
  },
  {
    "startTime": 221.76,
    "endTime": 224.48,
    "text": "whether or not i wanted to give this man"
  },
  {
    "startTime": 224.48,
    "endTime": 227.599,
    "text": "the death penalty"
  },
  {
    "startTime": 227.599,
    "endTime": 230.4,
    "text": "jury deliberations began"
  },
  {
    "startTime": 230.4,
    "endTime": 232.48,
    "text": "and the judge"
  },
  {
    "startTime": 232.48,
    "endTime": 236.159,
    "text": "gave us jury instructions"
  },
  {
    "startTime": 236.239,
    "endTime": 239.12,
    "text": "and it was to be used as a tool"
  },
  {
    "startTime": 239.12,
    "endTime": 242.72,
    "text": "in how to reach a verdict"
  },
  {
    "startTime": 242.72,
    "endTime": 244.64,
    "text": "well using this two"
  },
  {
    "startTime": 244.64,
    "endTime": 247.439,
    "text": "only led to one decision"
  },
  {
    "startTime": 247.439,
    "endTime": 250.319,
    "text": "and that was the death penalty"
  },
  {
    "startTime": 250.319,
    "endTime": 253.04,
    "text": "i felt backed into a corner"
  },
  {
    "startTime": 253.04,
    "endTime": 255.2,
    "text": "my head and my heart were in conflict"
  },
  {
    "startTime": 255.2,
    "endTime": 256.479,
    "text": "with each other"
  },
  {
    "startTime": 256.479,
    "endTime": 258.72,
    "text": "and the thought of the death penalty"
  },
  {
    "startTime": 258.72,
    "endTime": 261.519,
    "text": "made me sick"
  },
  {
    "startTime": 263.36,
    "endTime": 265.28,
    "text": "however"
  },
  {
    "startTime": 265.28,
    "endTime": 268.08,
    "text": "following the judge's instructions"
  },
  {
    "startTime": 268.08,
    "endTime": 271.84,
    "text": "being a law-abiding person"
  },
  {
    "startTime": 271.84,
    "endTime": 274.24,
    "text": "i gave up"
  },
  {
    "startTime": 274.24,
    "endTime": 277.52,
    "text": "i gave up and voted along with other 11"
  },
  {
    "startTime": 277.52,
    "endTime": 280.0,
    "text": "jurors"
  },
  {
    "startTime": 280.479,
    "endTime": 282.639,
    "text": "and there it was"
  },
  {
    "startTime": 282.639,
    "endTime": 288.16,
    "text": "our broken judicial system at work"
  },
  {
    "startTime": 289.919,
    "endTime": 292.32,
    "text": "so here i am in my car"
  },
  {
    "startTime": 292.32,
    "endTime": 294.08,
    "text": "and i'm wondering"
  },
  {
    "startTime": 294.08,
    "endTime": 298.96,
    "text": "how is my life ever going to be the same"
  },
  {
    "startTime": 298.96,
    "endTime": 301.919,
    "text": "my life was kids work"
  },
  {
    "startTime": 301.919,
    "endTime": 304.4,
    "text": "church ball games"
  },
  {
    "startTime": 304.4,
    "endTime": 306.24,
    "text": "just your average"
  },
  {
    "startTime": 306.24,
    "endTime": 308.88,
    "text": "normal everyday life"
  },
  {
    "startTime": 308.88,
    "endTime": 311.28,
    "text": "now everything felt trivial"
  },
  {
    "startTime": 311.28,
    "endTime": 314.88,
    "text": "i was going down this rabbit hole"
  },
  {
    "startTime": 314.88,
    "endTime": 316.479,
    "text": "the anger"
  },
  {
    "startTime": 316.479,
    "endTime": 318.24,
    "text": "the anxiety"
  },
  {
    "startTime": 318.24,
    "endTime": 319.44,
    "text": "the guilt"
  },
  {
    "startTime": 319.44,
    "endTime": 321.12,
    "text": "the depression"
  },
  {
    "startTime": 321.12,
    "endTime": 322.84,
    "text": "it just clung to"
  },
  {
    "startTime": 322.84,
    "endTime": 328.88,
    "text": "me i knew that i my life had to resume"
  },
  {
    "startTime": 328.88,
    "endTime": 331.12,
    "text": "so i sought counseling"
  },
  {
    "startTime": 331.12,
    "endTime": 335.12,
    "text": "the counselor diagnosed me with ptsd"
  },
  {
    "startTime": 335.12,
    "endTime": 336.4,
    "text": "and told me"
  },
  {
    "startTime": 336.4,
    "endTime": 340.32,
    "text": "that the best way to overcome the ptsd"
  },
  {
    "startTime": 340.32,
    "endTime": 343.44,
    "text": "was to talk about the trauma"
  },
  {
    "startTime": 343.44,
    "endTime": 346.479,
    "text": "however if i talked about or tried to"
  },
  {
    "startTime": 346.479,
    "endTime": 348.88,
    "text": "talk about the trauma"
  },
  {
    "startTime": 348.88,
    "endTime": 352.479,
    "text": "outside her office i was shut down"
  },
  {
    "startTime": 352.479,
    "endTime": 354.88,
    "text": "no one wanted to hear about it"
  },
  {
    "startTime": 354.88,
    "endTime": 357.12,
    "text": "he was just a murderer"
  },
  {
    "startTime": 357.12,
    "endTime": 359.44,
    "text": "get over it"
  },
  {
    "startTime": 359.44,
    "endTime": 362.479,
    "text": "it was then that i decided to become a"
  },
  {
    "startTime": 362.479,
    "endTime": 366.08,
    "text": "silent survivor"
  },
  {
    "startTime": 366.08,
    "endTime": 369.84,
    "text": "twelve years later 2006"
  },
  {
    "startTime": 369.84,
    "endTime": 373.12,
    "text": "i learned that bobby wilcher had dropped"
  },
  {
    "startTime": 373.12,
    "endTime": 374.96,
    "text": "all of his appeals"
  },
  {
    "startTime": 374.96,
    "endTime": 377.44,
    "text": "and his execution date"
  },
  {
    "startTime": 377.44,
    "endTime": 379.12,
    "text": "was approaching"
  },
  {
    "startTime": 379.12,
    "endTime": 382.08,
    "text": "that was like a punch in the stomach"
  },
  {
    "startTime": 382.08,
    "endTime": 384.0,
    "text": "all of those buried feelings just"
  },
  {
    "startTime": 384.0,
    "endTime": 386.96,
    "text": "started coming back"
  },
  {
    "startTime": 387.759,
    "endTime": 390.4,
    "text": "to try and find peace i called bobby's"
  },
  {
    "startTime": 390.4,
    "endTime": 392.639,
    "text": "attorney and i said"
  },
  {
    "startTime": 392.639,
    "endTime": 396.319,
    "text": "can i see bobby before he's executed"
  },
  {
    "startTime": 396.319,
    "endTime": 399.039,
    "text": "driving to the penitentiary on the day"
  },
  {
    "startTime": 399.039,
    "endTime": 401.199,
    "text": "of his execution"
  },
  {
    "startTime": 401.199,
    "endTime": 402.72,
    "text": "in my mind"
  },
  {
    "startTime": 402.72,
    "endTime": 405.919,
    "text": "bobby was going to be manic"
  },
  {
    "startTime": 405.919,
    "endTime": 407.199,
    "text": "but"
  },
  {
    "startTime": 407.199,
    "endTime": 410.8,
    "text": "surprisingly he was very calm"
  },
  {
    "startTime": 410.8,
    "endTime": 414.479,
    "text": "and for two hours he and i sit there and"
  },
  {
    "startTime": 414.479,
    "endTime": 416.639,
    "text": "talked about life"
  },
  {
    "startTime": 416.639,
    "endTime": 420.88,
    "text": "and i got to ask him to forgive me for"
  },
  {
    "startTime": 420.88,
    "endTime": 424.08,
    "text": "my hand in his death"
  },
  {
    "startTime": 424.08,
    "endTime": 426.639,
    "text": "his words to me were"
  },
  {
    "startTime": 426.639,
    "endTime": 428.88,
    "text": "you don't have to apologize"
  },
  {
    "startTime": 428.88,
    "endTime": 430.88,
    "text": "you didn't put me here"
  },
  {
    "startTime": 430.88,
    "endTime": 433.919,
    "text": "i did this myself"
  },
  {
    "startTime": 433.919,
    "endTime": 436.0,
    "text": "but if it'll make you feel better i"
  },
  {
    "startTime": 436.0,
    "endTime": 438.8,
    "text": "forgive you"
  },
  {
    "startTime": 439.039,
    "endTime": 440.72,
    "text": "on my way home"
  },
  {
    "startTime": 440.72,
    "endTime": 442.88,
    "text": "i stopped by a restaurant"
  },
  {
    "startTime": 442.88,
    "endTime": 446.08,
    "text": "and bought a margarita"
  },
  {
    "startTime": 448.96,
    "endTime": 450.56,
    "text": "i don't think i could get one big enough"
  },
  {
    "startTime": 450.56,
    "endTime": 452.24,
    "text": "but"
  },
  {
    "startTime": 452.24,
    "endTime": 455.759,
    "text": "to try and calm down"
  },
  {
    "startTime": 455.759,
    "endTime": 458.08,
    "text": "my phone rang"
  },
  {
    "startTime": 458.08,
    "endTime": 461.039,
    "text": "it was bobby's attorney"
  },
  {
    "startTime": 461.039,
    "endTime": 464.24,
    "text": "within two minutes of his execution they"
  },
  {
    "startTime": 464.24,
    "endTime": 467.599,
    "text": "had given him a stay"
  },
  {
    "startTime": 468.319,
    "endTime": 469.759,
    "text": "this day"
  },
  {
    "startTime": 469.759,
    "endTime": 472.24,
    "text": "gave me time"
  },
  {
    "startTime": 472.24,
    "endTime": 475.199,
    "text": "to reach out to bobby"
  },
  {
    "startTime": 475.199,
    "endTime": 478.16,
    "text": "and as crazy as it may sound we became"
  },
  {
    "startTime": 478.16,
    "endTime": 480.639,
    "text": "friends"
  },
  {
    "startTime": 480.8,
    "endTime": 482.8,
    "text": "three months later"
  },
  {
    "startTime": 482.8,
    "endTime": 484.56,
    "text": "he was executed by the state of"
  },
  {
    "startTime": 484.56,
    "endTime": 487.28,
    "text": "mississippi"
  },
  {
    "startTime": 487.36,
    "endTime": 489.12,
    "text": "i'm here"
  },
  {
    "startTime": 489.12,
    "endTime": 490.639,
    "text": "to tell you"
  },
  {
    "startTime": 490.639,
    "endTime": 493.039,
    "text": "my story"
  },
  {
    "startTime": 493.039,
    "endTime": 496.8,
    "text": "because it was precisely 22 years"
  },
  {
    "startTime": 496.8,
    "endTime": 498.08,
    "text": "later"
  },
  {
    "startTime": 498.08,
    "endTime": 500.879,
    "text": "that i even wanted to open up enough to"
  },
  {
    "startTime": 500.879,
    "endTime": 502.96,
    "text": "talk about it"
  },
  {
    "startTime": 502.96,
    "endTime": 506.96,
    "text": "when a friend encouraged me to hate"
  },
  {
    "startTime": 506.96,
    "endTime": 509.199,
    "text": "perhaps you need to talk to the other"
  },
  {
    "startTime": 509.199,
    "endTime": 511.199,
    "text": "jurors you've been through the same"
  },
  {
    "startTime": 511.199,
    "endTime": 513.76,
    "text": "experience"
  },
  {
    "startTime": 513.76,
    "endTime": 516.399,
    "text": "uncertain of what i was after"
  },
  {
    "startTime": 516.399,
    "endTime": 519.039,
    "text": "i did need to talk to them"
  },
  {
    "startTime": 519.039,
    "endTime": 522.479,
    "text": "so i set out on my quest"
  },
  {
    "startTime": 522.479,
    "endTime": 524.959,
    "text": "and i actually found most of them"
  },
  {
    "startTime": 524.959,
    "endTime": 527.519,
    "text": "the first juror i met"
  },
  {
    "startTime": 527.519,
    "endTime": 530.56,
    "text": "thought that bobby got what he deserved"
  },
  {
    "startTime": 530.56,
    "endTime": 533.2,
    "text": "another juror"
  },
  {
    "startTime": 533.2,
    "endTime": 535.44,
    "text": "well they just kind of regretted that it"
  },
  {
    "startTime": 535.44,
    "endTime": 539.2,
    "text": "took so long to carry the sentence out"
  },
  {
    "startTime": 539.2,
    "endTime": 541.04,
    "text": "then one juror i don't know what was"
  },
  {
    "startTime": 541.04,
    "endTime": 542.64,
    "text": "wrong with him but he didn't remember"
  },
  {
    "startTime": 542.64,
    "endTime": 545.76,
    "text": "anything about the trial"
  },
  {
    "startTime": 546.839,
    "endTime": 548.8,
    "text": "well"
  },
  {
    "startTime": 548.8,
    "endTime": 552.16,
    "text": "i'm thinking in my mind geez is this the"
  },
  {
    "startTime": 552.16,
    "endTime": 553.92,
    "text": "response i'm gonna get from everybody"
  },
  {
    "startTime": 553.92,
    "endTime": 555.839,
    "text": "else"
  },
  {
    "startTime": 555.839,
    "endTime": 557.279,
    "text": "well"
  },
  {
    "startTime": 557.279,
    "endTime": 559.519,
    "text": "thank god for alan"
  },
  {
    "startTime": 559.519,
    "endTime": 562.8,
    "text": "allen was a gentle soul"
  },
  {
    "startTime": 562.8,
    "endTime": 564.64,
    "text": "and when i talked to him he was"
  },
  {
    "startTime": 564.64,
    "endTime": 566.64,
    "text": "genuinely upset"
  },
  {
    "startTime": 566.64,
    "endTime": 569.04,
    "text": "about our decision"
  },
  {
    "startTime": 569.04,
    "endTime": 571.12,
    "text": "and he told me"
  },
  {
    "startTime": 571.12,
    "endTime": 574.0,
    "text": "about the day that the devastation"
  },
  {
    "startTime": 574.0,
    "endTime": 577.76,
    "text": "really set in on him and hit him"
  },
  {
    "startTime": 577.76,
    "endTime": 580.0,
    "text": "he was listening to the radio"
  },
  {
    "startTime": 580.0,
    "endTime": 581.36,
    "text": "and the radio"
  },
  {
    "startTime": 581.36,
    "endTime": 584.16,
    "text": "they were had a list of names of men to"
  },
  {
    "startTime": 584.16,
    "endTime": 589.04,
    "text": "be executed at parchman penitentiary"
  },
  {
    "startTime": 589.2,
    "endTime": 591.36,
    "text": "he heard bobby's name"
  },
  {
    "startTime": 591.36,
    "endTime": 594.24,
    "text": "and he then truly realized what he had"
  },
  {
    "startTime": 594.24,
    "endTime": 596.72,
    "text": "done and he said you know"
  },
  {
    "startTime": 596.72,
    "endTime": 598.959,
    "text": "i had a responsibility in that man's"
  },
  {
    "startTime": 598.959,
    "endTime": 601.2,
    "text": "death"
  },
  {
    "startTime": 601.2,
    "endTime": 603.36,
    "text": "now here it is 20 something years later"
  },
  {
    "startTime": 603.36,
    "endTime": 606.48,
    "text": "and alan is still dealing with that"
  },
  {
    "startTime": 606.48,
    "endTime": 608.0,
    "text": "issue"
  },
  {
    "startTime": 608.0,
    "endTime": 610.56,
    "text": "and he's never told anyone about it not"
  },
  {
    "startTime": 610.56,
    "endTime": 613.44,
    "text": "even his wife"
  },
  {
    "startTime": 613.92,
    "endTime": 616.079,
    "text": "he also told me that if the state of"
  },
  {
    "startTime": 616.079,
    "endTime": 617.6,
    "text": "mississippi wanted to keep the death"
  },
  {
    "startTime": 617.6,
    "endTime": 618.399,
    "text": "penalty"
  },
  {
    "startTime": 618.399,
    "endTime": 620.48,
    "text": "then hey they needed to"
  },
  {
    "startTime": 620.48,
    "endTime": 621.68,
    "text": "provide"
  },
  {
    "startTime": 621.68,
    "endTime": 624.8,
    "text": "counseling for the jurors"
  },
  {
    "startTime": 624.8,
    "endTime": 627.839,
    "text": "then the next juror i met was jane"
  },
  {
    "startTime": 627.839,
    "endTime": 629.92,
    "text": "jane is now totally against the death"
  },
  {
    "startTime": 629.92,
    "endTime": 631.12,
    "text": "penalty"
  },
  {
    "startTime": 631.12,
    "endTime": 633.279,
    "text": "and there was bill"
  },
  {
    "startTime": 633.279,
    "endTime": 636.48,
    "text": "bill said he had this crushing"
  },
  {
    "startTime": 636.48,
    "endTime": 638.56,
    "text": "depression for weeks"
  },
  {
    "startTime": 638.56,
    "endTime": 640.64,
    "text": "and when he went back to work"
  },
  {
    "startTime": 640.64,
    "endTime": 643.44,
    "text": "his colleagues would say things to him"
  },
  {
    "startTime": 643.44,
    "endTime": 645.76,
    "text": "like hey did you firm"
  },
  {
    "startTime": 645.76,
    "endTime": 648.72,
    "text": "to them it was just a joke"
  },
  {
    "startTime": 648.72,
    "endTime": 650.64,
    "text": "then there was john"
  },
  {
    "startTime": 650.64,
    "endTime": 653.12,
    "text": "john said his decision"
  },
  {
    "startTime": 653.12,
    "endTime": 654.959,
    "text": "weighed on him"
  },
  {
    "startTime": 654.959,
    "endTime": 658.399,
    "text": "and it burdened him daily"
  },
  {
    "startTime": 658.399,
    "endTime": 661.519,
    "text": "the final juror that i spoke to was ken"
  },
  {
    "startTime": 661.519,
    "endTime": 664.88,
    "text": "ken was the foreman of the jury"
  },
  {
    "startTime": 664.88,
    "endTime": 668.32,
    "text": "when we sat down to talk"
  },
  {
    "startTime": 668.32,
    "endTime": 670.72,
    "text": "it was apparent that he was deeply"
  },
  {
    "startTime": 670.72,
    "endTime": 675.36,
    "text": "saddened by what we were required to do"
  },
  {
    "startTime": 675.36,
    "endTime": 677.36,
    "text": "he relived the day"
  },
  {
    "startTime": 677.36,
    "endTime": 679.76,
    "text": "that he left the courthouse"
  },
  {
    "startTime": 679.76,
    "endTime": 681.6,
    "text": "and he drove home"
  },
  {
    "startTime": 681.6,
    "endTime": 683.92,
    "text": "and he went to put his key in his door"
  },
  {
    "startTime": 683.92,
    "endTime": 686.399,
    "text": "and unlock it and he said he literally"
  },
  {
    "startTime": 686.399,
    "endTime": 689.839,
    "text": "broke down"
  },
  {
    "startTime": 690.16,
    "endTime": 693.279,
    "text": "he said he knew that bobby was guilty"
  },
  {
    "startTime": 693.279,
    "endTime": 697.279,
    "text": "but the decision he made he did not"
  },
  {
    "startTime": 697.279,
    "endTime": 699.92,
    "text": "know if it was the right decision"
  },
  {
    "startTime": 699.92,
    "endTime": 701.92,
    "text": "and he said that he played it over and"
  },
  {
    "startTime": 701.92,
    "endTime": 703.839,
    "text": "over in his head"
  },
  {
    "startTime": 703.839,
    "endTime": 706.64,
    "text": "did we do the right thing"
  },
  {
    "startTime": 706.64,
    "endTime": 709.519,
    "text": "did we do the right thing"
  },
  {
    "startTime": 709.519,
    "endTime": 714.279,
    "text": "did we do the right thing"
  },
  {
    "startTime": 718.32,
    "endTime": 720.64,
    "text": "all those years"
  },
  {
    "startTime": 720.64,
    "endTime": 723.2,
    "text": "and i finally realized that i was not"
  },
  {
    "startTime": 723.2,
    "endTime": 726.639,
    "text": "the only disillusioned juror"
  },
  {
    "startTime": 726.639,
    "endTime": 728.639,
    "text": "and we talked about"
  },
  {
    "startTime": 728.639,
    "endTime": 731.68,
    "text": "sharing our experience"
  },
  {
    "startTime": 731.68,
    "endTime": 735.279,
    "text": "with potential jurors"
  },
  {
    "startTime": 735.279,
    "endTime": 737.68,
    "text": "to give them some insight into what to"
  },
  {
    "startTime": 737.68,
    "endTime": 739.92,
    "text": "expect"
  },
  {
    "startTime": 739.92,
    "endTime": 743.6,
    "text": "and to tell them do not be complacent"
  },
  {
    "startTime": 743.6,
    "endTime": 746.48,
    "text": "to know what you believe"
  },
  {
    "startTime": 746.48,
    "endTime": 751.2,
    "text": "to know where you stand and be prepared"
  },
  {
    "startTime": 751.2,
    "endTime": 753.6,
    "text": "because you don't want to walk in"
  },
  {
    "startTime": 753.6,
    "endTime": 755.76,
    "text": "one morning"
  },
  {
    "startTime": 755.76,
    "endTime": 757.36,
    "text": "as a juror"
  },
  {
    "startTime": 757.36,
    "endTime": 759.279,
    "text": "and leave at the end of the trial"
  },
  {
    "startTime": 759.279,
    "endTime": 762.399,
    "text": "feeling like a murderer"
  },
  {
    "startTime": 762.399,
    "endTime": 764.72,
    "text": "now through this storm of my life i did"
  },
  {
    "startTime": 764.72,
    "endTime": 766.48,
    "text": "find some inspiration"
  },
  {
    "startTime": 766.48,
    "endTime": 767.839,
    "text": "and it came in the form of my"
  },
  {
    "startTime": 767.839,
    "endTime": 770.56,
    "text": "granddaughters"
  },
  {
    "startTime": 770.56,
    "endTime": 773.6,
    "text": "my 14 year old granddaughter maddie"
  },
  {
    "startTime": 773.6,
    "endTime": 775.44,
    "text": "was writing an essay on the death"
  },
  {
    "startTime": 775.44,
    "endTime": 776.959,
    "text": "penalty for school"
  },
  {
    "startTime": 776.959,
    "endTime": 779.76,
    "text": "and she was asking me questions"
  },
  {
    "startTime": 779.76,
    "endTime": 782.16,
    "text": "well it dawned on me that this child was"
  },
  {
    "startTime": 782.16,
    "endTime": 785.2,
    "text": "being raised in the same"
  },
  {
    "startTime": 785.2,
    "endTime": 787.92,
    "text": "eye for an eye culture"
  },
  {
    "startTime": 787.92,
    "endTime": 789.519,
    "text": "as i was"
  },
  {
    "startTime": 789.519,
    "endTime": 792.32,
    "text": "or had been"
  },
  {
    "startTime": 792.32,
    "endTime": 795.04,
    "text": "and so i explained my experience to her"
  },
  {
    "startTime": 795.04,
    "endTime": 796.8,
    "text": "this way"
  },
  {
    "startTime": 796.8,
    "endTime": 798.56,
    "text": "that i had"
  },
  {
    "startTime": 798.56,
    "endTime": 801.68,
    "text": "sent someone to death"
  },
  {
    "startTime": 801.68,
    "endTime": 806.32,
    "text": "as i served on a jury and i asked her"
  },
  {
    "startTime": 806.32,
    "endTime": 809.519,
    "text": "did that make me a murderer"
  },
  {
    "startTime": 809.519,
    "endTime": 811.519,
    "text": "she couldn't answer"
  },
  {
    "startTime": 811.519,
    "endTime": 813.12,
    "text": "i knew then"
  },
  {
    "startTime": 813.12,
    "endTime": 815.279,
    "text": "that this topic needed to be open for"
  },
  {
    "startTime": 815.279,
    "endTime": 818.48,
    "text": "discussion and guess what happened"
  },
  {
    "startTime": 818.48,
    "endTime": 822.24,
    "text": "i got invited to speak just recently"
  },
  {
    "startTime": 822.24,
    "endTime": 825.44,
    "text": "in an abolitionist community"
  },
  {
    "startTime": 825.44,
    "endTime": 828.639,
    "text": "while i was there i got a t-shirt"
  },
  {
    "startTime": 828.639,
    "endTime": 831.839,
    "text": "and it said stop executions"
  },
  {
    "startTime": 831.839,
    "endTime": 833.92,
    "text": "well when i get home my 16 year old"
  },
  {
    "startTime": 833.92,
    "endTime": 836.639,
    "text": "granddaughter was there anna"
  },
  {
    "startTime": 836.639,
    "endTime": 839.92,
    "text": "and she says can i have that shirt"
  },
  {
    "startTime": 839.92,
    "endTime": 842.399,
    "text": "well i looked at her dad"
  },
  {
    "startTime": 842.399,
    "endTime": 844.72,
    "text": "her dad is my son"
  },
  {
    "startTime": 844.72,
    "endTime": 847.36,
    "text": "and i knew that he is still dealing with"
  },
  {
    "startTime": 847.36,
    "endTime": 849.6,
    "text": "this death penalty issue"
  },
  {
    "startTime": 849.6,
    "endTime": 851.36,
    "text": "so i turned around and i looked at her"
  },
  {
    "startTime": 851.36,
    "endTime": 854.56,
    "text": "and i said are you gonna wear this"
  },
  {
    "startTime": 854.56,
    "endTime": 856.56,
    "text": "so she turned and she looked at her dad"
  },
  {
    "startTime": 856.56,
    "endTime": 858.079,
    "text": "and she said"
  },
  {
    "startTime": 858.079,
    "endTime": 859.12,
    "text": "dad"
  },
  {
    "startTime": 859.12,
    "endTime": 860.959,
    "text": "i know how you feel"
  },
  {
    "startTime": 860.959,
    "endTime": 864.32,
    "text": "but i don't believe in the death penalty"
  },
  {
    "startTime": 864.32,
    "endTime": 865.6,
    "text": "my son"
  },
  {
    "startTime": 865.6,
    "endTime": 867.519,
    "text": "looked at me"
  },
  {
    "startTime": 867.519,
    "endTime": 871.68,
    "text": "shook his head and said"
  },
  {
    "startTime": 871.68,
    "endTime": 874.0,
    "text": "thanks mom"
  },
  {
    "startTime": 874.0,
    "endTime": 879.36,
    "text": "and i knew it wasn't a nice thanks mom"
  },
  {
    "startTime": 879.839,
    "endTime": 880.639,
    "text": "so"
  },
  {
    "startTime": 880.639,
    "endTime": 883.279,
    "text": "i learned that life had taught me some"
  },
  {
    "startTime": 883.279,
    "endTime": 885.839,
    "text": "lessons"
  },
  {
    "startTime": 886.079,
    "endTime": 887.76,
    "text": "it taught me"
  },
  {
    "startTime": 887.76,
    "endTime": 891.44,
    "text": "if i had not served on that jury"
  },
  {
    "startTime": 891.44,
    "endTime": 894.32,
    "text": "that i would still be of the same"
  },
  {
    "startTime": 894.32,
    "endTime": 896.88,
    "text": "mindset"
  },
  {
    "startTime": 896.88,
    "endTime": 900.399,
    "text": "it also gave me confidence to be able to"
  },
  {
    "startTime": 900.399,
    "endTime": 901.76,
    "text": "see through the eyes of my"
  },
  {
    "startTime": 901.76,
    "endTime": 903.68,
    "text": "granddaughters"
  },
  {
    "startTime": 903.68,
    "endTime": 905.92,
    "text": "that this younger generation"
  },
  {
    "startTime": 905.92,
    "endTime": 907.36,
    "text": "they're capable"
  },
  {
    "startTime": 907.36,
    "endTime": 908.959,
    "text": "and they're willing"
  },
  {
    "startTime": 908.959,
    "endTime": 911.44,
    "text": "to tackle these difficult"
  },
  {
    "startTime": 911.44,
    "endTime": 914.079,
    "text": "social issues"
  },
  {
    "startTime": 914.079,
    "endTime": 916.56,
    "text": "and because of my experience"
  },
  {
    "startTime": 916.56,
    "endTime": 918.8,
    "text": "my granddaughters"
  },
  {
    "startTime": 918.8,
    "endTime": 920.24,
    "text": "they're now"
  },
  {
    "startTime": 920.24,
    "endTime": 922.0,
    "text": "more equipped"
  },
  {
    "startTime": 922.0,
    "endTime": 924.839,
    "text": "to stand on their own and to think for"
  },
  {
    "startTime": 924.839,
    "endTime": 928.32,
    "text": "themselves than"
  },
  {
    "startTime": 928.32,
    "endTime": 932.16,
    "text": "to rely on cultural beliefs"
  },
  {
    "startTime": 932.16,
    "endTime": 934.079,
    "text": "so"
  },
  {
    "startTime": 934.079,
    "endTime": 936.639,
    "text": "being from a conservative christian"
  },
  {
    "startTime": 936.639,
    "endTime": 938.32,
    "text": "family"
  },
  {
    "startTime": 938.32,
    "endTime": 941.12,
    "text": "from a very conservative state in the"
  },
  {
    "startTime": 941.12,
    "endTime": 944.16,
    "text": "united states"
  },
  {
    "startTime": 944.32,
    "endTime": 946.8,
    "text": "i am here to tell you that"
  },
  {
    "startTime": 946.8,
    "endTime": 949.279,
    "text": "the death penalty has"
  },
  {
    "startTime": 949.279,
    "endTime": 951.44,
    "text": "new opponents"
  },
  {
    "startTime": 951.44,
    "endTime": 954.68,
    "text": "thank you"
  },
  {
    "startTime": 957.94,
    "endTime": 961.159,
    "text": "[Music]"
  }
]