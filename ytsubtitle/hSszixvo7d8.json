[
  {
    "startTime": 0.0,
    "endTime": 7.12,
    "text": "[Music]"
  },
  {
    "startTime": 7.12,
    "endTime": 7.839,
    "text": "for most"
  },
  {
    "startTime": 7.839,
    "endTime": 10.0,
    "text": "jobs it's understood that you can be"
  },
  {
    "startTime": 10.0,
    "endTime": 12.0,
    "text": "fired whether for crime"
  },
  {
    "startTime": 12.0,
    "endTime": 15.599,
    "text": "incompetence or just poor performance"
  },
  {
    "startTime": 15.599,
    "endTime": 17.6,
    "text": "but what if your job happens to be the"
  },
  {
    "startTime": 17.6,
    "endTime": 19.279,
    "text": "most powerful position"
  },
  {
    "startTime": 19.279,
    "endTime": 22.88,
    "text": "in the country or the world that's where"
  },
  {
    "startTime": 22.88,
    "endTime": 25.76,
    "text": "impeachment comes in impeachment isn't"
  },
  {
    "startTime": 25.76,
    "endTime": 26.56,
    "text": "the same as"
  },
  {
    "startTime": 26.56,
    "endTime": 29.84,
    "text": "actually removing someone from office"
  },
  {
    "startTime": 29.84,
    "endTime": 32.16,
    "text": "like an indictment in criminal court"
  },
  {
    "startTime": 32.16,
    "endTime": 34.48,
    "text": "it's only the formal accusation"
  },
  {
    "startTime": 34.48,
    "endTime": 37.04,
    "text": "that launches a trial which could end in"
  },
  {
    "startTime": 37.04,
    "endTime": 37.92,
    "text": "conviction"
  },
  {
    "startTime": 37.92,
    "endTime": 41.04,
    "text": "or acquittal originating in the united"
  },
  {
    "startTime": 41.04,
    "endTime": 41.76,
    "text": "kingdom"
  },
  {
    "startTime": 41.76,
    "endTime": 44.239,
    "text": "impeachment allowed parliament to vote"
  },
  {
    "startTime": 44.239,
    "endTime": 45.12,
    "text": "for removing"
  },
  {
    "startTime": 45.12,
    "endTime": 47.84,
    "text": "a government official from office even"
  },
  {
    "startTime": 47.84,
    "endTime": 50.079,
    "text": "without the king's consent"
  },
  {
    "startTime": 50.079,
    "endTime": 52.32,
    "text": "although this was an important check on"
  },
  {
    "startTime": 52.32,
    "endTime": 53.44,
    "text": "royal power"
  },
  {
    "startTime": 53.44,
    "endTime": 55.92,
    "text": "the king couldn't be impeached because"
  },
  {
    "startTime": 55.92,
    "endTime": 58.079,
    "text": "the monarch was considered the source of"
  },
  {
    "startTime": 58.079,
    "endTime": 59.84,
    "text": "all government power"
  },
  {
    "startTime": 59.84,
    "endTime": 61.68,
    "text": "but for the founders of the american"
  },
  {
    "startTime": 61.68,
    "endTime": 64.478,
    "text": "republic there was no higher authority"
  },
  {
    "startTime": 64.479,
    "endTime": 67.28,
    "text": "beyond the people themselves and so"
  },
  {
    "startTime": 67.28,
    "endTime": 69.28,
    "text": "impeachment was adopted in the united"
  },
  {
    "startTime": 69.28,
    "endTime": 69.92,
    "text": "states"
  },
  {
    "startTime": 69.92,
    "endTime": 72.799,
    "text": "as a power of congress applying to any"
  },
  {
    "startTime": 72.799,
    "endTime": 74.159,
    "text": "civil officers"
  },
  {
    "startTime": 74.159,
    "endTime": 76.72,
    "text": "up to and including the president"
  },
  {
    "startTime": 76.72,
    "endTime": 77.28,
    "text": "although"
  },
  {
    "startTime": 77.28,
    "endTime": 79.439,
    "text": "demands for impeachment can come from"
  },
  {
    "startTime": 79.439,
    "endTime": 81.04,
    "text": "any members of the public"
  },
  {
    "startTime": 81.04,
    "endTime": 83.2,
    "text": "only the house of representatives has"
  },
  {
    "startTime": 83.2,
    "endTime": 84.479,
    "text": "the power to actually"
  },
  {
    "startTime": 84.479,
    "endTime": 87.6,
    "text": "initiate the process it begins by"
  },
  {
    "startTime": 87.6,
    "endTime": 89.6,
    "text": "referring the matter to a committee"
  },
  {
    "startTime": 89.6,
    "endTime": 92.159,
    "text": "usually the house committee on rules and"
  },
  {
    "startTime": 92.159,
    "endTime": 94.479,
    "text": "the house committee on the judiciary"
  },
  {
    "startTime": 94.479,
    "endTime": 96.88,
    "text": "these committees review the accusations"
  },
  {
    "startTime": 96.88,
    "endTime": 98.24,
    "text": "examine the evidence"
  },
  {
    "startTime": 98.24,
    "endTime": 101.439,
    "text": "and issue a recommendation if they find"
  },
  {
    "startTime": 101.439,
    "endTime": 103.84,
    "text": "sufficient grounds to proceed the house"
  },
  {
    "startTime": 103.84,
    "endTime": 105.439,
    "text": "holds a separate vote"
  },
  {
    "startTime": 105.439,
    "endTime": 108.64,
    "text": "on each of the specific charges known as"
  },
  {
    "startTime": 108.64,
    "endTime": 111.68,
    "text": "articles of impeachment if one or more"
  },
  {
    "startTime": 111.68,
    "endTime": 114.64,
    "text": "passes by a simple majority the official"
  },
  {
    "startTime": 114.64,
    "endTime": 115.759,
    "text": "is impeached"
  },
  {
    "startTime": 115.759,
    "endTime": 118.96,
    "text": "and the stage is set for trial the"
  },
  {
    "startTime": 118.96,
    "endTime": 120.64,
    "text": "actual trial that follows"
  },
  {
    "startTime": 120.64,
    "endTime": 123.2,
    "text": "impeachment is held in the senate"
  },
  {
    "startTime": 123.2,
    "endTime": 125.119,
    "text": "selected members of the house"
  },
  {
    "startTime": 125.119,
    "endTime": 128.319,
    "text": "known as managers act as the prosecution"
  },
  {
    "startTime": 128.319,
    "endTime": 130.0,
    "text": "while the impeached official and their"
  },
  {
    "startTime": 130.0,
    "endTime": 132.4,
    "text": "lawyers present their defense"
  },
  {
    "startTime": 132.4,
    "endTime": 135.52,
    "text": "the senate acts as both judge and jury"
  },
  {
    "startTime": 135.52,
    "endTime": 138.239,
    "text": "conducting the trial and deliberating"
  },
  {
    "startTime": 138.239,
    "endTime": 139.04,
    "text": "after hearing"
  },
  {
    "startTime": 139.04,
    "endTime": 141.44,
    "text": "all the arguments if it's the president"
  },
  {
    "startTime": 141.44,
    "endTime": 143.68,
    "text": "or vice president being impeached"
  },
  {
    "startTime": 143.68,
    "endTime": 145.84,
    "text": "the chief justice of the supreme court"
  },
  {
    "startTime": 145.84,
    "endTime": 147.12,
    "text": "presides"
  },
  {
    "startTime": 147.12,
    "endTime": 150.16,
    "text": "a conviction requires a super majority"
  },
  {
    "startTime": 150.16,
    "endTime": 153.2,
    "text": "of two-thirds and results in automatic"
  },
  {
    "startTime": 153.2,
    "endTime": 155.12,
    "text": "removal from power"
  },
  {
    "startTime": 155.12,
    "endTime": 157.519,
    "text": "depending on the original charges it can"
  },
  {
    "startTime": 157.519,
    "endTime": 159.12,
    "text": "also disqualify them"
  },
  {
    "startTime": 159.12,
    "endTime": 161.84,
    "text": "from holding office in the future and"
  },
  {
    "startTime": 161.84,
    "endTime": 163.519,
    "text": "open them to standard criminal"
  },
  {
    "startTime": 163.519,
    "endTime": 164.959,
    "text": "prosecution"
  },
  {
    "startTime": 164.959,
    "endTime": 167.36,
    "text": "so what exactly can get someone"
  },
  {
    "startTime": 167.36,
    "endTime": 168.48,
    "text": "impeached"
  },
  {
    "startTime": 168.48,
    "endTime": 171.2,
    "text": "that's a bit more complicated unlike in"
  },
  {
    "startTime": 171.2,
    "endTime": 172.48,
    "text": "the united kingdom"
  },
  {
    "startTime": 172.48,
    "endTime": 175.04,
    "text": "impeachment in the u.s pits an elected"
  },
  {
    "startTime": 175.04,
    "endTime": 176.0,
    "text": "legislature"
  },
  {
    "startTime": 176.0,
    "endTime": 178.239,
    "text": "against other democratically elected"
  },
  {
    "startTime": 178.239,
    "endTime": 179.68,
    "text": "members of government"
  },
  {
    "startTime": 179.68,
    "endTime": 181.68,
    "text": "therefore to prevent the process from"
  },
  {
    "startTime": 181.68,
    "endTime": 184.0,
    "text": "being used as a political weapon the"
  },
  {
    "startTime": 184.0,
    "endTime": 186.239,
    "text": "constitution specifies that an official"
  },
  {
    "startTime": 186.239,
    "endTime": 187.92,
    "text": "can only be impeached"
  },
  {
    "startTime": 187.92,
    "endTime": 191.519,
    "text": "for treason bribery or other high crimes"
  },
  {
    "startTime": 191.519,
    "endTime": 193.12,
    "text": "and misdemeanors"
  },
  {
    "startTime": 193.12,
    "endTime": 195.12,
    "text": "that still leaves a lot of room for"
  },
  {
    "startTime": 195.12,
    "endTime": 196.159,
    "text": "interpretation"
  },
  {
    "startTime": 196.159,
    "endTime": 198.56,
    "text": "not to mention politics and many"
  },
  {
    "startTime": 198.56,
    "endTime": 199.76,
    "text": "impeachment trials"
  },
  {
    "startTime": 199.76,
    "endTime": 202.879,
    "text": "have split along partisan lines but the"
  },
  {
    "startTime": 202.879,
    "endTime": 203.44,
    "text": "process"
  },
  {
    "startTime": 203.44,
    "endTime": 205.92,
    "text": "is generally understood to be reserved"
  },
  {
    "startTime": 205.92,
    "endTime": 206.879,
    "text": "for serious"
  },
  {
    "startTime": 206.879,
    "endTime": 209.68,
    "text": "abuses of power the first official to be"
  },
  {
    "startTime": 209.68,
    "endTime": 210.4,
    "text": "impeached"
  },
  {
    "startTime": 210.4,
    "endTime": 213.56,
    "text": "was tennessee senator william blunt in"
  },
  {
    "startTime": 213.56,
    "endTime": 214.959,
    "text": "1797"
  },
  {
    "startTime": 214.959,
    "endTime": 217.84,
    "text": "for conspiring with britain to seize the"
  },
  {
    "startTime": 217.84,
    "endTime": 218.879,
    "text": "spanish colony"
  },
  {
    "startTime": 218.879,
    "endTime": 221.76,
    "text": "of louisiana since then the house has"
  },
  {
    "startTime": 221.76,
    "endTime": 223.76,
    "text": "launched impeachment investigations"
  },
  {
    "startTime": 223.76,
    "endTime": 226.879,
    "text": "about 60 times but only 19"
  },
  {
    "startTime": 226.879,
    "endTime": 228.799,
    "text": "have led to actual impeachment"
  },
  {
    "startTime": 228.799,
    "endTime": 230.08,
    "text": "proceedings"
  },
  {
    "startTime": 230.08,
    "endTime": 231.92,
    "text": "the eight cases that ended in a"
  },
  {
    "startTime": 231.92,
    "endTime": 234.0,
    "text": "conviction and removal from office"
  },
  {
    "startTime": 234.0,
    "endTime": 236.72,
    "text": "were all federal judges and impeachment"
  },
  {
    "startTime": 236.72,
    "endTime": 238.08,
    "text": "of a sitting president"
  },
  {
    "startTime": 238.08,
    "endTime": 241.2,
    "text": "is even more rare andrew johnson was"
  },
  {
    "startTime": 241.2,
    "endTime": 243.36,
    "text": "impeached in 1868"
  },
  {
    "startTime": 243.36,
    "endTime": 245.439,
    "text": "for attempting to replace secretary of"
  },
  {
    "startTime": 245.439,
    "endTime": 247.04,
    "text": "war edwin stanton"
  },
  {
    "startTime": 247.04,
    "endTime": 249.599,
    "text": "without consulting the senate over a"
  },
  {
    "startTime": 249.599,
    "endTime": 250.72,
    "text": "century later"
  },
  {
    "startTime": 250.72,
    "endTime": 252.64,
    "text": "bill clinton was impeached for making"
  },
  {
    "startTime": 252.64,
    "endTime": 254.48,
    "text": "false statements under oath"
  },
  {
    "startTime": 254.48,
    "endTime": 257.44,
    "text": "during a sexual harassment trial both"
  },
  {
    "startTime": 257.44,
    "endTime": 258.32,
    "text": "were ultimately"
  },
  {
    "startTime": 258.32,
    "endTime": 260.239,
    "text": "acquitted when the senate's votes to"
  },
  {
    "startTime": 260.239,
    "endTime": 261.44,
    "text": "convict fell"
  },
  {
    "startTime": 261.44,
    "endTime": 263.36,
    "text": "short of the required two-thirds"
  },
  {
    "startTime": 263.36,
    "endTime": 264.639,
    "text": "majority"
  },
  {
    "startTime": 264.639,
    "endTime": 267.28,
    "text": "and contrary to popular belief richard"
  },
  {
    "startTime": 267.28,
    "endTime": 268.639,
    "text": "nixon was never"
  },
  {
    "startTime": 268.639,
    "endTime": 270.8,
    "text": "actually impeached for the watergate"
  },
  {
    "startTime": 270.8,
    "endTime": 273.04,
    "text": "scandal he resigned before it could"
  },
  {
    "startTime": 273.04,
    "endTime": 273.84,
    "text": "happen"
  },
  {
    "startTime": 273.84,
    "endTime": 275.84,
    "text": "knowing he would almost certainly be"
  },
  {
    "startTime": 275.84,
    "endTime": 276.96,
    "text": "convicted"
  },
  {
    "startTime": 276.96,
    "endTime": 279.12,
    "text": "theoretically the u.s government is"
  },
  {
    "startTime": 279.12,
    "endTime": 281.36,
    "text": "already designed to prevent abuses of"
  },
  {
    "startTime": 281.36,
    "endTime": 282.08,
    "text": "power"
  },
  {
    "startTime": 282.08,
    "endTime": 283.919,
    "text": "limiting different branches through a"
  },
  {
    "startTime": 283.919,
    "endTime": 285.759,
    "text": "system of checks and balances"
  },
  {
    "startTime": 285.759,
    "endTime": 288.479,
    "text": "term limits and free elections but"
  },
  {
    "startTime": 288.479,
    "endTime": 289.36,
    "text": "impeachment"
  },
  {
    "startTime": 289.36,
    "endTime": 291.919,
    "text": "can be seen as an emergency break for"
  },
  {
    "startTime": 291.919,
    "endTime": 294.84,
    "text": "when these safeguards"
  },
  {
    "startTime": 294.84,
    "endTime": 297.199,
    "text": "fail"
  },
  {
    "startTime": 297.199,
    "endTime": 299.68,
    "text": "ted ed is a non-profit if you value our"
  },
  {
    "startTime": 299.68,
    "endTime": 303.68,
    "text": "work please consider supporting it on"
  },
  {
    "startTime": 304.22,
    "endTime": 308.84,
    "text": "[Music]"
  },
  {
    "startTime": 308.84,
    "endTime": 311.84,
    "text": "patreon.com"
  },
  {
    "startTime": 312.08,
    "endTime": 314.319,
    "text": "bye"
  }
]