  },
  {
    "startTime": 53.37,
    "endTime": 54.75,
    "text": "We both have dark hair."
  },
  {
    "startTime": 54.75,
    "endTime": 58.139,
    "text": "We're both white guys, which is not as exciting as it used to be."
  },
  {
    "startTime": 58.14,
