[
  {
    "startTime": 11.8,
    "endTime": 13.5,
    "text": "My New Year's resolution?"
  },
  {
    "startTime": 13.5,
    "endTime": 18.0,
    "text": "I resolve to share my sweater with anyone in the store who gets cold."
  },
  {
    "startTime": 18.0,
    "endTime": 23.8,
    "text": "This year, I vow to not leave here until I've written ten pages a day of my novel."
  },
  {
    "startTime": 23.8,
    "endTime": 27.0,
    "text": "Ten good pages."
  },
  {
    "startTime": 27.0,
    "endTime": 29.8,
    "text": "Oh, I'm going to master all my magic tricks. Yep."
  },
  {
    "startTime": 29.8,
    "endTime": 33.0,
    "text": "Looks like you have a quarter in your ear there."
  },
  {
    "startTime": 34.0,
    "endTime": 35.3,
    "text": "Yeah, that's stuck."
  },
  {
    "startTime": 35.3,
    "endTime": 37.0,
    "text": "Better get my pliers."
  },
  {
    "startTime": 38.0,
    "endTime": 43.0,
    "text": "And our resolution is to stop stressing out about what we're going to name our little bundle of joy."
  },
  {
    "startTime": 43.0,
    "endTime": 44.5,
    "text": "Ah! Joy! That's it. Joy!"
  },
  {
    "startTime": 44.5,
    "endTime": 45.5,
    "text": "We finally have the name!"
  },
  {
    "startTime": 46.0,
    "endTime": 47.0,
    "text": "-Yeah! -Congrats! -Yay!"
  },
  {
    "startTime": 50.3,
    "endTime": 52.0,
    "text": "His mother is Joy."
  },
  {
    "startTime": 52.0,
    "endTime": 53.0,
    "text": "-That's not the name. -Huh? Oh."
  },
  {
    "startTime": 57.8,
    "endTime": 63.0,
    "text": "I resolve to get inspiration from the things that are truly meaningful to me."
  },
  {
    "startTime": 63.0,
    "endTime": 65.0,
    "text": "I love it."
  },
  {
    "startTime": 65.0,
    "endTime": 66.8,
    "text": "Who is the ladybug?"
  },
  {
    "startTime": 66.8,
    "endTime": 69.0,
    "text": "What? I didn't draw a ladybug."
  },
  {
    "startTime": 69.7,
    "endTime": 71.0,
    "text": "I'm Cathy."
  },
  {
    "startTime": 71.0,
    "endTime": 73.0,
    "text": "Just kickin' it."
  }
