  },
  {
    "startTime": 401.3,
    "endTime": 404.03000000000003,
    "text": "What country have you never visited but you're dying to get there?"
  },
  {
    "startTime": 404.03,
    "endTime": 405.44,
    "text": "Sri Lanka."
  },
  {
    "startTime": 407.0,
    "endTime": 408.53,
    "text": "Oh, that would be Julia."
  },
  {
    "startTime": 408.53,
    "endTime": 411.02,
    "text": "When have you felt most starstruck?"
  },
  {
    "startTime": 411.02,
