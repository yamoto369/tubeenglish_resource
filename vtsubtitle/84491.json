  {
    "startTime": 393.42,
    "endTime": 394.0,
    "text": "Oh."
  },
  {
    "startTime": 394.0,
    "endTime": 395.25,
    "text": "What was the best part about Cannes?"
  },
  {
    "startTime": 395.25,
