  },
  {
    "startTime": 418.89,
    "endTime": 419.22999999999996,
    "text": "Hey!"
  },
  {
    "startTime": 419.23,
    "endTime": 420.0,
    "text": "- Hi, Moo. - Come on in."
  },
  {
    "startTime": 420.0,
    "endTime": 421.55,
    "text": "Who's this?"
