[
  {
    "startTime": 2.8,
    "endTime": 4.6,
    "text": "You're an interesting man..."
  },
  {
    "startTime": 4.8,
    "endTime": 8.222,
    "text": "Scott Lang."
  },
  {
    "startTime": 8.222,
    "endTime": 11.14,
    "text": "You're an Avenger."
  },
  {
    "startTime": 13.492,
    "endTime": 16.352,
    "text": "You have a daughter."
  },
  {
    "startTime": 16.352,
    "endTime": 21.6,
    "text": "But you've lost a lot of time, like me."
  },
  {
    "startTime": 21.8,
    "endTime": 26.200000000000003,
    "text": "We can help each other with that."
  },
  {
    "startTime": 26.357,
    "endTime": 31.4,
    "text": "Dad!"
  },
  {
    "startTime": 31.6,
    "endTime": 33.300000000000004,
    "text": "Who are you?"
  },
  {
    "startTime": 33.5,
    "endTime": 38.3,
    "text": "I'm the man who can give you the one thing you want."
  },
  {
    "startTime": 38.5,
    "endTime": 39.8,
    "text": "What's that?"
  },
  {
    "startTime": 40.0,
    "endTime": 42.817,
    "text": "Time."
  },
  {
    "startTime": 46.1,
    "endTime": 50.068,
    "text": "He can re-write existence..."
  },
  {
    "startTime": 50.068,
    "endTime": 54.232,
    "text": "...and shatter timelines."
  },
  {
    "startTime": 54.232,
    "endTime": 56.2,
    "text": "You cannot trust him!"
  },
  {
    "startTime": 56.4,
    "endTime": 58.199999999999996,
    "text": "I don't care who this guy is."
  },
  {
    "startTime": 58.4,
    "endTime": 59.6,
    "text": "I just lost so much."
  },
  {
    "startTime": 59.9,
    "endTime": 62.3,
    "text": "Daddy!"
  },
  {
    "startTime": 62.6,
    "endTime": 74.3,
    "text": "He can give us a second chance."
  },
  {
    "startTime": 74.5,
    "endTime": 78.353,
    "text": "Let me make this easy for you."
  },
  {
    "startTime": 78.353,
    "endTime": 81.22099999999999,
    "text": "You will bring me what I need..."
  },
  {
    "startTime": 81.221,
    "endTime": 83.9,
    "text": "...or everything you call a life..."
  },
  {
    "startTime": 84.0,
    "endTime": 91.4,
    "text": "...will end."
  },
  {
    "startTime": 91.6,
    "endTime": 97.139,
    "text": "This is all my fault."
  },
  {
    "startTime": 97.139,
    "endTime": 98.89999999999999,
    "text": "You may not want her to watch this."
  },
  {
    "startTime": 99.0,
    "endTime": 110.346,
    "text": "We had a deal."
  },
  {
    "startTime": 110.346,
    "endTime": 115.9,
    "text": "You thought you could win?!"
  },
  {
    "startTime": 116.1,
    "endTime": 119.3,
    "text": "I don't have to win."
  },
  {
    "startTime": 119.4,
    "endTime": 123.357,
    "text": "We both just have to lose."
  },
  {
    "startTime": 123.357,
    "endTime": 124.9,
    "text": "Dad!"
  },
  {
    "startTime": 125.1,
    "endTime": 128.42,
    "text": "I'm sorry, Cassie!"
  }
]