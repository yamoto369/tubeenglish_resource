[
  {
    "startTime": 0.0,
    "endTime": 1.8,
    "text": "Every map I make is wrong."
  },
  {
    "startTime": 1.9,
    "endTime": 4.129,
    "text": "All the exit signs led to traps."
  },
  {
    "startTime": 4.17,
    "endTime": 7.4239999999999995,
    "text": "Plus the braille, the hieroglyphics, and the tape recorder message, too."
  },
  {
    "startTime": 7.465,
    "endTime": 9.926,
    "text": "It's almost like the maze is trying to tell me something."
  },
  {
    "startTime": 9.968,
    "endTime": 11.594,
    "text": "Something confusing."
  },
  {
    "startTime": 11.636,
    "endTime": 13.1,
    "text": "Whatever!"
  },
  {
    "startTime": 13.2,
    "endTime": 15.889999999999999,
    "text": "Who needs you anyway, with your stupid signs and messages?"
  },
  {
    "startTime": 15.932,
    "endTime": 17.6,
    "text": "I'm Finn Mertens, ya heard?"
  },
  {
    "startTime": 17.642,
    "endTime": 19.3,
    "text": "And I don't need no nothing!"
  },
  {
    "startTime": 19.102,
    "endTime": 21.3,
    "text": "Watch me. (inhales deeply)"
  },
  {
    "startTime": 21.2,
    "endTime": 27.819,
    "text": "Babababababababababababa"
  },
  {
    "startTime": 28.69,
    "endTime": 32.448,
    "text": "Babababababa..."
  },
  {
    "startTime": 32.49,
    "endTime": 34.701,
    "text": "(sighs)"
  },
  {
    "startTime": 34.743,
    "endTime": 36.286,
    "text": "Jake: Finn?"
  },
  {
    "startTime": 36.327,
    "endTime": 38.37,
    "text": "(singsong voice) Finn!"
  },
  {
    "startTime": 38.413,
    "endTime": 40.955999999999996,
    "text": "Jake! [laughs] Jake, I'm coming!"
  },
  {
    "startTime": 40.999,
    "endTime": 43.835,
    "text": "Finn? Where are ya, buddy?"
  },
  {
    "startTime": 44.85,
    "endTime": 45.9,
    "text": "(grunts) Jake!"
  },
  {
    "startTime": 47.422,
    "endTime": 48.964,
    "text": "(sucking teeth)"
  },
  {
    "startTime": 49.0,
    "endTime": 51.259,
    "text": "That's a little disappointing. Still, though."
  },
  {
    "startTime": 51.301,
    "endTime": 52.886,
    "text": "I'm in the homestretch here."
  },
  {
    "startTime": 52.927,
    "endTime": 54.846,
    "text": "(babbles)"
  },
  {
    "startTime": 54.888,
    "endTime": 57.0,
    "text": "(grunts) Jake!"
  },
  {
    "startTime": 57.1,
    "endTime": 59.184000000000005,
    "text": "Finn! Hey, there you are."
  },
  {
    "startTime": 59.225,
    "endTime": 60.252,
    "text": "Yeah. (chuckles)"
  },
  {
    "startTime": 60.21,
    "endTime": 62.395,
    "text": "Sorry to pop up, then disappear again like that."
  },
  {
    "startTime": 62.437,
    "endTime": 64.855,
    "text": "Again? You just got here, son."
  },
  {
    "startTime": 64.9,
    "endTime": 66.858,
    "text": "I did? Shoot, man."
  },
  {
    "startTime": 66.9,
    "endTime": 69.44300000000001,
    "text": "This cave has got me straight scrambled up and down."
  },
  {
    "startTime": 69.486,
    "endTime": 70.44500000000001,
    "text": "What cave?"
  },
  {
    "startTime": 70.487,
    "endTime": 74.115,
    "text": "What? Oh. Uh-oh."
  }
