  },
  {
    "startTime": 119.76,
    "endTime": 125.019,
    "text": "Okay, I'm going to say this now in a way that is impossible for you to misunderstand."
  },
  {
    "startTime": 125.099,
    "endTime": 127.26,
    "text": "I mean, only the words I'm saying right now."
  },
  {
    "startTime": 127.339,
    "endTime": 129.85999999999999,
    "text": "There are no hidden meanings or subtexts."
  },
  {
    "startTime": 129.94,
    "endTime": 133.139,
    "text": "We do not need your charity."
  },
  {
    "startTime": 135.02,
    "endTime": 136.899,
    "text": "You're such a brave soul."
  },
  {
    "startTime": 136.979,
    "endTime": 137.979,
    "text": "Oh."
  },
  {
    "startTime": 138.059,
