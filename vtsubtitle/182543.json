  },
  {
    "startTime": 107.66,
    "endTime": 108.919,
    "text": "Let's put on a music festival."
  },
  {
    "startTime": 109.0,
    "endTime": 110.62,
    "text": "Can we make it a naked music festival?"
  },
  {
    "startTime": 110.699,
    "endTime": 111.879,
    "text": "Let's do a charity bake."
  },
  {
    "startTime": 111.959,
    "endTime": 112.959,
