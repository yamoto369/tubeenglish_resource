  {
    "startTime": 236.259,
    "endTime": 237.91899999999998,
    "text": "These guys are fake!"
  },
  {
    "startTime": 238.0,
    "endTime": 239.46,
    "text": "What do you want from us?"
  },
  {
    "startTime": 239.559,
    "endTime": 245.139,
    "text": "Do you really want to see us eat dog food on our squalid top of the house, wearing garbage bags?"
