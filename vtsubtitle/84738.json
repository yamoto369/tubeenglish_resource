[
  {
    "startTime": 0.0,
    "endTime": 2.128,
    "text": "Spenser Confidential, Netflix Film"
  },
  {
    "startTime": 2.128,
    "endTime": 2.712,
    "text": "Get in."
  },
  {
    "startTime": 2.795,
    "endTime": 3.505,
    "text": "You're in big trouble."
  },
  {
    "startTime": 3.505,
    "endTime": 4.172,
    "text": "For what?"
  },
  {
    "startTime": 4.172,
    "endTime": 6.215,
    "text": "You smashed the car through a restaurant!"
  },
  {
    "startTime": 8.0,
    "endTime": 9.5,
    "text": "What to watch in March?"
  },
  {
    "startTime": 10.0,
    "endTime": 11.5,
    "text": "Action"
  },
  {
    "startTime": 13.598,
    "endTime": 18.1,
    "text": "Dirty cops, drug cartels, and some big politicians, all working together."
  },
  {
    "startTime": 18.1,
    "endTime": 21.6,
    "text": "When I was a cop, I was trying to take these guys down, but they framed me."
  },
  {
    "startTime": 21.898,
    "endTime": 22.357,
    "text": "Gotcha."
  },
  {
    "startTime": 22.357,
    "endTime": 23.107,
    "text": "So what's the plan?"
  },
  {
    "startTime": 23.107,
    "endTime": 24.858,
    "text": "We're going to blow this wide open. You want in?"
  },
  {
    "startTime": 26.568,
    "endTime": 27.945,
    "text": "That's how you throw a punch!"
  },
  {
    "startTime": 28.0,
    "endTime": 30.0,
    "text": "The Platform, Netflix Film"
  },
  {
    "startTime": 39.5,
    "endTime": 43.0,
    "text": "Kingdom: Season 2, Netflix Original"
  },
  {
    "startTime": 45.0,
    "endTime": 45.88,
    "text": "Black Lightning: Season 3"
  },
  {
    "startTime": 45.88,
    "endTime": 47.923,
    "text": "All these soldiers arresting anybody they want."
  },
  {
    "startTime": 48.132,
    "endTime": 49.757,
    "text": "They don't care nothing about our community."
  },
  {
    "startTime": 50.677,
    "endTime": 51.803,
    "text": "Where is Black Lightning?"
  },
  {
    "startTime": 57.0,
    "endTime": 58.5,
    "text": "Spenser Confidential"
  },
  {
    "startTime": 58.5,
    "endTime": 59.9,
    "text": "The Platform"
  },
  {
    "startTime": 59.9,
    "endTime": 61.5,
    "text": "Kingdom: Season 2"
  },
  {
    "startTime": 61.5,
    "endTime": 63.5,
    "text": "Drama"
  },
  {
    "startTime": 63.5,
    "endTime": 64.8,
    "text": "Ozark: Season 3, Netflix Original"
  },
  {
    "startTime": 64.857,
    "endTime": 66.86,
    "text": "Don't worry about it. I've got everything under control."
  },
  {
    "startTime": 66.86,
    "endTime": 67.568,
    "text": "No, you don't."
  },
  {
    "startTime": 67.568,
    "endTime": 69.0,
    "text": "You're not acting out of logic."
  },
  {
    "startTime": 69.0,
    "endTime": 70.28,
    "text": "You're acting out of emotion."
  },
  {
    "startTime": 70.28,
    "endTime": 73.867,
    "text": "And we just have to wake up and make the right choices for us and our kids."
  },
  {
    "startTime": 74.45,
    "endTime": 76.11800000000001,
    "text": "You're telling me this now? Here?"
  },
  {
    "startTime": 76.577,
    "endTime": 78.036,
    "text": "I didn't have time to argue."
  },
  {
    "startTime": 78.245,
    "endTime": 80.54,
    "text": "(Elite: Season 3, Netflix Original) (Speaking Spanish) Look into my eyes. Did you kill Marina or not?"
  },
  {
    "startTime": 80.54,
    "endTime": 81.917,
    "text": "(Speaking Spanish) I didn't do it, Guzmán."
  },
  {
    "startTime": 81.917,
    "endTime": 83.96000000000001,
    "text": "(Speaking Spanish) You and I, Samuel? There is no you and I."
  },
  {
    "startTime": 83.96,
    "endTime": 86.672,
    "text": "(Speaking Spanish) So let's change that. I don't want to lose you too."
  },
  {
    "startTime": 88.548,
    "endTime": 91.718,
    "text": "(Speaking Spanish) Welcome to the competition, hon. Let the Hunger Games begin."
  },
  {
    "startTime": 91.8,
    "endTime": 92.218,
    "text": "Unorthodox, Netflix Original"
  },
  {
    "startTime": 92.218,
    "endTime": 93.553,
    "text": "Where are you from, Esther?"
  },
  {
    "startTime": 93.803,
    "endTime": 95.637,
    "text": "New York. I've never been anywhere else."
  },
  {
    "startTime": 96.013,
    "endTime": 98.808,
    "text": "I had to get as far as possible from my community."
  },
  {
    "startTime": 101.643,
    "endTime": 102.812,
    "text": "(Uncorked, Netflix Film) So wine's like your thing?"
  },
  {
    "startTime": 103.02,
    "endTime": 103.438,
    "text": "Yeah."
  },
  {
    "startTime": 103.522,
    "endTime": 105.357,
    "text": "But Pops, let me tell you about the restaurant."
  },
  {
    "startTime": 105.607,
    "endTime": 107.858,
    "text": "Ever since I started school, you've been giving me a hard time."
  },
  {
    "startTime": 108.025,
    "endTime": 109.735,
    "text": "Cause you think you're better than us."
  },
  {
    "startTime": 109.735,
    "endTime": 113.15,
    "text": "How do you choose between family, and your dream?"
  },
  {
    "startTime": 113.4,
    "endTime": 114.30000000000001,
    "text": "Lost Girls, Netflix Film"
  },
  {
    "startTime": 114.365,
    "endTime": 117.202,
    "text": "This is my daughter, Shannon Maria Gilbert."
  },
  {
    "startTime": 117.493,
    "endTime": 119.911,
    "text": "There's one here for every day that she's missing."
  },
  {
    "startTime": 119.912,
    "endTime": 124.0,
    "text": "I have been dismissed and ignored, but one thing, I won't be is silenced."
  },
  {
    "startTime": 124.0,
    "endTime": 131.0,
    "text": "The Decline, Netflix Film"
  },
  {
    "startTime": 131.0,
