    "endTime": 106.6,
    "text": "Like this?"
  },
  {
    "startTime": 106.6,
    "endTime": 109.42299999999999,
    "text": "Cause I can just like walk around like, doop, doop."
  },
  {
    "startTime": 110.532,
    "endTime": 112.115,
    "text": "Mmm, mmm, mmm, mmm."
  },
  {
    "startTime": 114.0,
