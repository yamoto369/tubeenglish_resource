[
  {
    "startTime": 0.0,
    "endTime": 1.94,
    "text": "Today, I'm \"at\" Trafalgar Square,"
  },
  {
    "startTime": 2.0,
    "endTime": 3.52,
    "text": "or I'm \"in\" Trafalgar Square..."
  },
  {
    "startTime": 3.7,
    "endTime": 5.36,
    "text": "I'm \"on\" Trafalgar Square?"
  },
  {
    "startTime": 5.6,
    "endTime": 6.72,
    "text": "Today, we're doing prepositions."
  },
  {
    "startTime": 11.96,
    "endTime": 13.040000000000001,
    "text": "Hello, Aly!"
  },
  {
    "startTime": 13.22,
    "endTime": 14.3,
    "text": "Oh, God! It's you again!"
  },
  {
    "startTime": 14.46,
    "endTime": 15.100000000000001,
    "text": "What are you doing?"
  },
  {
    "startTime": 15.2,
    "endTime": 16.74,
    "text": "I'm eating breakfast."
  },
  {
    "startTime": 16.82,
    "endTime": 18.36,
    "text": "Where are you eating breakfast?"
  },
  {
    "startTime": 18.46,
    "endTime": 21.64,
    "text": "Okay, fine. Ummm... I'm in home."
  },
  {
    "startTime": 21.6,
    "endTime": 22.6,
    "text": "At home!"
  },
  {
    "startTime": 22.44,
    "endTime": 24.96,
    "text": "Oh, God damn it. I hate prepositions!"
  },
  {
    "startTime": 25.12,
    "endTime": 27.720000000000002,
    "text": "Look, can I just say \"I'm home\"?"
  },
  {
    "startTime": 27.72,
    "endTime": 28.619999999999997,
    "text": "Yes!"
  },
  {
    "startTime": 28.86,
    "endTime": 30.7,
    "text": "Cool! Okay, with \"at\"..."
  },
  {
    "startTime": 30.82,
    "endTime": 31.78,
    "text": "\"I'm at home\"?"
  },
  {
    "startTime": 31.82,
    "endTime": 32.32,
    "text": "Yes."
  },
  {
    "startTime": 32.32,
    "endTime": 32.82,
    "text": "Cool."
  },
  {
    "startTime": 33.12,
    "endTime": 34.779999999999994,
    "text": "\"I'm at my home\"?"
  },
  {
    "startTime": 34.92,
    "endTime": 39.260000000000005,
    "text": "No! No! No! It's not necessary to say the possessive \"my\" with \"home.\""
  },
  {
    "startTime": 39.44,
    "endTime": 42.26,
    "text": "So say, \"At my house.\""
  },
  {
    "startTime": 44.46,
    "endTime": 46.06,
    "text": "Go talk to Cartoon Aly. I'm done."
  },
  {
    "startTime": 47.2,
    "endTime": 48.040000000000006,
    "text": "He's angry."
  },
  {
    "startTime": 48.44,
    "endTime": 50.0,
    "text": "Hello, Cartoon Aly!"
  },
  {
    "startTime": 50.46,
    "endTime": 51.28,
    "text": "Hello."
  },
  {
    "startTime": 51.3,
    "endTime": 52.36,
    "text": "Where are you?"
  },
  {
    "startTime": 53.0,
    "endTime": 54.76,
    "text": "Where am I? I'm here!"
  },
  {
    "startTime": 55.18,
    "endTime": 56.62,
    "text": "And where is \"here\"?"
  },
  {
    "startTime": 57.2,
    "endTime": 59.14,
    "text": "I don't know. \"At\" the coffee shop."
  },
  {
    "startTime": 59.56,
    "endTime": 60.84,
    "text": "Wait. \"In\" the coffee shop?"
  },
  {
    "startTime": 61.4,
    "endTime": 63.56,
    "text": "Which one should I use? \"At\" or \"in\"?"
  },
  {
    "startTime": 64.06,
    "endTime": 65.36,
    "text": "Are you inside?"
  },
  {
    "startTime": 65.48,
    "endTime": 66.36,
    "text": "Yes."
  },
  {
    "startTime": 66.72,
    "endTime": 68.56,
    "text": "Then say \"in\" the coffee shop!"
  },
  {
    "startTime": 68.88,
    "endTime": 71.28,
    "text": "Okay, but how about \"At the coffee shop\"?"
  },
  {
    "startTime": 71.42,
    "endTime": 72.18,
    "text": "Yes."
  },
  {
    "startTime": 72.86,
    "endTime": 75.5,
    "text": "What? Why? What's the difference?"
  },
  {
    "startTime": 75.8,
    "endTime": 81.2,
    "text": "\"In\" means you're inside, \"at\" means the general area of the place."
  },
  {
    "startTime": 81.3,
    "endTime": 83.6,
    "text": "Inside, outside, doesn't matter."
  },
  {
    "startTime": 83.62,
    "endTime": 85.58,
    "text": "So... okay."
  },
  {
    "startTime": 87.62,
    "endTime": 90.52000000000001,
    "text": "Oh! So, okay. Now I'm outside the coffee shop."
  },
  {
    "startTime": 90.74,
    "endTime": 93.53999999999999,
    "text": "But I'm still \"at\" the coffee shop, right?"
  },
  {
    "startTime": 94.0,
    "endTime": 95.24,
    "text": "Exactly!"
  },
  {
    "startTime": 95.42,
    "endTime": 96.42,
    "text": "Woohoo!"
  },
  {
    "startTime": 96.66,
    "endTime": 98.89999999999999,
    "text": "Cartoon Aly understands prepositions!"
  },
  {
    "startTime": 100.12,
    "endTime": 100.82000000000001,
    "text": "And..."
  },
  {
    "startTime": 101.08,
    "endTime": 104.92,
    "text": "So, here. Now I'm \"on\" the coffee shop, right?"
  },
  {
    "startTime": 105.36,
    "endTime": 106.82,
    "text": "Exactly."
  },
  {
    "startTime": 106.82,
    "endTime": 109.69999999999999,
    "text": "You're on top of the coffee shop, so \"on\"."
  },
  {
    "startTime": 110.1,
    "endTime": 112.14,
    "text": "And which city?"
  },
  {
    "startTime": 112.68,
    "endTime": 113.88000000000001,
    "text": "I'm \"at\" London!"
  },
  {
    "startTime": 115.12,
    "endTime": 115.62,
    "text": "Nope!"
  },
  {
    "startTime": 116.08,
    "endTime": 118.14,
    "text": "But... but it's London!"
  },
  {
    "startTime": 118.38,
    "endTime": 121.0,
    "text": "You said it doesn't matter if it's inside or outside."
  },
  {
    "startTime": 121.14,
    "endTime": 122.88,
    "text": "It's the general area."
  },
  {
    "startTime": 123.04,
    "endTime": 124.22000000000001,
    "text": "I'm \"at\" London!"
  },
  {
    "startTime": 124.38,
    "endTime": 125.89999999999999,
    "text": "Well, yes, but..."
  },
  {
    "startTime": 125.9,
    "endTime": 128.4,
    "text": "not with cities, towns, or countries."
  },
  {
    "startTime": 129.22,
    "endTime": 132.08,
    "text": "Why? Why is English so weird?"
  },
  {
    "startTime": 132.6,
    "endTime": 134.01999999999998,
    "text": "I'm sorry."
  },
  {
    "startTime": 135.1,
    "endTime": 137.18,
    "text": "Okay, I think I get it now."
  },
  {
    "startTime": 137.38,
    "endTime": 145.07999999999998,
    "text": "I'm not in the coffee shop, but I'm \"at\" and also \"on\" the coffee shop \"in\" London, right?"
  },
  {
    "startTime": 145.5,
    "endTime": 146.8,
    "text": "Exactly!"
  },
  {
    "startTime": 148.02,
    "endTime": 149.08,
    "text": "Thank you."
  },
  {
    "startTime": 149.24,
    "endTime": 150.74,
    "text": "Click here to watch another video."
  },
  {
    "startTime": 150.74,
    "endTime": 152.02,
    "text": "And please subscribe."
  },
  {
    "startTime": 152.12,
    "endTime": 152.86,
    "text": "Not finished!"
  },
  {
    "startTime": 152.9,
    "endTime": 156.1,
    "text": "- What? Where is this coming from? Okay.  - More prepositions!"
  },
  {
    "startTime": 156.3,
    "endTime": 157.60000000000002,
    "text": "The gym."
  },
  {
    "startTime": 158.9,
    "endTime": 161.70000000000002,
    "text": "- At the gym, in the gym?  - \"At\" and \"in\"."
  },
  {
    "startTime": 161.8,
    "endTime": 163.60000000000002,
    "text": "Well, both is fine. That's fine. Okay, next one."
  },
  {
    "startTime": 163.7,
    "endTime": 164.79999999999998,
    "text": "Office"
  },
  {
    "startTime": 166.3,
    "endTime": 169.14000000000001,
    "text": "I'm in the office, I'm at the office. You can use both."
  },
  {
    "startTime": 169.3,
    "endTime": 170.3,
    "text": "- Right?  - Yes!"
  },
  {
    "startTime": 170.35,
    "endTime": 172.23,
    "text": "Cool! Awesome! Next one, throw it at me!"
  },
  {
    "startTime": 172.3,
    "endTime": 177.5,
    "text": "- Party.  - Okay, I am in the party."
  },
  {
    "startTime": 177.8,
    "endTime": 181.0,
    "text": "- At the party.  - I'm \"at\" the party, fine. Next one."
  },
  {
    "startTime": 182.1,
    "endTime": 186.0,
    "text": "Something that you don't have, class."
  },
  {
    "startTime": 187.8,
    "endTime": 193.60000000000002,
    "text": "- I'm at class. In class. Okay, I'm \"in\" class.  - Stupid man, \"in\" class."
  },
  {
    "startTime": 194.0,
    "endTime": 196.1,
    "text": "I'm in class, not I'm at class."
  },
  {
    "startTime": 196.38,
    "endTime": 199.28,
    "text": "And I'm \"at\" the party or I'm \"at\" a party,"
  },
  {
    "startTime": 199.28,
    "endTime": 203.5,
    "text": "but I'm not \"in\" a party. That sounds weird."
  },
  {
    "startTime": 203.5,
    "endTime": 205.3,
    "text": "Lighting Round"
  },
  {
    "startTime": 205.96,
    "endTime": 206.94,
