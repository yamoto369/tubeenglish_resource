  {
    "startTime": 162.1,
    "endTime": 163.56,
    "text": "Ooh!"
  },
  {
    "startTime": 163.56,
    "endTime": 164.66,
    "text": "Yes, siree."
  },
  {
    "startTime": 164.66,
    "endTime": 167.16,
    "text": "Well, well, well, what have we here?"
  },
  {
    "startTime": 167.16,
    "endTime": 168.96,
    "text": "Hey, you gotta get out of here."
  },
  {
    "startTime": 169.53,
    "endTime": 170.66,
    "text": "(laughing)"
  },
  {
    "startTime": 171.3,
