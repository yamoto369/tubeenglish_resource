  },
  {
    "startTime": 106.83,
    "endTime": 108.33,
    "text": "Oh, no!"
  },
  {
    "startTime": 109.63,
    "endTime": 110.63,
    "text": "(grunting)"
  },
  {
    "startTime": 112.13,
    "endTime": 114.86,
    "text": "Don't go into the light, Pete! Don't go into the light!"
  },
  {
    "startTime": 115.86,
    "endTime": 117.0,
    "text": "(groans)"
  },
  {
    "startTime": 117.23,
    "endTime": 118.63000000000001,
    "text": "What are you doin'?"
  },
  {
    "startTime": 118.63,
    "endTime": 120.699,
    "text": "Can't a guy take a nap? (shattering)"
  },
  {
    "startTime": 120.7,
    "endTime": 122.23,
    "text": "You're alive!"
  },
  {
    "startTime": 122.23,
    "endTime": 124.33,
    "text": "(gloomily) Unfortunately."
  },
  {
    "startTime": 124.33,
    "endTime": 126.7,
    "text": "Gee, Pete. You look awful."
  },
  {
    "startTime": 126.7,
    "endTime": 129.16,
    "text": "(gasps) Your peg's even missing!"
  },
  {
    "startTime": 129.16,
    "endTime": 132.299,
    "text": "Where's your peg? You love your peg!"
  },
  {
    "startTime": 132.3,
    "endTime": 135.63000000000002,
    "text": "I don't know. It's around here someplace."
  },
  {
    "startTime": 135.63,
    "endTime": 138.0,
    "text": "Just beat it, would ya?"
  },
  {
    "startTime": 138.56,
    "endTime": 141.5,
    "text": "Gosh, it breaks my heart seeing him like this."
  },
  {
    "startTime": 141.5,
    "endTime": 143.3,
    "text": "I gotta do something."
  },
  {
    "startTime": 143.3,
    "endTime": 144.96,
    "text": "Ah!"
  },
  {
    "startTime": 146.4,
    "endTime": 148.63,
    "text": "Gee, that's weird."
  },
  {
    "startTime": 148.63,
    "endTime": 152.1,
    "text": "Someone left a bunch of pies on the sidewalk."
  },
  {
    "startTime": 156.83,
    "endTime": 162.10000000000002,
    "text": "I sure am glad no one is around to hit me in the face with these pies."
