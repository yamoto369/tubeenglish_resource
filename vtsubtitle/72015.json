    "text": "(coughing)"
  },
  {
    "startTime": 74.13,
    "endTime": 76.46,
    "text": "Ugh, a time-delay stink bomb?"
  },
  {
    "startTime": 76.46,
    "endTime": 78.33,
    "text": "That Mortimer's the worst!"
  },
  {
    "startTime": 78.46,
    "endTime": 81.5,
    "text": "I knew it! You do hate him more than me!"
  },
  {
    "startTime": 81.5,
    "endTime": 82.76,
    "text": "(sobbing)"
  },
  {
    "startTime": 82.76,
    "endTime": 85.76,
    "text": "Pete, I didn't mean it. Come back. (coughing)"
