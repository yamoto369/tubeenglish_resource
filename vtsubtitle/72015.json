  {
    "startTime": 42.2,
    "endTime": 44.0,
    "text": "What the heck was that?"
  },
  {
    "startTime": 44.0,
    "endTime": 46.3,
    "text": "Huh? Oh, hi, Pete."
  },
  {
    "startTime": 46.3,
    "endTime": 47.83,
    "text": "Don't \"Oh, hi, Pete\" me."
  },
  {
    "startTime": 47.83,
    "endTime": 50.4,
    "text": "What's the idea lettin' that guy pick on you?"
  },
  {
    "startTime": 50.4,
    "endTime": 51.93,
