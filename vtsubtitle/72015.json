  },
  {
    "startTime": 172.8,
    "endTime": 174.4,
    "text": "(snarls) Now look what you did!"
  },
  {
    "startTime": 174.4,
    "endTime": 175.96,
    "text": "These pies aren't for you."
  },
  {
    "startTime": 175.96,
    "endTime": 177.3,
    "text": "They're for Pete!"
  },
  {
    "startTime": 177.3,
    "endTime": 180.4,
    "text": "Peg Leg Pete? That guy's a real zero."
  },
  {
    "startTime": 180.4,
    "endTime": 183.20000000000002,
    "text": "Pete's 10 times the bully you'll ever be!"
  },
  {
    "startTime": 183.2,
    "endTime": 190.16,
    "text": "Ha! Well, I say he's a shmo, a schmendrick, a schlemiel, a dingus, a doofus, a dimwit, a dum..."
  },
  {
    "startTime": 193.13,
    "endTime": 194.63,
    "text": "Hiya, Pete."
  },
  {
    "startTime": 194.63,
    "endTime": 195.7,
    "text": "(growls)"
  },
  {
    "startTime": 195.7,
    "endTime": 197.2,
    "text": "(screaming)"
  },
  {
    "startTime": 198.96,
    "endTime": 201.83,
    "text": "I heard the nice things you said."
  },
  {
    "startTime": 201.83,
    "endTime": 204.16000000000003,
    "text": "And I meant every word of it."
  },
  {
    "startTime": 205.76,
    "endTime": 208.32899999999998,
    "text": "(both giggling)"
  },
  {
    "startTime": 208.33,
    "endTime": 209.76000000000002,
    "text": "Ow! Ow! Ow!"
  },
  {
    "startTime": 210.16,
