  {
    "startTime": 88.86,
    "endTime": 90.16,
    "text": "Hmm, that's weird."
  },
  {
    "startTime": 90.16,
    "endTime": 92.7,
    "text": "Pete's never late for my Tuesday 3:00 knuckle sandwich."
  },
  {
    "startTime": 92.7,
    "endTime": 95.56,
    "text": "Come to think of it, I haven't seen that guy in days."
  },
  {
    "startTime": 95.56,
    "endTime": 97.13,
    "text": "I hope he's okay."
  },
  {
    "startTime": 97.76,
    "endTime": 99.80000000000001,
    "text": "(Mysterious music plays) (bird cawing)"
  },
  {
    "startTime": 100.83,
    "endTime": 102.3,
    "text": "(Knock on door)"
  },
  {
    "startTime": 102.3,
    "endTime": 103.1,
    "text": "Pete?"
  },
  {
    "startTime": 103.5,
    "endTime": 104.5,
    "text": "Pete?"
  },
  {
    "startTime": 105.4,
    "endTime": 106.83000000000001,
