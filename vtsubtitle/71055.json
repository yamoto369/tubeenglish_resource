[
  {
    "startTime": 0.0,
    "endTime": 3.6,
    "text": "Dear Ryan, Can you make a horror skit about how it feels to be a Pokemon?"
  },
  {
    "startTime": 10.4,
    "endTime": 12.32,
    "text": "Pikachu Ryan: Come on, please, Mom?"
  },
  {
    "startTime": 13.28,
    "endTime": 14.6,
    "text": "Momma Pikachu Arden: *sigh* I don't know."
  },
  {
    "startTime": 14.6,
    "endTime": 16.14,
    "text": "It's gonna be dark soon."
  },
  {
    "startTime": 16.88,
    "endTime": 18.38,
    "text": "Pikachu: But I'm not even gonna go that far!"
  },
  {
    "startTime": 18.44,
    "endTime": 20.62,
    "text": "And I'll be back before dinner! I promise."
  },
  {
    "startTime": 20.94,
    "endTime": 22.46,
    "text": "*Momma Pikachu sighs*"
  },
  {
    "startTime": 23.1,
    "endTime": 24.380000000000003,
    "text": "What are the rules?"
  },
  {
    "startTime": 24.38,
    "endTime": 25.5,
    "text": "Pikachu: Oh! Um"
  },
  {
    "startTime": 25.5,
    "endTime": 26.98,
    "text": "No fighting, stay away from the city ,"
  },
  {
    "startTime": 26.98,
    "endTime": 28.22,
    "text": "And be back before it's dark!"
  },
  {
    "startTime": 28.22,
    "endTime": 28.919999999999998,
    "text": "See? I got it!"
  },
  {
    "startTime": 28.92,
    "endTime": 29.700000000000003,
    "text": "Momma Pikachu: And?"
  },
  {
    "startTime": 29.76,
    "endTime": 30.360000000000003,
    "text": "Pikachu: And.."
  },
  {
    "startTime": 30.36,
    "endTime": 31.32,
    "text": "Momma Pikachu: And if you see a human?"
  },
  {
    "startTime": 31.32,
    "endTime": 32.32,
    "text": "Pikachu: Come on, there's never been any--"
  },
  {
    "startTime": 32.32,
    "endTime": 33.8,
    "text": "Momma Pikachu: AND IF YOU SEE A HUMAN?"
  },
  {
    "startTime": 33.8,
    "endTime": 35.64,
    "text": "Pikachu: If I see a human, I will run away."
  },
  {
    "startTime": 35.64,
    "endTime": 37.64,
    "text": "(Momma Pikachu sighs)"
  },
  {
    "startTime": 38.32,
    "endTime": 39.1,
    "text": "Momma Pikachu: Be back before dinner."
  },
  {
    "startTime": 39.42,
    "endTime": 41.02,
    "text": "Pikachu: THANKS MOM!"
  },
  {
    "startTime": 41.92,
    "endTime": 43.120000000000005,
    "text": "(Pikachu laughs)"
  },
  {
    "startTime": 44.0,
    "endTime": 45.1,
    "text": "Growing up in the Viridian was,"
  },
  {
    "startTime": 46.3,
    "endTime": 47.099999999999994,
    "text": "Well , normal."
  },
  {
    "startTime": 47.56,
    "endTime": 49.04,
    "text": "We were in the deepest part of the forest,"
  },
  {
    "startTime": 49.04,
    "endTime": 51.14,
    "text": "So there weren't many other pokemon around."
  },
  {
    "startTime": 53.58,
    "endTime": 54.08,
    "text": "It was quiet..."
  },
  {
    "startTime": 54.6,
    "endTime": 55.32,
    "text": "peaceful..."
  },
  {
    "startTime": 55.32,
    "endTime": 57.24,
    "text": "nothing really ever happened."
  },
  {
    "startTime": 60.84,
    "endTime": 63.0,
    "text": "At least, that's what I thought..."
  },
  {
    "startTime": 69.38,
    "endTime": 71.14,
    "text": "Pikachu: MOOOM! I'M BACK!"
  },
  {
    "startTime": 72.76,
    "endTime": 73.26,
    "text": "Mom..?"
  },
  {
    "startTime": 75.42,
    "endTime": 77.84,
    "text": "Mom, why.. why's all the things in the front--"
  },
  {
    "startTime": 78.12,
    "endTime": 78.74000000000001,
    "text": "*GASP*"
  },
  {
    "startTime": 80.42,
    "endTime": 80.92,
    "text": "AH!"
  },
  {
    "startTime": 87.94,
    "endTime": 89.53999999999999,
    "text": "Momma Pikachu: ..Run.."
  },
  {
    "startTime": 99.34,
    "endTime": 100.78,
    "text": "Pikachu: AH AH AH"
  },
  {
    "startTime": 100.78,
    "endTime": 102.78,
    "text": "*ZAP*"
  },
  {
    "startTime": 108.88,
    "endTime": 109.92,
    "text": "*Pikachu crying*"
  },
  {
    "startTime": 115.42,
    "endTime": 116.22,
    "text": "PIKACHU..."
  },
  {
    "startTime": 117.3,
    "endTime": 117.8,
    "text": "I..."
  },
  {
    "startTime": 117.8,
    "endTime": 119.56,
    "text": "CHOOSE.. YOUUUUU..."
  },
  {
    "startTime": 119.56,
    "endTime": 120.68,
    "text": "Pikachu: AAAAAAAAAH!!!"
  },
  {
    "startTime": 122.4,
    "endTime": 123.92,
    "text": "*loud crowd cheering*"
  },
  {
    "startTime": 128.56,
    "endTime": 129.36,
    "text": "Ready, kid?"
  },
  {
    "startTime": 129.4,
    "endTime": 130.44,
    "text": "Pikachu: NANI?"
  },
  {
    "startTime": 130.44,
    "endTime": 131.34,
    "text": "Let's just get this battle over with."
  },
  {
    "startTime": 131.34,
    "endTime": 133.88,
    "text": "Pikachu: Battle? I-I don't want to battle you though."
  },
  {
    "startTime": 133.88,
    "endTime": 134.74,
    "text": "You don't get a choice."
  },
  {
    "startTime": 136.36,
    "endTime": 138.36,
    "text": "*punch*"
  },
  {
    "startTime": 143.66,
    "endTime": 144.54,
    "text": "*bell rings*"
  },
  {
    "startTime": 148.4,
    "endTime": 150.62,
    "text": "Nurse Joy: And.. there we go!"
  },
  {
    "startTime": 150.62,
    "endTime": 151.38,
    "text": "All better!"
  },
  {
    "startTime": 151.38,
    "endTime": 153.35999999999999,
    "text": "Lemme go and get your trainer for you."
  },
  {
    "startTime": 153.36,
    "endTime": 154.46,
    "text": "This your first time?"
  },
  {
    "startTime": 154.46,
    "endTime": 155.52,
    "text": "Pikachu: The hell's going on?"
  },
  {
    "startTime": 155.52,
    "endTime": 156.60000000000002,
    "text": "I was just all beat up and.."
  },
  {
    "startTime": 156.6,
    "endTime": 157.23999999999998,
    "text": "now I'm.."
  },
  {
    "startTime": 157.32,
    "endTime": 158.4,
    "text": "That human that just left."
  },
  {
    "startTime": 158.58,
    "endTime": 159.54000000000002,
    "text": "She healed us."
  },
  {
    "startTime": 159.54,
    "endTime": 161.29999999999998,
    "text": "Pikachu: Why would a human try to help us?"
  },
  {
    "startTime": 161.84,
    "endTime": 162.4,
    "text": "HELP US?"
  },
  {
    "startTime": 162.56,
    "endTime": 163.2,
    "text": "*scoffs*"
  },
  {
    "startTime": 163.2,
    "endTime": 164.82,
    "text": "You got a lot to learn.."
  },
  {
    "startTime": 165.06,
    "endTime": 167.74,
    "text": "They make us fight until the brink of death."
  },
  {
    "startTime": 167.8,
    "endTime": 170.48000000000002,
    "text": "Just before one of us dies, they heal us."
  },
  {
    "startTime": 170.48,
    "endTime": 171.14,
    "text": "Nurse Joy: And there we go."
  },
  {
    "startTime": 171.14,
    "endTime": 171.88,
    "text": "All better!"
  },
  {
    "startTime": 172.0,
    "endTime": 174.08,
    "text": "They make us do it all over again."
  },
  {
    "startTime": 178.22,
    "endTime": 179.48,
    "text": "Nurse Joy: And there we go!"
  },
  {
    "startTime": 179.48,
    "endTime": 180.06,
    "text": "All better!"
  },
  {
    "startTime": 180.16,
    "endTime": 181.84,
    "text": "Pikachu: But why don't you guys just NOT fight?"
  },
  {
    "startTime": 181.92,
    "endTime": 182.94,
    "text": "You don't HAVE to obey them."
  },
  {
    "startTime": 182.94,
    "endTime": 184.4,
    "text": "Don't you think we've tried that?"
  },
  {
    "startTime": 184.56,
    "endTime": 185.82,
    "text": "THEY BREAK YOU."
  },
  {
    "startTime": 186.44,
    "endTime": 187.44,
    "text": "Pikachu: LET ME OUTTTTTTTT"
  },
  {
    "startTime": 187.44,
    "endTime": 188.92,
    "text": "You don't know what it's like to be stuck in that ball"
  },
  {
    "startTime": 188.92,
    "endTime": 192.22,
    "text": "for weeks, months, even YEARS."
  },
  {
    "startTime": 192.36,
    "endTime": 194.60000000000002,
    "text": "Nothing to do.. nothing to see..."
  },
  {
    "startTime": 194.6,
    "endTime": 195.4,
    "text": "No one to talk to."
  },
  {
    "startTime": 195.56,
    "endTime": 196.74,
    "text": "You start to forget yourself."
  },
  {
    "startTime": 196.74,
    "endTime": 198.64000000000001,
    "text": "Pikachu: Ash is my Master..."
  },
  {
    "startTime": 198.64,
    "endTime": 199.94,
    "text": "Who you are.. where you're from.."
  },
  {
    "startTime": 199.94,
    "endTime": 202.46,
    "text": "I'd much rather fight every day of for the rest of my life,"
  },
  {
    "startTime": 202.46,
    "endTime": 204.78,
    "text": "for these 2-3 minutes of freedom."
  },
  {
    "startTime": 204.78,
    "endTime": 207.06,
    "text": "Than to be stuck in that ball.."
  },
  {
    "startTime": 207.88,
    "endTime": 208.79999999999998,
    "text": "..and lose myself."
  },
  {
    "startTime": 209.26,
    "endTime": 209.89999999999998,
    "text": "Echos: All Better!"
  },
  {
    "startTime": 210.18,
    "endTime": 212.04000000000002,
    "text": "Echos: Really hoped to see you today!"
  },
  {
    "startTime": 212.04,
    "endTime": 213.28,
    "text": "Pikachu: LET ME OUT, I KNOW YOU HEAR ME!"
  },
  {
    "startTime": 213.28,
    "endTime": 214.92,
    "text": "*screams and flashbacks*"
  },
  {
    "startTime": 219.58,
    "endTime": 222.92000000000002,
    "text": "PIKACHU.. I.. CHOOSE.. YOU..."
  },
  {
    "startTime": 230.2,
    "endTime": 232.04,
    "text": "Pikachu: *shaking* N-no.."
  },
  {
    "startTime": 232.64,
    "endTime": 233.6,
    "text": "Pikachu: Mom?"
  },
  {
    "startTime": 233.98,
    "endTime": 234.48,
    "text": "*smack*"
  },
  {
    "startTime": 234.48,
    "endTime": 237.39999999999998,
    "text": "*overlapping nurse voices*"
  },
  {
    "startTime": 238.12,
    "endTime": 239.48000000000002,
    "text": "Pikachu: MOM! STOP!"
  },
  {
    "startTime": 239.66,
    "endTime": 242.7,
    "text": "FIGHT! OR YOU'LL NEVER COME OUT OF THAT BALL AGAIN!"
  },
  {
    "startTime": 242.96,
    "endTime": 244.96,
    "text": "*flashbacks*"
  },
  {
    "startTime": 249.4,
    "endTime": 252.9,
    "text": "*intense fighting*"
  },
  {
    "startTime": 254.3,
    "endTime": 256.22,
    "text": "(Pikachu, shaking and sobs)"
  },
  {
    "startTime": 259.28,
    "endTime": 261.03999999999996,
    "text": "Pikachu: I'm sorry, Mom.."
  },
  {
    "startTime": 261.04,
    "endTime": 262.52000000000004,
    "text": "Pikachu: I'm so sorry.."
  },
  {
    "startTime": 265.5,
    "endTime": 268.24,
    "text": "Gotta Catch Em Allll... *evil laughter*"
  },
  {
    "startTime": 270.24,
    "endTime": 272.24,
    "text": "TEEHEE!"
  }
]