[
  {
    "startTime": 0.0,
    "endTime": 4.67,
    "text": "So, who broke it?"
  },
  {
    "startTime": 4.671,
    "endTime": 6.139,
    "text": "I'm not mad."
  },
  {
    "startTime": 6.139,
    "endTime": 9.376000000000001,
    "text": "I just want to know."
  },
  {
    "startTime": 9.376,
    "endTime": 11.777,
    "text": "-I did. I broke it. --No, no, you didn't."
  },
  {
    "startTime": 11.778,
    "endTime": 14.314,
    "text": "-Tom? -Don't look at me."
  },
  {
    "startTime": 14.314,
    "endTime": 15.615,
    "text": "Look at Ben."
  },
  {
    "startTime": 15.615,
    "endTime": 17.217,
    "text": "What? I didn't break it."
  },
  {
    "startTime": 17.217,
    "endTime": 18.517999999999997,
    "text": "Huh. That's weird."
  },
  {
    "startTime": 18.518,
    "endTime": 20.086000000000002,
    "text": "How'd you even know it was broken?"
  },
  {
    "startTime": 20.086,
    "endTime": 23.2,
    "text": "Because it's sitting right in front of us, and it's broken."
  },
  {
    "startTime": 23.2,
    "endTime": 25.29,
    "text": "-Suspicious. -No, it's not."
  },
  {
    "startTime": 25.291,
    "endTime": 28.428,
    "text": "If it matters - probably not - but April was the last one to use it."
  },
  {
    "startTime": 28.428,
    "endTime": 30.2,
    "text": "Liar! I don't even drink that crap."
  },
  {
    "startTime": 30.2,
    "endTime": 32.4,
    "text": "-Oh, really? Then what were you doing by the coffee cart earlier?"
  },
  {
    "startTime": 32.4,
    "endTime": 35.199999999999996,
    "text": "I use the wooden stirrers to push back my cuticles. Everyone knows that, Jerry!"
  },
  {
    "startTime": 35.2,
    "endTime": 37.437000000000005,
    "text": "Okay, let's not fight. I broke it. Let me pay for it, Ron."
  },
  {
    "startTime": 37.437,
    "endTime": 39.705,
    "text": "No. Who broke it?"
  },
  {
    "startTime": 41.708,
    "endTime": 44.477,
    "text": "Ron... Donna's been awfully quiet."
  },
  {
    "startTime": 44.477,
    "endTime": 45.879,
    "text": "-Really?! -Uh, yeah, really."
  },
  {
    "startTime": 49.382,
    "endTime": 50.75,
    "text": "I broke it."
  },
  {
    "startTime": 50.75,
    "endTime": 53.686,
    "text": "It burned my hand, so I punched it."
  },
  {
    "startTime": 53.686,
    "endTime": 59.592,
    "text": "I predict ten minutes from now, they'll be at each others' throats with war paint on their faces and a pig head on a stick."
  },
  {
    "startTime": 62.462,
    "endTime": 65.598,
    "text": "Good. It was getting a little chummy around here."
  }
]