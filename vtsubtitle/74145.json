[
  {
    "startTime": 19.5,
    "endTime": 26.58,
    "text": "The time I thought that we would have"
  },
  {
    "startTime": 26.58,
    "endTime": 32.15,
    "text": "Was taken from red to black"
  },
  {
    "startTime": 32.15,
    "endTime": 38.62,
    "text": "And I said things I can't take back"
  },
  {
    "startTime": 38.62,
    "endTime": 43.919,
    "text": "And I don't know how to live with that"
  },
  {
    "startTime": 43.92,
    "endTime": 49.980000000000004,
    "text": "There's a darkness that I've known"
  },
  {
    "startTime": 49.98,
    "endTime": 54.97,
    "text": "And it's shaken me to stone"
  },
  {
    "startTime": 54.97,
    "endTime": 61.839,
    "text": "And it kills me you might not know"
  },
  {
    "startTime": 61.84,
    "endTime": 67.76,
    "text": "After all"
  },
  {
    "startTime": 67.76,
    "endTime": 73.75,
    "text": "I know I don't let you see"
  },
  {
    "startTime": 73.75,
    "endTime": 80.14,
    "text": "But you mean the world to me"
  },
  {
    "startTime": 80.14,
    "endTime": 86.4,
    "text": "And I know that I can be pretty mean"
  },
  {
    "startTime": 86.4,
    "endTime": 92.66000000000001,
    "text": "But you mean the world to me"
  },
  {
    "startTime": 92.66,
    "endTime": 97.61,
    "text": "What the hell is wrong with me?"
  },
  {
    "startTime": 97.61,
    "endTime": 102.97,
    "text": "I just sat there and watched you leave"
  },
  {
    "startTime": 102.97,
    "endTime": 109.83,
    "text": "I am not this ice queen,"
  },
  {
    "startTime": 109.83,
    "endTime": 115.38,
    "text": "And you think I don't feel anything"
  },
  {
    "startTime": 115.38,
    "endTime": 121.81,
    "text": "There's a fear that I've known"
  },
  {
    "startTime": 121.81,
    "endTime": 127.24000000000001,
    "text": "And it's cut you to the bone"
  },
  {
    "startTime": 127.24,
    "endTime": 133.72,
    "text": "And I'm so sorry I've never shown"
  },
  {
    "startTime": 133.72,
    "endTime": 140.109,
    "text": "Just how much you hold"
  },
  {
    "startTime": 140.11,
    "endTime": 145.76000000000002,
    "text": "'Cause I know I don't let you see"
  },
  {
    "startTime": 145.76,
    "endTime": 151.66,
    "text": "But you mean the world to me"
  },
  {
    "startTime": 151.66,
    "endTime": 157.96,
    "text": "And I know that I can be pretty mean"
  },
  {
    "startTime": 157.96,
    "endTime": 163.71,
    "text": "But you mean the world to me"
  },
  {
    "startTime": 163.71,
    "endTime": 169.57000000000002,
    "text": "World to me"
  },
  {
    "startTime": 169.57,
    "endTime": 177.82,
    "text": "World to me"
  },
  {
