[
  {
    "startTime": 0.0,
    "endTime": 1.76,
    "text": "Hi! I'm Roy,"
  },
  {
    "startTime": 1.76,
    "endTime": 4.08,
    "text": "and today I'm going to tell you the difference"
  },
  {
    "startTime": 4.08,
    "endTime": 7.09,
    "text": "between 'continuously' and 'continually'."
  },
  {
    "startTime": 7.09,
    "endTime": 9.7,
    "text": "Both of these words are adverbs,"
  },
  {
    "startTime": 9.7,
    "endTime": 11.86,
    "text": "and they can be confusing."
  },
  {
    "startTime": 11.86,
    "endTime": 16.0,
    "text": "They look similar, but they have different meanings."
  },
  {
    "startTime": 16.0,
    "endTime": 18.04,
    "text": "'Continuously' means that something"
  },
  {
    "startTime": 18.04,
    "endTime": 20.96,
    "text": "'doesn't stop or end'."
  },
  {
    "startTime": 20.96,
    "endTime": 25.12,
    "text": "He spoke continuously for 15 minutes."
  },
  {
    "startTime": 25.12,
    "endTime": 30.200000000000003,
    "text": "That means he spoke for 15 minutes without stopping."
  },
  {
    "startTime": 30.2,
    "endTime": 33.14,
    "text": "'Continually' is a 'repeated action"
  },
  {
    "startTime": 33.14,
    "endTime": 35.72,
    "text": "that happens over a period of time'"
  },
  {
    "startTime": 35.72,
    "endTime": 39.46,
    "text": "– so something starts and stops over some time."
  },
  {
    "startTime": 39.46,
    "endTime": 43.02,
    "text": "I continually tell my dog I love her."
  },
  {
    "startTime": 43.02,
    "endTime": 47.699000000000005,
    "text": "That means it's a repeated event. I say it many times."
  },
  {
    "startTime": 47.699,
    "endTime": 49.879,
    "text": "Well, that's all for today,"
  },
  {
    "startTime": 49.88,
    "endTime": 52.620000000000005,
    "text": "but we here at BBC Learning English"
  },
  {
    "startTime": 52.62,
    "endTime": 56.379,
    "text": "continually make new videos so keep watching!"
  },
  {
    "startTime": 56.38,
    "endTime": 57.24,
    "text": "Bye!"
  }
]