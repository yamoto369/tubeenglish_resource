[
  {
    "startTime": 0.6,
    "endTime": 1.5,
    "text": "Halloween's coming up."
  },
  {
    "startTime": 1.5,
    "endTime": 1.55,
    "text": "Yes."
  },
  {
    "startTime": 1.55,
    "endTime": 2.54,
    "text": "Is this a true story?"
  },
  {
    "startTime": 2.54,
    "endTime": 3.51,
    "text": "I want to know."
  },
  {
    "startTime": 3.51,
    "endTime": 5.31,
    "text": "I heard you're scared of clowns."
  },
  {
    "startTime": 5.31,
    "endTime": 5.939,
    "text": "No."
  },
  {
    "startTime": 5.94,
    "endTime": 7.140000000000001,
    "text": "I heard that."
  },
  {
    "startTime": 7.14,
    "endTime": 8.799999999999999,
    "text": "Impossible."
  },
  {
    "startTime": 8.8,
    "endTime": 9.0,
    "text": "Why is it impossible?"
  },
  {
    "startTime": 9.0,
    "endTime": 9.999,
    "text": "Because I'm a black man."
  },
  {
    "startTime": 9.999,
    "endTime": 12.381,
    "text": "[LAUGHTER]"
  },
  {
    "startTime": 12.381,
    "endTime": 13.13,
    "text": "You can be scare--"
  },
  {
    "startTime": 13.13,
    "endTime": 15.126000000000001,
    "text": "I have so many other things to be fearful of."
  },
  {
    "startTime": 15.126,
    "endTime": 16.5,
    "text": "A clown is not going to scare me."
  },
  {
    "startTime": 16.5,
    "endTime": 17.0,
    "text": "Really?"
  },
  {
    "startTime": 17.0,
    "endTime": 18.17,
    "text": "Yes."
  },
  {
    "startTime": 18.17,
    "endTime": 19.55,
    "text": "I'm not afraid of clowns."
  },
  {
    "startTime": 19.55,
    "endTime": 20.810000000000002,
    "text": "But I heard that you were."
  },
  {
    "startTime": 20.81,
    "endTime": 21.81,
    "text": "[CLOWN YELLING]"
  },
  {
    "startTime": 21.81,
    "endTime": 23.31,
    "text": "Oh [BLEEP]!"
  },
  {
    "startTime": 23.31,
    "endTime": 25.81,
    "text": "[SCREAMING]"
  },
  {
    "startTime": 37.31,
    "endTime": 39.31,
    "text": "OK."
  },
  {
    "startTime": 39.31,
    "endTime": 42.81,
    "text": "Yeah, I got you."
  },
  {
    "startTime": 42.81,
    "endTime": 46.14,
    "text": "Oh, you want to play?"
  },
  {
    "startTime": 46.14,
    "endTime": 47.61,
    "text": "That's why I had to move this."
  },
  {
    "startTime": 47.61,
    "endTime": 48.775,
    "text": "You sat it on top of it."
  },
  {
    "startTime": 48.776,
    "endTime": 50.150000000000006,
    "text": "And I'm like, I had to move that."
  },
  {
    "startTime": 52.75,
    "endTime": 54.31,
    "text": "You know, I woke up this morning,"
  },
  {
    "startTime": 54.31,
    "endTime": 57.7,
    "text": "and I said, I want my life to be full of surprises."
  },
  {
    "startTime": 57.7,
    "endTime": 58.82,
    "text": "Ellen, I thank you."
  },
  {
    "startTime": 58.82,
    "endTime": 59.816,
    "text": "Oh, oh."
  },
  {
    "startTime": 59.816,
    "endTime": 60.812000000000005,
    "text": "Mwah."
  },
  {
    "startTime": 60.812,
    "endTime": 61.808,
    "text": "You're welcome."
  },
  {
    "startTime": 64.8,
    "endTime": 66.88,
    "text": "That was the next time--"
  },
  {
    "startTime": 66.88,
    "endTime": 68.32,
    "text": "I mean, that was the best--"
  },
  {
    "startTime": 68.32,
    "endTime": 71.46,
    "text": "I don't even know when I've had that much--"
  },
  {
    "startTime": 71.46,
    "endTime": 74.89999999999999,
    "text": "that was so gratifying."
  },
  {
    "startTime": 74.1,
    "endTime": 75.75999999999999,
    "text": "I only did that because you didn't send me"
  },
  {
    "startTime": 75.76,
    "endTime": 77.134,
    "text": "a bottle with your other friends."
  },
  {
    "startTime": 77.134,
    "endTime": 80.1,
    "text": "But let's take a look because that was a really good one."
  },
  {
    "startTime": 80.1,
    "endTime": 80.50999999999999,
    "text": "Aw, man."
  },
  {
    "startTime": 80.51,
    "endTime": 81.322,
    "text": "--clowns."
  },
  {
    "startTime": 81.322,
    "endTime": 82.66,
    "text": "But I heard that you were."
  },
  {
    "startTime": 82.66,
    "endTime": 83.63,
    "text": "[CLOWN YELLING]"
  },
  {
    "startTime": 83.63,
    "endTime": 85.85,
    "text": "Oh, shit!"
  },
  {
    "startTime": 85.85,
    "endTime": 87.509,
    "text": "[SCREAMING]"
  },
  {
    "startTime": 93.815,
    "endTime": 95.87,
    "text": "I like that you dance when you get scared."
  },
  {
    "startTime": 100.16,
    "endTime": 101.41,
    "text": "You dance when you get scared."
  },
  {
    "startTime": 101.41,
    "endTime": 102.19,
    "text": "I like it."
  },
  {
    "startTime": 102.19,
    "endTime": 103.3,
    "text": "All right, we're going to take a break,"
  },
  {
    "startTime": 103.3,
    "endTime": 104.3,
    "text": "and we're going to talk about--"
  },
  {
    "startTime": 104.3,
    "endTime": 106.363,
    "text": "You really affected my street cred with that, all right?"
  },
  {
    "startTime": 108.91,
    "endTime": 110.11,
    "text": "Yeah!"
  },
  {
    "startTime": 110.11,
    "endTime": 110.71,
    "text": "Yeah."
  },
  {
    "startTime": 110.71,
    "endTime": 112.86,
    "text": "We'll be back."
  }
]