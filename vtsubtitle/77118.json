    "text": "Of course!"
  },
  {
    "startTime": 87.989,
    "endTime": 90.801,
    "text": "Especially if it's to keep the people of Townsville safe!"
  },
  {
    "startTime": 92.901,
    "endTime": 94.8,
    "text": "Mission control, I got your call."
  },
  {
    "startTime": 94.999,
    "endTime": 95.66,
    "text": "What's the problem?"
  },
  {
    "startTime": 95.991,
    "endTime": 97.989,
