  {
    "startTime": 20.999,
    "endTime": 21.701,
    "text": "Yes, Ms. Keane?"
  },
  {
    "startTime": 22.299,
    "endTime": 28.695,
    "text": "Martin Beanowitz from the Bean Town Beanery is visiting the class tomorrow to talk about running a small restaurant."
