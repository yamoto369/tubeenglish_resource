  {
    "startTime": 33.45,
    "endTime": 41.774,
    "text": "And you're the only student I can trust to write a speech that won't be filled with inappropriate bean jokes."
  },
  {
    "startTime": 42.0,
    "endTime": 44.601,
    "text": "Unless you don't have the time, of course."
  },
  {
    "startTime": 44.999,
    "endTime": 47.399,
    "text": "Consider me your number-one bean counter."
  },
  {
    "startTime": 48.001,
