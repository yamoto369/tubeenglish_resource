    "text": "Now I'm in the zone."
  },
  {
    "startTime": 67.499,
    "endTime": 69.56899999999999,
    "text": "Uh, Blossom? Uh, Blossom, down here!"
  },
  {
    "startTime": 69.801,
    "endTime": 71.401,
