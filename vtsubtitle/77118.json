    "text": "\"Hangry\"?"
  },
  {
    "startTime": 106.701,
    "endTime": 108.59899999999999,
    "text": "Hungry and angry."
  },
  {
    "startTime": 109.81,
    "endTime": 111.176,
    "text": "We're hangry!"
  },
  {
