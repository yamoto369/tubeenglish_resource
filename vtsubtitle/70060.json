    "text": "ME NO LIKE! RUN, JAKE, RUN!"
  },
  {
    "startTime": 74.335,
    "endTime": 76.253,
    "text": "BUT SHE SAID I'M RUNNING IN HER LIGHT!"
  },
  {
    "startTime": 76.296,
