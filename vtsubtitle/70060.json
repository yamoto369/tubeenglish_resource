  },
  {
    "startTime": 42.387,
    "endTime": 44.139,
    "text": "HEY."
  },
  {
    "startTime": 44.18,
    "endTime": 45.682,
    "text": "WE'RE LEADING YOU TO A TRAP."
  },
  {
    "startTime": 45.724,
    "endTime": 48.101,
    "text": "WE'RE GONNA SUCK OUT YOUR HEALING POWER AND DUST YOU."
  },
  {
    "startTime": 49.394,
    "endTime": 51.687999999999995,
    "text": "AND THEN I'M GONNA PUT YOUR DUST IN A LITTER BOX."
  },
  {
    "startTime": 51.73,
    "endTime": 54.5,
    "text": "AND GET A TIGER TO DROP A HUGE SMELLY TIGER BOMB"
  },
  {
    "startTime": 54.92,
    "endTime": 55.275,
    "text": "ON YOUR SORRY DUST CLUMPS!"
  },
  {
    "startTime": 55.316,
