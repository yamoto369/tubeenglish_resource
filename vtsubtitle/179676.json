  },
  {
    "startTime": 59.0,
    "endTime": 63.0,
    "text": "Take off your secret agent hat just for tonight and put on your adventure hat."
  },
  {
    "startTime": 63.0,
    "endTime": 63.0,
    "text": "That's my guy!"
  },
  {
    "startTime": 63.0,
