[
  {
    "startTime": 0.0,
    "endTime": 1.0,
    "text": "Oh, goody."
  },
  {
    "startTime": 1.0,
    "endTime": 2.0,
    "text": "Trick-or-treaters."
  },
  {
    "startTime": 2.0,
    "endTime": 2.0,
    "text": "Trick-or-treat!"
  },
  {
    "startTime": 2.0,
    "endTime": 3.0,
    "text": "Okay, let's see."
  },
  {
    "startTime": 3.0,
    "endTime": 4.0,
    "text": "What do we have here?"
  },
  {
    "startTime": 4.0,
    "endTime": 8.0,
    "text": "Class dunce with a fake scar, and you must be the princess of Meatland."
  },
  {
    "startTime": 8.0,
    "endTime": 8.0,
    "text": "And..."
  },
  {
    "startTime": 8.0,
    "endTime": 11.0,
    "text": "oh, upset rooster head."
  },
  {
    "startTime": 11.0,
    "endTime": 13.0,
    "text": "And what are you supposed to be?"
  },
  {
    "startTime": 13.0,
    "endTime": 15.0,
    "text": "A kid in a sheet?"
  },
  {
    "startTime": 15.0,
    "endTime": 16.0,
    "text": "A platypus in a sheet?"
  },
  {
    "startTime": 16.0,
    "endTime": 17.0,
    "text": "Hey!"
  },
  {
    "startTime": 17.0,
    "endTime": 19.0,
    "text": "A platypus in a sheet?"
  },
  {
    "startTime": 19.0,
    "endTime": 19.0,
    "text": "Well, that's perfect."
  },
  {
    "startTime": 19.0,
    "endTime": 21.0,
    "text": "Wait, wait, I was hoping you'd..."
  },
  {
    "startTime": 21.0,
    "endTime": 22.0,
    "text": "Oh, whoa, whoa, whoa, whoa."
  },
  {
    "startTime": 22.0,
    "endTime": 23.0,
    "text": "I'm being sincere."
  },
  {
    "startTime": 23.0,
    "endTime": 25.0,
    "text": "There's no trap, no innate, or just..."
  },
  {
    "startTime": 25.0,
    "endTime": 25.0,
    "text": "Come over here."
  },
  {
    "startTime": 25.0,
    "endTime": 26.0,
    "text": "You've got to see this."
  },
  {
    "startTime": 26.0,
    "endTime": 27.0,
    "text": "It was delivered today."
  },
  {
    "startTime": 27.0,
    "endTime": 29.0,
    "text": "I had to sign for it and everything."
  },
  {
    "startTime": 29.0,
    "endTime": 32.0,
    "text": "It's a real castle with a moat."
  },
  {
    "startTime": 32.0,
    "endTime": 34.0,
    "text": "Who delivers a moat?"
  },
  {
    "startTime": 34.0,
    "endTime": 35.0,
    "text": "How do they even get that on a plane?"
  },
  {
    "startTime": 35.0,
    "endTime": 37.0,
    "text": "It's from my great-aunt Henrietta Hockenschmidt."
  },
  {
    "startTime": 37.0,
    "endTime": 40.0,
    "text": "She left it to me in her will."
  },
  {
    "startTime": 40.0,
    "endTime": 40.0,
    "text": "Lookit, listen to this."
  },
  {
    "startTime": 40.0,
    "endTime": 45.0,
    "text": "To Heinz Doofenshmirtz, you are my only nephew, except for Roger, and I hated him."
  },
  {
    "startTime": 45.0,
    "endTime": 45.0,
    "text": "See?"
  },
  {
    "startTime": 45.0,
    "endTime": 46.0,
    "text": "See why I liked her?"
  },
  {
    "startTime": 46.0,
    "endTime": 51.0,
    "text": "Therefore, I leave you my castle, and hidden inside is a very large treasure."
  },
  {
    "startTime": 51.0,
    "endTime": 51.0,
    "text": "Huh?"
  },
  {
    "startTime": 51.0,
    "endTime": 55.0,
    "text": "And look, there's a little treasure map with clues."
  },
  {
    "startTime": 55.0,
    "endTime": 56.0,
    "text": "Want to help me?"
  },
  {
    "startTime": 56.0,
    "endTime": 59.0,
