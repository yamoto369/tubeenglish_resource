  },
  {
    "startTime": 11.0,
    "endTime": 14.8,
    "text": "I don't remember subscribing to Fancy Livin' Digest."
  },
  {
    "startTime": 14.8,
    "endTime": 16.8,
    "text": "Whoa!"
  },
  {
    "startTime": 16.8,
    "endTime": 20.5,
    "text": "Look at these glossy depictions of a higher standard of living."
  },
  {
    "startTime": 20.5,
    "endTime": 22.0,
    "text": "Get me that!"
  },
  {
    "startTime": 22.0,
    "endTime": 23.6,
    "text": "Stealing my mail, eh?"
  },
  {
    "startTime": 23.6,
    "endTime": 27.0,
    "text": "Hey, Squidward, how do the people in that magazine get all that money?"
  },
  {
    "startTime": 27.0,
    "endTime": 28.7,
    "text": "They're entrepreneurs."
  },
  {
    "startTime": 28.7,
    "endTime": 30.2,
    "text": "They sell things to people."
  },
  {
    "startTime": 30.2,
    "endTime": 36.1,
    "text": "Quick, Patrick, without thinking, if you could have anything in the world right now, what would it be?"
  },
  {
    "startTime": 36.1,
    "endTime": 38.0,
    "text": "More time for thinking."
  },
  {
    "startTime": 38.0,
    "endTime": 39.4,
    "text": "Something you would pay for."
  },
  {
    "startTime": 39.4,
