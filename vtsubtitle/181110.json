  },
  {
    "startTime": 61.5,
    "endTime": 63.5,
    "text": "Okay, the first guy didn't count."
  },
  {
    "startTime": 63.5,
    "endTime": 65.5,
    "text": "This is our real first step."
  },
  {
    "startTime": 65.5,
    "endTime": 66.9,
    "text": "Good morning, sir."
  },
  {
    "startTime": 66.8,
    "endTime": 69.0,
    "text": "Would you like to buy some chocolate?"
  },
  {
    "startTime": 69.0,
    "endTime": 74.0,
    "text": "No self-respecting candy bar salesman would be caught dead without one of these."
  },
  {
    "startTime": 74.0,
    "endTime": 76.0,
    "text": "Wow, what is it?"
  },
  {
    "startTime": 76.0,
    "endTime": 79.2,
    "text": "It's a candy bar bag, you knucklehead."
  },
  {
    "startTime": 79.0,
    "endTime": 81.0,
    "text": "But you don't need these bags."
  },
  {
    "startTime": 81.0,
