  },
  {
    "startTime": 40.9,
    "endTime": 44.0,
    "text": "That's a great idea, Pat."
  },
  {
    "startTime": 44.0,
    "endTime": 45.4,
    "text": "Good afternoon, sir."
  },
  {
    "startTime": 45.4,
    "endTime": 48.699999999999996,
    "text": "Could we interest you in some chocolate?"
  },
  {
    "startTime": 48.7,
    "endTime": 50.0,
    "text": "Chocolate?"
  },
  {
