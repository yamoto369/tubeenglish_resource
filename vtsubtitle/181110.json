    "text": "We'll take 20."
  },
  {
    "startTime": 114.4,
    "endTime": 118.2,
    "text": "There must be something to this selling game that we're just not getting."
  },
  {
    "startTime": 118.2,
    "endTime": 119.3,
    "text": "Other people do it."
  },
  {
    "startTime": 119.3,
    "endTime": 121.0,
    "text": "I mean, look at that."
  },
  {
    "startTime": 121.0,
    "endTime": 122.6,
    "text": "Eat barnacle chips."
