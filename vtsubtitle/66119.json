[
  {
    "startTime": 75.64,
    "endTime": 81.6,
    "text": "God, I'm down here on my knees"
  },
  {
    "startTime": 81.6,
    "endTime": 82.759,
    "text": "'Cause it's the last place left to fall"
  },
  {
    "startTime": 82.76,
    "endTime": 83.77000000000001,
    "text": "Beggin' for another chance"
  },
  {
    "startTime": 83.77,
    "endTime": 85.71,
    "text": "If there's any chance at all"
  },
  {
    "startTime": 85.71,
    "endTime": 88.779,
    "text": "That You might still be listenin'"
  },
  {
    "startTime": 88.78,
    "endTime": 93.75,
    "text": "Lovin' and forgivin' guys like me"
  },
  {
    "startTime": 93.75,
    "endTime": 102.31,
    "text": "I've spent my whole life"
  },
  {
    "startTime": 102.31,
    "endTime": 105.33,
    "text": "Gettin' it all wrong"
  },
  {
    "startTime": 105.33,
    "endTime": 110.31,
    "text": "And I sure could use Your help"
  },
  {
    "startTime": 110.31,
    "endTime": 112.37,
    "text": "'Cause from now on"
  },
  {
    "startTime": 112.37,
    "endTime": 116.39,
    "text": "I want to be a good man"
  },
  {
    "startTime": 116.39,
    "endTime": 119.49,
    "text": "A do like I should man"
  },
  {
    "startTime": 119.49,
    "endTime": 120.49,
    "text": "I want to be the kind of man"
  },
  {
    "startTime": 120.49,
    "endTime": 125.419,
    "text": "The mirror likes to see"
  },
  {
    "startTime": 125.42,
    "endTime": 128.43,
    "text": "I want to be a strong man"
  },
  {
    "startTime": 128.43,
    "endTime": 133.58,
    "text": "And admit that I was wrong man"
  },
  {
    "startTime": 133.58,
    "endTime": 138.55,
    "text": "God, I'm asking You to come change me"
  },
  {
    "startTime": 138.55,
    "endTime": 147.34,
    "text": "Into the man I want to be"
  },
  {
    "startTime": 147.34,
    "endTime": 148.0,
    "text": "If there's anyway for her and me"
  },
  {
    "startTime": 148.0,
    "endTime": 153.39,
    "text": "To make another start"
  },
  {
    "startTime": 153.39,
    "endTime": 155.32,
    "text": "Could You see what You could do"
  },
  {
    "startTime": 155.32,
    "endTime": 158.38,
    "text": "To put some love back in her heart?"
  },
  {
    "startTime": 158.38,
    "endTime": 163.35,
    "text": "'Cause it goin' to take a miracle"
  },
  {
    "startTime": 163.35,
    "endTime": 169.42,
    "text": "After all I've done to really make her see"
  },
  {
    "startTime": 169.42,
    "endTime": 172.41,
    "text": "That I want to be a stay man"
  },
  {
    "startTime": 172.41,
    "endTime": 176.42,
    "text": "I want to be a brave man"
  },
  {
    "startTime": 176.42,
    "endTime": 178.48899999999998,
    "text": "I want to be the kind of man"
  },
  {
    "startTime": 178.49,
    "endTime": 182.57000000000002,
    "text": "She sees in her dreams"
  },
  {
    "startTime": 182.57,
    "endTime": 186.549,
    "text": "God, I want to be Your man"
  },
  {
    "startTime": 186.55,
    "endTime": 190.24,
    "text": "And I want to be her man"
  },
  {
    "startTime": 190.24,
    "endTime": 195.31,
    "text": "God, I only hope she still believes"
  },
  {
    "startTime": 195.31,
    "endTime": 198.35,
    "text": "In the man I want to be"
  },
  {
    "startTime": 198.35,
    "endTime": 206.299,
    "text": "Well, I know this late at night the talk is cheap"
  },
  {
    "startTime": 206.3,
    "endTime": 226.48000000000002,
    "text": "But Lord, don't give up on me"
  },
  {
    "startTime": 226.48,
    "endTime": 230.459,
    "text": "I want to be a givin' man"
  },
  {
    "startTime": 230.46,
    "endTime": 234.58,
    "text": "I want to really start livin', man"
  },
  {
    "startTime": 234.58,
    "endTime": 239.24,
    "text": "God, I'm asking You to come change me"
  },
  {
    "startTime": 239.24,
    "endTime": 252.38,
    "text": "Into the man I want to be"
  }
]