  },
  {
    "startTime": 166.4,
    "endTime": 169.20000000000002,
    "text": "What is something you don't understand about grown-ups?"
  },
  {
    "startTime": 169.2,
    "endTime": 170.463,
    "text": "The kissing."
  },
  {
    "startTime": 171.0,
