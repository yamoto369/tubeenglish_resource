[
  {
    "startTime": 4.74,
    "endTime": 5.939,
    "text": "Hey guys, I'm Alex."
  },
  {
    "startTime": 6.139,
    "endTime": 8.285,
    "text": "Thanks for clicking, and welcome to this"
  },
  {
