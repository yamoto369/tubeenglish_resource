    "text": "a time as well, so you can say,"
  },
  {
    "startTime": 81.205,
    "endTime": 85.493,
    "text": "\"See ya later.\""
  },
  {
    "startTime": 85.493,
    "endTime": 90.023,
    "text": "\"See ya on the weekend.\""
  },
  {
    "startTime": 91.733,
    "endTime": 95.623,
