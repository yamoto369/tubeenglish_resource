[
  {
    "startTime": 4.64,
    "endTime": 5.859999999999999,
    "text": "Eleven."
  },
  {
    "startTime": 6.0,
    "endTime": 6.72,
    "text": "Mike."
  },
  {
    "startTime": 11.58,
    "endTime": 12.58,
    "text": "Is that...?"
  },
  {
    "startTime": 17.935,
    "endTime": 19.215,
    "text": "I never gave up on you."
  },
  {
    "startTime": 20.46,
    "endTime": 21.86,
    "text": "I called you every night."
  },
  {
    "startTime": 22.54,
    "endTime": 24.72,
    "text": "- Every night for...\r\n- 353 days."
  },
  {
    "startTime": 26.78,
    "endTime": 27.78,
    "text": "I heard."
  },
  {
    "startTime": 28.64,
    "endTime": 30.080000000000002,
    "text": "Why didn't you tell me you were there?"
  },
  {
    "startTime": 30.84,
    "endTime": 31.52,
    "text": "That you were okay?"
  },
  {
    "startTime": 31.68,
    "endTime": 33.339999999999996,
    "text": "- Because I wouldn't let her."
  },
  {
    "startTime": 36.08,
    "endTime": 38.66,
    "text": "- The hell is this? Where have you been?\r\n- Where have you been?"
  },
  {
    "startTime": 41.015,
    "endTime": 42.205,
    "text": "You've been hiding her."
  },
  {
    "startTime": 43.185,
    "endTime": 44.84,
    "text": "You've been hiding her this whole time!"
  },
  {
    "startTime": 44.84,
    "endTime": 45.755,
    "text": "Hey-- hey!"
  },
  {
    "startTime": 45.985,
    "endTime": 47.725,
    "text": "Let's talk."
  },
  {
    "startTime": 48.355,
    "endTime": 49.625,
    "text": "Alone."
  },
  {
    "startTime": 54.695,
    "endTime": 57.485,
    "text": "Protecting her! Protecting her?!"
  },
  {
    "startTime": 57.485,
    "endTime": 58.22,
    "text": "Listen to me."
  },
  {
    "startTime": 58.22,
    "endTime": 62.72,
    "text": "The more people know about her, the more danger she's in, and the more danger you and your family are in."
  },
  {
    "startTime": 62.88,
    "endTime": 66.06,
    "text": "- Oh, what, so I should be thanking you then?!\r\n- I'm not asking you to thank me!"
  },
  {
    "startTime": 66.06,
    "endTime": 68.2,
    "text": "I'm asking you to try to understand."
  },
  {
    "startTime": 68.2,
    "endTime": 69.78,
    "text": "I don't! I don't understand!"
  },
  {
    "startTime": 69.78,
    "endTime": 73.12,
    "text": "That's fine, that's fine! Just do not blame her, all right?"
  },
  {
    "startTime": 73.12,
    "endTime": 74.94,
    "text": "- She's upset enough as it is.\r\n- I don't blame her!"
  },
  {
    "startTime": 74.94,
    "endTime": 76.2,
    "text": "I blame you!"
  },
  {
    "startTime": 76.2,
    "endTime": 78.04,
    "text": "- I blame you!\r\n- That's okay, kid."
  },
  {
    "startTime": 78.5,
    "endTime": 81.02,
    "text": "- That's okay.\r\n- No! Nothing about this okay!"
  },
  {
    "startTime": 81.36,
    "endTime": 82.54,
    "text": "Nothing about this is okay!"
  },
  {
    "startTime": 84.12,
    "endTime": 87.76,
    "text": "- You're a stupid, disgusting, lying... you piece of shit!\r\n- Okay, all right! Stop it."
  },
  {
    "startTime": 88.04,
    "endTime": 89.4,
    "text": "- Liar! Liar! Liar!\r\n- Stop it. It's okay!"
  },
  {
    "startTime": 89.88,
    "endTime": 92.1,
    "text": "- Stop it, stop it.\r\n- (crying) Liar. Liar."
  },
  {
    "startTime": 96.4,
    "endTime": 97.74000000000001,
    "text": "You're okay, kid."
  },
  {
    "startTime": 98.98,
    "endTime": 100.02000000000001,
    "text": "You're okay."
  },
  {
    "startTime": 102.84,
    "endTime": 104.06,
    "text": "I'm sorry, kid."
  },
  {
    "startTime": 107.54,
    "endTime": 109.995,
    "text": "- We missed you.\r\n- I missed you too."
  },
  {
    "startTime": 110.0,
    "endTime": 112.02,
    "text": "We talked about you pretty much every day."
  },
  {
    "startTime": 117.18,
    "endTime": 118.18,
    "text": "- Teeth."
  },
  {
    "startTime": 118.48,
    "endTime": 120.62,
    "text": "- What?\r\n- You have teeth."
  },
  {
    "startTime": 121.345,
    "endTime": 124.125,
    "text": "Oh. You like these pearls?"
  },
  {
    "startTime": 124.125,
    "endTime": 125.125,
    "text": "(growling noise)"
  },
  {
    "startTime": 125.465,
    "endTime": 126.495,
    "text": "- Eleven?"
  },
  {
    "startTime": 128.445,
    "endTime": 131.61499999999998,
    "text": "Hey. Um, I'm Max."
  },
  {
    "startTime": 131.835,
    "endTime": 133.055,
    "text": "I've heard a lot about you."
  },
  {
    "startTime": 139.505,
    "endTime": 140.505,
    "text": "Hey, sweetheart."
  },
  {
    "startTime": 142.98,
    "endTime": 143.48,
    "text": "Hey."
  },
  {
    "startTime": 146.095,
    "endTime": 147.095,
    "text": "Can I see him?"
  }
]