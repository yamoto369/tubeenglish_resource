[
  {
    "startTime": 7.895,
    "endTime": 8.895,
    "text": "Simba,"
  },
  {
    "startTime": 10.495,
    "endTime": 12.405,
    "text": "You must remember who you are."
  },
  {
    "startTime": 16.125,
    "endTime": 17.895,
    "text": "The one true king."
  },
  {
    "startTime": 28.575,
    "endTime": 29.735,
    "text": "Life's"
  },
  {
    "startTime": 30.285,
    "endTime": 31.705,
    "text": "not fair."
  },
  {
    "startTime": 32.494,
    "endTime": 34.065,
    "text": "Is it, my little friend?"
  },
  {
    "startTime": 35.415,
    "endTime": 37.555,
    "text": "While some are born to feast,"
  },
  {
    "startTime": 38.755,
    "endTime": 41.065000000000005,
    "text": "others spend their lives in the dark,"
  },
  {
    "startTime": 46.925,
    "endTime": 48.834999999999994,
    "text": "begging for scraps."
  },
  {
    "startTime": 54.495,
    "endTime": 55.945,
    "text": "Everything you see,"
  },
  {
    "startTime": 57.305,
    "endTime": 60.205,
    "text": "exists together in a delicate balance."
  },
  {
    "startTime": 65.265,
    "endTime": 67.815,
    "text": "While others search for what they can take,"
  },
  {
    "startTime": 68.545,
    "endTime": 71.565,
    "text": "a true king searches for what he can give."
  },
  {
    "startTime": 78.595,
    "endTime": 79.825,
    "text": "Run away, Simba."
  },
  {
    "startTime": 81.955,
    "endTime": 83.355,
    "text": "And NEVER return."
  },
  {
    "startTime": 101.395,
    "endTime": 102.445,
    "text": "You must take your place"
  },
  {
    "startTime": 107.345,
    "endTime": 108.705,
    "text": "in the circle of life."
  },
  {
    "startTime": 141.0,
    "endTime": 144.0,
    "text": "Everything the light touches,"
  },
  {
    "startTime": 146.515,
    "endTime": 147.58499999999998,
    "text": "is our kingdom."
  },
  {
    "startTime": 150.035,
    "endTime": 152.10399999999998,
    "text": "But a king's time as ruler,"
  },
  {
    "startTime": 153.235,
    "endTime": 155.585,
    "text": "rises and falls like the sun."
  },
  {
    "startTime": 158.175,
    "endTime": 159.175,
    "text": "One day,"
  },
  {
    "startTime": 160.535,
    "endTime": 161.95499999999998,
    "text": "the sun will set on my time here,"
  },
  {
    "startTime": 165.255,
    "endTime": 168.095,
    "text": "and will rise with you as the new king."
  },
  {
    "startTime": 210.0,
    "endTime": 211.0,
    "text": "Remember."
  }
]