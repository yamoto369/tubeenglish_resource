    "text": "(heavy breathing)"
  },
  {
    "startTime": 36.412,
    "endTime": 39.449999999999996,
    "text": "(somber music)"
  },
  {
    "startTime": 39.45,
    "endTime": 40.57,
    "text": "- Are you okay?"
  },
  {
    "startTime": 40.57,
    "endTime": 41.403,
    "text": "- I'm fine."
  },
  {
    "startTime": 43.01,
    "endTime": 44.138,
    "text": "- What are these?"
  },
  {
    "startTime": 44.138,
    "endTime": 45.434999999999995,
    "text": "(moans)"
  },
  {
    "startTime": 45.435,
    "endTime": 48.083000000000006,
    "text": "- They look like moments in time."
  },
  {
    "startTime": 49.48,
    "endTime": 51.38999999999999,
    "text": "- What's that thing you say, Olaf?"
  },
  {
    "startTime": 51.39,
    "endTime": 52.81,
    "text": "- The thing? Oh!"
  },
  {
    "startTime": 52.81,
    "endTime": 54.81,
    "text": "My theory about advancing technologies"
  },
  {
    "startTime": 54.81,
    "endTime": 56.550000000000004,
    "text": "as both our savior and our doom?"
  },
  {
    "startTime": 56.55,
    "endTime": 58.89,
    "text": "- No, not, not that one. The one about--"
  },
  {
    "startTime": 58.89,
    "endTime": 59.730000000000004,
    "text": "- [Olaf] The one about cucumbers?"
  },
  {
    "startTime": 59.73,
    "endTime": 61.129999999999995,
    "text": "- No, the thing about water."
  },
  {
    "startTime": 61.13,
    "endTime": 63.232,
    "text": "- Oh, yeah. Water has memory."
  },
  {
    "startTime": 63.232,
    "endTime": 69.403,
    "text": "The water that makes up you and me has passed through at least four humans and/or animals before us."
  },
  {
    "startTime": 70.29,
    "endTime": 71.123,
    "text": "- Hm."
  },
  {
    "startTime": 71.123,
    "endTime": 73.819,
    "text": "- And remembers everything."
  },
  {
    "startTime": 73.819,
    "endTime": 74.886,
    "text": "(moans)"
  },
  {
    "startTime": 74.886,
    "endTime": 76.72,
    "text": "(laughing) The wind's back!"
  },
  {
    "startTime": 76.72,
    "endTime": 79.276,
    "text": "Woo-hoo-hoo! Delicious!"
  },
  {
    "startTime": 79.276,
    "endTime": 82.294,
    "text": "I think I'll name you Gale."
  },
  {
    "startTime": 82.294,
    "endTime": 85.785,
    "text": "- Ah! Whoa! Get out of there! Whoa!"
  },
  {
    "startTime": 85.785,
    "endTime": 88.917,
    "text": "- Oh, hi! Aren't you curious? Oh!"
  },
  {
    "startTime": 89.989,
    "endTime": 91.93900000000001,
    "text": "- You in a better mood now?"
  },
  {
    "startTime": 91.939,
    "endTime": 93.053,
    "text": "(laughter)"
  },
  {
    "startTime": 93.053,
    "endTime": 95.264,
    "text": "(gusting)"
  },
  {
    "startTime": 95.264,
    "endTime": 97.11,
    "text": "(somber music)"
  },
  {
    "startTime": 97.11,
    "endTime": 99.11,
    "text": "(gasps)"
  },
  {
    "startTime": 101.984,
    "endTime": 103.74199999999999,
    "text": "- Father."
  },
  {
    "startTime": 103.742,
    "endTime": 105.423,
    "text": "That's father!"
  },
  {
    "startTime": 107.505,
    "endTime": 108.491,
    "text": "- This girl?"
  },
  {
    "startTime": 108.491,
    "endTime": 110.851,
    "text": "- [Olaf] She's saving him."
  },
  {
    "startTime": 110.851,
    "endTime": 112.468,
    "text": "- She's Northuldra."
  },
  {
    "startTime": 112.468,
