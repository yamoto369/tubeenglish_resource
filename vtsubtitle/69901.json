  {
    "startTime": 76.3,
    "endTime": 80.0,
    "text": "I asked Ryan Reynolds for an autograph while he was having dinner at the restaurant I worked at."
  },
  {
    "startTime": 80.0,
    "endTime": 82.0,
    "text": "My boss yelled, \"YOU'RE FIRED!\" and I yelled back, \"TOTALLY WORTH IT!\""
