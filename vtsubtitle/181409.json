  },
  {
    "startTime": 69.0,
    "endTime": 70.0,
    "text": "Ow!"
  },
  {
    "startTime": 70.0,
    "endTime": 71.0,
    "text": "Watch the ponytail."
  },
  {
    "startTime": 71.0,
    "endTime": 72.0,
    "text": "Let him up, please."
  },
  {
    "startTime": 73.0,
    "endTime": 74.0,
    "text": "What are you doing here?"
  },
  {
    "startTime": 74.0,
    "endTime": 80.0,
    "text": "I knew you'd need some help keeping it real, so I figured I could be, like, your co-president."
  },
  {
    "startTime": 80.0,
    "endTime": 81.0,
    "text": "Co-president?"
  },
  {
    "startTime": 81.0,
    "endTime": 83.0,
    "text": "Are you crazy?"
  },
  {
    "startTime": 83.0,
    "endTime": 84.0,
    "text": "Mom!"
  },
  {
    "startTime": 84.0,
    "endTime": 85.0,
    "text": "Lisa won't share!"
  },
  {
    "startTime": 85.0,
    "endTime": 87.0,
    "text": "Be nice to your brother, Lisa."
  },
  {
    "startTime": 89.0,
    "endTime": 93.0,
    "text": "Don't you think we should wait for Lisa?"
  },
  {
    "startTime": 94.0,
    "endTime": 95.0,
    "text": "She is the president."
  },
  {
    "startTime": 95.0,
    "endTime": 97.0,
