  },
  {
    "startTime": 7.38,
    "endTime": 11.92,
    "text": "Uh, sir, this might just be me, but don't you think the girls were acting a little strange?"
  },
  {
    "startTime": 12.0,
    "endTime": 12.76,
    "text": "How so?"
  },
  {
    "startTime": 12.84,
    "endTime": 17.799,
    "text": "Well, robbing the bank, the jewelry store, your house, beating the living daylights out of you."
  },
  {
    "startTime": 17.879,
    "endTime": 19.1,
    "text": "Need I go on?"
  },
  {
    "startTime": 19.18,
    "endTime": 20.68,
    "text": "Yes, I'm not following."
  },
  {
    "startTime": 20.76,
    "endTime": 24.86,
    "text": "The deep voices, the facial hair, the height, not to mention the manly odor."
  },
  {
    "startTime": 24.94,
