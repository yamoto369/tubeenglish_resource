[
  {
    "startTime": 21.294,
    "endTime": 25.074,
    "text": "Some days I'm up and the next day, I'm down."
  },
  {
    "startTime": 25.48,
    "endTime": 28.3,
    "text": "Like an emotional rollercoaster, huh?"
  },
  {
    "startTime": 29.523,
    "endTime": 33.933,
    "text": "Do you ever feel like you are on the rollercoaster, Charlie Brown?"
  },
  {
    "startTime": 34.099,
    "endTime": 37.958999999999996,
    "text": "How about bumper cars?"
  },
  {
    "startTime": 37.959,
    "endTime": 41.0,
    "text": "I've been thinking about your case a lot lately."
  },
  {
    "startTime": 41.3,
    "endTime": 43.199999999999996,
    "text": "That's very gratifying."
  },
  {
    "startTime": 43.845,
    "endTime": 46.873999999999995,
    "text": "You know where your trouble is, Charlie Brown?"
  },
  {
    "startTime": 46.874,
    "endTime": 50.037,
    "text": "You don't have a personal philosophy!"
  },
  {
    "startTime": 50.1,
    "endTime": 54.9,
    "text": "You need to develop a philosophy that will carry you through times of stress."
  },
  {
    "startTime": 55.718,
    "endTime": 57.763000000000005,
    "text": "Can you do that?"
  },
  {
    "startTime": 57.763,
    "endTime": 60.375,
    "text": "Can you develop a personal philosophy?"
  },
  {
    "startTime": 60.375,
    "endTime": 63.81,
    "text": "Think, Charlie Brown. Think hard!"
  },
  {
    "startTime": 63.85,
    "endTime": 64.005,
    "text": "Umm..."
  },
  {
    "startTime": 64.148,
    "endTime": 66.5,
    "text": "Life is like an ice cream cone."
  },
  {
    "startTime": 67.0,
    "endTime": 70.005,
    "text": "You have to learn to lick it!"
  },
  {
    "startTime": 71.8,
    "endTime": 75.5,
    "text": "That's the most stupid philosophy I've ever heard!"
  },
  {
    "startTime": 76.094,
    "endTime": 79.94399999999999,
    "text": "I can't do anything for someone who has the philosophy like that!"
  },
  {
    "startTime": 80.009,
    "endTime": 84.372,
    "text": "You are hopeless, Charlie Brown!"
  },
  {
    "startTime": 84.372,
    "endTime": 90.012,
    "text": "It's hard to develop a real personal philosophy in less than 20 seconds..."
  }
]