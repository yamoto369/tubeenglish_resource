[
  {
    "startTime": 1.016,
    "endTime": 2.0,
    "text": "My name is Guy."
  },
  {
    "startTime": 2.1,
    "endTime": 5.1,
    "text": "Sunday should be warm and sunny with just a scattering of drive-bys."
  },
  {
    "startTime": 5.11,
    "endTime": 8.242,
    "text": "And I live in paradise."
  },
  {
    "startTime": 9.66,
    "endTime": 10.71,
    "text": "I've got a best friend."
  },
  {
    "startTime": 10.72,
