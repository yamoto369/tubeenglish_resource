    "text": "Come on!"
  },
  {
    "startTime": 105.87,
    "endTime": 107.808,
    "text": "That actually hurt my hand."
  },
  {
    "startTime": 108.141,
    "endTime": 111.777,
    "text": "We can save our world, but we have to fight together!"
  },
  {
    "startTime": 111.777,
