    "text": "Woo!"
  },
  {
    "startTime": 93.975,
    "endTime": 95.074,
    "text": "Terminate him."
  },
  {
    "startTime": 94.87,
    "endTime": 97.345,
    "text": "This is the first time I've ever driven a car before!"
  },
  {
    "startTime": 97.345,
    "endTime": 98.975,
    "text": "I really wish you'd mentioned that."
  },
  {
    "startTime": 99.058,
    "endTime": 101.03200000000001,
    "text": "-Yeah-ha-ha! -Yeah-ha-ha!"
  },
  {
    "startTime": 101.516,
