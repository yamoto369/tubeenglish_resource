  },
  {
    "startTime": 127.18,
    "endTime": 130.13,
    "text": "No matter how I feel"
  },
  {
    "startTime": 130.13,
    "endTime": 136.49,
    "text": "Now I live by what I know"
  },
  {
    "startTime": 136.5,
    "endTime": 139.36,
    "text": "Mmm, just as sure as trials come"
