[
  {
    "startTime": 0.397,
    "endTime": 3.1470000000000002,
    "text": "(Earth rumbling)"
  },
  {
    "startTime": 4.638,
    "endTime": 7.305,
    "text": "(title ringing)"
  },
  {
    "startTime": 10.207,
    "endTime": 12.014000000000001,
    "text": "(radio chattering)"
  },
  {
    "startTime": 12.014,
    "endTime": 14.764,
    "text": "(dramatic music)"
  },
  {
    "startTime": 20.141,
    "endTime": 22.808,
    "text": "(ISS whooshing)"
  },
  {
    "startTime": 24.706,
    "endTime": 28.076,
    "text": "♪ Come on and take a free ride ♪"
  },
  {
    "startTime": 28.076,
    "endTime": 32.27,
    "text": "♪ Yeah, yeah, yeah, yeah ♪"
  },
  {
    "startTime": 32.27,
    "endTime": 35.721000000000004,
    "text": "♪ Come on and take a free ride ♪"
  },
  {
    "startTime": 35.721,
    "endTime": 38.519999999999996,
    "text": "♪ Yeah, yeah, yeah, yeah ♪"
  },
  {
    "startTime": 38.52,
    "endTime": 42.257000000000005,
    "text": "- Commander, we are good for pre-flight."
  },
  {
    "startTime": 42.257,
    "endTime": 43.582,
    "text": "- [Ethan] Roger that."
  },
  {
    "startTime": 43.582,
    "endTime": 44.415,
    "text": "♪ Yeah, yeah, yeah, yeah ♪"
  },
  {
    "startTime": 44.415,
    "endTime": 47.21,
    "text": "- Standby for final telemetry upload and lock."
  },
  {
    "startTime": 47.21,
    "endTime": 50.44,
    "text": "Oh, and the crew hope you're enjoying"
  },
  {
    "startTime": 50.44,
    "endTime": 52.327999999999996,
    "text": "your send off serenade."
  },
  {
    "startTime": 52.328,
    "endTime": 53.470000000000006,
    "text": "♪ Yeah, yeah, ooh, hoo ♪"
  },
  {
    "startTime": 53.47,
    "endTime": 54.56,
    "text": "- It's perfect, thank you."
  },
  {
    "startTime": 54.56,
    "endTime": 56.868,
    "text": "- [Sarah] Thought you'd like it."
  },
  {
    "startTime": 56.868,
    "endTime": 58.32,
    "text": "♪ Take a free ride ♪ - Standby for final checks"
  },
  {
    "startTime": 58.32,
    "endTime": 59.434,
    "text": "and transmission tests."
  },
  {
    "startTime": 59.434,
    "endTime": 60.266999999999996,
    "text": "♪ Yeah, yeah, yeah, yeah ♪"
  },
  {
    "startTime": 60.267,
    "endTime": 61.1,
    "text": "- Five by five, Flight."
  },
  {
    "startTime": 61.1,
    "endTime": 62.59,
    "text": "Ready to disengage."
  },
  {
    "startTime": 62.59,
    "endTime": 63.423,
    "text": "- Proceed."
  },
  {
    "startTime": 65.254,
    "endTime": 68.004,
    "text": "(dramatic music)"
  },
  {
    "startTime": 78.95,
    "endTime": 80.943,
    "text": "You are cleared for initial trust."
  },
  {
    "startTime": 81.96,
    "endTime": 84.77099999999999,
    "text": "- Roger that, moving out, quarter impulse."
  },
  {
    "startTime": 84.771,
    "endTime": 85.97,
    "text": "- [Sarah] Nerd!"
  },
  {
    "startTime": 85.97,
    "endTime": 87.103,
    "text": "- Card carrying."
  },
  {
    "startTime": 89.21,
    "endTime": 90.52999999999999,
    "text": "And if you don't say make it so,"
  },
  {
    "startTime": 90.53,
    "endTime": 91.953,
    "text": "I'll be very disappointed."
  },
  {
    "startTime": 92.802,
    "endTime": 94.152,
    "text": "- [Sarah] Noted, Commander."
  },
  {
    "startTime": 95.24,
    "endTime": 98.068,
    "text": "Please proceed to drive initiation point."
  },
  {
    "startTime": 98.068,
    "endTime": 99.068,
    "text": "- On my way."
  },
  {
    "startTime": 107.517,
    "endTime": 108.6,
    "text": "See you soon."
  },
  {
    "startTime": 113.156,
    "endTime": 114.739,
    "text": "- Ah, he's so fast!"
  },
  {
    "startTime": 117.553,
    "endTime": 120.136,
    "text": "(mellow music)"
  },
  {
    "startTime": 129.62,
    "endTime": 130.983,
    "text": "Someone's excited."
  },
  {
    "startTime": 133.01,
    "endTime": 133.843,
    "text": "You're looking forward to playing"
  },
  {
    "startTime": 133.843,
    "endTime": 135.70999999999998,
    "text": "with your new toy, Commander?"
  },
  {
    "startTime": 136.769,
    "endTime": 138.04,
    "text": "- I am, but maybe don't tell anyone"
  },
  {
    "startTime": 138.04,
    "endTime": 140.0,
    "text": "you call it my toy, honey"
  },
  {
    "startTime": 140.0,
    "endTime": 143.387,
    "text": "They may ask us to cover the trillion-dollar bill."
  },
  {
    "startTime": 148.198,
    "endTime": 149.031,
    "text": "Hey."
  },
  {
    "startTime": 150.427,
    "endTime": 151.344,
    "text": "Look at me."
  },
  {
    "startTime": 153.65,
    "endTime": 154.543,
    "text": "I'm coming back."
  },
  {
    "startTime": 155.45,
    "endTime": 156.283,
    "text": "I always do."
  },
  {
    "startTime": 158.536,
    "endTime": 159.963,
    "text": "I wouldn't do this if I thought otherwise."
  },
  {
    "startTime": 161.336,
    "endTime": 163.12800000000001,
    "text": "- You better."
  },
  {
    "startTime": 163.128,
    "endTime": 166.128,
    "text": "- You can't get rid of me that easy."
  },
  {
    "startTime": 168.681,
    "endTime": 172.27700000000002,
    "text": "(melancholy music)"
  },
  {
    "startTime": 172.277,
    "endTime": 175.027,
    "text": "(engine humming)"
  },
  {
    "startTime": 182.63,
    "endTime": 184.843,
    "text": "Flight, we are green across the board, please confirm."
  },
  {
    "startTime": 184.843,
    "endTime": 186.493,
    "text": "- [Sarah] Confirmed, Longshot."
  },
  {
    "startTime": 187.439,
    "endTime": 189.522,
    "text": "- Disengaging interlocks."
  },
  {
    "startTime": 197.736,
    "endTime": 200.04,
    "text": "Flight, we are a go for FTL burn."
  },
  {
    "startTime": 200.04,
    "endTime": 201.48999999999998,
    "text": "It's now or never."
  },
  {
    "startTime": 201.49,
    "endTime": 202.613,
    "text": "- [Sarah] God speed, Commander."
  },
  {
    "startTime": 203.925,
    "endTime": 205.90900000000002,
    "text": "See you on the other side."
  },
  {
    "startTime": 205.909,
    "endTime": 208.626,
    "text": "- Come on Flight, let's hear it, you can do it."
  },
  {
    "startTime": 208.626,
    "endTime": 209.459,
    "text": "- Fine."
  },
  {
    "startTime": 210.53,
    "endTime": 212.013,
    "text": "Make it so, Commander."
  },
  {
    "startTime": 212.93,
    "endTime": 213.788,
    "text": "- [Ethan] There you go."
  },
  {
    "startTime": 213.788,
    "endTime": 214.73700000000002,
    "text": "- [Reporter] The world awaits the test"
  },
  {
    "startTime": 214.737,
    "endTime": 218.29999999999998,
    "text": "of the very first faster-than-light propulsion system."
  },
  {
    "startTime": 218.3,
    "endTime": 221.77,
    "text": "The Longshot is the most advanced spacecraft ever built."
  },
  {
    "startTime": 221.77,
    "endTime": 224.81,
    "text": "And in it, Commander Kane will travel to Mars."
  },
  {
    "startTime": 224.81,
    "endTime": 226.66,
    "text": "A journey that, according to NASA,"
  },
  {
    "startTime": 226.66,
    "endTime": 229.174,
    "text": "will take just over three minutes."
  },
  {
    "startTime": 229.174,
    "endTime": 230.007,
    "text": "- [Ethan] Lighting it up"
  },
  {
    "startTime": 230.007,
    "endTime": 235.007,
    "text": "in three, two, one. (engine whining)"
  },
  {
    "startTime": 235.073,
    "endTime": 235.906,
    "text": "Mark!"
  },
  {
    "startTime": 239.873,
    "endTime": 242.873,
    "text": "(people chattering)"
  },
  {
    "startTime": 247.484,
    "endTime": 250.38400000000001,
    "text": "(ethereal music)"
  },
  {
    "startTime": 250.384,
    "endTime": 253.301,
    "text": "(energy crackling)"
  },
  {
    "startTime": 256.08,
    "endTime": 259.163,
    "text": "(spaceship rumbling)"
  },
  {
    "startTime": 260.955,
    "endTime": 263.455,
    "text": "(tense music)"
  },
  {
    "startTime": 271.123,
    "endTime": 272.133,
    "text": "1.25 c."
  },
  {
    "startTime": 273.43,
    "endTime": 274.85,
    "text": "Spinning down in five."
  },
  {
    "startTime": 278.655,
    "endTime": 283.655,
    "text": "(spaceship whooshing) (engine whining)"
  },
  {
    "startTime": 291.88,
    "endTime": 293.286,
    "text": "Flight, do you copy?"
  },
  {
    "startTime": 293.286,
    "endTime": 297.733,
    "text": "(Mission Control applauding) - That's right, yes!"
  },
  {
    "startTime": 297.733,
    "endTime": 299.133,
    "text": "- Loud and clear, Commander."
  },
  {
    "startTime": 300.06,
    "endTime": 303.2,
    "text": "Welcome back to our corner of space-time."
  },
  {
    "startTime": 303.2,
    "endTime": 305.15,
    "text": "- [Ethan] It's good to be back."
  },
  {
    "startTime": 305.15,
    "endTime": 306.67999999999995,
    "text": "- And this just in!"
  },
  {
    "startTime": 306.68,
    "endTime": 309.29,
    "text": "Commander Kane has arrived at his destination"
  },
  {
    "startTime": 309.29,
    "endTime": 313.166,
    "text": "and is now the first man to travel faster than light."
  },
  {
    "startTime": 313.166,
    "endTime": 314.1,
    "text": "- Thank God!"
  },
  {
    "startTime": 314.1,
    "endTime": 315.74,
    "text": "- [Reporter] The commander will now launch"
  },
  {
    "startTime": 315.74,
    "endTime": 318.75,
    "text": "an entangled satellite into orbit around Mars"
  },
  {
    "startTime": 318.75,
    "endTime": 320.61,
    "text": "allowing real-time communication"
  },
  {
    "startTime": 320.61,
    "endTime": 322.781,
    "text": "between Earth and Mars Colony One."
  },
  {
    "startTime": 322.781,
    "endTime": 325.531,
    "text": "(dramatic music)"
  },
  {
    "startTime": 327.73,
    "endTime": 328.833,
    "text": "- Q sat, online."
  },
  {
    "startTime": 330.54,
    "endTime": 332.47700000000003,
    "text": "- [Ethan] All right, let's do this again"
  },
  {
    "startTime": 332.477,
    "endTime": 333.87699999999995,
    "text": "before you miss me too much."
  },
  {
    "startTime": 335.63,
    "endTime": 337.193,
    "text": "- Initiate return sequence."
  },
  {
    "startTime": 338.14,
    "endTime": 340.19,
    "text": "- [Ethan] Starting FTL spin-up sequence."
  },
  {
    "startTime": 340.19,
    "endTime": 341.74,
    "text": "- [Sarah] Roger that, Longshot."
  },
  {
    "startTime": 343.901,
    "endTime": 346.98400000000004,
    "text": "(spaceship humming)"
  },
  {
    "startTime": 351.27,
    "endTime": 353.317,
    "text": "- And we are a go across the board, Flight."
  },
  {
    "startTime": 353.317,
    "endTime": 356.031,
    "text": "- [Sarah] Spin her up, Commander."
  },
  {
    "startTime": 356.031,
    "endTime": 358.781,
    "text": "(engine whining)"
  },
  {
    "startTime": 362.061,
    "endTime": 365.01,
    "text": "- Flight, it looks like I may have an interlock issue here."
  },
  {
    "startTime": 365.01,
    "endTime": 366.52,
    "text": "- We're seeing the same thing here."
  },
  {
    "startTime": 366.52,
    "endTime": 368.393,
    "text": "Let's take a look at diagnostics."
  },
  {
    "startTime": 370.7,
    "endTime": 373.183,
    "text": "Abort FTL drive start and spin down."
  },
  {
    "startTime": 374.1,
    "endTime": 374.93300000000005,
    "text": "- Roger that."
  },
  {
    "startTime": 375.83,
    "endTime": 376.663,
    "text": "Spinning down."
  },
  {
    "startTime": 387.638,
    "endTime": 390.22999999999996,
    "text": "(computer beeping)"
  },
  {
    "startTime": 390.23,
    "endTime": 391.22900000000004,
    "text": "Flight, we have a problem."
  },
  {
    "startTime": 391.229,
    "endTime": 394.39599999999996,
    "text": "(spaceship whooshing)"
  },
  {
    "startTime": 395.662,
    "endTime": 398.71999999999997,
    "text": "(alarm beeping)"
  },
  {
    "startTime": 398.72,
    "endTime": 403.72,
    "text": "(energy crackling) (dramatic music)"
  },
  {
    "startTime": 405.06,
    "endTime": 406.53000000000003,
    "text": "Flight, I have lost drive control."
  },
  {
    "startTime": 406.53,
    "endTime": 408.623,
    "text": "Repeat, I have lost drive control."
  },
  {
    "startTime": 410.322,
    "endTime": 413.343,
    "text": "I have no nav comm and I am approaching light speed."
  },
  {
    "startTime": 419.626,
    "endTime": 421.49899999999997,
    "text": "- Find him, Comms!"
  },
  {
    "startTime": 421.499,
    "endTime": 425.416,
    "text": "- [Ethan] I am being pulled in to a new vector!"
  },
  {
    "startTime": 428.028,
    "endTime": 429.87100000000004,
    "text": "- [Computer] Warning, hull breach."
  },
  {
    "startTime": 429.871,
    "endTime": 431.724,
    "text": "Warning, hull breach."
  },
  {
    "startTime": 431.724,
    "endTime": 433.592,
    "text": "Warning, hull breach."
  },
  {
    "startTime": 433.592,
    "endTime": 435.017,
    "text": "Warning."
  },
  {
    "startTime": 435.017,
    "endTime": 440.017,
    "text": "(metal groaning) (engine whining)"
  },
  {
    "startTime": 442.067,
    "endTime": 445.234,
    "text": "(spaceship whooshing)"
  },
  {
    "startTime": 448.833,
    "endTime": 450.583,
    "text": "Warning, hull breach."
  },
  {
    "startTime": 451.906,
    "endTime": 453.656,
    "text": "Warning, hull breach."
  },
  {
    "startTime": 454.78,
    "endTime": 455.613,
    "text": "Warning."
  },
  {
    "startTime": 457.434,
    "endTime": 462.434,
    "text": "(ethereal music) (spaceship rumbling)"
  },
  {
    "startTime": 492.099,
    "endTime": 493.849,
    "text": "Warning, hull breach."
  },
  {
    "startTime": 495.22,
    "endTime": 496.97,
    "text": "Warning, hull breach."
  },
  {
    "startTime": 499.99,
    "endTime": 501.97,
    "text": "- I need information people, come on!"
  },
  {
    "startTime": 501.97,
    "endTime": 502.83000000000004,
    "text": "Where's our bird?"
  },
  {
    "startTime": 502.83,
    "endTime": 504.5,
    "text": "- Gone, I mean gone."
  },
  {
    "startTime": 504.5,
    "endTime": 506.17,
    "text": "No vector, nothing to track."
  },
  {
    "startTime": 506.17,
    "endTime": 507.00300000000004,
    "text": "We should be able to get him"
  },
  {
    "startTime": 507.003,
    "endTime": 508.52,
    "text": "on Q comm anywhere, but nothing."
  },
  {
    "startTime": 512.43,
    "endTime": 515.543,
    "text": "- Stand by, we're receiving some new information."
  },
  {
    "startTime": 516.76,
    "endTime": 518.843,
    "text": "Commander Kane seems to have disappeared."
  },
  {
    "startTime": 519.91,
    "endTime": 521.2099999999999,
    "text": "- Where did Dad go?"
  },
  {
    "startTime": 521.21,
    "endTime": 522.5600000000001,
    "text": "- [Reporter] The Longshot was ready to make"
  },
  {
    "startTime": 522.56,
    "endTime": 524.0899999999999,
    "text": "the return voyage home"
  },
  {
    "startTime": 524.09,
    "endTime": 526.13,
    "text": "but something seems to have gone wrong."
  },
  {
    "startTime": 526.13,
    "endTime": 528.02,
    "text": "We will continue to follow the story"
  },
  {
    "startTime": 528.02,
    "endTime": 530.8679999999999,
    "text": "and provide updates on any new developments."
  },
  {
    "startTime": 530.868,
    "endTime": 533.368,
    "text": "(tense music)"
  },
  {
    "startTime": 537.014,
    "endTime": 539.179,
    "text": "- [Computer] Warning, hull breach."
  },
  {
    "startTime": 539.179,
    "endTime": 540.675,
    "text": "- A first contact."
  },
  {
    "startTime": 540.675,
    "endTime": 542.6709999999999,
    "text": "Okay, way above my pay grade."
  },
  {
    "startTime": 542.671,
    "endTime": 545.504,
    "text": "- [Computer] Warning, hull breach."
  },
  {
    "startTime": 554.087,
    "endTime": 556.909,
    "text": "Warning, hull breach. (glass cracking)"
  },
  {
    "startTime": 556.909,
    "endTime": 561.909,
    "text": "Warning, hull breach. (metal groaning)"
  },
  {
    "startTime": 566.057,
    "endTime": 571.057,
    "text": "(sad music) (glass cracking)"
  },
  {
    "startTime": 591.264,
    "endTime": 594.014,
    "text": "(aliens buzzing)"
  },
  {
    "startTime": 599.979,
    "endTime": 602.729,
    "text": "(metal groaning)"
  },
  {
    "startTime": 609.74,
    "endTime": 612.49,
    "text": "(aliens buzzing)"
  },
  {
    "startTime": 642.761,
    "endTime": 643.909,
    "text": "- [Reporter] After almost a day"
  },
  {
    "startTime": 643.909,
    "endTime": 645.63,
    "text": "since his last communication,"
  },
  {
    "startTime": 645.63,
    "endTime": 647.923,
    "text": "the search for Commander Kane continues."
  },
  {
    "startTime": 648.83,
    "endTime": 652.2810000000001,
    "text": "We have reached out for the Commander's family for comment."
  },
  {
    "startTime": 652.281,
    "endTime": 655.0899999999999,
    "text": "We're sure it's been a difficult time for them."
  },
  {
    "startTime": 655.09,
    "endTime": 656.61,
    "text": "Along with the rest of the world,"
  },
  {
    "startTime": 656.61,
    "endTime": 659.183,
    "text": "we hold out hope for a safe return."
  },
  {
    "startTime": 678.176,
    "endTime": 680.9200000000001,
    "text": "- [Sarah] Nothing more to do today."
  },
  {
    "startTime": 680.92,
    "endTime": 681.7529999999999,
    "text": "Go home."
  },
  {
    "startTime": 688.236,
    "endTime": 691.549,
    "text": "(radio squelching)"
  },
  {
    "startTime": 691.549,
    "endTime": 692.632,
    "text": "- Uh, Flight?"
  },
  {
    "startTime": 694.09,
    "endTime": 695.2,
    "text": "There's something."
  },
  {
    "startTime": 695.2,
    "endTime": 697.45,
    "text": "- [Ethan] Control, come in."
  },
  {
    "startTime": 698.38,
    "endTime": 699.58,
    "text": "- You guys getting this?"
  },
  {
    "startTime": 701.32,
    "endTime": 702.5300000000001,
    "text": "- [NavCom] NORAD is reporting an anomaly"
  },
  {
    "startTime": 702.53,
    "endTime": 705.24,
    "text": "approximately 2.4 clicks from ISS."
  },
  {
    "startTime": 705.24,
    "endTime": 706.073,
    "text": "- Anomaly?"
  },
  {
    "startTime": 706.073,
    "endTime": 706.906,
    "text": "Do we have a visual?"
  },
  {
    "startTime": 706.906,
    "endTime": 708.063,
    "text": "- Coming up."
  },
  {
    "startTime": 709.947,
    "endTime": 712.697,
    "text": "(dramatic music)"
  },
  {
    "startTime": 714.504,
    "endTime": 715.754,
    "text": "- What is that?"
  },
  {
    "startTime": 725.945,
    "endTime": 728.778,
    "text": "(aliens whizzing)"
  },
  {
    "startTime": 739.877,
    "endTime": 740.7099999999999,
    "text": "Can you track?"
  },
  {
    "startTime": 740.71,
    "endTime": 745.71,
    "text": "- I don't."
  },
  {
