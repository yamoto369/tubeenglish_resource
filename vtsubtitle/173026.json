[
  {
    "startTime": 18.2,
    "endTime": 20.3,
    "text": "Whoa! What kind of airship is that?"
  },
  {
    "startTime": 20.4,
    "endTime": 22.2,
    "text": "I've never seen anything like it!"
  },
  {
    "startTime": 22.5,
    "endTime": 24.0,
    "text": "Baby Clade!"
  },
  {
    "startTime": 24.1,
    "endTime": 26.1,
    "text": "What is the president doing in our front yard?"
  },
  {
    "startTime": 26.6,
    "endTime": 28.700000000000003,
    "text": "Our entire world is in grave danger."
  },
  {
    "startTime": 28.8,
    "endTime": 31.2,
    "text": "I want you to come with me on an expedition."
  },
  {
    "startTime": 32.2,
    "endTime": 33.400000000000006,
    "text": "I'm not my father."
  },
  {
    "startTime": 33.9,
    "endTime": 35.4,
    "text": "He was the explorer."
  },
  {
    "startTime": 35.8,
    "endTime": 41.3,
    "text": "I know you were just a kid when he went missing, but now... you're all we got."
  },
  {
    "startTime": 41.7,
    "endTime": 44.1,
    "text": "- Mr. Clade, I'm a huge fan...  - Oh, thank you."
  },
  {
    "startTime": 44.2,
    "endTime": 45.1,
    "text": "... of your dad."
  },
  {
    "startTime": 45.2,
    "endTime": 48.0,
    "text": "- Do you think you could forge his autograph?  - What?"
  },
  {
    "startTime": 51.2,
    "endTime": 53.900000000000006,
    "text": "Where in the world are we?"
  },
  {
    "startTime": 55.3,
    "endTime": 56.699999999999996,
    "text": "Ethan, you brought the dog?"
  },
  {
    "startTime": 56.8,
    "endTime": 57.5,
    "text": "Sorry!"
  },
  {
    "startTime": 61.2,
    "endTime": 63.7,
    "text": "We are clearly in uncharted territory."
  },
  {
    "startTime": 70.4,
    "endTime": 70.9,
    "text": "Hello."
  },
  {
    "startTime": 71.0,
    "endTime": 73.2,
    "text": "You probably don't understand a word I'm saying."
  },
  {
    "startTime": 73.4,
    "endTime": 75.0,
    "text": "Of course I understand you."
  },
  {
    "startTime": 75.1,
    "endTime": 75.89999999999999,
    "text": "Huh?"
  },
  {
    "startTime": 76.1,
    "endTime": 76.69999999999999,
    "text": "Dad?"
  },
  {
    "startTime": 76.8,
    "endTime": 77.39999999999999,
    "text": "Dad?"
  },
  {
    "startTime": 77.5,
    "endTime": 78.0,
    "text": "Grandpa?"
  },
  {
    "startTime": 78.1,
    "endTime": 79.0,
    "text": "I'm a grandpa?"
  },
  {
    "startTime": 79.9,
    "endTime": 81.30000000000001,
    "text": "What is this place?"
  },
  {
    "startTime": 81.4,
    "endTime": 82.9,
    "text": "The cliffs are alive."
  },
  {
    "startTime": 83.3,
    "endTime": 85.7,
    "text": "And the waters dissolve the flesh off your bones."
  },
  {
    "startTime": 85.8,
    "endTime": 87.8,
    "text": "Everything down here is trying to kill us!"
  },
  {
    "startTime": 95.7,
    "endTime": 97.5,
    "text": "Do you mind if I call you Splat?"
  },
  {
    "startTime": 97.8,
    "endTime": 99.3,
    "text": "You just kind of give me Splat vibes."
  },
  {
    "startTime": 99.8,
    "endTime": 102.0,
    "text": "Ow! I guess I deserve that."
  },
  {
    "startTime": 104.6,
    "endTime": 105.69999999999999,
    "text": "Grandpa's awesome!"
  },
  {
    "startTime": 105.8,
    "endTime": 106.89999999999999,
    "text": "He is not awesome!"
  },
  {
    "startTime": 107.0,
    "endTime": 109.2,
    "text": "You gave me a machete for my birthday."
  },
  {
    "startTime": 109.8,
    "endTime": 111.5,
    "text": "Classic Jaeger Clade."
  },
  {
    "startTime": 111.6,
    "endTime": 112.89999999999999,
    "text": "I was 2."
  },
  {
    "startTime": 114.0,
    "endTime": 118.1,
    "text": "I'm loving this family reunion, but come on, we got a world to save!"
  },
  {
    "startTime": 119.4,
    "endTime": 123.30000000000001,
    "text": "We need you to figure this out, otherwise we're doomed; we are doomed!"
  },
  {
    "startTime": 123.4,
    "endTime": 124.60000000000001,
    "text": "Wait, seriously?"
  },
  {
    "startTime": 125.2,
    "endTime": 127.2,
    "text": "No, I'm just messing with you."
  },
  {
    "startTime": 129.5,
    "endTime": 131.0,
    "text": "Didn't see that coming."
  }
]