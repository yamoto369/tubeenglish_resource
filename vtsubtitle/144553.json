[
  {
    "startTime": 2.375,
    "endTime": 3.417,
    "text": "Hello, interweb."
  },
  {
    "startTime": 4.5,
    "endTime": 7.0,
    "text": "My name is Emma Nolan, and I'm 17."
  },
  {
    "startTime": 8.417,
    "endTime": 11.125,
    "text": "You might have heard about the prom in Indiana."
  },
  {
    "startTime": 11.208,
    "endTime": 13.417,
    "text": "I just want to go to prom like any other kid."
  },
  {
    "startTime": 13.5,
    "endTime": 14.75,
    "text": "All opposed?"
  },
  {
    "startTime": 16.958,
    "endTime": 22.040999999999997,
    "text": "I know we all have stories to tell and…here's mine."
  },
  {
    "startTime": 25.583,
    "endTime": 27.25,
    "text": "Oh, my gosh, check this out."
  },
  {
    "startTime": 27.333,
    "endTime": 28.708,
    "text": "It's all over Twitter."
  },
  {
    "startTime": 28.792,
    "endTime": 34.625,
    "text": "She wanted to take her girlfriend to the high school prom, and the PTA went apeshit, and they canceled it."
  },
  {
    "startTime": 34.708,
    "endTime": 36.458,
    "text": "We have got to go down there."
  },
  {
    "startTime": 36.542,
    "endTime": 38.0,
    "text": "-Yes. -And raise holy hell!"
  },
  {
    "startTime": 38.083,
    "endTime": 43.042,
    "text": "We will be the biggest thing to happen in Indiana since…whatever's happened in Indiana."
  },
  {
    "startTime": 45.167,
    "endTime": 50.125,
    "text": "We have come to this community…on behalf of a young girl."
  },
  {
    "startTime": 50.208,
    "endTime": 53.625,
    "text": "I just wanna dance with you."
  },
  {
    "startTime": 53.708,
    "endTime": 55.875,
    "text": "I'm sorry. Who are you people?"
  },
  {
    "startTime": 55.958,
    "endTime": 57.667,
    "text": "We are from Broadway."
  },
  {
    "startTime": 58.208,
    "endTime": 61.083,
    "text": "I just wanna dance with you."
  },
  {
    "startTime": 61.625,
    "endTime": 62.75,
    "text": "We're not monsters."
  },
  {
    "startTime": 65.042,
    "endTime": 67.375,
    "text": "We're cultural disruptors."
  },
  {
    "startTime": 70.042,
    "endTime": 74.667,
    "text": "Your beliefs are not our beliefs. You don't know this town."
  },
  {
    "startTime": 75.75,
    "endTime": 80.5,
    "text": "I thought that when my parents rejected me, that I would never feel any worse."
  },
  {
    "startTime": 82.25,
    "endTime": 84.625,
    "text": "I've never felt so alone in my life."
  },
  {
    "startTime": 85.792,
    "endTime": 87.0,
    "text": "But you're not alone."
  },
  {
    "startTime": 89.083,
    "endTime": 90.208,
    "text": "And you do have friends."
  },
  {
    "startTime": 90.292,
    "endTime": 91.167,
    "text": "Where are they?"
  },
  {
    "startTime": 92.792,
    "endTime": 93.792,
    "text": "Okay, people."
  },
  {
    "startTime": 93.875,
    "endTime": 96.208,
    "text": "This is the part where we roll up our sleeves"
  },
  {
    "startTime": 96.292,
    "endTime": 98.708,
    "text": "and we put on a prom with our own bare hands."
  },
  {
    "startTime": 100.458,
    "endTime": 102.333,
    "text": "I just don't understand it."
  },
  {
    "startTime": 102.417,
    "endTime": 103.75,
    "text": "Well, I think it's brave."
  },
  {
    "startTime": 104.792,
    "endTime": 107.333,
    "text": "Let's get this party started!"
  },
  {
    "startTime": 107.417,
    "endTime": 112.0,
    "text": "It's time to build a prom for everyone"
  },
  {
    "startTime": 112.083,
    "endTime": 115.25,
    "text": "Show them all it can be done"
  },
  {
    "startTime": 115.792,
    "endTime": 118.583,
    "text": "If music blares And no one cares"
  },
  {
    "startTime": 119.583,
    "endTime": 122.542,
    "text": "Who your unruly heart loves"
  },
  {
    "startTime": 122.625,
    "endTime": 124.542,
    "text": "Build it now…"
  },
  {
    "startTime": 124.625,
    "endTime": 125.958,
    "text": "I'm gonna take a stand…"
  },
  {
    "startTime": 127.833,
    "endTime": 134.333,
    "text": "for all the people out there who love someone in a way the world just doesn't understand."
  },
  {
    "startTime": 134.417,
    "endTime": 136.083,
    "text": "But till that day comes"
  },
  {
    "startTime": 136.167,
    "endTime": 137.917,
    "text": "I say cue the drums"
  },
  {
    "startTime": 138.0,
    "endTime": 139.75,
    "text": "And take to the floor"
  },
  {
    "startTime": 139.833,
    "endTime": 141.083,
    "text": "That's what the floor's for"
  },
  {
    "startTime": 141.167,
    "endTime": 142.708,
    "text": "It's time to dance"
  },
  {
    "startTime": 143.917,
    "endTime": 145.25,
    "text": "Okay, I admit that got to me."
  },
  {
    "startTime": 145.333,
    "endTime": 149.75,
    "text": "It's time to dance"
  },
  {
    "startTime": 149.833,
    "endTime": 153.125,
    "text": "Dance"
  },
  {
    "startTime": 153.208,
    "endTime": 154.25,
    "text": "It's time to dance!"
  }
]