[
  {
    "startTime": 0.0,
    "endTime": 2.101,
    "text": "♪♪♪"
  },
  {
    "startTime": 2.134,
    "endTime": 3.136,
    "text": "What's this?"
  },
  {
    "startTime": 6.806,
    "endTime": 8.241,
    "text": "You folks need to turn around."
  },
  {
    "startTime": 8.274,
    "endTime": 9.674999999999999,
    "text": "Pretty bad accident up ahead."
  },
  {
    "startTime": 9.809,
    "endTime": 10.777,
    "text": "Anything we can do?"
  },
  {
    "startTime": 10.81,
    "endTime": 12.312000000000001,
    "text": "You a doctor or something?"
  },
  {
    "startTime": 12.645,
    "endTime": 13.645,
    "text": "Or something."
  },
  {
    "startTime": 19.685,
    "endTime": 20.586,
    "text": "Nice doll."
  },
  {
    "startTime": 20.619,
    "endTime": 22.255,
    "text": "That's what you think."
  },
  {
    "startTime": 22.288,
    "endTime": 26.292,
    "text": "♪♪♪"
  },
  {
    "startTime": 28.127,
    "endTime": 29.095,
    "text": "Did it work?"
  },
  {
    "startTime": 29.128,
    "endTime": 31.664,
    "text": "The evil is contained."
  },
  {
    "startTime": 33.365,
    "endTime": 34.7,
    "text": "How could you not tell me you're babysitting"
  },
  {
    "startTime": 34.733,
    "endTime": 35.601,
    "text": "for the Warrens tonight?"
  },
  {
    "startTime": 35.634,
    "endTime": 37.603,
    "text": "And we'll be back  early tomorrow morning."
  },
  {
    "startTime": 37.636,
    "endTime": 38.438,
    "text": "Have fun."
  },
  {
    "startTime": 39.005,
    "endTime": 41.307,
    "text": "Don't your parents keep any creepy stuff around?"
  },
  {
    "startTime": 41.34,
    "endTime": 43.376000000000005,
    "text": "We keep it all  locked away in a room."
  },
  {
    "startTime": 44.11,
    "endTime": 46.312,
    "text": "It's not good for anyone to go in there."
  },
  {
    "startTime": 49.748,
    "endTime": 52.684,
    "text": "My dad says that everything in there is either..."
  },
  {
    "startTime": 53.419,
    "endTime": 54.821,
    "text": "haunted, cursed..."
  },
  {
    "startTime": 54.854,
    "endTime": 57.123,
    "text": "or used in some  ritualistic practice."
  },
  {
    "startTime": 57.69,
    "endTime": 59.291,
    "text": "-What's that? -The Ferryman."
  },
  {
    "startTime": 59.625,
    "endTime": 61.561,
    "text": "They put coins over the eyes of the dead..."
  },
  {
    "startTime": 61.861,
    "endTime": 63.196,
    "text": "so he could take their souls."
  },
  {
    "startTime": 64.897,
    "endTime": 66.766,
    "text": "And what about the doll that's in there?"
  },
  {
    "startTime": 66.799,
    "endTime": 67.46700000000001,
    "text": "Annabelle."
  },
  {
    "startTime": 67.5,
    "endTime": 69.402,
    "text": "She's in a case for a reason."
  },
  {
    "startTime": 86.218,
    "endTime": 87.787,
    "text": "Can Annabelle  come out to play?"
  },
  {
    "startTime": 98.197,
    "endTime": 99.199,
    "text": "No."
  },
  {
    "startTime": 106.272,
    "endTime": 107.107,
    "text": "Ah!"
  },
  {
    "startTime": 107.941,
    "endTime": 110.81,
    "text": "Annabelle is the beacon for other spirits."
  },
  {
    "startTime": 122.755,
    "endTime": 124.49,
    "text": "Go away!"
  },
  {
    "startTime": 124.523,
    "endTime": 125.658,
    "text": "-Mrs. Warren? -Mom?"
  },
  {
    "startTime": 125.691,
    "endTime": 126.626,
    "text": "Is everything okay?"
  },
  {
    "startTime": 126.659,
    "endTime": 128.69400000000002,
    "text": "Something is happening inside your house..."
  },
  {
    "startTime": 128.727,
    "endTime": 130.597,
    "text": "and we're not really sure what to do."
  },
  {
    "startTime": 131.064,
    "endTime": 132.732,
    "text": "Can I speak to Annabelle?"
  },
  {
    "startTime": 133.532,
    "endTime": 134.567,
    "text": "I'm sorry."
  },
  {
    "startTime": 134.6,
    "endTime": 137.236,
    "text": "You need to give her a soul, dear."
  },
  {
    "startTime": 137.269,
    "endTime": 139.739,
    "text": "She wants a soul!"
  }
]