    "text": "(laughs)"
  },
  {
    "startTime": 41.5,
    "endTime": 42.4,
    "text": "Hey Big Bird."
  },
  {
    "startTime": 42.42,
    "endTime": 43.300000000000004,
    "text": "Oh hey Mike."
  },
  {
    "startTime": 43.32,
    "endTime": 46.81,
    "text": "Oh, I wanted to thank you   again for the standing nest."
