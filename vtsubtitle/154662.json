  },
  {
    "startTime": 10.52,
    "endTime": 12.33,
    "text": "What's Big Bird doing here?"
  },
  {
    "startTime": 12.35,
    "endTime": 13.799999999999999,
    "text": "Oh, right."
  },
  {
    "startTime": 13.82,
    "endTime": 18.36,
    "text": "You guys, this is Big Bird.   He's going to be interning with us here at Funny or Die   for the fall."
  },
  {
    "startTime": 18.38,
    "endTime": 27.79,
    "text": "I want to be a comedy  writer when I grow up, and a fireman, and an astronaut."
