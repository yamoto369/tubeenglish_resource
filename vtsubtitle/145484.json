  {
    "startTime": 150.04,
    "endTime": 151.88,
    "text": "Yeah cause I have a tendency to be dramatic."
  },
  {
    "startTime": 151.98,
    "endTime": 152.79999999999998,
    "text": "A."
  },
  {
    "startTime": 154.54,
    "endTime": 155.76,
    "text": "B, I have to be B."
  },
  {
    "startTime": 155.8,
    "endTime": 157.42000000000002,
    "text": "OK, so what's your blood type?"
  },
  {
    "startTime": 157.43,
    "endTime": 160.20000000000002,
    "text": "Mogyao, what's your blood type?"
  },
  {
    "startTime": 160.2,
    "endTime": 162.06,
    "text": "OK, good to know."
  },
  {
    "startTime": 162.1,
