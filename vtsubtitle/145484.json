    "text": "Let's see if it is true."
  },
  {
    "startTime": 164.7,
    "endTime": 170.66,
    "text": "It's your lucky day because we've organized to have your blood type analyzed."
  },
  {
    "startTime": 170.66,
    "endTime": 175.34,
    "text": "Nothing serious, we're just gonna head off to the blood donation center and we're going to suck your blood out for about an hour."
  },
  {
    "startTime": 176.3,
    "endTime": 176.8,
    "text": "Is that cool?"
  },
  {
    "startTime": 178.16,
    "endTime": 178.98,
    "text": "Let's go find out then."
  },
  {
    "startTime": 178.98,
    "endTime": 179.48,
    "text": "Yeah."
  },
  {
    "startTime": 179.48,
    "endTime": 179.98,
    "text": "Cool."
  },
  {
    "startTime": 202.28,
    "endTime": 204.0,
    "text": "So how did you find the experience?"
