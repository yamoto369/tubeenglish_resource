  },
  {
    "startTime": 247.5,
    "endTime": 248.5,
    "text": "What's option B?"
  },
  {
    "startTime": 248.5,
    "endTime": 251.5,
    "text": "I back off Romero, never find out where the drugs are."
  },
  {
    "startTime": 251.5,
    "endTime": 252.5,
