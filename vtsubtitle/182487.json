  {
    "startTime": 190.5,
    "endTime": 191.5,
    "text": "We've been worried sick."
  },
  {
    "startTime": 191.5,
    "endTime": 193.5,
    "text": "Do you care to explain yourself?"
  },
  {
    "startTime": 193.5,
    "endTime": 194.5,
    "text": "I'm just 70 seconds late."
