  {
    "startTime": 86.5,
    "endTime": 88.5,
    "text": "I just got it out of the vent to rub it in your faces."
  },
  {
    "startTime": 88.5,
    "endTime": 89.5,
    "text": "Name of your sex tape."
  },
  {
    "startTime": 89.5,
