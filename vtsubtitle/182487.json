  },
  {
    "startTime": 44.6,
    "endTime": 45.6,
    "text": "He's white as a sheet."
  },
  {
    "startTime": 46.0,
    "endTime": 47.3,
    "text": "And he says to me, I'll never forget what he said."
  },
  {
    "startTime": 47.7,
    "endTime": 50.7,
