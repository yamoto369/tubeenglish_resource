  {
    "startTime": 98.0,
    "endTime": 99.5,
    "text": "Title of your sex tape."
  },
  {
    "startTime": 99.5,
    "endTime": 101.0,
    "text": "What do you have to say for yourself?"
  },
  {
    "startTime": 101.0,
    "endTime": 105.0,
    "text": "The whole NYPD knows where you are and they're coming for you right now."
  },
  {
    "startTime": 105.0,
    "endTime": 106.5,
    "text": "Okay, thanks for the tip."
  },
  {
    "startTime": 106.5,
    "endTime": 108.5,
    "text": "Let's kill them both, get out of here before the cops come."
