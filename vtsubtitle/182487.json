  },
  {
    "startTime": 8.5,
    "endTime": 10.0,
    "text": "Why you cutting me out of the operation?"
  },
  {
    "startTime": 10.0,
    "endTime": 11.5,
    "text": "What? That's crazy."
  },
  {
    "startTime": 11.5,
    "endTime": 15.0,
    "text": "Boyle, come in here and stand in front of my body and tell him that's crazy."
