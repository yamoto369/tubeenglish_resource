  },
  {
    "startTime": 109.5,
    "endTime": 110.5,
    "text": "I was lying about the backup."
  },
  {
    "startTime": 110.5,
    "endTime": 111.5,
    "text": "I came alone."
  },
  {
    "startTime": 111.5,
    "endTime": 112.5,
    "text": "Title of my sex tape."
  },
  {
    "startTime": 112.5,
    "endTime": 113.5,
    "text": "Dress is out-of-towners."
  },
  {
    "startTime": 113.5,
    "endTime": 115.0,
    "text": "Hope the perp picks us up."
  },
  {
    "startTime": 115.0,
    "endTime": 116.0,
    "text": "Don't worry, Sarge."
  },
  {
    "startTime": 116.0,
    "endTime": 117.0,
    "text": "We'll nail this guy."
  },
  {
    "startTime": 118.5,
    "endTime": 119.5,
    "text": "Grand Theft Auto."
  },
  {
    "startTime": 119.5,
    "endTime": 120.5,
    "text": "Grand Theft Auto."
  },
  {
    "startTime": 120.5,
    "endTime": 121.5,
    "text": "Dog fraud."
  },
  {
    "startTime": 121.5,
    "endTime": 123.5,
    "text": "I saw the guy fake Pekingese."
  },
  {
    "startTime": 123.5,
    "endTime": 124.5,
    "text": "T'was a cat."
  },
  {
    "startTime": 124.5,
    "endTime": 127.5,
    "text": "You will not win me over with your use of t'was."
  },
  {
    "startTime": 127.5,
    "endTime": 128.5,
    "text": "T'wasn't trying to."
  },
  {
    "startTime": 128.5,
    "endTime": 130.5,
    "text": "No, no, no."
  },
  {
    "startTime": 130.5,
    "endTime": 131.5,
    "text": "I know why you're so upset, man."
  },
  {
    "startTime": 131.5,
    "endTime": 134.5,
    "text": "I'm the one who had to come to this backwater stinkhole."
  },
  {
    "startTime": 134.5,
    "endTime": 135.5,
    "text": "What's up, little man?"
  },
  {
    "startTime": 135.5,
    "endTime": 136.5,
    "text": "What's up?"
  },
  {
    "startTime": 136.5,
    "endTime": 137.5,
    "text": "You feeling sexy, huh?"
  },
  {
    "startTime": 137.5,
