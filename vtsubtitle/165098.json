  },
  {
    "startTime": 35.33,
    "endTime": 37.769999999999996,
    "text": "Scissors cuts paper, paper covers rock, rock crushes lizard, lizard poisons Spock,"
  },
  {
    "startTime": 40.51,
    "endTime": 43.29,
    "text": "Spock smashes scissors, scissors decapitates lizard, lizard eats paper, paper disproves Spock,"
  },
  {
    "startTime": 45.65,
    "endTime": 52.8,
    "text": "Spock vaporizes rock, and as it always has, rock crushes scissors."
  },
  {
    "startTime": 53.0,
    "endTime": 55.465,
    "text": "Okay. I think I got it."
  },
  {
