    "endTime": 21.33,
    "text": "My name is Sarah Connor."
  },
  {
    "startTime": 23.66,
    "endTime": 31.169,
    "text": "August 29th, 1997 was supposed to be Judgment Day."
  },
  {
    "startTime": 34.55,
    "endTime": 36.47,
    "text": "But I changed the future."
  },
  {
