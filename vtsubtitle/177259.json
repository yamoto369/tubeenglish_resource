[
  {
    "startTime": 0.0,
    "endTime": 2.3,
    "text": "Three, two, one!"
  },
  {
    "startTime": 2.6,
    "endTime": 3.375,
    "text": "Asha!"
  },
  {
    "startTime": 3.375,
    "endTime": 5.042,
    "text": "I'm here! I'm here!"
  },
  {
    "startTime": 5.042,
    "endTime": 7.167,
    "text": "Woo! Just... one second."
  },
  {
    "startTime": 7.167,
    "endTime": 8.6,
    "text": "Let me catch my breath. Haha."
  },
  {
    "startTime": 8.8,
    "endTime": 17.6,
    "text": "Once upon a time, stood Rosas, a most magical kingdom founded by a king with the power to grant wishes."
  },
  {
    "startTime": 17.8,
    "endTime": 20.7,
    "text": "You are their handsomest, most beloved king."
  },
  {
    "startTime": 20.9,
    "endTime": 23.041999999999998,
    "text": "You're right. I am a handsome king."
  },
  {
    "startTime": 24.167,
    "endTime": 26.400000000000002,
    "text": "I'm so nervous, I think I'm going to explode."
  },
  {
    "startTime": 26.6,
    "endTime": 28.700000000000003,
    "text": "My best friend, the King's apprentice."
  },
  {
    "startTime": 28.9,
    "endTime": 30.083,
    "text": "Is my mouth drooping?"
  },
  {
    "startTime": 30.083,
    "endTime": 32.8,
    "text": "I feel like it's drooping."
  },
  {
    "startTime": 33.0,
    "endTime": 34.292,
    "text": "Asha, come with me."
  },
  {
    "startTime": 34.292,
    "endTime": 36.125,
    "text": "The wishes of Rosas."
  },
  {
    "startTime": 36.125,
    "endTime": 36.9,
    "text": "Whoa."
  },
  {
    "startTime": 37.1,
    "endTime": 41.9,
    "text": "People give their wishes to me, and I grant the wishes I am sure are good for Rosas."
  },
  {
    "startTime": 42.1,
    "endTime": 43.7,
    "text": "Some of these will never be granted?"
  },
  {
    "startTime": 43.9,
    "endTime": 45.8,
    "text": "Not some, most."
  },
  {
    "startTime": 46.0,
    "endTime": 47.4,
    "text": "They deserve more than-"
  },
  {
    "startTime": 47.7,
    "endTime": 51.900000000000006,
    "text": "I decide what everyone deserves!"
  },
  {
    "startTime": 52.1,
    "endTime": 56.0,
    "text": "♫ So I look up at the stars to guide me ♫"
  },
  {
    "startTime": 56.0,
    "endTime": 57.083,
    "text": "I wish..."
  },
  {
    "startTime": 57.4,
    "endTime": 63.9,
    "text": "♫ And throw caution to every warning sign ♫"
  },
  {
    "startTime": 64.1,
    "endTime": 66.125,
    "text": "Oh, you spoil us with your magic."
  },
  {
    "startTime": 66.3,
    "endTime": 67.292,
    "text": "I didn't do it."
  },
  {
    "startTime": 67.292,
    "endTime": 70.375,
    "text": "What?"
  },
  {
    "startTime": 70.375,
    "endTime": 73.375,
    "text": "Last night, I made a wish, on a star."
  },
  {
    "startTime": 74.375,
    "endTime": 77.334,
    "text": "And the star answered."
  },
  {
    "startTime": 84.209,
    "endTime": 86.5,
    "text": "I'm talking. I am talking. Ha!"
  },
  {
    "startTime": 86.7,
    "endTime": 89.083,
    "text": "Who knew my voice would be this low?"
  },
  {
    "startTime": 89.1,
    "endTime": 91.04199999999999,
    "text": "I believe I have just been threatened."
  },
  {
    "startTime": 91.2,
    "endTime": 92.5,
    "text": "Who would dare threaten you?"
  },
  {
    "startTime": 92.6,
    "endTime": 93.8,
    "text": "Wah! Huh! Yuh! Yah!"
  },
  {
    "startTime": 94.0,
    "endTime": 96.8,
    "text": "I have no response to that."
  },
  {
    "startTime": 97.0,
    "endTime": 99.125,
    "text": "There is a traitor amongst us."
  },
  {
    "startTime": 99.125,
    "endTime": 101.8,
    "text": "Find Asha!"
  },
  {
    "startTime": 102.0,
    "endTime": 102.6,
    "text": "It's a dead end."
  },
  {
    "startTime": 102.8,
    "endTime": 105.834,
    "text": "With unsanded mahogany."
  },
  {
    "startTime": 105.3,
    "endTime": 106.375,
    "text": "Heh... ah!"
  },
  {
    "startTime": 106.375,
    "endTime": 108.167,
    "text": "Ooh, good find, Valentino."
  },
  {
    "startTime": 108.167,
    "endTime": 112.417,
    "text": "My butt found it."
  },
  {
    "startTime": 114.5,
    "endTime": 116.042,
    "text": "I started this."
  },
  {
    "startTime": 116.1,
    "endTime": 120.375,
    "text": "I have to finish it."
  },
  {
    "startTime": 123.5,
    "endTime": 127.5,
    "text": "♫ So I make this wish ♫"
  },
  {
    "startTime": 127.7,
    "endTime": 128.3,
    "text": "What are you hiding?"
  },
  {
    "startTime": 128.5,
    "endTime": 129.3,
    "text": "Oh! Nothing!"
  },
  {
    "startTime": 129.5,
    "endTime": 130.2,
    "text": "Life is to be lived!"
  },
  {
    "startTime": 130.4,
    "endTime": 131.4,
    "text": "And nobody."
  },
  {
    "startTime": 131.6,
    "endTime": 133.1,
    "text": "What is going on in there?"
  },
  {
    "startTime": 133.3,
    "endTime": 134.8,
    "text": "Okay, ladies!"
  },
  {
    "startTime": 135.0,
    "endTime": 138.125,
    "text": "Your wings can't fly, but your voices can!"
  }
]