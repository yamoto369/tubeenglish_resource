[
  {
    "startTime": 0.0,
    "endTime": 2.05,
    "text": "Wait, why is there a car coming?"
  },
  {
    "startTime": 2.05,
    "endTime": 3.429,
    "text": "Oh God, we're on the wrong side of the road!"
  },
  {
    "startTime": 3.43,
    "endTime": 4.550000000000001,
    "text": "Oh my God."
  },
  {
    "startTime": 4.55,
    "endTime": 6.545,
    "text": "Oh my God, oh my God, oh my God."
  },
  {
    "startTime": 6.545,
    "endTime": 8.22,
    "text": "8 Struggles of being a Brit in America"
  },
  {
    "startTime": 10.27,
    "endTime": 11.43,
    "text": "Hey, what can I get you guys?"
  },
  {
    "startTime": 11.43,
    "endTime": 12.629,
    "text": "Can we get a glass of water?"
  },
  {
    "startTime": 12.63,
    "endTime": 14.31,
    "text": "Water? - Water."
  },
  {
    "startTime": 14.31,
    "endTime": 15.940000000000001,
    "text": "Hey Steve, do we know a Walter?"
  },
  {
    "startTime": 15.94,
    "endTime": 16.939,
    "text": "Water?"
  },
  {
    "startTime": 16.94,
    "endTime": 19.400000000000002,
    "text": "Oh water. Yeah, sure."
  },
  {
    "startTime": 19.5,
    "endTime": 21.9,
    "text": "You're expected to know all Brits"
  },
  {
    "startTime": 21.9,
    "endTime": 23.45,
    "text": "My friend Sarah lives in England."
  },
  {
    "startTime": 23.45,
    "endTime": 23.854,
    "text": "Do you know her?"
  },
  {
    "startTime": 23.854,
    "endTime": 24.65,
    "text": "Well, England's--"
  },
  {
    "startTime": 24.65,
    "endTime": 25.279,
    "text": "Sarah Patterson."
  },
  {
    "startTime": 25.28,
    "endTime": 26.950000000000003,
    "text": "Well there's 50 million people in England."
  },
  {
    "startTime": 26.95,
    "endTime": 28.41,
    "text": "Ooh, do you know the Queen?"
  },
  {
    "startTime": 28.42,
    "endTime": 31.290000000000003,
    "text": "The geography confuses people"
  },
  {
    "startTime": 31.29,
    "endTime": 32.75,
    "text": "What part of London are you from?"
  },
  {
    "startTime": 32.75,
    "endTime": 34.12,
    "text": "Oh we're not from London."
  },
  {
    "startTime": 34.12,
    "endTime": 36.79,
    "text": "But, you just said you're from England."
  },
  {
    "startTime": 39.59,
    "endTime": 41.13,
    "text": "Is all of England like Harry Potter?"
  },
  {
    "startTime": 41.13,
    "endTime": 41.993,
    "text": "Hogwarts."
  },
  {
    "startTime": 41.993,
    "endTime": 43.5,
    "text": "You're a wizard, Harry!"
  },
  {
    "startTime": 43.5,
    "endTime": 45.63,
    "text": "Expelliarmus! Expelliarmus!"
  },
  {
    "startTime": 45.63,
    "endTime": 47.72,
    "text": "Expelliarmus, Steve!"
  },
  {
    "startTime": 47.73,
    "endTime": 50.51,
    "text": "Everyone assumes you love tea"
  },
  {
    "startTime": 50.51,
    "endTime": 53.059,
    "text": "I figured you would enjoy tea."
  },
  {
    "startTime": 53.06,
    "endTime": 54.34,
    "text": "You're welcome."
  },
  {
    "startTime": 54.35,
    "endTime": 57.19,
    "text": "Accent confusion"
  },
  {
    "startTime": 57.19,
    "endTime": 58.559,
    "text": "Oh, let me give you some room."
  },
  {
    "startTime": 58.56,
    "endTime": 60.0,
    "text": "Oh wow, I love your accent."
  },
  {
    "startTime": 60.0,
    "endTime": 61.69,
    "text": "Oh, thank you."
  },
  {
    "startTime": 61.69,
    "endTime": 63.312,
    "text": "Where in Australia are you from?"
  },
  {
    "startTime": 63.313,
    "endTime": 64.74000000000001,
    "text": "Oh I'm from England."
  },
  {
    "startTime": 64.75,
    "endTime": 67.07,
    "text": "Food assumptions"
  },
  {
    "startTime": 67.07,
    "endTime": 67.74,
    "text": "Can I get--"
  },
  {
    "startTime": 67.74,
    "endTime": 69.16,
    "text": "Let me guess, fish and chips, right?"
  },
  {
    "startTime": 69.16,
    "endTime": 70.119,
    "text": "No, can I--"
  },
  {
    "startTime": 70.12,
    "endTime": 74.83,
    "text": "Well we don't have like mash, or pudding, what else do you guys eat?"
  },
  {
    "startTime": 74.84,
    "endTime": 76.5,
    "text": "But then you remember..."
  },
  {
    "startTime": 76.5,
    "endTime": 78.75,
    "text": "You can be just as bad!"
  },
  {
    "startTime": 78.75,
    "endTime": 79.92,
    "text": "I miss home."
  },
  {
    "startTime": 79.92,
    "endTime": 82.38,
    "text": "I'm just fed up with these stereotypes."
  },
  {
    "startTime": 82.38,
    "endTime": 84.455,
    "text": "I miss home, too."
  },
  {
    "startTime": 84.455,
    "endTime": 87.3,
    "text": "Oh, where are you from, like the East coast or something?"
  },
  {
    "startTime": 87.3,
    "endTime": 89.09,
    "text": "No, I'm from Canada."
  },
  {
    "startTime": 89.09,
    "endTime": 89.97,
    "text": "What?"
  },
  {
    "startTime": 89.97,
    "endTime": 92.24,
    "text": "Oh my God, Canada, eh?"
  },
  {
    "startTime": 92.24,
    "endTime": 93.429,
    "text": "Is it just so cold there?"
  },
  {
    "startTime": 93.43,
    "endTime": 94.27000000000001,
    "text": "Do you play ice hockey all day?"
  },
  {
    "startTime": 94.27,
    "endTime": 95.672,
    "text": "Do you put maple syrup on everything?"
  },
  {
    "startTime": 95.672,
    "endTime": 96.94,
    "text": "Have you got a pet moose?"
  },
  {
    "startTime": 96.94,
    "endTime": 99.056,
    "text": "Expelliarmus! Expelliarmus!"
  }
]