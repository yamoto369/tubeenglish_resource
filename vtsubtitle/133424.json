[
  {
    "startTime": 1.75,
    "endTime": 3.5,
    "text": "Jake, my boyfriend."
  },
  {
    "startTime": 4.167,
    "endTime": 5.0,
    "text": "It's snowing."
  },
  {
    "startTime": 5.083,
    "endTime": 6.542,
    "text": "Winter is coming in!"
  },
  {
    "startTime": 7.875,
    "endTime": 9.625,
    "text": "We have a real connection."
  },
  {
    "startTime": 10.083,
    "endTime": 12.375,
    "text": "A rare and intense attachment."
  },
  {
    "startTime": 13.625,
    "endTime": 15.5,
    "text": "I've never experienced anything like it."
  },
  {
    "startTime": 17.125,
    "endTime": 18.708,
    "text": "I'm thinking of ending things."
  },
  {
    "startTime": 19.792,
    "endTime": 21.542,
    "text": "-What? -Did you say something?"
  },
  {
    "startTime": 21.625,
    "endTime": 22.833,
    "text": "I don't think so."
  },
  {
    "startTime": 23.125,
    "endTime": 23.958,
    "text": "Weird."
  },
  {
    "startTime": 26.333,
    "endTime": 28.5,
    "text": "I'm visiting Jake's parents for the first time."
  },
  {
    "startTime": 28.625,
    "endTime": 30.333,
    "text": "He hasn't been my boyfriend very long."
  },
  {
    "startTime": 30.417,
    "endTime": 33.042,
    "text": "They really are looking forward to meeting you."
  },
  {
    "startTime": 33.542,
    "endTime": 34.917,
    "text": "I'm thinking of ending things."
  },
  {
    "startTime": 35.625,
    "endTime": 37.292,
    "text": "Hello? We're here."
  },
  {
    "startTime": 38.167,
    "endTime": 39.333,
    "text": "Hi!"
  },
  {
    "startTime": 41.042,
    "endTime": 42.208,
    "text": "He's all wet."
  },
  {
    "startTime": 50.042,
    "endTime": 51.167,
    "text": "Here they come."
  },
  {
    "startTime": 51.25,
    "endTime": 53.958,
    "text": "Jake has told us so much about you."
  },
  {
    "startTime": 54.042,
    "endTime": 56.25,
    "text": "He's told me so much about both of you too."
  },
  {
    "startTime": 56.333,
    "endTime": 57.667,
    "text": "And you came anyway?"
  },
  {
    "startTime": 61.25,
    "endTime": 64.5,
    "text": "Jake tells me you're studying quantum psychics."
  },
  {
    "startTime": 65.875,
    "endTime": 67.333,
    "text": "-Physics. -Really?"
  },
  {
    "startTime": 68.333,
    "endTime": 71.25,
    "text": "There's just something profoundly wrong here."
  },
  {
    "startTime": 71.333,
    "endTime": 72.25,
    "text": "Are you okay?"
  },
  {
    "startTime": 72.667,
    "endTime": 73.5,
    "text": "Yeah."
  },
  {
    "startTime": 73.583,
    "endTime": 74.75,
    "text": "I'm thinking of ending things."
  },
  {
    "startTime": 74.833,
    "endTime": 78.417,
    "text": "I am so glad Jake has found someone."
  },
  {
    "startTime": 83.042,
    "endTime": 84.875,
    "text": "Soon, this will all be a distant memory."
  },
  {
    "startTime": 86.208,
    "endTime": 87.167,
    "text": "Who is this?"
  },
  {
    "startTime": 87.25,
    "endTime": 88.167,
    "text": "That's me."
  },
  {
    "startTime": 88.708,
    "endTime": 90.042,
    "text": "No, it was me."
  },
  {
    "startTime": 90.125,
    "endTime": 91.333,
    "text": "I tell you,"
  },
  {
    "startTime": 91.417,
    "endTime": 92.792,
    "text": "I would misplace my own head"
  },
  {
    "startTime": 92.875,
    "endTime": 94.583,
    "text": "if it wasn't screwed onto my own head."
  },
  {
    "startTime": 94.667,
    "endTime": 96.917,
    "text": "I feel like I was seeing them as they were,"
  },
  {
    "startTime": 97.0,
    "endTime": 98.583,
    "text": "seeing them as they will be,"
  },
  {
    "startTime": 98.667,
    "endTime": 100.583,
    "text": "seeing them after they're gone."
  },
  {
    "startTime": 100.667,
    "endTime": 102.375,
    "text": "-I'm thinking of ending things. -Stay here."
  },
  {
    "startTime": 104.625,
    "endTime": 105.458,
    "text": "Excuse me?"
  },
  {
    "startTime": 105.917,
    "endTime": 106.917,
    "text": "You don't have to go."
  },
  {
    "startTime": 107.0,
    "endTime": 108.125,
    "text": "I don't have to go where?"
  },
  {
    "startTime": 108.25,
    "endTime": 109.083,
    "text": "Forward."
  },
  {
    "startTime": 112.125,
    "endTime": 114.5,
    "text": "People like to think of themselves as points"
  },
  {
    "startTime": 114.583,
    "endTime": 115.5,
    "text": "moving through time."
  },
  {
    "startTime": 116.667,
    "endTime": 118.333,
    "text": "But I think it's the opposite."
  },
  {
    "startTime": 120.0,
    "endTime": 121.5,
    "text": "We're stationary,"
  },
  {
    "startTime": 122.5,
    "endTime": 123.583,
    "text": "and time..."
  },
  {
    "startTime": 124.417,
    "endTime": 125.625,
    "text": "passes through us..."
  },
  {
    "startTime": 127.792,
    "endTime": 129.292,
    "text": "blowing like cold wind."
  },
  {
    "startTime": 134.417,
    "endTime": 137.042,
    "text": "Maybe this is how it was always going to end."
  }
]