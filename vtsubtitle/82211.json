[
  {
    "startTime": 3.57,
    "endTime": 4.859,
    "text": "Hello."
  },
  {
    "startTime": 4.86,
    "endTime": 6.7010000000000005,
    "text": "Jasper Johannson, Postman."
  },
  {
    "startTime": 8.267,
    "endTime": 10.972999999999999,
    "text": "Ah, Mr. Klaus, you have a gift."
  },
  {
    "startTime": 11.87,
    "endTime": 15.26,
    "text": "You were meant for making toys."
  },
  {
    "startTime": 15.26,
    "endTime": 20.683,
    "text": "So I figured, if you donate your old toys, I'll deliver them for free."
  },
  {
    "startTime": 25.19,
    "endTime": 26.69,
    "text": "Tonight, I go with you."
  },
  {
    "startTime": 26.69,
    "endTime": 28.443,
    "text": "There's no need for you to come with me, really."
  },
  {
    "startTime": 29.43,
    "endTime": 30.498,
    "text": "Tonight then."
  },
  {
    "startTime": 35.45,
    "endTime": 36.283,
    "text": "Oh!"
  },
  {
    "startTime": 36.283,
    "endTime": 42.206,
    "text": "Our cousin told us if we write a letter to Mr. Klaus, he'll make us a toy."
  },
  {
    "startTime": 43.75,
    "endTime": 45.02,
    "text": "Dear Mr. Klaus."
  },
  {
    "startTime": 45.02,
    "endTime": 46.870000000000005,
    "text": "Dear Mr. Klaus."
  },
  {
    "startTime": 46.87,
    "endTime": 47.73,
    "text": "Shall we, then?"
  },
  {
    "startTime": 47.73,
    "endTime": 48.782,
    "text": "Yep!"
  },
  {
    "startTime": 49.616,
    "endTime": 51.5,
    "text": "Mr. Klaus is the coolest!"
  },
  {
    "startTime": 51.5,
    "endTime": 53.172,
    "text": "Klaus? What about me?"
  },
  {
    "startTime": 53.172,
    "endTime": 54.803,
    "text": "Ow!"
  },
  {
    "startTime": 54.4,
    "endTime": 55.0,
    "text": "What the - ?"
  },
  {
    "startTime": 55.0,
    "endTime": 55.5,
    "text": "Loser!"
  },
  {
    "startTime": 55.5,
    "endTime": 59.55,
    "text": "Oh, yeah, well if I'm a loser, then you - you're a - you're a uh -"
  },
  {
    "startTime": 59.55,
    "endTime": 61.282,
    "text": "Oh, you're too far, you're gone."
  },
  {
    "startTime": 62.53,
    "endTime": 64.29,
    "text": "Hey, what do you guys think you're doing?!"
  },
  {
    "startTime": 64.29,
    "endTime": 67.123,
    "text": "This is Smearinsberg, the unhappiest place on Earth."
  },
  {
    "startTime": 68.37,
    "endTime": 70.113,
    "text": "And you two can't change that."
  },
  {
    "startTime": 72.56,
    "endTime": 76.813,
    "text": "The Postman and Toymaker are brainwashing everyone!"
  },
  {
    "startTime": 78.04,
    "endTime": 83.71000000000001,
    "text": "We need to show people that a true selfless act always sparks another."
  },
  {
    "startTime": 83.71,
    "endTime": 85.53899999999999,
    "text": "Hi! What's happening right now?"
  },
  {
    "startTime": 85.54,
    "endTime": 86.69000000000001,
    "text": "Oh no..."
  },
  {
    "startTime": 86.69,
    "endTime": 87.527,
    "text": "Holy mother - !"
  },
  {
    "startTime": 89.54,
    "endTime": 90.0,
    "text": "What happened?"
  },
  {
    "startTime": 90.0,
    "endTime": 91.29,
    "text": "Not a word!"
  },
  {
    "startTime": 91.29,
    "endTime": 92.123,
    "text": "You just sit there."
  },
  {
    "startTime": 92.123,
    "endTime": 93.85900000000001,
    "text": "Be all magical and awesome."
  },
  {
    "startTime": 93.859,
    "endTime": 96.53,
    "text": "♪ Had to have high, high hopes for a living ♪"
  },
  {
    "startTime": 96.531,
    "endTime": 99.47800000000001,
    "text": "♪ Shooting for the stars when I couldn't make a killing ♪"
  },
  {
    "startTime": 99.478,
    "endTime": 101.8,
    "text": "♪ Didn't have a dime but I always had a vision ♪"
  },
  {
    "startTime": 101.8,
    "endTime": 103.66,
    "text": "Jasper! We're doing it!"
  },
  {
    "startTime": 103.66,
    "endTime": 104.493,
    "text": "Let's go!"
  },
  {
    "startTime": 105.813,
    "endTime": 106.646,
    "text": "Ho, ho, ho!"
  },
  {
    "startTime": 108.08,
    "endTime": 109.637,
    "text": "Wait, wait, wait, time out. Really?"
  },
  {
    "startTime": 109.637,
    "endTime": 111.319,
    "text": "That's how you laugh?"
  },
  {
    "startTime": 111.319,
    "endTime": 113.236,
    "text": "♪ High, high hopes for a living ♪"
  },
  {
    "startTime": 113.236,
    "endTime": 116.159,
    "text": "♪ Didn't know how but I always had a feeling ♪"
  },
  {
    "startTime": 116.159,
    "endTime": 119.51,
    "text": "♪ I was gonna be that one in a million ♪"
  },
  {
    "startTime": 119.51,
    "endTime": 120.0,
    "text": "Come on, we're running out of time!"
  },
  {
    "startTime": 120.8,
    "endTime": 122.8,
    "text": "Those kids are counting on us!"
  },
  {
    "startTime": 122.8,
    "endTime": 127.13,
    "text": "If we don't stop them tonight, this town will never be the same!"
  },
  {
    "startTime": 127.13,
    "endTime": 128.874,
    "text": "Destroy those toys!"
  },
  {
    "startTime": 128.874,
    "endTime": 130.75199999999998,
    "text": "No, no, no, no, no! No!"
  },
  {
    "startTime": 133.586,
    "endTime": 135.9,
    "text": "Ha! Eat our snow, you - !"
  },
  {
    "startTime": 135.9,
    "endTime": 136.3,
    "text": "They're not attached."
  },
  {
    "startTime": 136.3,
    "endTime": 137.67000000000002,
    "text": "Why aren't they attached?"
  },
  {
    "startTime": 137.67,
    "endTime": 138.88,
    "text": "I thought they were attached."
  },
  {
    "startTime": 138.88,
    "endTime": 143.721,
    "text": "I would never in a million years have done what I just did if I didn't think these were attached."
  },
  {
    "startTime": 143.721,
    "endTime": 148.721,
    "text": "♪ Always had high, high hopes ♪"
  }
]