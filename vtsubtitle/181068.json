[
  {
    "startTime": 0.0,
    "endTime": 3.0,
    "text": "Well, without further ado, I give you Crowbar Jones."
  },
  {
    "startTime": 5.0,
    "endTime": 5.0,
    "text": "Boop."
  },
  {
    "startTime": 6.0,
    "endTime": 6.0,
    "text": "Boop."
  },
  {
    "startTime": 7.0,
    "endTime": 8.0,
    "text": "Boop."
  },
  {
    "startTime": 8.0,
    "endTime": 10.0,
    "text": "Crowbar Jones!"
  },
  {
    "startTime": 11.0,
    "endTime": 13.0,
    "text": "Who's the bear that won't let you drown?"
  },
  {
    "startTime": 13.0,
    "endTime": 14.0,
    "text": "Crowbar Jones!"
  },
  {
    "startTime": 15.0,
    "endTime": 16.0,
    "text": "Ghost problem?"
  },
  {
    "startTime": 16.0,
    "endTime": 18.0,
    "text": "How about no problem?"
  },
  {
    "startTime": 18.0,
    "endTime": 20.0,
    "text": "There's Crowbar Jones!"
  },
  {
    "startTime": 22.0,
    "endTime": 26.0,
    "text": "Welcome to jail, Dr. Destructo."
  },
  {
    "startTime": 26.0,
    "endTime": 30.0,
    "text": "Hope you brought a book, because you're gonna be here for a hundred years."
  },
  {
    "startTime": 31.0,
    "endTime": 33.0,
    "text": "Dr. Destructo will see you again very soon."
  },
  {
    "startTime": 34.0,
    "endTime": 37.0,
    "text": "Great work."
  },
  {
    "startTime": 37.0,
    "endTime": 38.0,
    "text": "Ah, thank you, Captain."
  },
  {
    "startTime": 38.0,
    "endTime": 41.0,
    "text": "If you keep this up, you will put everyone out of a job."
  },
  {
    "startTime": 41.0,
    "endTime": 45.0,
    "text": "I may be a rookie cop, but I am hungry for justice."
  },
  {
    "startTime": 45.0,
    "endTime": 47.0,
    "text": "A couple of the guys are going to Ice Cream Bar."
  },
  {
    "startTime": 47.0,
    "endTime": 48.0,
    "text": "What does rookie say?"
  },
  {
    "startTime": 48.0,
    "endTime": 51.0,
    "text": "I wish I could go, but I got three things waiting for me back home."
  },
  {
    "startTime": 51.0,
    "endTime": 54.0,
    "text": "My supermodel girlfriend, a delicious dinner, and my sweet guitar."
  },
  {
    "startTime": 56.0,
    "endTime": 58.0,
    "text": "Sweetie, I'm home."
  },
  {
    "startTime": 58.0,
    "endTime": 60.0,
    "text": "No girlfriend?"
  },
  {
    "startTime": 61.0,
    "endTime": 61.0,
    "text": "No dinner?"
  },
  {
    "startTime": 62.0,
    "endTime": 63.0,
    "text": "My tunes!"
  },
  {
    "startTime": 63.0,
    "endTime": 63.0,
    "text": "What?"
  },
  {
    "startTime": 63.0,
    "endTime": 64.0,
    "text": "No!"
  },
  {
    "startTime": 65.0,
    "endTime": 65.0,
    "text": "Huh?"
  },
  {
    "startTime": 66.0,
    "endTime": 67.0,
    "text": "A left sock?"
  },
  {
    "startTime": 68.0,
    "endTime": 72.0,
    "text": "Dr. Destructo told your girlfriend to leave, ate your dinner, and hates your guitar."
  },
  {
    "startTime": 72.0,
    "endTime": 73.0,
    "text": "Sorry, not sorry."
  },
  {
    "startTime": 73.0,
    "endTime": 74.0,
    "text": "No!"
  },
  {
    "startTime": 75.0,
    "endTime": 78.0,
    "text": "I've never been so upset in my entire life."
  },
  {
    "startTime": 78.0,
    "endTime": 79.0,
    "text": "I've lost everything."
  },
  {
    "startTime": 79.0,
    "endTime": 81.0,
    "text": "Ice Waiter thinks you've had enough apple juice."
  },
  {
    "startTime": 81.0,
    "endTime": 83.0,
    "text": "I'll tell you when I've had enough apple juice!"
  },
  {
    "startTime": 85.0,
    "endTime": 88.0,
    "text": "But then something changed my life."
  },
  {
    "startTime": 89.0,
    "endTime": 90.0,
    "text": "Joining the Super Spy Program."
  },
  {
    "startTime": 90.0,
    "endTime": 91.0,
    "text": "Requirements?"
  },
  {
    "startTime": 92.0,
    "endTime": 93.0,
    "text": "Having lost everything."
  },
  {
    "startTime": 95.0,
    "endTime": 96.0,
    "text": "Captain?"
  },
  {
    "startTime": 97.0,
    "endTime": 100.0,
    "text": "I want to join the Super Spy Program."
  },
  {
    "startTime": 101.0,
    "endTime": 102.0,
    "text": "Okay, why not?"
  },
  {
    "startTime": 104.0,
    "endTime": 104.0,
    "text": "Huh?"
  },
  {
    "startTime": 104.0,
    "endTime": 105.0,
    "text": "What is this?"
  },
  {
    "startTime": 106.0,
    "endTime": 107.0,
    "text": "The process begins."
  },
  {
    "startTime": 108.0,
    "endTime": 109.0,
    "text": "Combining new DNA."
  },
  {
    "startTime": 110.0,
    "endTime": 113.0,
    "text": "Strength of tiger."
  },
  {
    "startTime": 114.0,
    "endTime": 114.0,
    "text": "Eyes of eagle."
  },
  {
    "startTime": 115.0,
    "endTime": 121.0,
    "text": "Brain of frog."
  },
  {
    "startTime": 122.0,
    "endTime": 134.0,
    "text": "Congratulations."
  },
  {
    "startTime": 135.0,
    "endTime": 140.0,
    "text": "I won't rest until the city is safe again from the clutches of Dr. Destructo."
  },
  {
    "startTime": 141.0,
    "endTime": 141.0,
    "text": "Hooray."
  },
  {
    "startTime": 141.0,
    "endTime": 143.0,
    "text": "Crowbar Jones and partner will do great out there."
  },
  {
    "startTime": 143.0,
    "endTime": 144.0,
    "text": "Wait, partner?"
  },
  {
    "startTime": 145.0,
    "endTime": 145.0,
    "text": "Huh?"
  },
  {
    "startTime": 146.0,
    "endTime": 149.0,
    "text": "Sorry I'm late, Captain."
  },
  {
    "startTime": 149.0,
    "endTime": 151.0,
    "text": "I got locked inside the bathroom again."
  },
  {
    "startTime": 152.0,
    "endTime": 152.0,
    "text": "No way."
  },
  {
    "startTime": 152.0,
    "endTime": 153.0,
    "text": "I work alone!"
  },
  {
    "startTime": 153.0,
    "endTime": 156.0,
    "text": "I don't need Rando over here slowing me down!"
  },
  {
    "startTime": 156.0,
    "endTime": 159.0,
    "text": "First of all, my name is Pando, and I also work alone."
  },
  {
    "startTime": 159.0,
    "endTime": 160.0,
    "text": "Ice Cop likes Pando."
  },
  {
    "startTime": 161.0,
    "endTime": 162.0,
    "text": "Ice Cop likes Jones."
  },
  {
    "startTime": 162.0,
    "endTime": 164.0,
    "text": "Ice Cop loves togetherness."
  },
  {
    "startTime": 165.0,
    "endTime": 167.0,
    "text": "Remember, with great power comes great car."
  },
  {
    "startTime": 168.0,
    "endTime": 169.0,
    "text": "I'll drive!"
  },
  {
    "startTime": 169.0,
    "endTime": 169.0,
    "text": "What?"
  },
  {
    "startTime": 169.0,
    "endTime": 170.0,
    "text": "No!"
  },
  {
    "startTime": 170.0,
    "endTime": 171.0,
    "text": "I'm the cool one!"
  },
  {
    "startTime": 171.0,
    "endTime": 174.0,
    "text": "Oh boy, I can't wait to drive at a safe speed in this baby."
  },
  {
    "startTime": 174.0,
    "endTime": 176.0,
    "text": "But first..."
  },
  {
    "startTime": 176.0,
    "endTime": 178.0,
    "text": "Want some water?"
  },
  {
    "startTime": 178.0,
    "endTime": 181.0,
    "text": "I always try to stay hydrated before every mission."
  },
  {
    "startTime": 181.0,
    "endTime": 184.0,
    "text": "There's only one thing that can quench my thirst right now."
  },
  {
    "startTime": 185.0,
    "endTime": 186.0,
    "text": "Revenge."
  },
  {
    "startTime": 188.0,
    "endTime": 188.0,
    "text": "Aha!"
  },
  {
    "startTime": 189.0,
    "endTime": 190.0,
    "text": "Dr. Destructo's secret lair."
  },
  {
    "startTime": 190.0,
    "endTime": 191.0,
    "text": "Great."
  },
  {
    "startTime": 191.0,
    "endTime": 194.0,
    "text": "How are we going to get to the elevator without being detected by Destructo's army?"
  },
  {
    "startTime": 195.0,
    "endTime": 198.0,
    "text": "Who said anything about elevators, champ?"
  },
  {
    "startTime": 198.0,
    "endTime": 204.0,
    "text": "Hurry up, Pando!"
  },
  {
    "startTime": 204.0,
    "endTime": 205.0,
    "text": "I'm coming!"
  },
  {
    "startTime": 205.0,
    "endTime": 205.0,
    "text": "I'm coming!"
  },
  {
    "startTime": 206.0,
    "endTime": 207.0,
    "text": "Good thing I brought my grappling hook."
  },
  {
    "startTime": 208.0,
    "endTime": 214.0,
    "text": "Made it."
  },
  {
    "startTime": 214.0,
    "endTime": 215.0,
    "text": "Can I get a hand?"
  },
  {
    "startTime": 215.0,
    "endTime": 216.0,
    "text": "Fine, I guess."
  },
  {
    "startTime": 217.0,
    "endTime": 217.0,
    "text": "Thanks."
  },
  {
    "startTime": 217.0,
    "endTime": 222.0,
    "text": "So I was thinking, now we can find where he keeps his supercomputer and then download the computer virus."
  },
  {
    "startTime": 222.0,
    "endTime": 223.0,
    "text": "Cool, right?"
  },
  {
    "startTime": 224.0,
    "endTime": 226.0,
    "text": "Not as cool as my fists!"
  },
  {
    "startTime": 226.0,
    "endTime": 227.0,
    "text": "That's a horrible idea."
  },
  {
    "startTime": 227.0,
    "endTime": 228.0,
    "text": "Mine is the better way."
  },
  {
    "startTime": 228.0,
    "endTime": 230.0,
    "text": "Nothing is better than my fists!"
  },
  {
    "startTime": 230.0,
    "endTime": 231.0,
    "text": "So you have arrived."
  },
  {
    "startTime": 231.0,
    "endTime": 235.0,
    "text": "Dr. Destructo welcomes you both to your doom."
  },
  {
    "startTime": 236.0,
    "endTime": 236.0,
    "text": "Pando!"
  },
  {
    "startTime": 236.0,
    "endTime": 237.0,
    "text": "No!"
  },
  {
    "startTime": 237.0,
    "endTime": 237.0,
    "text": "Stop!"
  },
  {
    "startTime": 238.0,
    "endTime": 239.0,
    "text": "Let go of me, you tin can!"
  },
  {
    "startTime": 239.0,
    "endTime": 240.0,
    "text": "Oh no!"
  },
  {
    "startTime": 240.0,
    "endTime": 241.0,
    "text": "What do I do?"
  },
  {
    "startTime": 245.0,
    "endTime": 246.0,
    "text": "You okay, Pando?"
  },
  {
    "startTime": 246.0,
    "endTime": 247.0,
    "text": "Wow!"
  },
  {
    "startTime": 247.0,
    "endTime": 248.0,
    "text": "That was amazing!"
  },
  {
    "startTime": 248.0,
    "endTime": 249.0,
    "text": "Thank you for saving me!"
  },
  {
    "startTime": 249.0,
    "endTime": 251.0,
    "text": "All in a day's work."
  },
  {
    "startTime": 251.0,
    "endTime": 252.0,
    "text": "Behind you!"
  },
  {
    "startTime": 253.0,
    "endTime": 257.0,
    "text": "My system is now functioning without global malfunction."
  },
  {
    "startTime": 259.0,
    "endTime": 261.0,
    "text": "Dr. Destructo was a robot?"
  },
  {
    "startTime": 262.0,
    "endTime": 266.0,
    "text": "That'll teach him to mess with me and my trusty partner."
  },
  {
    "startTime": 266.0,
    "endTime": 266.0,
    "text": "Partner?"
  },
  {
    "startTime": 267.0,
    "endTime": 269.0,
    "text": "I like the sound of that, Officer Jones."
  },
  {
    "startTime": 270.0,
    "endTime": 274.0,
    "text": "From now on, Pando, you can call me Robot Jones!"
  },
  {
    "startTime": 276.0,
    "endTime": 277.0,
    "text": "Crowbar Jones!"
  },
  {
    "startTime": 277.0,
    "endTime": 280.0,
    "text": "He's the master of every martial art known to man."
  },
  {
    "startTime": 280.0,
    "endTime": 283.0,
    "text": "He is skilled in the art of stealth."
  },
  {
    "startTime": 284.0,
    "endTime": 287.0,
    "text": "He punched a guy so hard once he sent him to space."
  },
  {
    "startTime": 288.0,
    "endTime": 290.0,
    "text": "He is Crowbar Jones!"
  },
  {
    "startTime": 290.0,
    "endTime": 292.0,
    "text": "Robot snakes!"
  },
  {
    "startTime": 292.0,
    "endTime": 293.0,
    "text": "They're everywhere."
  },
  {
    "startTime": 293.0,
    "endTime": 294.0,
    "text": "I'm gonna need you to break the metal door, Pando."
  },
  {
    "startTime": 295.0,
    "endTime": 296.0,
    "text": "Don't worry."
  },
  {
    "startTime": 296.0,
    "endTime": 298.0,
    "text": "I'll open the metal door with my laser app."
  },
  {
    "startTime": 299.0,
    "endTime": 299.0,
    "text": "Oh no!"
  },
  {
    "startTime": 300.0,
    "endTime": 300.0,
    "text": "What's wrong, Pando?"
  },
  {
    "startTime": 301.0,
    "endTime": 302.0,
    "text": "Is the laser not working?"
  },
  {
    "startTime": 302.0,
    "endTime": 303.0,
    "text": "Worse."
  },
  {
    "startTime": 303.0,
    "endTime": 306.0,
    "text": "My internet girlfriend just broke up with me."
  },
  {
    "startTime": 306.0,
    "endTime": 307.0,
    "text": "Life is meaningless."
  },
  {
    "startTime": 308.0,
    "endTime": 309.0,
    "text": "Don't worry."
  },
  {
    "startTime": 309.0,
    "endTime": 310.0,
    "text": "I'll break the door."
  },
  {
    "startTime": 310.0,
    "endTime": 311.0,
    "text": "Pow."
  },
  {
    "startTime": 312.0,
    "endTime": 312.0,
    "text": "Come on, Pando."
  },
  {
    "startTime": 313.0,
    "endTime": 314.0,
    "text": "We gotta save the world before it blows up."
  },
  {
    "startTime": 314.0,
    "endTime": 318.0,
    "text": "This hurts a lot, but not as much as a broken heart."
  },
  {
    "startTime": 319.0,
    "endTime": 322.0,
    "text": "We gotta stop them before they blow up the world."
  },
  {
    "startTime": 323.0,
    "endTime": 325.0,
    "text": "We will stop them, but I gotta go to the bathroom."
  },
  {
    "startTime": 326.0,
    "endTime": 326.0,
    "text": "Don't worry."
  },
  {
    "startTime": 326.0,
    "endTime": 327.0,
    "text": "It won't take too long."
  },
  {
    "startTime": 329.0,
    "endTime": 331.0,
    "text": "Ah, much better."
  },
  {
    "startTime": 331.0,
    "endTime": 333.0,
    "text": "Now let's get those evildoers."
  },
  {
    "startTime": 333.0,
    "endTime": 334.0,
    "text": "Crowbar Jones?"
  },
  {
    "startTime": 334.0,
    "endTime": 335.0,
    "text": "Oh, Pando."
  },
  {
    "startTime": 336.0,
    "endTime": 339.0,
    "text": "It's been 40 years since I last saw you."
  },
  {
    "startTime": 339.0,
    "endTime": 342.0,
    "text": "In a city consumed by crime..."
  },
  {
    "startTime": 342.0,
    "endTime": 343.0,
    "text": "Ah, help!"
  },
  {
    "startTime": 343.0,
    "endTime": 346.0,
    "text": "Only one bear has the power to bring order to chaos."
  },
  {
    "startTime": 347.0,
    "endTime": 347.0,
    "text": "Ah-yah!"
  },
  {
    "startTime": 347.0,
    "endTime": 349.0,
    "text": "Crowbar Jones!"
  },
  {
    "startTime": 350.0,
    "endTime": 351.0,
    "text": "Bear-tropolis."
  },
  {
    "startTime": 352.0,
    "endTime": 353.0,
    "text": "The year's 2034."
  },
  {
    "startTime": 354.0,
    "endTime": 356.0,
    "text": "Crime is running rampant through the streets."
  },
  {
    "startTime": 356.0,
    "endTime": 359.0,
    "text": "But what crime wasn't expecting was..."
  },
  {
    "startTime": 359.0,
    "endTime": 360.0,
    "text": "Crowbar Jones!"
  },
  {
    "startTime": 361.0,
    "endTime": 361.0,
    "text": "Ah-yah!"
  },
  {
    "startTime": 362.0,
    "endTime": 364.0,
    "text": "Congratulations, Crowbar Jones!"
  },
  {
    "startTime": 364.0,
    "endTime": 366.0,
    "text": "You've done it again!"
  },
  {
    "startTime": 366.0,
    "endTime": 369.0,
    "text": "Now the world is a safer place because of you, Chip-Chip Cheerio."
  },
  {
    "startTime": 370.0,
    "endTime": 371.0,
    "text": "I'm just doing my job, sir."
  },
  {
    "startTime": 372.0,
    "endTime": 376.0,
    "text": "Well, a job well done deserves recognition and a Medal of Awesomeness."
  },
  {
    "startTime": 376.0,
    "endTime": 379.0,
    "text": "Also, your album went platinum while you were saving the world."
  },
  {
    "startTime": 379.0,
    "endTime": 380.0,
    "text": "Ah, stop it."
  },
  {
    "startTime": 380.0,
    "endTime": 380.0,
    "text": "This is too much."
  },
  {
    "startTime": 381.0,
    "endTime": 383.0,
    "text": "I couldn't have done it without my trusty sidekick, Pando."
  },
  {
    "startTime": 383.0,
    "endTime": 385.0,
    "text": "Oh, thank you, Mr. Crowbar."
  },
  {
    "startTime": 386.0,
    "endTime": 388.0,
    "text": "Would either of you like a pickle?"
  },
  {
    "startTime": 388.0,
    "endTime": 391.0,
    "text": "Classic Pando."
  },
  {
    "startTime": 391.0,
    "endTime": 393.0,
    "text": "Ah, you guys are the best."
  },
  {
    "startTime": 393.0,
    "endTime": 396.0,
    "text": "It also makes me want to give you the keys to my Ferrari Turbo."
  },
  {
    "startTime": 396.0,
    "endTime": 398.0,
    "text": "Ah, Mr. President, we just couldn't."
  },
  {
    "startTime": 398.0,
    "endTime": 399.0,
    "text": "Wait a second."
  },
  {
    "startTime": 399.0,
    "endTime": 402.0,
    "text": "President would never give out his Ferrari Turbo to anyone."
  },
  {
    "startTime": 403.0,
    "endTime": 404.0,
    "text": "Who are you?"
  },
  {
    "startTime": 404.0,
    "endTime": 405.0,
    "text": "Where's the real president?"
  },
  {
    "startTime": 405.0,
    "endTime": 407.0,
    "text": "I knew it."
  },
  {
    "startTime": 407.0,
    "endTime": 408.0,
    "text": "A danger bot."
  },
  {
    "startTime": 408.0,
    "endTime": 410.0,
    "text": "What does this mean, Mr. Crowbar?"
  },
  {
    "startTime": 410.0,
    "endTime": 413.0,
    "text": "It means that the president has been kidnapped."
  },
  {
    "startTime": 413.0,
    "endTime": 414.0,
    "text": "Meanwhile, back at the base."
  },
  {
    "startTime": 415.0,
    "endTime": 416.0,
    "text": "Who kidnapped the president?"
  },
  {
    "startTime": 416.0,
    "endTime": 417.0,
    "text": "Could it have been Agent Cobra?"
  },
  {
    "startTime": 417.0,
    "endTime": 420.0,
    "text": "Maybe it was my old nemesis, Nefario Dawson."
  },
  {
    "startTime": 420.0,
    "endTime": 421.0,
    "text": "Ah, it just doesn't make sense."
  },
  {
    "startTime": 421.0,
    "endTime": 422.0,
    "text": "Have you found anything, Pando?"
  },
  {
    "startTime": 422.0,
    "endTime": 423.0,
    "text": "Not really."
  },
  {
    "startTime": 423.0,
    "endTime": 426.0,
    "text": "The security camera didn't pick up anything unusual."
  },
  {
    "startTime": 426.0,
    "endTime": 427.0,
    "text": "Wait a second."
  },
  {
    "startTime": 427.0,
    "endTime": 428.0,
    "text": "Let me see the computer."
  },
  {
    "startTime": 429.0,
    "endTime": 429.0,
    "text": "There."
  },
  {
    "startTime": 429.0,
    "endTime": 430.0,
    "text": "Enhance."
  },
  {
    "startTime": 430.0,
    "endTime": 432.0,
    "text": "Evil Robot Headquarters?"
  },
  {
    "startTime": 432.0,
    "endTime": 434.0,
    "text": "This goes deeper than I thought."
  },
  {
    "startTime": 434.0,
    "endTime": 435.0,
    "text": "Come on, Pando."
  },
  {
    "startTime": 435.0,
    "endTime": 436.0,
    "text": "Let's head to the lab."
  },
  {
    "startTime": 437.0,
    "endTime": 440.0,
    "text": "Right behind you, Mr. Jones!"
  },
  {
    "startTime": 448.0,
    "endTime": 449.0,
    "text": "Ah!"
  },
  {
    "startTime": 449.0,
    "endTime": 450.0,
    "text": "Hello, Agent W."
  },
  {
    "startTime": 451.0,
    "endTime": 452.0,
    "text": "I'm stuck, Crowbar!"
  },
  {
    "startTime": 453.0,
    "endTime": 454.0,
    "text": "Ah, Mr. Jones."
  },
  {
    "startTime": 454.0,
    "endTime": 456.0,
    "text": "Late as usual."
  },
  {
    "startTime": 456.0,
    "endTime": 457.0,
    "text": "Fashionably late, you mean?"
  },
  {
    "startTime": 457.0,
    "endTime": 459.0,
    "text": "No, not really."
  },
  {
    "startTime": 459.0,
    "endTime": 461.0,
    "text": "All right, here you go."
  },
  {
    "startTime": 461.0,
    "endTime": 462.0,
    "text": "No!"
  },
  {
    "startTime": 462.0,
    "endTime": 465.0,
    "text": "Ended up doing some modifications to the jetpack."
  },
  {
    "startTime": 465.0,
    "endTime": 466.0,
    "text": "What's this weight for?"
  },
  {
    "startTime": 466.0,
    "endTime": 470.0,
    "text": "That's to maintain your totally sweet-ripped bod, my good man."
  },
  {
    "startTime": 470.0,
    "endTime": 471.0,
    "text": "Good thinking, W."
  },
  {
    "startTime": 471.0,
    "endTime": 473.0,
    "text": "I'll do a few thousand reps on my way there."
  },
  {
    "startTime": 474.0,
    "endTime": 475.0,
    "text": "Better come back in one piece, you hear?"
  },
  {
    "startTime": 476.0,
    "endTime": 477.6,
    "text": "Of course."
  },
  {
    "startTime": 477.6,
    "endTime": 480.40000000000003,
    "text": "I promised my girlfriend an ice cream date."
  },
  {
    "startTime": 480.4,
    "endTime": 481.5,
    "text": "You're not coming back."
  },
  {
    "startTime": 481.5,
    "endTime": 482.0,
    "text": "I just know it."
  },
  {
    "startTime": 482.0,
    "endTime": 482.7,
    "text": "I hate you."
  },
  {
    "startTime": 482.7,
    "endTime": 483.4,
    "text": "I love you."
  },
  {
    "startTime": 483.4,
    "endTime": 483.7,
    "text": "I hate you."
  },
  {
    "startTime": 483.7,
    "endTime": 484.0,
    "text": "I love you."
  },
  {
    "startTime": 484.4,
    "endTime": 485.0,
    "text": "I hate you."
  },
  {
    "startTime": 485.0,
    "endTime": 485.0,
    "text": "I love you."
  },
  {
    "startTime": 485.0,
    "endTime": 486.0,
    "text": "I hate you."
  },
  {
    "startTime": 486.0,
    "endTime": 489.2,
    "text": "I love you."
  },
  {
    "startTime": 489.2,
    "endTime": 491.4,
    "text": "No!"
  },
  {
    "startTime": 491.4,
    "endTime": 492.7,
    "text": "Crowbar, help me!"
  },
  {
    "startTime": 492.7,
    "endTime": 495.0,
    "text": "I think something's wrong with my jetpack!"
  },
  {
    "startTime": 495.0,
    "endTime": 496.4,
    "text": "Get it together, Pando."
  },
  {
    "startTime": 496.4,
    "endTime": 501.7,
    "text": "Now let's dive!"
  },
  {
    "startTime": 501.7,
    "endTime": 503.9,
    "text": "Seems like you made a new friend, Pando."
  },
  {
    "startTime": 503.9,
    "endTime": 505.0,
    "text": "If only I knew how to swim!"
  },
  {
    "startTime": 505.0,
    "endTime": 507.0,
    "text": "We're here."
  },
  {
    "startTime": 507.0,
    "endTime": 510.0,
    "text": "Okay, Pando, I gotta find some place to freshen up."
  },
  {
    "startTime": 510.0,
    "endTime": 514.2,
    "text": "Oh, my phone got wet!"
  },
  {
    "startTime": 514.2,
    "endTime": 516.3000000000001,
    "text": "Evil robot spa."
  },
  {
    "startTime": 516.3,
    "endTime": 523.0,
    "text": "Don't mind if I do."
  },
  {
    "startTime": 523.0,
    "endTime": 525.5,
    "text": "Aw, yeah."
  },
  {
    "startTime": 525.5,
    "endTime": 528.6,
    "text": "Check out those biceps."
  },
  {
    "startTime": 528.6,
    "endTime": 531.0,
    "text": "Yeah, you know."
  },
  {
    "startTime": 531.0,
    "endTime": 533.0,
    "text": "Crowbar Jones."
  },
  {
    "startTime": 533.0,
    "endTime": 544.0,
    "text": "Now do me a little tiny favor and break it down."
  },
  {
    "startTime": 544.0,
    "endTime": 545.5,
    "text": "So many choices."
  },
  {
    "startTime": 545.5,
    "endTime": 546.5,
    "text": "Huh?"
  },
  {
    "startTime": 546.5,
    "endTime": 548.0,
    "text": "Hello?"
  },
  {
    "startTime": 548.0,
    "endTime": 552.6,
    "text": "Anyone there?"
  },
  {
    "startTime": 552.6,
    "endTime": 553.8000000000001,
    "text": "Hello, my friend."
  },
  {
    "startTime": 553.8,
    "endTime": 555.5999999999999,
    "text": "I've been sent here to destroy you."
  },
  {
    "startTime": 555.6,
    "endTime": 559.7,
    "text": "Oh, then allow me to introduce myself."
  },
  {
    "startTime": 559.7,
    "endTime": 561.0,
    "text": "It can't be."
  },
  {
    "startTime": 561.0,
    "endTime": 564.0,
    "text": "My name is Crowbar Jones."
  },
  {
    "startTime": 564.0,
    "endTime": 573.5,
    "text": "And I'm the bear that's gonna bring you down."
  },
  {
    "startTime": 573.5,
    "endTime": 576.8,
    "text": "Who sent you?"
  },
  {
    "startTime": 576.8,
    "endTime": 578.3,
    "text": "I won't ask you again, bro."
  },
  {
    "startTime": 578.3,
    "endTime": 580.0,
    "text": "Um, I mean, ninja."
  },
  {
    "startTime": 585.0,
    "endTime": 586.3,
    "text": "No, it can't be."
  },
  {
    "startTime": 586.3,
    "endTime": 589.0999999999999,
    "text": "They're mixing ninja DNA with robot DNA."
  },
  {
    "startTime": 589.1,
    "endTime": 595.0,
    "text": "That's just evil!"
  },
  {
    "startTime": 595.0,
    "endTime": 597.0,
    "text": "Not so fast!"
  },
  {
    "startTime": 597.0,
    "endTime": 599.0,
    "text": "You are in a world of trouble, buddy."
  },
  {
    "startTime": 599.0,
    "endTime": 600.0,
    "text": "Pando!"
  },
  {
    "startTime": 600.0,
    "endTime": 607.0,
    "text": "That's right! Get ready to feel the true power of the Pando!"
  },
  {
    "startTime": 607.0,
    "endTime": 610.0,
    "text": "Whoa, Pando's infamous fireball kick."
  },
  {
    "startTime": 610.0,
    "endTime": 611.3,
    "text": "Awesome move, Pando."
  },
  {
    "startTime": 611.3,
    "endTime": 618.8,
    "text": "Yeah, totally meant to do that, so..."
  },
  {
    "startTime": 618.8,
    "endTime": 630.8,
    "text": "Let's take this ninja to Justicetown."
  },
  {
    "startTime": 630.6,
    "endTime": 632.4,
    "text": "Zap, zap, short circuit."
  },
  {
    "startTime": 632.4,
    "endTime": 633.0,
    "text": "Yeah!"
  },
  {
    "startTime": 638.0,
    "endTime": 641.2,
    "text": "Finally, the world is once again a safer place."
  },
  {
    "startTime": 641.2,
    "endTime": 642.5,
    "text": "Thanks to you, Crowbar Jones."
  },
  {
    "startTime": 642.5,
    "endTime": 644.3,
    "text": "Well, it's like I always say."
  },
  {
    "startTime": 644.3,
    "endTime": 647.0,
    "text": "Saving the world is not a one-bear job."
  },
  {
    "startTime": 647.0,
    "endTime": 650.0,
    "text": "Pando here is as big a hero as any one of us."
  },
  {
    "startTime": 650.0,
    "endTime": 651.5,
    "text": "I owe you my life."
  },
  {
    "startTime": 651.5,
    "endTime": 653.2,
    "text": "Oh, thank you, Grizz."
  },
  {
    "startTime": 653.2,
    "endTime": 666.8000000000001,
    "text": "Oh, I mean Crowbar Jones."
  },
  {
    "startTime": 666.7,
    "endTime": 667.5,
    "text": "No!"
  },
  {
    "startTime": 667.5,
    "endTime": 669.5,
    "text": "Pando, speak to me, buddy."
  },
  {
    "startTime": 669.5,
    "endTime": 672.9,
    "text": "I feel so cold."
  },
  {
    "startTime": 672.9,
    "endTime": 674.5,
    "text": "Don't go into the light, buddy."
  },
  {
    "startTime": 674.5,
    "endTime": 676.7,
    "text": "You've got your whole life ahead of you."
  },
  {
    "startTime": 676.7,
    "endTime": 680.0,
    "text": "In the words of the great poet, life is..."
  },
  {
    "startTime": 680.0,
    "endTime": 681.0,
    "text": "Shh!"
  },
  {
    "startTime": 681.0,
    "endTime": 683.0,
    "text": "Good night, sweet prince."
  },
  {
    "startTime": 683.0,
    "endTime": 686.2,
    "text": "Go to sleep."
  },
  {
    "startTime": 686.2,
    "endTime": 690.3000000000001,
    "text": "Pando!"
  },
  {
    "startTime": 690.3,
    "endTime": 695.0,
    "text": "Crowbar Jones!"
  },
  {
    "startTime": 695.0,
    "endTime": 696.2,
    "text": "Later."
  },
  {
    "startTime": 696.0,
    "endTime": 699.0,
    "text": "Wow, being hydrated before a mission does feel good."
  },
  {
    "startTime": 699.0,
    "endTime": 700.2,
    "text": "Told ya."
  },
  {
    "startTime": 700.2,
    "endTime": 705.1,
    "text": "Now, who could that be?"
  },
  {
    "startTime": 705.0,
    "endTime": 706.3,
    "text": "Hey, little buddy."
  },
  {
    "startTime": 706.3,
    "endTime": 708.0,
    "text": "How can I help you?"
  },
  {
    "startTime": 708.0,
    "endTime": 713.0,
    "text": "The real question is, how can I help you, Father?"
  }
]