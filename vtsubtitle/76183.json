[
  {
    "startTime": 0.0,
    "endTime": 2.6,
    "text": "The \"Spider-Man: Far From Home\" trailer is about to play."
  },
  {
    "startTime": 2.6,
    "endTime": 8.298,
    "text": "But if you haven't seen \"Avengers: End Game\" yet, stop watching because there's some serious spoilers about to come up."
  },
  {
    "startTime": 8.298,
    "endTime": 12.001,
    "text": "But if you have seen \"Avengers: End Game\", enjoy the trailer."
  },
  {
    "startTime": 13.38,
    "endTime": 15.620000000000001,
    "text": "Everywhere I go, I see his face."
  },
  {
    "startTime": 17.24,
    "endTime": 18.139999999999997,
    "text": "I just really miss him."
  },
  {
    "startTime": 19.4,
    "endTime": 20.419999999999998,
    "text": "Yeah, I miss him, too."
  },
  {
    "startTime": 22.2,
    "endTime": 27.08,
    "text": "I don't think Tony would have done what he did, if he didn't know that you were gonna be here after he was gone."
  },
  {
    "startTime": 35.14,
    "endTime": 36.7,
    "text": "You gonna be the next Iron Man now?"
  },
  {
    "startTime": 36.7,
    "endTime": 37.5,
    "text": "Well, no, I don't have time."
  },
  {
    "startTime": 37.5,
    "endTime": 38.72,
    "text": "I'm too busy doing your jobs."
  },
  {
    "startTime": 38.98,
    "endTime": 39.48,
    "text": "What?"
  },
  {
    "startTime": 39.66,
    "endTime": 40.44,
    "text": "I'm kidding, I'm kidding."
  },
  {
    "startTime": 40.44,
    "endTime": 41.72,
    "text": "Look, keep up the good work."
  },
  {
    "startTime": 42.0,
    "endTime": 44.22,
    "text": "Because I am going on vacation."
  },
  {
    "startTime": 47.68,
    "endTime": 48.26,
    "text": "Heads up."
  },
  {
    "startTime": 48.48,
    "endTime": 49.72,
    "text": "Nick Fury's calling you."
  },
  {
    "startTime": 50.74,
    "endTime": 51.68,
    "text": "I don't really want to talk to Nick Fury."
  },
  {
    "startTime": 51.68,
    "endTime": 52.18,
    "text": "Answer your phone."
  },
  {
    "startTime": 52.3,
    "endTime": 52.8,
    "text": "Why?"
  },
  {
    "startTime": 52.86,
    "endTime": 54.46,
    "text": "Because if you don't talk to him, then I have to talk to him."
  },
  {
    "startTime": 54.46,
    "endTime": 55.18,
    "text": "I don't wanna talk to him."
  },
  {
    "startTime": 56.26,
    "endTime": 57.6,
    "text": "You sent Nick Fury to voicemail?"
  },
  {
    "startTime": 57.66,
    "endTime": 58.239999999999995,
    "text": "I gotta go."
  },
  {
    "startTime": 58.34,
    "endTime": 59.84,
    "text": "You do not ghost Nick Fury!"
  },
  {
    "startTime": 60.48,
    "endTime": 60.98,
    "text": "What up, dorks?"
  },
  {
    "startTime": 61.06,
    "endTime": 61.56,
    "text": "What's up?"
  },
  {
    "startTime": 61.58,
    "endTime": 62.78,
    "text": "We're just talking about the trip."
  },
  {
    "startTime": 63.28,
    "endTime": 64.84,
    "text": "I'm here in St. Marco Polo's... owww!"
  },
  {
    "startTime": 65.72,
    "endTime": 66.9,
    "text": "I think MJ really likes me."
  },
  {
    "startTime": 67.16,
    "endTime": 68.11999999999999,
    "text": "Reminds me of when I first fell in love."
  },
  {
    "startTime": 70.62,
    "endTime": 73.66000000000001,
    "text": "You're a very difficult person to contact."
  },
  {
    "startTime": 74.0,
    "endTime": 74.5,
    "text": "Spider-Man."
  },
  {
    "startTime": 77.52,
    "endTime": 79.42,
    "text": "This Is Mr. Beck."
  },
  {
    "startTime": 80.08,
    "endTime": 81.74,
    "text": "We could use someone like you on my world."
  },
  {
    "startTime": 81.88,
    "endTime": 82.44,
    "text": "Your world?"
  },
  {
    "startTime": 82.5,
    "endTime": 83.6,
    "text": "Beck is from Earth."
  },
  {
    "startTime": 83.6,
    "endTime": 84.44,
    "text": "Just not ours."
  },
  {
    "startTime": 84.68,
    "endTime": 86.38000000000001,
    "text": "The Snap tore a hole in our dimension."
  },
  {
    "startTime": 86.38,
    "endTime": 89.66,
    "text": "You're saying there's a Multiverse?"
  },
  {
    "startTime": 89.66,
    "endTime": 90.75999999999999,
    "text": "We have a job to do."
  },
  {
    "startTime": 91.42,
    "endTime": 92.32000000000001,
    "text": "You're coming with us."
  },
  {
    "startTime": 95.84,
    "endTime": 97.66,
    "text": "There's gotta be something else you can use."
  },
  {
    "startTime": 97.76,
    "endTime": 98.38000000000001,
    "text": "What about Thor?"
  },
  {
    "startTime": 98.52,
    "endTime": 99.36,
    "text": "Off-world."
  },
  {
    "startTime": 99.48,
    "endTime": 100.24000000000001,
    "text": "Captain Marvel?"
  },
  {
    "startTime": 100.28,
    "endTime": 100.98,
    "text": "Unavailable."
  },
  {
    "startTime": 102.96,
    "endTime": 104.72,
    "text": "But I'm just a friendly neighborhood Spider-Man."
  },
  {
    "startTime": 107.04,
    "endTime": 107.78,
    "text": "Bitch, please."
  },
  {
    "startTime": 107.82,
    "endTime": 108.77999999999999,
    "text": "You've been to space."
  },
  {
    "startTime": 109.94,
    "endTime": 111.0,
    "text": "What do you want, Peter?"
  },
  {
    "startTime": 112.68,
    "endTime": 116.0,
    "text": "I wanna go back on my trip with the girl who I really like and tell her how I feel."
  },
  {
    "startTime": 116.06,
    "endTime": 117.12,
    "text": "MJ, I..."
  },
  {
    "startTime": 117.12,
    "endTime": 117.74000000000001,
    "text": "Am Spider-Man?"
  },
  {
    "startTime": 118.82,
    "endTime": 119.88,
    "text": "No, of course not."
  },
  {
    "startTime": 120.54,
    "endTime": 122.30000000000001,
    "text": "I mean it's kind of obvious."
  },
  {
    "startTime": 123.56,
    "endTime": 124.94,
    "text": "You're right, you may not be ready."
  },
  {
    "startTime": 124.94,
    "endTime": 126.89999999999999,
    "text": "But this is my responsibility."
  },
  {
    "startTime": 126.9,
    "endTime": 129.0,
    "text": "Saving the world requires sacrifice."
  },
  {
    "startTime": 130.28,
    "endTime": 131.5,
    "text": "Sometimes, people die."
  },
  {
    "startTime": 134.12,
    "endTime": 134.84,
    "text": "Oh, my God."
  },
  {
    "startTime": 135.82,
    "endTime": 137.92,
    "text": "I always feel like I'm putting my friends in danger."
  },
  {
    "startTime": 138.94,
    "endTime": 140.48,
    "text": "The world needs the next Iron Man."
  },
  {
    "startTime": 143.42,
    "endTime": 144.95999999999998,
    "text": "You going to step up or not?"
  },
  {
    "startTime": 157.34,
    "endTime": 158.4,
    "text": "I gotta get you guys outta here!"
  },
  {
    "startTime": 158.5,
    "endTime": 159.18,
    "text": "Get on the jet!"
  },
  {
    "startTime": 159.22,
    "endTime": 159.72,
    "text": "Who are you?"
  },
  {
    "startTime": 159.96,
    "endTime": 160.9,
    "text": "I work with Spider-Man."
  },
  {
    "startTime": 160.9,
    "endTime": 161.99800000000002,
    "text": "You work for Spider-Man?!"
  },
  {
    "startTime": 162.12,
    "endTime": 163.92000000000002,
    "text": "I work with Spider-Man, not for Spider-Man!"
  },
  {
    "startTime": 165.86,
    "endTime": 166.36,
    "text": "New plan!"
  }
]