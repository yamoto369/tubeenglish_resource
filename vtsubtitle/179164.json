  {
    "startTime": 314.5,
    "endTime": 315.0,
    "text": "And you're right."
  },
  {
    "startTime": 315.0,
    "endTime": 317.0,
    "text": "This Tamatoa guy really likes his treasure."
  },
  {
    "startTime": 317.0,
    "endTime": 317.5,
    "text": "Stay."
