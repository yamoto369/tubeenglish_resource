[
  {
    "startTime": 1.0,
    "endTime": 2.4690000000000003,
    "text": "Yes."
  },
  {
    "startTime": 5.638,
    "endTime": 7.073,
    "text": "(clears throat)"
  },
  {
    "startTime": 14.38,
    "endTime": 16.049,
    "text": "- (breathless) Hi. - Hello."
  },
  {
    "startTime": 16.082,
    "endTime": 19.118000000000002,
    "text": "I would love to... cash this... here check."
  },
  {
    "startTime": 19.151,
    "endTime": 19.985,
    "text": "Okay."
  },
  {
    "startTime": 19.151,
    "endTime": 19.985,
    "text": "If I may?"
  },
  {
    "startTime": 20.019,
    "endTime": 22.121,
    "text": "- Thank you.  - Name on the account, please."
  },
  {
    "startTime": 22.154,
    "endTime": 24.557,
    "text": "Yes, it's Nora, N-O-R-A, no \"H.\""
  },
  {
    "startTime": 24.59,
    "endTime": 26.092,
    "text": "(both chuckling)"
  },
  {
    "startTime": 26.125,
    "endTime": 27.293,
    "text": "Lin, L-I-N."
  },
  {
    "startTime": 27.326,
    "endTime": 30.129,
    "text": "Nora Lin, Forley Road, Elmhurst?"
  },
  {
    "startTime": 30.162,
    "endTime": 31.264,
    "text": "That is correct, yes."
  },
  {
    "startTime": 31.297,
    "endTime": 33.566,
    "text": "It says here you're dead."
  },
  {
    "startTime": 33.599,
    "endTime": 35.20099999999999,
    "text": "Sorry, what?!"
  },
  {
    "startTime": 35.234,
    "endTime": 36.669000000000004,
    "text": "The bank automatically closes accounts"
  },
  {
    "startTime": 36.702,
    "endTime": 38.370999999999995,
    "text": "that have been inactive for two years."
  },
  {
    "startTime": 38.404,
    "endTime": 40.139,
    "text": "We assume you died."
  },
  {
    "startTime": 38.404,
    "endTime": 40.139,
    "text": "No."
  },
  {
    "startTime": 40.172,
    "endTime": 43.57599999999999,
    "text": "No, no. No. I am-- I am alive!"
  },
  {
    "startTime": 43.609,
    "endTime": 44.644,
    "text": "Here's what I can do. (sighs)"
  },
  {
    "startTime": 44.677,
    "endTime": 46.345,
    "text": "If you want to reopen your account,"
  },
  {
    "startTime": 46.378,
    "endTime": 48.181,
    "text": "I just need a form of identification."
  },
  {
    "startTime": 48.214,
    "endTime": 50.583,
    "text": "Yes. Actually, I can accommodate with that."
  },
  {
    "startTime": 51.884,
    "endTime": 54.087,
    "text": "(softly) Okay, here we go, that's..."
  },
  {
    "startTime": 55.187,
    "endTime": 56.455999999999996,
    "text": "Yes."
  },
  {
    "startTime": 55.187,
    "endTime": 56.455999999999996,
    "text": "Thank you."
  },
  {
    "startTime": 56.489,
    "endTime": 58.224,
    "text": "This is expired."
  },
  {
    "startTime": 58.257,
    "endTime": 59.458999999999996,
    "text": "Where does it say that?"
  },
  {
    "startTime": 59.492,
    "endTime": 61.227,
    "text": "No, no."
  },
  {
    "startTime": 61.26,
    "endTime": 62.495,
    "text": "Because this license is expired,"
  },
  {
    "startTime": 62.528,
    "endTime": 63.562999999999995,
    "text": "I'm legally obligated to do this."
  },
  {
    "startTime": 63.596,
    "endTime": 65.164,
    "text": "Oh. Oh. Oh!"
  },
  {
    "startTime": 65.197,
    "endTime": 66.599,
    "text": "(plastic snaps)"
  },
  {
    "startTime": 65.197,
    "endTime": 66.599,
    "text": "Oh!"
  },
  {
    "startTime": 66.632,
    "endTime": 70.13600000000001,
    "text": "Do you have another form of identification?"
  },
  {
    "startTime": 70.169,
    "endTime": 72.405,
    "text": "Do you know your social security number?"
  },
  {
    "startTime": 72.438,
    "endTime": 74.24000000000001,
    "text": "Yes! Yes, I know it."
  },
  {
    "startTime": 74.273,
    "endTime": 76.37599999999999,
    "text": "Um, it's 1-8..."
  },
  {
    "startTime": 77.576,
    "endTime": 80.246,
    "text": "hundred, 5-7-9-6-8-5-9."
  },
  {
    "startTime": 80.279,
    "endTime": 82.315,
    "text": "Okay, that's too many numbers."
  },
  {
    "startTime": 82.348,
    "endTime": 83.883,
    "text": "Why do I even need a bank account?"
  },
  {
    "startTime": 83.916,
    "endTime": 85.25099999999999,
    "text": "Well, for starters, to build up your credit,"
  },
  {
    "startTime": 85.284,
    "endTime": 86.519,
    "text": "apply for a loan, buy a house"
  },
  {
    "startTime": 86.552,
    "endTime": 88.32100000000001,
    "text": "and get a mortgage, not to mention"
  },
  {
    "startTime": 88.354,
    "endTime": 90.123,
    "text": "set up a basic investment portfolio"
  },
  {
    "startTime": 90.156,
    "endTime": 91.82400000000001,
    "text": "and formulate a retirement plan."
  },
  {
    "startTime": 91.857,
    "endTime": 93.826,
    "text": "But without proper identification,"
  },
  {
    "startTime": 93.859,
    "endTime": 96.729,
    "text": "I can't verify that a..."
  },
  {
    "startTime": 96.762,
    "endTime": 99.398,
    "text": "Nora Lin actually exists."
  },
  {
    "startTime": 99.431,
    "endTime": 100.86699999999999,
    "text": "Sorry."
  },
  {
    "startTime": 104.17,
    "endTime": 105.33800000000001,
    "text": "(whispering) Hey."
  },
  {
    "startTime": 105.371,
    "endTime": 106.672,
    "text": "What if you asked me something"
  },
  {
    "startTime": 106.705,
    "endTime": 109.442,
    "text": "that only the real Nora Lin would know?"
  },
  {
    "startTime": 109.475,
    "endTime": 111.577,
    "text": "I literally know nothing about you."
  },
  {
    "startTime": 111.61,
    "endTime": 112.812,
    "text": "(normal voice) So, I can't cash this check?"
  },
  {
    "startTime": 112.845,
    "endTime": 114.313,
    "text": "Nope."
  },
  {
    "startTime": 114.346,
    "endTime": 118.15100000000001,
    "text": "I... look like a f***** blow-up doll!"
  },
  {
    "startTime": 118.184,
    "endTime": 120.18599999999999,
    "text": "Huh?!"
  },
  {
    "startTime": 120.219,
    "endTime": 123.189,
    "text": "Thank you for being so f***** lovely."
  },
  {
    "startTime": 120.219,
    "endTime": 123.189,
    "text": "You're welcome."
  },
  {
    "startTime": 123.222,
    "endTime": 125.491,
    "text": "- Have a nice day.  - Yeah!"
  },
  {
    "startTime": 125.524,
    "endTime": 127.124,
    "text": "What are you lookin' at?!"
  }
]