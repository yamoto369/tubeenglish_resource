  {
    "startTime": 102.436,
    "endTime": 104.70500000000001,
    "text": "The wings make you hover over, close your eyes."
  },
  {
    "startTime": 104.705,
    "endTime": 105.99,
    "text": "You don't oppose your trip."
  },
  {
    "startTime": 105.99,
    "endTime": 106.5,
    "text": "Everything is beautiful."
  },
  {
    "startTime": 106.5,
    "endTime": 109.209,
    "text": "Hands, hats, all the important shit"
