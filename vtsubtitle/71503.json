  {
    "startTime": 117.251,
    "endTime": 121.321,
    "text": "I'm a big fat guy who has children on my knee, Ho Ho Ho!"
  },
  {
    "startTime": 121.121,
    "endTime": 122.95599999999999,
    "text": "Usually you see from the top down."
  },
  {
    "startTime": 122.956,
    "endTime": 125.525,
    "text": "It's an external to internal transformation."
  },
  {
    "startTime": 125.525,
    "endTime": 129.596,
    "text": "Acting is for me about facing your fears."
  },
  {
    "startTime": 129.596,
    "endTime": 132.43200000000002,
    "text": "and confronting harsh truths."
  },
  {
    "startTime": 133.1,
    "endTime": 134.5,
    "text": "I don't like your face."
  },
  {
    "startTime": 134.5,
    "endTime": 137.204,
    "text": "That's really rude."
