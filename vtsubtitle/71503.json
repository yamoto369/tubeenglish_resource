  {
    "startTime": 89.256,
    "endTime": 93.927,
    "text": "Again! With entertainment."
  },
  {
    "startTime": 93.927,
    "endTime": 95.99600000000001,
    "text": "This course will cover everything."
  },
  {
    "startTime": 95.996,
    "endTime": 99.499,
    "text": "You're a snake, you're a giraffe reaching up through the canopy of the jungle."
