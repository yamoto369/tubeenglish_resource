  {
    "startTime": 60.761,
    "endTime": 61.128,
    "text": "That's it."
  },
  {
    "startTime": 61.128,
    "endTime": 63.03,
    "text": "What the hell is wrong with you?"
  },
  {
    "startTime": 63.03,
    "endTime": 65.0,
    "text": "(You) have to feel... it."
