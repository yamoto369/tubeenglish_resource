  {
    "startTime": 153.0,
    "endTime": 154.0,
    "text": "Let me explain."
  },
  {
    "startTime": 154.0,
    "endTime": 157.0,
    "text": "You have gone dentist."
  },
  {
    "startTime": 157.0,
    "endTime": 164.0,
    "text": "That means that you will serve a brief tour of duty and in exchange we will provide full dental rehabilitation."
  },
  {
    "startTime": 164.0,
    "endTime": 166.0,
    "text": "You will be on the front fighting monsters."
  },
  {
    "startTime": 167.0,
    "endTime": 169.0,
    "text": "Monstrous monster."
  },
  {
    "startTime": 170.0,
    "endTime": 170.0,
    "text": "Worms."
  },
  {
    "startTime": 171.0,
    "endTime": 172.0,
    "text": "Worms."
  },
  {
    "startTime": 172.0,
    "endTime": 174.0,
    "text": "The worms are employed by the flies."
  },
  {
    "startTime": 175.0,
    "endTime": 175.0,
    "text": "Worms."
  },
  {
    "startTime": 176.0,
    "endTime": 176.0,
    "text": "Work for the flies."
  },
  {
    "startTime": 177.0,
    "endTime": 179.0,
    "text": "You fight them, we'll fix your teeth."
