  },
  {
    "startTime": 181.0,
    "endTime": 185.0,
    "text": "Your mission is to secure this junction at all costs."
  },
  {
    "startTime": 186.0,
    "endTime": 190.0,
    "text": "Upon completion of service, you will be sworn to absolute secrecy."
  },
  {
    "startTime": 190.0,
    "endTime": 192.0,
    "text": "The flies have spies everywhere."
  },
  {
    "startTime": 192.0,
    "endTime": 193.0,
