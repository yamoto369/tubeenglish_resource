  {
    "startTime": 125.0,
    "endTime": 127.0,
    "text": "I'm a very busy woman."
  },
  {
    "startTime": 129.0,
    "endTime": 131.0,
    "text": "Hello, my name is General Tarsil."
  },
  {
    "startTime": 131.0,
    "endTime": 134.0,
    "text": "I am the current Queen of this regiment and please have a seat."
  },
  {
    "startTime": 135.0,
    "endTime": 142.0,
    "text": "As a first time recruit, I'm confident that you have no idea what you're doing here."
  },
  {
    "startTime": 143.0,
    "endTime": 143.0,
    "text": "My tooth hurts."
  },
  {
    "startTime": 144.0,
    "endTime": 145.0,
    "text": "Let's take a look at your file."
  },
  {
    "startTime": 146.0,
    "endTime": 148.0,
    "text": "Ah, you're a fighter."
  },
  {
    "startTime": 148.0,
    "endTime": 149.0,
    "text": "We can use a fighter."
  },
  {
    "startTime": 150.0,
    "endTime": 150.0,
    "text": "My tooth hurts."
