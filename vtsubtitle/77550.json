  {
    "startTime": 90.62,
    "endTime": 92.32000000000001,
    "text": "What's your favourite sexual position?"
  },
  {
    "startTime": 92.32,
    "endTime": 93.75999999999999,
    "text": "Normal, front-facing, normal."
  },
  {
    "startTime": 93.76,
    "endTime": 94.82000000000001,
    "text": "What kind of question is that?"
  },
  {
    "startTime": 94.82,
    "endTime": 95.72,
    "text": "That's all it took, look at you!"
  },
  {
    "startTime": 95.74,
    "endTime": 97.52,
