[
  {
    "startTime": 8.08,
    "endTime": 12.620000000000001,
    "text": "Charlotte, I would like to endorse you to be the next president of the United States."
  },
  {
    "startTime": 12.62,
    "endTime": 13.42,
    "text": "Oh my god."
  },
  {
    "startTime": 13.42,
    "endTime": 15.620000000000001,
    "text": "You've been a great secretary."
  },
  {
    "startTime": 15.62,
    "endTime": 16.82,
    "text": "Of State."
  },
  {
    "startTime": 16.82,
    "endTime": 17.76,
    "text": "Which state again?"
  },
  {
    "startTime": 17.76,
    "endTime": 18.32,
    "text": "All of them."
  },
  {
    "startTime": 21.9,
    "endTime": 23.299999999999997,
    "text": "Is that the Secretary of State looking at us?"
  },
  {
    "startTime": 23.31,
    "endTime": 24.22,
    "text": "I kind of know her."
  },
  {
    "startTime": 24.22,
    "endTime": 25.36,
    "text": "It's like kind of knowing a mermaid."
  },
  {
    "startTime": 25.36,
    "endTime": 26.36,
    "text": "Do you tell people that?"
  },
  {
    "startTime": 26.36,
    "endTime": 27.48,
    "text": "She probably doesn't remember who I am."
  },
  {
    "startTime": 27.72,
    "endTime": 29.4,
    "text": "Secretary Field would like to speak with you."
  },
  {
    "startTime": 29.56,
    "endTime": 30.54,
    "text": "With me?"
  },
  {
    "startTime": 31.39,
    "endTime": 33.6,
    "text": "I can't shake this feeling that we know each other."
  },
  {
    "startTime": 33.6,
    "endTime": 34.1,
    "text": "We do!"
  },
  {
    "startTime": 34.1,
    "endTime": 34.6,
    "text": "We do?"
  },
  {
    "startTime": 34.6,
    "endTime": 37.84,
    "text": "Picture me, I guess, maybe like 20 years younger, but like this."
  },
  {
    "startTime": 37.84,
    "endTime": 38.800000000000004,
    "text": "Flarsky?"
  },
  {
    "startTime": 38.8,
    "endTime": 39.599999999999994,
    "text": "Yeah."
  },
  {
    "startTime": 39.6,
    "endTime": 40.6,
    "text": "What are you doing these days?"
  },
  {
    "startTime": 40.6,
    "endTime": 41.300000000000004,
    "text": "I'm a journalist."
  },
  {
    "startTime": 41.3,
    "endTime": 45.18,
    "text": "You're a great writer, but, sometimes you're a little too much."
  },
  {
    "startTime": 45.18,
    "endTime": 48.6,
    "text": "I don't think I am too much! I actually think I'm the perfect, right, portion."
  },
  {
    "startTime": 48.66,
    "endTime": 50.239999999999995,
    "text": "It's really nice to see you again."
  },
  {
    "startTime": 50.24,
    "endTime": 50.74,
    "text": "Woah!"
