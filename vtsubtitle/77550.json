  {
    "startTime": 59.48,
    "endTime": 59.98,
    "text": "*chuckles*"
  },
  {
    "startTime": 59.98,
    "endTime": 61.36,
    "text": "It's to babysit for him."
  },
  {
    "startTime": 61.36,
    "endTime": 62.62,
    "text": "You babysat for him?"
  },
  {
    "startTime": 62.62,
    "endTime": 65.1,
    "text": "Wow. Time has not been kind."
  },
  {
    "startTime": 65.88,
    "endTime": 68.16,
    "text": "I need some writers to punch up my speeches."
  },
  {
    "startTime": 68.16,
    "endTime": 71.02,
    "text": "Fred's writing is really good and he knows me."
  },
  {
    "startTime": 71.02,
    "endTime": 73.11999999999999,
    "text": "Oh, I feel so scared."
  },
  {
    "startTime": 73.64,
    "endTime": 77.94,
    "text": "In order to write better for you, I should kind of get to know you better... if you have a minute."
  },
  {
    "startTime": 77.94,
    "endTime": 79.06,
    "text": "I actually have seven."
  },
  {
    "startTime": 79.06,
    "endTime": 80.12,
    "text": "Seven minutes in heaven."
