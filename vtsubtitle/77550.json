  },
  {
    "startTime": 97.52,
    "endTime": 98.5,
    "text": "Don't be gross, alright?"
  },
  {
    "startTime": 100.14,
    "endTime": 100.78,
    "text": "Do a date."
  },
  {
    "startTime": 100.78,
    "endTime": 104.92,
    "text": "I mean, who wants to follow me around the world and hope I have five minutes to be affectionate?"
