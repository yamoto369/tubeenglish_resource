  {
    "startTime": 54.36,
    "endTime": 55.1,
    "text": "I'm okay!"
  },
  {
    "startTime": 55.1,
    "endTime": 56.4,
    "text": "Okay, did he just call me a cracker?"
  },
  {
    "startTime": 57.46,
    "endTime": 59.480000000000004,
    "text": "What is the relationship exactly?"
