    "endTime": 20.111,
    "text": "Really? Okay."
  },
  {
    "startTime": 21.7,
    "endTime": 25.988,
    "text": "You are my fire."
  },
  {
    "startTime": 27.1,
    "endTime": 28.200000000000003,
    "text": "Number two, keep it going."
  },
  {
    "startTime": 28.4,
    "endTime": 32.4,
    "text": "The one desire."
  },
  {
    "startTime": 32.6,
    "endTime": 33.1,
    "text": "Number three."
  },
  {
    "startTime": 33.3,
    "endTime": 37.099999999999994,
    "text": "Believe when I say."
  },
  {
    "startTime": 37.3,
    "endTime": 37.699999999999996,
    "text": "Number four."
  },
  {
    "startTime": 38.0,
    "endTime": 41.305,
    "text": "I want it that way."
  },
  {
    "startTime": 41.9,
    "endTime": 43.0,
    "text": "Tell me why."
  },
  {
    "startTime": 43.2,
    "endTime": 46.400000000000006,
    "text": "Ain't nothing but a heartache."
  },
  {
    "startTime": 46.6,
    "endTime": 47.7,
    "text": "Tell me why."
  },
  {
    "startTime": 48.0,
    "endTime": 51.1,
    "text": "Ain't nothing but a mistake."
  },
  {
    "startTime": 51.4,
    "endTime": 52.699999999999996,
    "text": "Now number five."
  },
  {
    "startTime": 53.0,
    "endTime": 57.0,
    "text": "I never wanna hear you say."
  },
  {
    "startTime": 57.2,
    "endTime": 61.203,
    "text": "I want it that way."
  },
  {
    "startTime": 62.1,
