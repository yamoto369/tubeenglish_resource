[
  {
    "startTime": 3.44,
    "endTime": 6.0,
    "text": "Some kid on the playground pushed me."
  },
  {
    "startTime": 6.0,
    "endTime": 7.7,
    "text": "I want you to teach him a lesson."
  },
  {
    "startTime": 7.7,
    "endTime": 9.9,
    "text": "I want you to pound him into the ground."
  },
  {
    "startTime": 9.9,
    "endTime": 10.8,
    "text": "Forget it."
  },
  {
    "startTime": 10.8,
    "endTime": 14.420000000000002,
    "text": "I'm not going over to some kids house to beat him up for you."
  },
  {
    "startTime": 14.42,
    "endTime": 15.46,
    "text": "You don't have to."
  },
  {
    "startTime": 15.47,
    "endTime": 16.48,
    "text": "I brought him here."
  },
  {
    "startTime": 16.49,
    "endTime": 17.599999999999998,
    "text": "What?"
  },
  {
    "startTime": 17.6,
    "endTime": 19.25,
    "text": "This is the kid that pushed you?"
  },
  {
    "startTime": 19.25,
    "endTime": 21.14,
    "text": "I can't beat up a little kid."
  },
  {
    "startTime": 21.15,
    "endTime": 22.459999999999997,
    "text": "You're my big brother."
  },
  {
    "startTime": 22.47,
    "endTime": 24.299999999999997,
    "text": "You're supposed to stand up for me."
  },
  {
    "startTime": 24.3,
    "endTime": 26.01,
    "text": "He is just a little kid."
  },
  {
    "startTime": 26.02,
    "endTime": 27.439999999999998,
    "text": "But on the home team."
  },
  {
    "startTime": 27.45,
    "endTime": 29.84,
    "text": "Whatever happened to your team, spirit?"
  },
  {
    "startTime": 29.85,
    "endTime": 31.1,
    "text": "I won't do it."
  },
  {
    "startTime": 31.1,
    "endTime": 33.24,
    "text": "You won't hit him for me?"
  },
  {
    "startTime": 33.25,
    "endTime": 33.84,
    "text": "No."
  },
  {
    "startTime": 33.85,
    "endTime": 36.300000000000004,
    "text": "Could you get your dog to bite him for me?"
  },
  {
    "startTime": 36.31,
    "endTime": 36.95,
    "text": "No."
  },
  {
    "startTime": 36.95,
    "endTime": 40.410000000000004,
    "text": "Would you look at him crossly for me?"
  },
  {
    "startTime": 40.42,
    "endTime": 40.95,
    "text": "Good."
  },
  {
    "startTime": 40.95,
    "endTime": 41.790000000000006,
    "text": "Grief!"
  },
  {
    "startTime": 41.8,
    "endTime": 43.86,
    "text": "Look, kid, why did you push Sally?"
  },
  {
    "startTime": 43.87,
    "endTime": 45.169999999999995,
    "text": "It was an accident."
  },
  {
    "startTime": 45.18,
    "endTime": 47.03,
    "text": "I tripped on a rock and fell into her."
  },
  {
    "startTime": 47.04,
    "endTime": 48.81,
    "text": "A likely story."
  },
  {
    "startTime": 48.82,
    "endTime": 51.2,
    "text": "Sally, I think you should let him go home."
  },
  {
    "startTime": 51.2,
    "endTime": 52.59,
    "text": "He seems nice enough."
  },
  {
    "startTime": 52.6,
    "endTime": 53.7,
    "text": "He just tripped."
  },
  {
    "startTime": 53.79,
    "endTime": 54.55,
    "text": "It's true."
  },
  {
    "startTime": 54.55,
    "endTime": 55.75,
    "text": "I would never push Sally."
  },
  {
    "startTime": 55.76,
    "endTime": 56.949999999999996,
    "text": "I think she's cute."
  },
  {
    "startTime": 56.95,
    "endTime": 58.900000000000006,
    "text": "He just thinks you're cute, Sally."
  },
  {
    "startTime": 58.9,
    "endTime": 61.56,
    "text": "Little kids do crazy things when they're in love."
  },
  {
    "startTime": 61.56,
    "endTime": 65.56,
    "text": "What could he possibly know about love?"
  },
  {
    "startTime": 65.56,
    "endTime": 67.63,
    "text": "Look here, kid."
  },
  {
    "startTime": 67.64,
    "endTime": 69.4,
    "text": "You better watch your step."
  },
  {
    "startTime": 69.4,
    "endTime": 72.9,
    "text": "Next time you push me around, we won't go so easy on you."
  },
  {
    "startTime": 72.91,
    "endTime": 75.25999999999999,
    "text": "Now get lost."
  },
  {
    "startTime": 76.54,
    "endTime": 77.86,
    "text": "Stupid kid."
  },
  {
    "startTime": 80.14,
    "endTime": 82.7,
    "text": "Weren't you awfully hard on him?"
  },
  {
    "startTime": 82.7,
    "endTime": 84.25,
    "text": "I think he's cute."
  },
  {
    "startTime": 85.54,
    "endTime": 85.96000000000001,
    "text": "Mm hmm."
  }
]