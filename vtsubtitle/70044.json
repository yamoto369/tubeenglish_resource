[
  {
    "startTime": 1.0,
    "endTime": 4.3,
    "text": "♪♪"
  },
  {
    "startTime": 10.844,
    "endTime": 11.886,
    "text": "Michael Banks: I honestly can't remember why"
  },
  {
    "startTime": 11.886,
    "endTime": 13.177999999999999,
    "text": "we kept most of this stuff to begin with."
  },
  {
    "startTime": 13.471,
    "endTime": 15.39,
    "text": "Don't you remember that kite?"
  },
  {
    "startTime": 15.39,
    "endTime": 18.226,
    "text": "We used to love flying that with Mother and Father."
  },
  {
    "startTime": 18.893,
    "endTime": 21.21,
    "text": "Michael Banks: Those days are long behind me."
  },
  {
    "startTime": 32.907,
    "endTime": 34.159,
    "text": "As I live and breathe."
  },
  {
    "startTime": 36.995,
    "endTime": 39.538,
    "text": "I was flying the kite and it got caught on a nanny."
  },
  {
    "startTime": 42.25,
    "endTime": 42.834,
    "text": "Mary…"
  },
  {
    "startTime": 42.834,
    "endTime": 45.300000000000004,
    "text": "…Poppins. You came back."
  },
  {
    "startTime": 45.253,
    "endTime": 46.755,
    "text": "You seem hardly to have aged at all."
  },
  {
    "startTime": 47.47,
    "endTime": 47.964,
    "text": "Really?!"
  },
  {
    "startTime": 47.964,
    "endTime": 50.216,
    "text": "One never discusses a woman's age, Michael."
  },
  {
    "startTime": 50.216,
    "endTime": 51.593,
    "text": "Would have hoped I taught you better."
  },
  {
    "startTime": 57.974,
    "endTime": 60.141999999999996,
    "text": "What brings you here after all this time?"
  },
  {
    "startTime": 60.143,
    "endTime": 61.561,
    "text": "Same thing that brought me the first time:"
  },
  {
    "startTime": 61.561,
    "endTime": 63.354,
    "text": "I have come to look after the Banks children."
  },
  {
    "startTime": 63.354,
    "endTime": 64.105,
    "text": "Us?"
  },
  {
    "startTime": 64.105,
    "endTime": 65.65,
    "text": "Oh yes, you too."
  },
  {
    "startTime": 68.68,
    "endTime": 70.402,
    "text": "Michael Banks: We're about to lose our home!"
  },
  {
    "startTime": 70.403,
    "endTime": 72.906,
    "text": "Everything's fallen to pieces since your mother…"
  },
  {
    "startTime": 76.785,
    "endTime": 77.994,
    "text": "I miss Mother."
  },
  {
    "startTime": 79.579,
    "endTime": 86.419,
    "text": "♪♪ Nothing's gone forever only out of place. ♪♪"
  },
  {
    "startTime": 88.338,
    "endTime": 90.631,
    "text": "It's a good thing you've come along when you did Mary Poppins."
  },
  {
    "startTime": 92.884,
    "endTime": 93.843,
    "text": "How'd you do that?"
  },
  {
    "startTime": 93.843,
    "endTime": 94.552,
    "text": "Do what?"
  },
  {
    "startTime": 98.306,
    "endTime": 100.30799999999999,
    "text": "♪♪"
  },
  {
    "startTime": 108.24,
    "endTime": 109.734,
    "text": "So you've been off filling the childrens' heads with"
  },
  {
    "startTime": 109.734,
    "endTime": 110.693,
    "text": "stuff and nonsense."
  },
  {
    "startTime": 112.28,
    "endTime": 113.822,
    "text": "You've forgotten what it's like…"
  },
  {
    "startTime": 114.656,
    "endTime": 116.32000000000001,
    "text": "to be a child."
  },
  {
    "startTime": 116.866,
    "endTime": 117.867,
    "text": "♪♪"
  },
  {
    "startTime": 130.38,
    "endTime": 131.464,
    "text": "Everything is possible."
  },
  {
    "startTime": 132.882,
    "endTime": 133.883,
    "text": "Even the impossible."
  },
  {
    "startTime": 137.971,
    "endTime": 139.139,
    "text": "Off we go."
  },
  {
    "startTime": 140.431,
    "endTime": 142.14200000000002,
    "text": "♪♪"
  }
]