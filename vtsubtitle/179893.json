  {
    "startTime": 171.839,
    "endTime": 173.839,
    "text": "Now you will join me."
  },
  {
    "startTime": 173.839,
    "endTime": 175.839,
    "text": "Step away from the rebel."
  },
  {
    "startTime": 175.839,
    "endTime": 176.839,
    "text": "Don't shoot him."
  },
  {
    "startTime": 176.839,
    "endTime": 177.839,
    "text": "He's my brother."
  },
  {
    "startTime": 177.839,
    "endTime": 179.839,
    "text": "Your brother's a Sith warrior?"
  },
  {
    "startTime": 179.839,
    "endTime": 180.839,
    "text": "No, I mean, yes."
  },
  {
    "startTime": 180.839,
    "endTime": 182.839,
    "text": "I mean, it's a recent development."
  },
  {
    "startTime": 182.839,
    "endTime": 184.839,
    "text": "Wait, why are you helping me?"
  },
  {
    "startTime": 184.839,
    "endTime": 185.839,
    "text": "I'm a rebel."
  },
  {
    "startTime": 185.839,
    "endTime": 186.839,
    "text": "I had to."
  },
  {
    "startTime": 186.839,
    "endTime": 187.839,
    "text": "I couldn't just leave you hanging."
  },
  {
    "startTime": 187.839,
    "endTime": 188.839,
    "text": "Hey, heads up."
  },
  {
    "startTime": 188.839,
    "endTime": 189.839,
    "text": "Ah!"
  },
  {
    "startTime": 189.839,
