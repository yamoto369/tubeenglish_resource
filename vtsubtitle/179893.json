  },
  {
    "startTime": 208.839,
    "endTime": 211.839,
    "text": "You're gonna split out the elastic."
  },
  {
    "startTime": 211.839,
    "endTime": 212.839,
    "text": "Fearme, please, stop."
  },
  {
    "startTime": 212.839,
    "endTime": 213.839,
    "text": "Percival, stop!"
  },
  {
    "startTime": 213.839,
