[
  {
    "startTime": 0.0,
    "endTime": 11.84,
    "text": "What is that?"
  },
  {
    "startTime": 11.84,
    "endTime": 19.759999999999998,
    "text": "It looks like it was built by Ferb?"
  },
  {
    "startTime": 19.76,
    "endTime": 22.840000000000003,
    "text": "Cool face paint!"
  },
  {
    "startTime": 22.84,
    "endTime": 25.36,
    "text": "So is there a face painting booth around here or something?"
  },
  {
    "startTime": 25.36,
    "endTime": 26.36,
    "text": "And where's Perry?"
  },
  {
    "startTime": 26.36,
    "endTime": 27.759999999999998,
    "text": "Were you able to find him?"
  },
  {
    "startTime": 27.76,
    "endTime": 28.76,
    "text": "I found this."
  },
  {
    "startTime": 28.76,
    "endTime": 29.76,
    "text": "The Sithinator."
  },
  {
    "startTime": 29.76,
    "endTime": 33.0,
    "text": "And I've modified it so I can create an army of Sith warriors."
  },
  {
    "startTime": 33.0,
    "endTime": 36.4,
    "text": "Join me on the dark side, brother."
  },
  {
    "startTime": 36.4,
    "endTime": 41.638999999999996,
    "text": "Shut up, Ferb."
  },
  {
    "startTime": 41.639,
    "endTime": 42.799,
    "text": "Come on, let's get out of here."
  },
  {
    "startTime": 42.799,
    "endTime": 43.799,
    "text": "Isabelle already left."
  },
  {
    "startTime": 43.799,
    "endTime": 46.439,
    "text": "We gotta find a ship so we can get home."
  },
  {
    "startTime": 46.439,
    "endTime": 47.84,
    "text": "Dark side is my home now."
  },
  {
    "startTime": 47.84,
    "endTime": 48.84,
    "text": "Whoa!"
  },
  {
    "startTime": 48.84,
    "endTime": 49.84,
    "text": "Ferb!"
  },
  {
    "startTime": 49.84,
    "endTime": 50.84,
    "text": "What are you doing?"
  },
  {
    "startTime": 51.84,
    "endTime": 57.84,
    "text": "Come on, quit messing around."
  },
  {
    "startTime": 57.84,
    "endTime": 61.84,
    "text": "Hey, this isn't funny."
  },
  {
    "startTime": 61.84,
    "endTime": 65.839,
    "text": "I'm not gonna fight you."
  },
  {
    "startTime": 65.839,
    "endTime": 74.839,
    "text": "If you will not join me, then I must destroy you."
  },
  {
    "startTime": 74.839,
    "endTime": 76.839,
    "text": "Okay, I can see you're serious."
  },
  {
    "startTime": 76.839,
    "endTime": 79.839,
    "text": "Ferb, this isn't you."
  },
  {
    "startTime": 79.839,
    "endTime": 82.839,
    "text": "We're brothers."
  },
  {
    "startTime": 82.839,
    "endTime": 86.839,
    "text": "Hey, this is crazy."
  },
  {
    "startTime": 86.839,
    "endTime": 92.839,
    "text": "We would never try to hurt each other."
  },
  {
    "startTime": 92.839,
    "endTime": 98.839,
    "text": "Is that the best you got?"
  },
  {
    "startTime": 98.839,
    "endTime": 104.839,
    "text": "Oh, we're allowing modifications, huh?"
  },
  {
    "startTime": 105.839,
    "endTime": 110.839,
    "text": "Give me a sec."
  },
  {
    "startTime": 130.839,
    "endTime": 131.839,
    "text": "You'll be back."
  },
  {
    "startTime": 131.839,
    "endTime": 132.839,
    "text": "Hey, you're too late."
  },
  {
    "startTime": 132.839,
    "endTime": 133.839,
    "text": "There's no stopping you now."
  },
  {
    "startTime": 133.839,
    "endTime": 134.839,
    "text": "Hey, it's cold in here."
  },
  {
    "startTime": 134.839,
