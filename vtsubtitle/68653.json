[
  {
    "startTime": 0.49,
    "endTime": 2.42,
    "text": "Hi, this is Kee from BBC Learning English."
  },
  {
    "startTime": 2.42,
    "endTime": 4.66,
    "text": "Today I'm going to tell you three different"
  },
  {
    "startTime": 4.66,
    "endTime": 7.28,
    "text": "ways of using the phrasal verb take off."
  },
  {
    "startTime": 7.28,
    "endTime": 10.92,
    "text": "First, we use take off to describe removing clothing."
  },
  {
    "startTime": 11.34,
    "endTime": 14.7,
    "text": "It's really hot here so I'm going to take off my jumper."
  },
  {
    "startTime": 19.18,
    "endTime": 23.16,
    "text": "You can also separate take and off and say:"
  },
  {
    "startTime": 23.16,
    "endTime": 25.1,
    "text": "take my jumper off."
  },
  {
    "startTime": 25.34,
    "endTime": 27.78,
    "text": "Second, we use take off to describe"
  },
  {
    "startTime": 27.78,
    "endTime": 29.84,
    "text": "something becoming successful."
  },
  {
    "startTime": 29.84,
    "endTime": 31.108999999999998,
    "text": "I'm going to be rich."
  },
  {
    "startTime": 31.109,
    "endTime": 33.5,
    "text": "My business has taken off."
  },
  {
    "startTime": 33.5,
    "endTime": 37.3,
    "text": "Third, we use take off to describe not going to work."
  },
  {
    "startTime": 37.3,
    "endTime": 40.51,
    "text": "I'm going to take a day off work tomorrow."
  },
  {
    "startTime": 40.51,
    "endTime": 41.78,
    "text": "So, we can say:"
  },
  {
    "startTime": 41.78,
    "endTime": 44.64,
    "text": "take off my jumper, or take my jumper off."
  },
  {
    "startTime": 44.64,
    "endTime": 46.160000000000004,
    "text": "My business has taken off."
  },
  {
    "startTime": 46.16,
    "endTime": 48.12,
    "text": "And lastly, take a day off."
  }
]