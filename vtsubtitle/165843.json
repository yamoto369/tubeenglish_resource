  },
  {
    "startTime": 50.4,
    "endTime": 51.384,
    "text": "I lied."
  },
  {
    "startTime": 51.843,
    "endTime": 55.05500000000001,
    "text": "Happy holidays. Feliz Navidad."
  },
  {
    "startTime": 56.222,
    "endTime": 58.6,
    "text": "Allo, and Merry Christmas."
  },
  {
    "startTime": 58.8,
    "endTime": 60.0,
    "text": "Oh, thank you, sir."
  },
  {
    "startTime": 60.2,
    "endTime": 61.519000000000005,
    "text": "Here's some joy."
  },
  {
    "startTime": 62.9,
    "endTime": 64.272,
    "text": "- Phoebe.  - Hey."
  },
  {
    "startTime": 64.3,
    "endTime": 65.3,
    "text": "Come to see how it's going."
  },
  {
    "startTime": 65.4,
    "endTime": 67.10000000000001,
    "text": "- Well, it's going okay.   - Oh, good."
  },
  {
    "startTime": 67.1,
    "endTime": 68.443,
    "text": "Here, let me help you out."
  },
  {
    "startTime": 68.526,
    "endTime": 70.2,
    "text": "- Oh, thanks.   - Yeah."
  },
  {
    "startTime": 70.3,
    "endTime": 71.529,
    "text": "Wow."
  },
  {
    "startTime": 72.8,
    "endTime": 75.45,
    "text": "Is that a new suede jacket? It looks really expensive."
