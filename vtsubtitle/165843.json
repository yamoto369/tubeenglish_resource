  {
    "startTime": 174.591,
    "endTime": 175.842,
    "text": "Yeah."
  },
  {
    "startTime": 175.884,
    "endTime": 180.6,
    "text": "Oh, but you know what? I can't go totally back because street Phoebe really wouldn't be friends with you guys."
  },
  {
    "startTime": 193.943,
    "endTime": 196.0,
    "text": "Whoa-oh-oh! Wait a minute; open your hand."
