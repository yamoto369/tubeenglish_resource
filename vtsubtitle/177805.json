  },
  {
    "startTime": 39.189,
    "endTime": 40.2,
    "text": "Now, presents."
  },
  {
    "startTime": 40.4,
    "endTime": 42.417,
    "text": "And a nice big box for Ron."
  },
  {
    "startTime": 42.417,
    "endTime": 44.141,
    "text": "Big box for you."
  },
  {
    "startTime": 44.141,
    "endTime": 47.510999999999996,
    "text": "And, um .."
  },
  {
    "startTime": 47.511,
    "endTime": 47.1,
    "text": "Ooh."
  },
  {
    "startTime": 47.1,
    "endTime": 48.800000000000004,
    "text": "There you go, George."
  },
  {
    "startTime": 48.8,
    "endTime": 50.122,
    "text": "Come on. Open up."
  },
  {
    "startTime": 50.122,
    "endTime": 51.113,
    "text": "I want to see your faces."
  },
  {
    "startTime": 51.113,
    "endTime": 52.495,
    "text": "Yeah."
  },
  {
    "startTime": 52.495,
    "endTime": 53.422,
    "text": "Try it on."
  },
  {
    "startTime": 53.422,
    "endTime": 53.9,
    "text": "Thanks, Mum."
  },
  {
    "startTime": 54.0,
    "endTime": 58.196,
    "text": "It's perfect."
  },
  {
    "startTime": 58.196,
    "endTime": 59.028,
    "text": "Guys, let me go."
  },
  {
    "startTime": 59.028,
    "endTime": 60.0,
    "text": "Clever Harry."
  },
  {
    "startTime": 60.0,
    "endTime": 61.42,
    "text": "But not clever enough."
  },
  {
    "startTime": 61.42,
    "endTime": 63.236000000000004,
    "text": "Besides, we've got a better way."
  },
  {
    "startTime": 63.236,
    "endTime": 63.8,
    "text": "Guys, come on."
  },
  {
    "startTime": 63.8,
    "endTime": 65.121,
    "text": "I'm trying to get to Hogsmeade."
  },
  {
    "startTime": 65.121,
    "endTime": 66.17,
    "text": "We know."
  },
  {
    "startTime": 66.17,
    "endTime": 69.31,
    "text": "Harry, I think it's Christmas Eve."
  },
  {
    "startTime": 69.31,
    "endTime": 72.5,
    "text": "Merry Christmas, Hermione."
  },
  {
    "startTime": 72.5,
    "endTime": 83.9,
    "text": "Merry Christmas, Harry."
  },
  {
    "startTime": 83.9,
    "endTime": 85.025,
    "text": "Pie?"
  },
  {
    "startTime": 85.025,
    "endTime": 86.31800000000001,
    "text": "Not for me, no."
  },
  {
    "startTime": 86.318,
    "endTime": 87.185,
    "text": "What is it?"
  },
  {
    "startTime": 87.185,
    "endTime": 89.07300000000001,
    "text": "Some kind of cloak."
  },
  {
    "startTime": 89.073,
    "endTime": 93.118,
    "text": "Well, let's see then. Put it on."
  },
  {
    "startTime": 93.118,
    "endTime": 94.443,
    "text": "Woah."
  },
  {
    "startTime": 94.443,
    "endTime": 96.0,
    "text": "My body's gone."
  },
  {
    "startTime": 96.0,
    "endTime": 97.7,
    "text": "I know what that is."
  },
  {
    "startTime": 97.7,
    "endTime": 103.09,
    "text": "That's an invisibility cloak!"
  },
  {
    "startTime": 103.09,
    "endTime": 105.09700000000001,
    "text": "Harry!"
  },
  {
    "startTime": 105.097,
    "endTime": 107.062,
    "text": "Bloody hell, Harry."
  },
  {
    "startTime": 107.062,
    "endTime": 111.0,
    "text": "That was not funny."
  },
  {
    "startTime": 111.0,
    "endTime": 113.275,
    "text": "Thanks, Mum."
  },
  {
    "startTime": 113.275,
    "endTime": 114.34,
    "text": "Oh! Harry."
  },
  {
    "startTime": 114.34,
    "endTime": 116.006,
    "text": "Harry."
  },
  {
    "startTime": 116.006,
    "endTime": 119.0,
    "text": "There you are."
  },
  {
    "startTime": 119.0,
    "endTime": 120.0,
    "text": "Happy Christmas."
  },
  {
    "startTime": 120.0,
    "endTime": 121.397,
    "text": "Thank you."
  },
  {
    "startTime": 121.397,
    "endTime": 122.48700000000001,
    "text": "Lovely to have you with us."
  },
  {
    "startTime": 122.487,
    "endTime": 123.03099999999999,
    "text": "Thank you."
  },
  {
    "startTime": 123.031,
    "endTime": 134.20000000000002,
    "text": "A Christmas toast to Mr. Harry Potter, without whom I would not be here."
  },
  {
    "startTime": 134.4,
    "endTime": 135.654,
    "text": "Harry."
  },
  {
