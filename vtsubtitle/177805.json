    "endTime": 1.4,
    "text": "Harry, wake up!"
  },
  {
    "startTime": 1.6,
    "endTime": 6.6,
    "text": "Come on, Harry! Wake up!"
  },
  {
    "startTime": 6.8,
    "endTime": 8.2,
    "text": "Happy Christmas, Harry."
  },
  {
    "startTime": 8.2,
    "endTime": 9.399999999999999,
    "text": "Happy Christmas, Ron."
  },
  {
    "startTime": 9.4,
    "endTime": 10.489,
    "text": "What are you wearing?"
  },
  {
    "startTime": 10.489,
    "endTime": 12.3,
    "text": "Oh, my mum made it."
  },
  {
    "startTime": 12.5,
    "endTime": 14.2,
    "text": "Looks like you've got one too."
  },
  {
    "startTime": 14.2,
    "endTime": 15.5,
    "text": "I've got presents?"
  },
  {
    "startTime": 15.5,
    "endTime": 28.108,
    "text": "Yeah."
  },
  {
    "startTime": 28.108,
    "endTime": 31.1,
    "text": "Is that Hermione Granger with Viktor Krum?"
  },
  {
    "startTime": 31.254,
    "endTime": 38.0,
    "text": "No. Absolutely not."
  },
  {
    "startTime": 38.0,
    "endTime": 39.189,
