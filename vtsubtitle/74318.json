[
  {
    "startTime": 0.0,
    "endTime": 2.794,
    "text": "Everyone, Bonnie made a friend in class!"
  },
  {
    "startTime": 2.794,
    "endTime": 4.671,
    "text": "Oh she's already making friends."
  },
  {
    "startTime": 4.671,
    "endTime": 7.507,
    "text": "No, no she literally made a new friend."
  },
  {
    "startTime": 7.507,
    "endTime": 10.135,
    "text": "I want you to meet...Forky!"
  },
  {
    "startTime": 10.135,
    "endTime": 11.136,
    "text": "H-h-h-hi?"
  },
  {
    "startTime": 11.136,
    "endTime": 12.0,
    "text": "Hello! Hi!"
  },
  {
    "startTime": 12.0,
    "endTime": 13.5,
    "text": "Aaaaahh!"
  },
  {
    "startTime": 13.5,
    "endTime": 14.597,
    "text": "He's a spork!"
  },
  {
    "startTime": 14.597,
    "endTime": 15.724,
    "text": "Yes, yeah, I know."
  },
  {
    "startTime": 15.724,
    "endTime": 17.2,
    "text": "♪♪"
  },
  {
    "startTime": 17.2,
    "endTime": 20.186,
    "text": "Forky is the most important toy to Bonnie right now."
  },
  {
    "startTime": 20.478,
    "endTime": 22.772000000000002,
    "text": "We all have to make sure nothing happens to him."
  },
  {
    "startTime": 23.857,
    "endTime": 25.66,
    "text": "Woody! We have a situation."
  },
  {
    "startTime": 26.151,
    "endTime": 27.318,
    "text": "I am not a toy."
  },
  {
    "startTime": 27.318,
    "endTime": 31.197000000000003,
    "text": "I was made for soup, salad, maybe chili, and then the trash!"
  },
  {
    "startTime": 31.197,
    "endTime": 32.406,
    "text": "Freedom!"
  },
  {
    "startTime": 33.0,
    "endTime": 34.409,
    "text": "Buzz! We've gotta get Forky!"
  },
  {
    "startTime": 34.409,
    "endTime": 35.16,
    "text": "Affirmative!"
  },
  {
    "startTime": 36.5,
    "endTime": 38.329,
    "text": "Aaahh! Ohh...owww..."
  },
  {
    "startTime": 39.539,
    "endTime": 40.582,
    "text": "Why am I alive?"
  },
  {
    "startTime": 40.582,
    "endTime": 41.958,
    "text": "You're Bonnie's toy."
  },
  {
    "startTime": 41.958,
    "endTime": 47.5,
    "text": "You are going to help create happy memories that will last for the rest of her life!"
  },
  {
    "startTime": 47.5,
    "endTime": 48.548,
    "text": "Huh? What?"
  },
  {
    "startTime": 48.548,
    "endTime": 50.800000000000004,
    "text": "Ohh! Gah! Ahh! I! Uhhh! Ugh."
  },
  {
    "startTime": 53.178,
    "endTime": 54.846,
    "text": "Bo? Forky, come on!"
  },
  {
    "startTime": 55.346,
    "endTime": 55.846,
    "text": "Bo?"
  },
  {
    "startTime": 55.847,
    "endTime": 56.431000000000004,
    "text": "Bo?"
  },
  {
    "startTime": 56.431,
    "endTime": 58.391,
    "text": "Hi there! My name is Gabby Gabby."
  },
  {
    "startTime": 58.391,
    "endTime": 59.391,
    "text": "We can't stay."
  },
  {
    "startTime": 59.392,
    "endTime": 61.77,
    "text": "Yes you can. Boys?"
  },
  {
    "startTime": 62.145,
    "endTime": 63.188,
    "text": "Aaahhh!"
  },
  {
    "startTime": 63.73,
    "endTime": 65.5,
    "text": "Woody, behind you!"
  },
  {
    "startTime": 66.0,
    "endTime": 67.525,
    "text": "Bo! What are you doing here?"
  },
  {
    "startTime": 67.525,
    "endTime": 68.902,
    "text": "No time to explain."
  },
  {
    "startTime": 68.902,
    "endTime": 69.569,
    "text": "Come with me."
  },
  {
    "startTime": 69.569,
    "endTime": 70.904,
    "text": "We need to get back to our kid."
  },
  {
    "startTime": 70.904,
    "endTime": 74.532,
    "text": "Aww, Sheriff Woody, always comin' to the rescue."
  },
  {
    "startTime": 74.532,
    "endTime": 75.783,
    "text": "Bonnie needs Forky."
  },
  {
    "startTime": 75.784,
    "endTime": 80.872,
    "text": "Woody, who needs a kid's room when you can have all of this...?"
  },
  {
    "startTime": 80.872,
    "endTime": 81.831,
    "text": "Wow."
  },
  {
    "startTime": 81.831,
    "endTime": 84.125,
    "text": "Woody, aren't we goin' to Bonnie?"
  },
  {
    "startTime": 84.375,
    "endTime": 86.0,
    "text": "♪♪"
  },
  {
    "startTime": 86.0,
    "endTime": 87.0,
    "text": "We have to find them."
  },
  {
    "startTime": 87.0,
    "endTime": 87.7,
    "text": "What do we do, Buzz?"
  },
  {
    "startTime": 87.7,
    "endTime": 88.8,
    "text": "What would Woody do?"
  },
  {
    "startTime": 88.8,
    "endTime": 90.3,
    "text": "Jump out of a moving vehicle."
  },
  {
    "startTime": 90.3,
    "endTime": 91.216,
    "text": "Let's go!"
  },
  {
    "startTime": 91.216,
    "endTime": 92.92599999999999,
    "text": "Hey, if you gotta go, you gotta go."
  },
  {
    "startTime": 97.0,
    "endTime": 100.934,
    "text": "You know, you've handled this lost toy life better than I could."
  },
  {
    "startTime": 100.934,
    "endTime": 102.685,
    "text": "Open your eyes Woody."
  },
  {
    "startTime": 102.685,
    "endTime": 104.646,
    "text": "There's plenty of kids out there."
  },
  {
    "startTime": 104.646,
    "endTime": 105.897,
    "text": "Sometimes change can be good."
  },
  {
    "startTime": 105.897,
    "endTime": 108.0,
    "text": "You can't teach this old toy new tricks."
  },
  {
    "startTime": 108.0,
    "endTime": 108.983,
    "text": "You'd be surprised."
  },
  {
    "startTime": 110.0,
    "endTime": 111.0,
    "text": "Bonnie?!"
  },
  {
    "startTime": 111.0,
    "endTime": 112.32,
    "text": "We're going home, Forky!"
  },
  {
    "startTime": 114.572,
    "endTime": 115.61500000000001,
    "text": "Bonnie, I'm comin'!"
  },
  {
    "startTime": 117.117,
    "endTime": 118.159,
    "text": "On my way Woody!"
  },
  {
    "startTime": 118.159,
    "endTime": 120.203,
    "text": "To infinity...and beyond!"
  },
  {
    "startTime": 121.746,
    "endTime": 122.747,
    "text": "Aaahhh!"
  },
  {
    "startTime": 122.747,
    "endTime": 123.456,
    "text": "Whoa, whoa!"
  },
  {
    "startTime": 123.456,
    "endTime": 124.20700000000001,
    "text": "Kaboom!"
  },
  {
    "startTime": 125.875,
    "endTime": 126.96,
    "text": "Don't let Woody leave!"
  },
  {
    "startTime": 127.669,
    "endTime": 129.628,
    "text": "Kids lose their toys every day."
  },
  {
    "startTime": 129.628,
    "endTime": 131.714,
    "text": "I was made to help a child."
  },
  {
    "startTime": 131.714,
    "endTime": 133.55,
    "text": "I don't remember it being this hard."
  },
  {
    "startTime": 133.55,
    "endTime": 134.0,
    "text": "Woody?"
  },
  {
    "startTime": 134.0,
    "endTime": 135.468,
    "text": "Somebody's whispering in your ear..."
  },
  {
    "startTime": 137.0,
    "endTime": 138.68,
    "text": "Everything's gonna be ok."
  },
  {
    "startTime": 140.223,
    "endTime": 143.268,
    "text": "♪♪"
  }
]