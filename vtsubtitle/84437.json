    "endTime": 599.749,
    "text": "THE WALLS!"
  },
  {
    "startTime": 599.749,
    "endTime": 601.618,
    "text": ">> THIS LITTLE TITANIC SMEAR,"
  },
  {
    "startTime": 601.618,
    "endTime": 602.152,
    "text": "YEAH, YEAH."
  },
  {
    "startTime": 602.152,
    "endTime": 603.9200000000001,
    "text": ">> Jimmy: ARE YOU THAT ALL"
  },
  {
    "startTime": 603.92,
    "endTime": 607.0559999999999,
    "text": "BALANCED ALL THE TIME THAT YOU"
  },
  {
    "startTime": 607.057,
    "endTime": 608.725,
    "text": "HAVE TO -- SPIDERMAN IS IN THE"
  },
  {
    "startTime": 608.725,
    "endTime": 608.9250000000001,
    "text": "HOUSE."
  },
  {
    "startTime": 608.925,
    "endTime": 610.06,
    "text": "THEY'RE ALL OVER THE WALLS."
  },
  {
    "startTime": 610.06,
    "endTime": 610.794,
    "text": ">> YES."
  },
  {
    "startTime": 610.794,
    "endTime": 611.728,
    "text": ">> Jimmy: YEAH, YOU HAVE TO"
  },
  {
    "startTime": 611.728,
    "endTime": 612.429,
    "text": "PROTECT THE WALLS."
  },
  {
    "startTime": 612.429,
    "endTime": 614.314,
    "text": ">> PROTECT THE WALLS AT ALL"
  },
  {
    "startTime": 614.314,
    "endTime": 614.514,
    "text": "COSTS."
  },
  {
    "startTime": 614.514,
    "endTime": 616.049,
    "text": ">> Jimmy: WHAT'S GOING ON FOR"
  },
  {
    "startTime": 616.049,
    "endTime": 618.084,
    "text": "CHRISTMAS?"
  },
  {
    "startTime": 618.084,
    "endTime": 618.4499999999999,
    "text": "YOU HAVE A PLAN?"
  },
  {
    "startTime": 618.451,
    "endTime": 619.119,
    "text": "YOU GOING HOME?"
  },
  {
    "startTime": 619.119,
    "endTime": 621.788,
    "text": ">> UM, PROBABLY NOT."
  },
  {
    "startTime": 621.788,
    "endTime": 623.289,
    "text": "MY DAD RUINED THANKSGIVING, I'VE"
  },
  {
    "startTime": 623.289,
    "endTime": 625.058,
    "text": "HAD ENOUGH."
  },
  {
    "startTime": 625.058,
    "endTime": 627.727,
    "text": ">> Jimmy: YOU KNOW WHAT WOULD BE"
  },
  {
    "startTime": 627.727,
    "endTime": 628.962,
    "text": "A FUN THING, INVITE YOUR FRIENDS"
  },
  {
    "startTime": 628.962,
    "endTime": 630.33,
    "text": "OVER TO THE HOUSE, LET THEM CLOG"
  },
  {
    "startTime": 630.33,
    "endTime": 632.082,
    "text": "UP THE TOILETS."
  },
  {
    "startTime": 632.082,
    "endTime": 634.584,
    "text": "THE YULETIDE CLOG, A TRADITION"
  },
  {
    "startTime": 634.584,
    "endTime": 634.818,
    "text": "FOR YOU."
  },
  {
    "startTime": 634.818,
    "endTime": 636.953,
    "text": ">> THAT WOULD BE VERY FESTIVE,"
  },
  {
    "startTime": 636.953,
    "endTime": 637.454,
    "text": "YES."
  },
  {
    "startTime": 637.454,
    "endTime": 637.92,
    "text": "I LOVE T."
  },
  {
    "startTime": 637.921,
    "endTime": 640.7570000000001,
    "text": ">> Jimmy: THE MOVIE IS CALLED"
  },
  {
    "startTime": 640.757,
    "endTime": 642.7579999999999,
    "text": "JUMANJI, THE NEXT LEVEL"
  }
]