[
  {
    "startTime": 0.0,
    "endTime": 2.04,
    "text": "Welcome to BBC Learning English."
  },
  {
    "startTime": 2.04,
    "endTime": 4.54,
    "text": "I'm Sam and today we're going to look at"
  },
  {
    "startTime": 4.54,
    "endTime": 6.46,
    "text": "adverbs of frequency."
  },
  {
    "startTime": 6.46,
    "endTime": 7.7,
    "text": "You know these!"
  },
  {
    "startTime": 7.7,
    "endTime": 10.68,
    "text": "Always, sometimes, never."
  },
  {
    "startTime": 10.68,
    "endTime": 12.92,
    "text": "But where do they go in a sentence?"
  },
  {
    "startTime": 12.929,
    "endTime": 15.46,
    "text": "Look at 'always' in this sentence."
  },
  {
    "startTime": 15.46,
    "endTime": 19.34,
    "text": "Does it come before or after the verb?"
  },
  {
    "startTime": 19.34,
    "endTime": 23.369,
    "text": "Helen always starts work at seven."
  },
  {
    "startTime": 23.369,
    "endTime": 27.6,
    "text": "The verb is 'starts' and 'always' comes before"
  },
  {
    "startTime": 27.6,
    "endTime": 29.060000000000002,
    "text": "– rule number one."
  },
  {
    "startTime": 29.06,
    "endTime": 30.32,
    "text": "Next sentence:"
  },
  {
    "startTime": 30.32,
    "endTime": 33.82,
    "text": "Helen isn't always happy about this."
  },
  {
    "startTime": 33.82,
    "endTime": 38.04,
    "text": "The verb is 'is' and 'always' was after"
  },
  {
    "startTime": 38.04,
    "endTime": 39.519,
    "text": "– rule number two"
  },
  {
    "startTime": 39.52,
    "endTime": 40.940000000000005,
    "text": "Last sentence:"
  },
  {
    "startTime": 40.94,
    "endTime": 44.55,
    "text": "Helen has always hated early starts."
  },
  {
    "startTime": 44.55,
    "endTime": 45.839,
    "text": "Trick question!"
  },
  {
    "startTime": 45.84,
    "endTime": 50.02,
    "text": "There was an auxiliary verb 'has' and a main verb 'hated'"
  },
  {
    "startTime": 50.02,
    "endTime": 53.42100000000001,
    "text": "and 'always' went after the auxiliary verb"
  },
  {
    "startTime": 53.421,
    "endTime": 55.06,
    "text": "– rule number three"
  }
]