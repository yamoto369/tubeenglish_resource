    "text": "There's this voice."
  },
  {
    "startTime": 37.574,
    "endTime": 39.417,
    "text": "Voice? What does that mean?"
  },
  {
    "startTime": 45.59,
    "endTime": 46.769000000000005,
    "text": "Head for the cliffs!"
  },
  {
    "startTime": 46.834,
    "endTime": 47.856,
    "text": "I'm gonna blow!"
  },
  {
    "startTime": 47.856,
    "endTime": 49.007000000000005,
    "text": "I got you."
  },
  {
    "startTime": 51.318,
    "endTime": 54.303,
    "text": "The kingdom is not safe."
  },
  {
    "startTime": 56.788,
    "endTime": 59.068,
    "text": "Find who is calling to you."
  },
  {
    "startTime": 59.068,
    "endTime": 61.552,
    "text": "They may have answers."
  },
  {
    "startTime": 61.608,
    "endTime": 62.622,
    "text": "I'm going with you."
  },
  {
    "startTime": 62.647,
    "endTime": 63.684,
    "text": "Anna, no."
  },
  {
    "startTime": 63.709,
    "endTime": 67.7,
    "text": "Excuse me, I climbed the North Mountains, survived a frozen heart, and saved you from my ex-boyfriend."
  },
  {
    "startTime": 67.7,
    "endTime": 70.279,
    "text": "So, you know, I'm coming."
  },
  {
    "startTime": 72.155,
    "endTime": 73.162,
    "text": "That's normal."
  },
  {
    "startTime": 76.685,
    "endTime": 78.02,
    "text": "Where are we?"
  },
  {
    "startTime": 80.11,
    "endTime": 81.28,
    "text": "How did you get in the forest?"
  },
  {
    "startTime": 81.28,
    "endTime": 82.723,
    "text": "The mist parted for us."
  },
  {
    "startTime": 82.748,
    "endTime": 83.811,
    "text": "Impossible!"
  },
  {
    "startTime": 84.287,
    "endTime": 85.748,
    "text": "Where did you learn magic?"
  },
  {
    "startTime": 92.74,
    "endTime": 94.295,
    "text": "Elsa, get out of there!"
  },
  {
    "startTime": 94.345,
    "endTime": 96.099,
    "text": "You can't just follow me into fire."
  },
  {
    "startTime": 96.199,
    "endTime": 98.326,
    "text": "Then don't run into fire!"
  },
  {
    "startTime": 102.936,
    "endTime": 104.80000000000001,
    "text": "Magic is very alluring."
  },
  {
    "startTime": 104.8,
