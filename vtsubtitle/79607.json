[
  {
    "startTime": 1.484,
    "endTime": 6.754,
    "text": "Far away, as north as we can go, once stood an enchanted forest."
  },
  {
    "startTime": 6.836,
    "endTime": 8.859,
    "text": "You've seen an enchanted forest?"
