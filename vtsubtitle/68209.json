[
  {
    "startTime": 25.41,
    "endTime": 28.63,
    "text": "It's a late Friday night"
  },
  {
    "startTime": 28.63,
    "endTime": 38.19,
    "text": "The street lamps are shining up in my bedroom"
  },
  {
    "startTime": 38.2,
    "endTime": 44.53,
    "text": "There's a mighty big fight between the thunder and lightning"
  },
  {
    "startTime": 44.53,
    "endTime": 50.61,
    "text": "Wonder who you will lose"
  },
  {
    "startTime": 50.61,
    "endTime": 53.74,
    "text": "I see a party balloon"
  },
  {
    "startTime": 53.74,
    "endTime": 57.480000000000004,
    "text": "And I ain't been invited"
  },
  {
    "startTime": 57.48,
    "endTime": 60.0,
    "text": "Hey look that moon"
  },
  {
    "startTime": 60.0,
    "endTime": 63.68,
    "text": "There ain't nothing like it"
  },
  {
    "startTime": 63.68,
    "endTime": 69.98,
    "text": "All grey and Gold"
  },
  {
    "startTime": 69.98,
    "endTime": 79.96000000000001,
    "text": "Down on Jubilee Road"
  },
  {
    "startTime": 79.96,
    "endTime": 82.839,
    "text": "I see Mr. Bouvier"
  },
  {
    "startTime": 82.84,
    "endTime": 86.9,
    "text": "In his two bedroom basement"
  },
  {
    "startTime": 86.9,
    "endTime": 92.34,
    "text": "In his purple dungarees"
  },
  {
    "startTime": 92.34,
    "endTime": 95.61,
    "text": "He's grumpy and he's gray"
  },
  {
    "startTime": 95.61,
    "endTime": 98.89,
    "text": "Oh, he's sweeping off the pavement"
  },
  {
    "startTime": 98.89,
    "endTime": 105.25,
    "text": "Cigarettes and leaves"
  },
  {
    "startTime": 105.25,
    "endTime": 108.42,
    "text": "His kid's up in China"
  },
  {
    "startTime": 108.42,
    "endTime": 111.42,
    "text": "His wife's up in heaven"
  },
  {
    "startTime": 111.42,
    "endTime": 114.94,
    "text": "Always I wave"
  },
  {
    "startTime": 114.94,
    "endTime": 118.179,
    "text": "'Cause he's got this expression"
  },
  {
    "startTime": 118.18,
    "endTime": 124.54,
    "text": "That he's so alone"
  },
  {
    "startTime": 124.54,
    "endTime": 134.58,
    "text": "Down on Jubilee Road"
  },
  {
    "startTime": 134.58,
    "endTime": 140.14000000000001,
    "text": "Oh, I think tomorrow night"
  },
  {
    "startTime": 140.14,
    "endTime": 146.54,
    "text": "I will knock on his door and hear all about his life"
  },
  {
    "startTime": 146.54,
    "endTime": 152.989,
    "text": "'Cause I think that's the kind of thing that I might like"
  },
  {
    "startTime": 152.99,
    "endTime": 159.59,
    "text": "When I'm old, when I'm old"
  },
  {
    "startTime": 159.59,
    "endTime": 162.85,
    "text": "There's Max and there's Maud"
  },
  {
    "startTime": 162.85,
    "endTime": 166.4,
    "text": "In the house by the station"
  },
  {
    "startTime": 166.4,
    "endTime": 172.31,
    "text": "Call them my best friends"
  },
  {
    "startTime": 172.31,
    "endTime": 175.53,
    "text": "He drinks like a horse"
  },
  {
    "startTime": 175.53,
    "endTime": 185.26,
    "text": "She don't appreciate all this money he seems to spend"
  },
  {
    "startTime": 185.26,
    "endTime": 188.45,
    "text": "I can hear them tonight"
  },
  {
    "startTime": 188.45,
    "endTime": 191.54899999999998,
    "text": "He can't find no vocation"
  },
  {
    "startTime": 191.55,
    "endTime": 198.3,
    "text": "The neighbours they sigh at that new generation"
  },
  {
    "startTime": 198.3,
    "endTime": 204.56,
    "text": "Just getting stoned"
  },
  {
    "startTime": 204.56,
    "endTime": 214.1,
    "text": "Down on Jubilee Road"
  },
  {
    "startTime": 214.1,
    "endTime": 220.19,
    "text": "Oh, I feel the summertime"
  },
  {
    "startTime": 220.19,
    "endTime": 226.46,
    "text": "I will call you up, make everything alright"
  },
  {
    "startTime": 226.46,
    "endTime": 233.8,
    "text": "Then we'll fill up our cups with that bitter wine"
  },
  {
    "startTime": 233.8,
    "endTime": 240.70000000000002,
    "text": "And I'll show you, I'll show you"
  },
  {
    "startTime": 240.7,
    "endTime": 246.11999999999998,
    "text": "Mice still here, your wardrobe still empty"
  },
  {
    "startTime": 246.12,
    "endTime": 253.20000000000002,
    "text": "And the walls are still paper thin"
  },
  {
    "startTime": 253.2,
    "endTime": 255.67,
    "text": "And the neighbours, my dear"
  },
  {
    "startTime": 255.67,
    "endTime": 265.37,
    "text": "I think they still hate me for all these songs I endlessly sing"
  },
  {
    "startTime": 265.37,
    "endTime": 268.24,
    "text": "'Cause it ain't no perfect street"
  },
  {
    "startTime": 268.24,
    "endTime": 271.46000000000004,
    "text": "And I ain't no perfect lover"
  },
  {
    "startTime": 271.46,
    "endTime": 274.62,
    "text": "Life it is brief"
  },
  {
    "startTime": 274.62,
    "endTime": 277.96,
    "text": "I don't think we get no other"
  },
  {
    "startTime": 277.96,
    "endTime": 284.479,
    "text": "Come back home"
  },
  {
    "startTime": 284.48,
    "endTime": 290.86,
    "text": "Down on Jubilee Road"
  },
  {
    "startTime": 290.86,
    "endTime": 300.35,
    "text": "Down on Jubilee Road"
  }
]