[
  {
    "startTime": 0.0,
    "endTime": 3.04,
    "text": "Hi everyone. Tom here for BBC Learning English."
  },
  {
    "startTime": 3.04,
    "endTime": 5.93,
    "text": "Today, I'm going to show you how to use the"
  },
  {
    "startTime": 5.93,
    "endTime": 8.1,
    "text": "future continuous."
  },
  {
    "startTime": 8.1,
    "endTime": 10.58,
    "text": "We use the future continuous"
  },
  {
    "startTime": 10.58,
    "endTime": 13.86,
    "text": "to describe actions in progress"
  },
  {
    "startTime": 13.86,
    "endTime": 17.14,
    "text": "at a future point in time."
  },
  {
    "startTime": 17.14,
    "endTime": 18.1,
    "text": "For example:"
  },
  {
    "startTime": 18.1,
    "endTime": 23.200000000000003,
    "text": "In the next scene I will be wearing a jumper."
  },
  {
    "startTime": 23.2,
    "endTime": 26.08,
    "text": "We make the future continuous using"
  },
  {
    "startTime": 26.08,
    "endTime": 31.659,
    "text": "will + be and verb(ing)."
  },
  {
    "startTime": 31.66,
    "endTime": 35.6,
    "text": "Note, that we can use any subject pronoun"
  },
  {
    "startTime": 35.6,
    "endTime": 38.44,
    "text": "and the structure won't change."
  },
  {
    "startTime": 38.44,
    "endTime": 41.699,
    "text": "For example, these are my hands."
  },
  {
    "startTime": 41.7,
    "endTime": 45.18,
    "text": "The subject pronoun is 'they'."
  },
  {
    "startTime": 45.18,
    "endTime": 50.78,
    "text": "In the next scene, they will be holding a melon."
  },
  {
    "startTime": 50.78,
    "endTime": 54.5,
    "text": "So now you will be thinking about"
  },
  {
    "startTime": 54.5,
    "endTime": 56.48,
    "text": "how to use the new grammar."
  },
  {
    "startTime": 56.48,
    "endTime": 57.839,
    "text": "Why not give it a try?"
  }
]