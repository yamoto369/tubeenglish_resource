[
  {
    "startTime": 0.0,
    "endTime": 2.72,
    "text": "Come on, come on, come on, come on, come on."
  },
  {
    "startTime": 2.72,
    "endTime": 3.74,
    "text": "Yes!"
  },
  {
    "startTime": 3.74,
    "endTime": 4.98,
    "text": "Game over!"
  },
  {
    "startTime": 4.98,
    "endTime": 7.76,
    "text": "Woo!"
  },
  {
    "startTime": 7.76,
    "endTime": 8.48,
    "text": "Okay..."
  },
  {
    "startTime": 8.48,
    "endTime": 10.08,
    "text": "Can we go do something now?"
  },
  {
    "startTime": 10.08,
    "endTime": 10.9,
    "text": "Oh yeah."
  },
  {
    "startTime": 10.9,
    "endTime": 11.72,
    "text": "I'mma go get my shoes."
  },
  {
    "startTime": 11.72,
    "endTime": 12.620000000000001,
    "text": "Okay."
  },
  {
    "startTime": 12.62,
    "endTime": 14.0,
    "text": "What do you wanna do, by the way?"
  },
  {
    "startTime": 14.0,
    "endTime": 14.8,
    "text": "I don't know."
  },
  {
    "startTime": 14.8,
    "endTime": 15.74,
    "text": "I'm kinda hungry."
  },
  {
    "startTime": 15.74,
    "endTime": 28.78,
    "text": "We should go eat."
  },
  {
    "startTime": 28.78,
    "endTime": 30.5,
    "text": "Welcome back, Ladies and Gentlemen."
  },
  {
    "startTime": 30.5,
    "endTime": 31.14,
    "text": "Katherine."
  },
  {
    "startTime": 31.14,
    "endTime": 36.32,
    "text": "There's one question between you and a million dollars."
  },
  {
    "startTime": 36.32,
    "endTime": 38.14,
    "text": "Where.."
  },
  {
    "startTime": 38.14,
    "endTime": 39.480000000000004,
    "text": "Do you.."
  },
  {
    "startTime": 39.48,
    "endTime": 40.5,
    "text": "Want.."
  },
  {
    "startTime": 40.5,
    "endTime": 44.0,
    "text": "To eat?"
  },
  {
    "startTime": 44.0,
    "endTime": 46.44,
    "text": "A. Chipotle"
  },
  {
    "startTime": 46.44,
    "endTime": 48.879999999999995,
    "text": "B. Let me choose."
  },
  {
    "startTime": 48.88,
    "endTime": 55.400000000000006,
    "text": "C. That one restaurant we couldn't get into because it was too busy and probably won't get in again, which is gonna get you mad."
  },
  {
    "startTime": 55.4,
    "endTime": 59.0,
    "text": "And by the time we do find somewhere to eat, you're gonna pretend like you're not hungry."
  },
  {
    "startTime": 59.0,
    "endTime": 64.0,
    "text": "And by the time the food is out, we'll have already made up and you'll just pick off my plate."
  },
  {
    "startTime": 64.38,
    "endTime": 67.61999999999999,
    "text": "Or D, Taco Bell."
  },
  {
    "startTime": 67.62,
    "endTime": 69.32000000000001,
    "text": "Chipotle.."
  },
  {
    "startTime": 69.32,
    "endTime": 71.22,
    "text": "I mean, it's really good."
  },
  {
    "startTime": 71.22,
    "endTime": 72.7,
    "text": "But I just had Chipotle yesterday."
  },
  {
    "startTime": 72.7,
    "endTime": 75.26,
    "text": "I can't have Chipotle two days in a row."
  },
  {
    "startTime": 75.26,
    "endTime": 77.7,
    "text": "Now remember, we have all lifelines available."
  },
  {
    "startTime": 77.7,
    "endTime": 80.08,
    "text": "You know what, I'm going to phone a friend."
  },
  {
    "startTime": 80.08,
    "endTime": 81.74,
    "text": "Okay, she's going to phone a friend!"
  },
  {
    "startTime": 81.74,
    "endTime": 82.74,
    "text": "Who would you like to phone?"
  },
  {
    "startTime": 82.74,
    "endTime": 84.36,
    "text": "I'd like to call my grandma."
  },
  {
    "startTime": 84.36,
    "endTime": 92.9,
    "text": "Let's get Guadalupe on the line!"
  },
  {
    "startTime": 92.9,
    "endTime": 93.44000000000001,
    "text": "Hello?"
  },
  {
    "startTime": 93.44,
    "endTime": 94.44,
    "text": "Hi Guadalupe."
  },
  {
    "startTime": 94.44,
    "endTime": 94.94,
    "text": "What?"
  },
  {
    "startTime": 94.94,
    "endTime": 96.08,
    "text": "Yes, I'm here with your granddaughter."
  },
  {
    "startTime": 96.08,
    "endTime": 96.58,
    "text": "What?"
  },
  {
    "startTime": 96.58,
    "endTime": 97.5,
    "text": "She's going for a million dollars!"
  },
  {
    "startTime": 97.5,
    "endTime": 98.78,
    "text": "And she needs your help."
  },
  {
    "startTime": 98.78,
    "endTime": 102.36,
    "text": "Oh my God, you kidnapped my granddaughter and you want a million dollars?"
  },
  {
    "startTime": 102.36,
    "endTime": 106.06,
    "text": "No grandma, I'm on a game show and I'm going to win a million dollars."
  },
  {
    "startTime": 106.06,
    "endTime": 108.14,
    "text": "I don't have that kind of money!"
  },
  {
    "startTime": 108.14,
    "endTime": 109.9,
    "text": "No, she's not... She's on a game show!"
  },
  {
    "startTime": 109.9,
    "endTime": 110.4,
    "text": "What?"
  },
  {
    "startTime": 110.4,
    "endTime": 111.28,
    "text": "Okay grandma."
  },
  {
    "startTime": 111.28,
    "endTime": 112.62,
    "text": "Don't scare me like that."
  },
  {
    "startTime": 112.62,
    "endTime": 114.24000000000001,
    "text": "Where would I like to eat?"
  },
  {
    "startTime": 114.24,
    "endTime": 115.39999999999999,
    "text": "It's for a million dollars!"
  },
  {
    "startTime": 115.4,
    "endTime": 116.18,
    "text": "What?"
  },
  {
    "startTime": 116.18,
    "endTime": 117.68,
    "text": "I said where would I like to eat, grandma?"
  },
  {
    "startTime": 117.68,
    "endTime": 118.38000000000001,
    "text": "Are you hungry?"
  },
  {
    "startTime": 118.38,
    "endTime": 119.25999999999999,
    "text": "At least four places."
  },
  {
    "startTime": 119.26,
    "endTime": 121.08,
    "text": "You want me to cook for you mija?"
  },
  {
    "startTime": 121.08,
    "endTime": 122.24,
    "text": "Don't go out, I'll cook."
  },
  {
    "startTime": 122.24,
    "endTime": 123.83999999999999,
    "text": "No, grandma, please."
  },
  {
    "startTime": 123.84,
    "endTime": 124.66,
    "text": "I'm tryna eat too."
  },
  {
    "startTime": 124.66,
    "endTime": 125.16,
    "text": "What?"
  },
  {
    "startTime": 125.16,
    "endTime": 125.75999999999999,
    "text": "Please hurry up!"
  },
  {
    "startTime": 125.76,
    "endTime": 126.52000000000001,
    "text": "Who are you talking to?"
  },
  {
    "startTime": 126.52,
    "endTime": 127.97999999999999,
    "text": "I'm talking to your granddaughter."
  },
  {
    "startTime": 127.98,
    "endTime": 129.36,
    "text": "Where does she wanna go eat?"
  },
  {
    "startTime": 129.36,
    "endTime": 131.04000000000002,
    "text": "Woah, I'm starving."
  },
  {
    "startTime": 131.04,
    "endTime": 133.0,
    "text": "Where do you wanna eat?"
  },
  {
    "startTime": 133.0,
    "endTime": 134.2,
    "text": "Where do I wanna eat?"
  },
  {
    "startTime": 134.2,
    "endTime": 134.7,
    "text": "Hmm.."
  },
  {
    "startTime": 134.7,
    "endTime": 135.48,
    "text": "We have 10 seconds left, grandma."
  },
  {
    "startTime": 135.48,
    "endTime": 136.82,
    "text": "I don't know."
  },
  {
    "startTime": 136.82,
    "endTime": 137.84,
    "text": "Give me a second."
  },
  {
    "startTime": 137.84,
    "endTime": 139.04,
    "text": "B: Have my boyfriend choose."
  },
  {
    "startTime": 139.04,
    "endTime": 140.82,
    "text": "Where do I want to eat?"
  },
  {
    "startTime": 140.82,
    "endTime": 141.95999999999998,
    "text": "Just make up your mind."
  },
  {
    "startTime": 141.96,
    "endTime": 143.74,
    "text": "Don't raise your voice at me."
  },
  {
    "startTime": 143.74,
    "endTime": 144.8,
    "text": "Where do you wanna eat, woman?"
  },
  {
    "startTime": 144.8,
    "endTime": 147.52,
    "text": "I said don't raise your voice at me!"
  },
  {
    "startTime": 147.52,
    "endTime": 148.16,
    "text": "5 seconds!"
  },
  {
    "startTime": 148.16,
    "endTime": 150.24,
    "text": "Let me call you back."
  },
  {
    "startTime": 150.24,
    "endTime": 152.06,
    "text": "I told you I don't know!"
  },
  {
    "startTime": 152.06,
    "endTime": 153.24,
    "text": "No, no."
  },
  {
    "startTime": 153.24,
    "endTime": 154.38,
    "text": "Grandma?"
  },
  {
    "startTime": 154.38,
    "endTime": 157.12,
    "text": "And we are out of time, Ladies and Gentlemen."
  },
  {
    "startTime": 157.12,
    "endTime": 158.34,
    "text": "Now, Katherine.."
  },
  {
    "startTime": 158.34,
    "endTime": 160.04,
    "text": "You still have two lifelines left."
  },
  {
    "startTime": 160.04,
    "endTime": 163.45999999999998,
    "text": "I'd like to eliminate two."
  },
  {
    "startTime": 163.46,
    "endTime": 167.72,
    "text": "Fifty-fifty, let's get two off the board!"
  },
  {
    "startTime": 167.72,
    "endTime": 170.35999999999999,
    "text": "Yes!"
  },
  {
    "startTime": 170.36,
    "endTime": 172.16000000000003,
    "text": "Uh, okay, so..."
  },
  {
    "startTime": 172.16,
    "endTime": 173.94,
    "text": "What do I want? What do I want?"
  },
  {
    "startTime": 173.94,
    "endTime": 179.6,
    "text": "Once I did let my previous boyfriend choose where to eat and we broke up because of it."
  },
  {
    "startTime": 179.6,
    "endTime": 183.82,
    "text": "Let's take B off the board."
  },
  {
    "startTime": 183.82,
    "endTime": 191.2,
    "text": "I am going to ask the audience."
  },
  {
    "startTime": 191.2,
    "endTime": 195.07999999999998,
    "text": "There's one option!"
  },
  {
    "startTime": 195.08,
    "endTime": 198.48000000000002,
    "text": "Okay, we're gonna ask the audience!"
  },
  {
    "startTime": 198.48,
    "endTime": 201.39999999999998,
    "text": "Tough one."
  },
  {
    "startTime": 201.4,
    "endTime": 204.0,
    "text": "Results are in!"
  },
  {
    "startTime": 204.0,
    "endTime": 207.8,
    "text": "100% go for C."
  },
  {
    "startTime": 207.8,
    "endTime": 208.3,
    "text": "Okay."
  },
  {
    "startTime": 208.3,
    "endTime": 210.54000000000002,
    "text": "I didn't think it was gonna be this hard."
  },
  {
    "startTime": 210.54,
    "endTime": 213.6,
    "text": "A million dollars...um..."
  },
  {
    "startTime": 213.6,
    "endTime": 215.38,
    "text": "There's just one answer left."
  },
  {
    "startTime": 215.38,
    "endTime": 218.1,
    "text": "I know but still, I don't know."
  },
  {
    "startTime": 218.1,
    "endTime": 219.32,
    "text": "Okay, you know what?"
  },
  {
    "startTime": 219.32,
    "endTime": 220.82,
    "text": "There's just one right there!"
  },
  {
    "startTime": 220.82,
    "endTime": 221.88,
    "text": "Just say C!"
  },
  {
    "startTime": 221.88,
    "endTime": 224.42,
    "text": "Say C, final answer!"
  },
  {
    "startTime": 224.42,
    "endTime": 225.98,
    "text": "I'm going to say C.."
  },
  {
    "startTime": 225.98,
    "endTime": 232.1,
    "text": "That's my final answer."
  },
  {
    "startTime": 232.1,
    "endTime": 234.04,
    "text": "She's won a million dollars!"
  },
  {
    "startTime": 234.04,
    "endTime": 234.88,
    "text": "Yes!"
  },
  {
    "startTime": 234.88,
    "endTime": 241.32,
    "text": "I won!"
  },
  {
    "startTime": 241.32,
    "endTime": 243.18,
    "text": "Wait.. Wait.. Wait.. Wait.."
  },
  {
    "startTime": 243.18,
    "endTime": 245.34,
    "text": "Can I still pick Chipotle?"
  },
  {
    "startTime": 245.34,
    "endTime": 246.26,
    "text": "What!?"
  },
  {
    "startTime": 246.26,
    "endTime": 247.98,
    "text": "Come on!"
  },
  {
    "startTime": 247.98,
    "endTime": 251.35999999999999,
    "text": "Why couldn\"t you just say that to begin with?"
  },
  {
    "startTime": 251.36,
    "endTime": 252.66000000000003,
    "text": "I'mma go get my shoes, okay?"
  },
  {
    "startTime": 252.66,
    "endTime": 253.68,
    "text": "Oh wait, babe."
  },
  {
    "startTime": 253.68,
    "endTime": 255.56,
    "text": "One last question."
  },
  {
    "startTime": 255.56,
    "endTime": 259.32,
    "text": "Do I look fat in this dress?"
  },
  {
    "startTime": 259.32,
    "endTime": 260.68,
    "text": "Don't..."
  },
  {
    "startTime": 260.68,
    "endTime": 263.92,
    "text": "Be honest."
  },
  {
    "startTime": 263.92,
    "endTime": 264.42,
    "text": "Wait, wait."
  },
  {
    "startTime": 264.42,
    "endTime": 265.98,
    "text": "Um, um.."
  },
  {
    "startTime": 265.98,
    "endTime": 267.78000000000003,
    "text": "Wait!"
  },
  {
    "startTime": 267.78,
    "endTime": 269.26,
    "text": "Thank you, Ladies and Gentlemen."
  },
  {
    "startTime": 269.26,
    "endTime": 273.32,
    "text": "And welcome back to Who Wants To Be A Dead Boyfriend."
  },
  {
    "startTime": 273.32,
    "endTime": 273.98,
    "text": "No, no, no, no, no, no!"
  },
  {
    "startTime": 273.98,
    "endTime": 276.0,
    "text": "For a million dollar question, how do I look in this dress?"
  }
]