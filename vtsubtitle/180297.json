  {
    "startTime": 97.099,
    "endTime": 98.199,
    "text": "Make marshmallow magic."
  },
  {
    "startTime": 98.199,
    "endTime": 100.099,
    "text": "That's it, marshmallow magic."
  },
  {
    "startTime": 100.099,
    "endTime": 106.5,
    "text": "OK, Michelle, let's show Mr. Malatesta just how we practiced it."
  },
  {
    "startTime": 106.5,
    "endTime": 107.3,
    "text": "No more."
  },
  {
    "startTime": 111.3,
    "endTime": 113.199,
    "text": "This is just how she warms up."
  },
  {
    "startTime": 113.199,
    "endTime": 115.3,
    "text": "That's right, she throws one first."
  },
  {
    "startTime": 115.3,
    "endTime": 116.599,
    "text": "Meryl Streep, same technique."
  },
  {
    "startTime": 118.4,
    "endTime": 121.099,
    "text": "OK, Michelle, remember, yummy in the tummy."
  },
  {
    "startTime": 121.5,
    "endTime": 121.9,
    "text": "Yucky."
  },
  {
    "startTime": 125.9,
    "endTime": 128.3,
    "text": "It sounded like she said yucky."
