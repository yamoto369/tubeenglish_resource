    "endTime": 4.5,
    "text": "You're starting to toast my marshmallows."
  },
  {
    "startTime": 4.5,
    "endTime": 5.4,
    "text": "Thank you very much."
  },
  {
    "startTime": 5.4,
    "endTime": 6.300000000000001,
    "text": "You're a nice kid."
