  {
    "startTime": 67.599,
    "endTime": 68.5,
    "text": "That's right."
  },
  {
    "startTime": 68.5,
    "endTime": 71.199,
    "text": "She's a teeny, tiny Tina."
  },
  {
    "startTime": 71.199,
    "endTime": 73.099,
    "text": "And look at that little tushy."
  },
  {
    "startTime": 73.099,
    "endTime": 74.599,
    "text": "Whoa, whoa, whoa, whoa, Mother."
  },
  {
    "startTime": 74.599,
    "endTime": 77.0,
    "text": "Do you have to grab everyone's tushy?"
  },
  {
    "startTime": 77.0,
    "endTime": 79.0,
    "text": "Come on, Irene."
  },
  {
    "startTime": 79.0,
    "endTime": 80.199,
    "text": "All right."
  },
  {
    "startTime": 80.199,
    "endTime": 81.89999999999999,
    "text": "Here we go, little angel."
  },
  {
    "startTime": 81.9,
    "endTime": 87.0,
    "text": "OK, now what you do, you sit up here on the marshmallow."
  },
  {
    "startTime": 87.099,
    "endTime": 87.9,
    "text": "Ma."
  },
  {
    "startTime": 93.199,
    "endTime": 94.599,
    "text": "Stand by, everyone."
  },
  {
    "startTime": 94.599,
    "endTime": 95.4,
