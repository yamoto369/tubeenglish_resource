[
  {
    "startTime": 3.04,
    "endTime": 10.48,
    "text": "I just think I need to be alone today... with my… feelings?"
  },
  {
    "startTime": 11.0,
    "endTime": 11.96,
    "text": "Do you lie?"
  },
  {
    "startTime": 11.96,
    "endTime": 13.72,
    "text": "What? No!"
  },
  {
    "startTime": 16.72,
    "endTime": 17.88,
    "text": "Friends don't lie."
  },
  {
    "startTime": 30.92,
    "endTime": 31.520000000000003,
    "text": "Shit."
  },
  {
    "startTime": 31.96,
    "endTime": 36.32,
    "text": "But please tell me this, and be honest: Have you ever actually won a fight?"
  },
  {
    "startTime": 36.32,
    "endTime": 37.68,
    "text": "Okay, that was one time!"
  },
  {
    "startTime": 37.68,
    "endTime": 39.28,
    "text": "Twice. Jonathan, year prior."
  },
  {
    "startTime": 42.28,
    "endTime": 43.24,
    "text": "Listen that doesn't count."
  },
  {
    "startTime": 43.24,
    "endTime": 43.96,
    "text": "Why wouldn't it count?"
  },
  {
    "startTime": 43.96,
    "endTime": 45.72,
    "text": "Cause it looks like he beat the shit out of you."
  },
  {
    "startTime": 48.92,
    "endTime": 50.72,
    "text": "Oh n-no, no, no, Nancy!"
  },
  {
    "startTime": 54.16,
    "endTime": 54.638999999999996,
    "text": "Sorry."
  },
  {
    "startTime": 57.32,
    "endTime": 60.0,
    "text": "I think this is big."
  },
  {
    "startTime": 60.0,
    "endTime": 61.28,
    "text": "Bigger than one article."
  },
  {
    "startTime": 61.28,
    "endTime": 64.12,
    "text": "In fact, I think that has got to be a book."
  },
  {
    "startTime": 64.12,
    "endTime": 67.64,
    "text": "The Mysterious Case of the Missing Fertilizer: A Nancy Drew mystery."
  },
  {
    "startTime": 74.96,
    "endTime": 76.839,
    "text": "It's just one little mistake."
  },
  {
    "startTime": 76.84,
    "endTime": 79.04,
    "text": "I've made hundreds, thousands."
  },
  {
    "startTime": 79.04,
    "endTime": 81.60000000000001,
    "text": "Max has dumped me five times!"
  },
  {
    "startTime": 84.32,
    "endTime": 85.39899999999999,
    "text": "But what have I done?"
  },
  {
    "startTime": 85.4,
    "endTime": 86.32000000000001,
    "text": "Huh?"
  },
  {
    "startTime": 86.32,
    "endTime": 87.67899999999999,
    "text": "Have I despaired?"
  },
  {
    "startTime": 87.68,
    "endTime": 88.76,
    "text": "No."
  },
  {
    "startTime": 88.76,
    "endTime": 94.759,
    "text": "I've marched back into battle, and I've won her back every single frickin' time."
  },
  {
    "startTime": 96.52,
    "endTime": 98.0,
    "text": "Wait, guys!"
  },
  {
    "startTime": 98.0,
    "endTime": 99.24,
    "text": "I'm still here!"
  },
  {
    "startTime": 103.88,
    "endTime": 104.96,
    "text": "Guys?"
  },
  {
    "startTime": 105.16,
    "endTime": 106.479,
    "text": "Three favorite movies. Go."
  },
  {
    "startTime": 107.48,
    "endTime": 111.16000000000001,
    "text": "\"The Apartment,\" \"Hidden Fortress,\" \"Children of Paradise.\""
  },
  {
    "startTime": 111.16,
    "endTime": 112.32,
    "text": "You. Go."
  },
  {
    "startTime": 112.72,
    "endTime": 113.4,
    "text": "Favorite movies?"
  },
  {
    "startTime": 113.4,
    "endTime": 114.16000000000001,
    "text": "Did I stutter?"
  },
  {
    "startTime": 114.16,
    "endTime": 115.119,
    "text": "Uh."
  },
  {
    "startTime": 117.84,
    "endTime": 120.0,
    "text": "\"Animal House,\" for sure."
  },
  {
    "startTime": 149.6,
    "endTime": 150.76,
    "text": "Can't we just hear your rendition?"
  },
  {
    "startTime": 151.12,
    "endTime": 151.6,
    "text": "No."
  },
  {
    "startTime": 151.6,
