    "text": "Please? Just one verse?"
  },
  {
    "startTime": 152.72,
    "endTime": 153.24,
    "text": "No!"
  },
  {
    "startTime": 156.16,
    "endTime": 159.68,
    "text": "No way, it's reserved for Suzie's ears and Suzie's ears alone."
  },
