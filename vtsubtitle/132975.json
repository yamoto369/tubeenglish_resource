[
  {
    "startTime": 1.084,
    "endTime": 3.879,
    "text": "As the attorney representing Adrian's trust,"
  },
  {
    "startTime": 5.005,
    "endTime": 8.3,
    "text": "I'm required to read a prepared statement."
  },
  {
    "startTime": 8.3,
    "endTime": 9.760000000000002,
    "text": "Cecilia,"
  },
  {
    "startTime": 9.76,
    "endTime": 13.639,
    "text": "although our relationship was far from perfect"
  },
  {
    "startTime": 13.639,
    "endTime": 16.767,
    "text": "I thought that you would talk to me rather than run away."
  },
  {
    "startTime": 16.767,
    "endTime": 18.143,
    "text": "Are you OK?"
  },
  {
    "startTime": 18.143,
    "endTime": 20.812,
    "text": "OPEN THE DOOR!"
  },
  {
    "startTime": 20.979,
    "endTime": 22.855,
    "text": "What happened to him?"
  },
  {
    "startTime": 22.856,
    "endTime": 23.941000000000003,
    "text": "He cut his wrists."
  },
  {
    "startTime": 23.941,
    "endTime": 26.108999999999998,
    "text": "Per his final wishes,"
  },
  {
    "startTime": 26.109,
    "endTime": 28.32,
    "text": "you're getting five million dollars."
  },
  {
    "startTime": 28.32,
    "endTime": 30.656,
    "text": "Contingent of course on the fine print."
  },
  {
    "startTime": 30.656,
    "endTime": 33.074,
    "text": "You can't be ruled to be mentally incompetent."
  },
  {
    "startTime": 35.16,
    "endTime": 37.162,
    "text": "It just doesn't make any sense."
  },
  {
    "startTime": 37.162,
    "endTime": 39.623,
    "text": "What? Adrian wouldn't kill himself."
  },
  {
    "startTime": 40.999,
    "endTime": 44.044000000000004,
    "text": "Listen, you're getting your freedom back, OK?"
  },
  {
    "startTime": 44.044,
    "endTime": 46.797,
    "text": "Don't let him haunt you."
  },
  {
    "startTime": 46.797,
    "endTime": 47.964,
    "text": "Hello?"
  },
  {
    "startTime": 56.348,
    "endTime": 57.474,
    "text": "I'm scared."
  },
  {
    "startTime": 57.474,
    "endTime": 60.0,
    "text": "You don't have to be scared of him anymore."
  },
  {
    "startTime": 60.0,
    "endTime": 62.271,
    "text": "He was a sociopath."
  },
  {
    "startTime": 62.271,
    "endTime": 66.233,
    "text": "Completely in control of everything."
  },
  {
    "startTime": 66.233,
    "endTime": 69.444,
    "text": "He said that wherever I went, he would find me."
  },
  {
    "startTime": 69.444,
    "endTime": 73.031,
    "text": "Walk right up to me, and I wouldn't be able to see him."
  },
  {
    "startTime": 75.117,
    "endTime": 76.32600000000001,
    "text": "You OK?"
  },
  {
    "startTime": 76.326,
    "endTime": 79.16099999999999,
    "text": "Someone's sitting in that chair."
  },
  {
    "startTime": 81.915,
    "endTime": 86.253,
    "text": "I found something that can prove what I'm experiencing."
  },
  {
    "startTime": 86.253,
    "endTime": 89.298,
    "text": "You need help. Adrian is dead."
  },
  {
    "startTime": 89.673,
    "endTime": 91.758,
    "text": "I went to his house today."
  },
  {
    "startTime": 91.758,
    "endTime": 94.636,
    "text": "He's not dead."
  },
  {
    "startTime": 94.636,
    "endTime": 96.262,
    "text": "I have a pile of ashes in a box"
  },
  {
    "startTime": 96.263,
    "endTime": 98.14,
    "text": "that would disagree with you."
  },
  {
    "startTime": 98.14,
    "endTime": 101.351,
    "text": "He has figured out a way to be invisible."
  },
  {
    "startTime": 102.269,
    "endTime": 104.354,
    "text": "The only thing more brilliant"
  },
  {
    "startTime": 104.354,
    "endTime": 107.357,
    "text": "than inventing something that makes you invisible"
  },
  {
    "startTime": 107.357,
    "endTime": 110.319,
    "text": "is coming up with the perfect way to torture you,"
  },
  {
    "startTime": 110.319,
    "endTime": 111.57000000000001,
    "text": "even in death."
  },
  {
    "startTime": 113.28,
    "endTime": 116.325,
    "text": "Adrian's true genius was how he got in people's heads."
  },
  {
    "startTime": 116.325,
    "endTime": 118.285,
    "text": "Don't come any closer! HEY!"
  },
  {
    "startTime": 118.785,
    "endTime": 120.0,
    "text": "I'm not crazy."
  },
  {
    "startTime": 121.83,
    "endTime": 122.831,
    "text": "Please listen to me!"
  },
  {
    "startTime": 122.831,
    "endTime": 127.544,
    "text": "You're saying the person trying to kill you"
  },
  {
    "startTime": 127.544,
    "endTime": 129.67,
    "text": "is in the room right now,"
  },
  {
    "startTime": 129.67,
    "endTime": 132.63199999999998,
    "text": "but we can't see him?"
  },
  {
    "startTime": 132.632,
    "endTime": 134.55100000000002,
    "text": "He's listening."
  },
  {
    "startTime": 134.551,
    "endTime": 136.386,
    "text": "Where are you?"
  },
  {
    "startTime": 136.386,
    "endTime": 140.307,
    "text": "Where are you? Show yourself! Come on!"
  },
  {
    "startTime": 140.307,
    "endTime": 141.475,
    "text": "Do it!"
  },
  {
    "startTime": 141.475,
    "endTime": 143.101,
    "text": "There you are."
  }
]