[
  {
    "startTime": 0.0,
    "endTime": 3.0,
    "text": "Do you like to give your friends compliments?"
  },
  {
    "startTime": 3.0,
    "endTime": 9.2,
    "text": "Listen to this story and learn three ways to give compliments in American English."
  },
  {
    "startTime": 9.5,
    "endTime": 13.3,
    "text": "Yesterday, I invited my friends to my new apartment."
  },
  {
    "startTime": 13.5,
    "endTime": 16.0,
    "text": "They really liked the place."
  },
  {
    "startTime": 16.2,
    "endTime": 18.4,
    "text": "Nice view!"
  },
  {
    "startTime": 18.5,
    "endTime": 21.8,
    "text": "I really like the flowers."
  },
  {
    "startTime": 22.0,
    "endTime": 24.3,
    "text": "What a great painting!"
  },
  {
    "startTime": 24.5,
    "endTime": 26.7,
    "text": "Thanks, guys!"
  },
  {
    "startTime": 26.9,
    "endTime": 31.7,
    "text": "Here are three ways to give compliments in American English."
  },
  {
    "startTime": 31.87,
    "endTime": 35.0,
    "text": "One way is, \"nice\" plus a noun."
  },
  {
    "startTime": 35.0,
    "endTime": 37.0,
    "text": "\"Nice\" hat!"
  },
  {
    "startTime": 37.0,
    "endTime": 39.3,
    "text": "\"Nice\" laptop!"
  },
  {
    "startTime": 39.6,
    "endTime": 43.0,
    "text": "Another way is, \"I really like\" plus an item."
  },
  {
    "startTime": 43.8,
    "endTime": 46.3,
    "text": "\"I really like\" that photograph!"
  },
  {
    "startTime": 46.5,
    "endTime": 49.7,
    "text": "\"I really like\" your shoes!"
  },
  {
    "startTime": 49.9,
    "endTime": 54.0,
    "text": "We can also say, \"What a great\" plus a noun."
  },
  {
    "startTime": 54.0,
    "endTime": 56.0,
    "text": "\"What a great\" essay!"
  },
  {
    "startTime": 56.0,
    "endTime": 59.0,
    "text": "\"What a great\" bike!"
  },
  {
    "startTime": 59.3,
    "endTime": 60.8,
    "text": "Now it's your turn."
  },
  {
