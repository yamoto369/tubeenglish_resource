  {
    "startTime": 334.8,
    "endTime": 337.0,
    "text": "Am I allowed to say one thing?"
  },
  {
    "startTime": 337.0,
    "endTime": 338.0,
    "text": "Yes, Mr. President."
  },
  {
    "startTime": 338.0,
    "endTime": 341.5,
    "text": "What we need in this country is law and order."
  },
  {
    "startTime": 341.6,
    "endTime": 345.0,
