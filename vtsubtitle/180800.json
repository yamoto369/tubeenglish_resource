    "text": "Hey."
  },
  {
    "startTime": 443.0,
    "endTime": 449.0,
    "text": "And I better listen to, uh, my meditation tape as well."
  },
  {
    "startTime": 450.0,
    "endTime": 465.1,
    "text": "Ladies and gentlemen, leaders and fighters for freedom and liberty and the American dream, the best is yet to come!"
