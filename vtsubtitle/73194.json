  {
    "startTime": 70.58,
    "endTime": 72.747,
    "text": "Uh...I'm a wizard too."
  },
  {
    "startTime": 72.747,
    "endTime": 74.78,
    "text": "Will we die just a little?"
  },
  {
    "startTime": 76.58,
    "endTime": 77.5,
    "text": "There."
  },
  {
    "startTime": 78.04,
    "endTime": 79.98,
    "text": "Who knows how many lives we just saved?"
  },
  {
    "startTime": 82.98,
