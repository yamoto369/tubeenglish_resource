  {
    "startTime": 43.43,
    "endTime": 47.21,
    "text": "add the short and open AH sound"
  },
  {
    "startTime": 47.21,
    "endTime": 51.47,
    "text": "end with a T by placing your tongue behind your top teeth"
  },
  {
    "startTime": 51.47,
    "endTime": 53.16,
    "text": "taught"
  },
  {
    "startTime": 53.16,
