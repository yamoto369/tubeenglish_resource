[
  {
    "startTime": 9.29,
    "endTime": 10.95,
    "text": "Ladies and gents"
  },
  {
    "startTime": 10.95,
    "endTime": 13.19,
    "text": "This is the moment you've waited for"
  },
  {
    "startTime": 13.19,
    "endTime": 15.62,
    "text": "(Woah)"
  },
  {
    "startTime": 15.62,
    "endTime": 17.279,
    "text": "You've been searching in the dark"
  },
  {
    "startTime": 17.28,
    "endTime": 19.34,
    "text": "Your sweat soaking through the floor"
  },
  {
    "startTime": 19.34,
    "endTime": 21.88,
    "text": "(Woah)"
  },
  {
    "startTime": 21.88,
    "endTime": 23.45,
    "text": "And buried in your bones"
  },
  {
    "startTime": 23.45,
    "endTime": 25.43,
    "text": "There's an ache that you can't ignore"
  },
  {
    "startTime": 25.43,
    "endTime": 26.87,
    "text": "Taking your breath"
  },
  {
    "startTime": 26.87,
    "endTime": 28.37,
    "text": "Stealing your mind"
  },
  {
    "startTime": 28.37,
    "endTime": 31.85,
    "text": "And all that was real is left behind"
  },
  {
    "startTime": 31.85,
    "endTime": 34.96,
    "text": "Don't fight it, it's coming for you, running at ya"
  },
  {
    "startTime": 34.96,
    "endTime": 36.86,
    "text": "It's only this moment"
  },
  {
    "startTime": 36.86,
    "endTime": 38.25,
    "text": "Don't care what comes after"
  },
  {
    "startTime": 38.25,
    "endTime": 39.56,
    "text": "Your fever dream"
  },
  {
    "startTime": 39.56,
    "endTime": 41.22,
    "text": "Can't you see it getting closer?"
  },
  {
    "startTime": 41.22,
    "endTime": 44.19,
    "text": "Just surrender 'cause you feel the feeling taking over"
  },
  {
    "startTime": 44.19,
    "endTime": 46.3,
    "text": "It's fire, it's freedom"
  },
  {
    "startTime": 46.3,
    "endTime": 47.55,
    "text": "It's flooding open"
  },
  {
    "startTime": 47.55,
    "endTime": 50.44,
    "text": "It's the preacher in the pulpit and your blind devotion"
  },
  {
    "startTime": 50.44,
    "endTime": 53.8,
    "text": "There's something breaking at the brick of every wall"
  },
  {
    "startTime": 53.8,
    "endTime": 54.93,
    "text": "It's holding all that you know"
  },
  {
    "startTime": 54.93,
    "endTime": 57.32,
    "text": "So tell me do you wanna go?"
  },
  {
    "startTime": 57.32,
    "endTime": 60.44,
    "text": "Where it's covered in all the colored lights"
  },
  {
    "startTime": 60.44,
    "endTime": 63.4,
    "text": "Where the runaways are running the night"
  },
  {
    "startTime": 63.4,
    "endTime": 65.179,
    "text": "Impossible comes true"
  },
  {
    "startTime": 65.18,
    "endTime": 66.77000000000001,
    "text": "It's taking over you"
  },
  {
    "startTime": 66.77,
