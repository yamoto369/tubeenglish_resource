[
  {
    "startTime": 25.97,
    "endTime": 28.33,
    "text": "Do I know you?"
  },
  {
    "startTime": 28.33,
    "endTime": 30.4,
    "text": "Yes, you do"
  },
  {
    "startTime": 30.4,
    "endTime": 33.17,
    "text": "This seems so familiar"
  },
  {
    "startTime": 33.17,
    "endTime": 34.760000000000005,
    "text": "You're in a dream"
  },
  {
    "startTime": 34.76,
    "endTime": 37.32,
    "text": "Who are you?"
  },
  {
    "startTime": 37.32,
    "endTime": 47.0,
    "text": "I am your reflection... you've been asleep for a very long time"
  },
  {
    "startTime": 47.0,
    "endTime": 68.6,
    "text": "I lay awake every night"
  },
  {
    "startTime": 68.6,
    "endTime": 70.1,
    "text": "Lookin' back on my life"
  },
  {
    "startTime": 70.1,
    "endTime": 71.77,
    "text": "Will apologies to the people I love"
  },
  {
    "startTime": 71.77,
    "endTime": 72.82,
    "text": "For the things I've done"
  },
  {
    "startTime": 72.82,
    "endTime": 74.58999999999999,
    "text": "Really make it right?"
  },
  {
    "startTime": 74.6,
    "endTime": 75.88,
    "text": "I guess it might just then I realized"
  },
  {
    "startTime": 75.88,
    "endTime": 77.69,
    "text": "My past is the reason I'm here right now"
  },
  {
    "startTime": 77.69,
    "endTime": 79.17,
    "text": "As a matter of fact I won't apologize"
  },
  {
    "startTime": 79.17,
    "endTime": 80.41,
    "text": "You bitches always pissed"
  },
  {
    "startTime": 80.41,
    "endTime": 81.729,
    "text": "'Cause I am constantly changin'"
  },
  {
    "startTime": 81.73,
    "endTime": 83.41000000000001,
    "text": "Think of how far that I've made it"
  },
  {
    "startTime": 83.41,
    "endTime": 86.89999999999999,
    "text": "From my incarceration it's amazin' ain't it?"
  },
  {
    "startTime": 86.1,
    "endTime": 87.47999999999999,
    "text": "But I'm in the zone"
  },
  {
    "startTime": 87.48,
    "endTime": 88.2,
    "text": "I'm a rolling-stone"
  },
  {
    "startTime": 88.2,
    "endTime": 88.95,
    "text": "I'm coming home"
  },
  {
    "startTime": 88.95,
    "endTime": 89.85000000000001,
    "text": "But I'm not alone"
  },
  {
    "startTime": 89.85,
    "endTime": 91.449,
    "text": "Do I really got to let another motherfucker know?"
  },
  {
    "startTime": 91.45,
    "endTime": 97.15,
    "text": "No I won't surrender, surrender"
  },
  {
    "startTime": 97.15,
    "endTime": 99.28,
    "text": "No I won't"
  },
  {
    "startTime": 99.28,
    "endTime": 102.12,
    "text": "Let you bring me down"
  },
  {
    "startTime": 102.12,
    "endTime": 106.22,
    "text": "So where the hell do I go from here?"
  },
  {
    "startTime": 106.22,
    "endTime": 109.3,
    "text": "Who do I believe, who do I believe when everyone"
  },
  {
    "startTime": 109.3,
    "endTime": 111.98,
    "text": "Feels so insincere?"
  },
  {
    "startTime": 111.98,
    "endTime": 114.93,
    "text": "(Like everyone's out to get me)"
  },
  {
    "startTime": 114.93,
    "endTime": 117.9,
    "text": "Who will save my life?"
  },
  {
    "startTime": 117.9,
    "endTime": 121.12,
    "text": "How do I believe, how do I believe in anyone?"
  },
  {
    "startTime": 121.12,
    "endTime": 123.23,
    "text": "Please don't mind me"
  },
  {
    "startTime": 123.23,
    "endTime": 127.78,
    "text": "I just kill myself sometimes."
  },
  {
    "startTime": 127.78,
    "endTime": 129.27,
    "text": "Uh daddy?"
  },
  {
    "startTime": 129.27,
    "endTime": 130.15,
    "text": "Yes honey?"
  },
  {
    "startTime": 130.15,
    "endTime": 131.3,
    "text": "Why did you go to jail?"
  },
  {
    "startTime": 131.3,
    "endTime": 131.93,
    "text": "Uhhhhhhh"
  },
  {
    "startTime": 131.93,
    "endTime": 133.57,
    "text": "I'm a lot smarter than you think"
  },
  {
    "startTime": 133.57,
    "endTime": 135.85899999999998,
    "text": "Everything I did was planned"
  },
  {
    "startTime": 135.86,
    "endTime": 136.85000000000002,
    "text": "To get you to listen"
  },
  {
    "startTime": 136.85,
    "endTime": 138.73,
    "text": "To get your attention so you post your opinion"
  },
  {
    "startTime": 138.73,
    "endTime": 140.48999999999998,
    "text": "And it gets me bigger"
  },
  {
    "startTime": 140.5,
    "endTime": 142.34,
