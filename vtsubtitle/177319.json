[
  {
    "startTime": 2.0,
    "endTime": 3.347,
    "text": "This is great."
  },
  {
    "startTime": 3.347,
    "endTime": 4.0,
    "text": "Oh, man."
  },
  {
    "startTime": 4.101,
    "endTime": 9.02,
    "text": "Dude, dude, dude, it says please take one."
  },
  {
    "startTime": 9.02,
    "endTime": 17.456,
    "text": "More like one bucket!"
  },
  {
    "startTime": 17.456,
    "endTime": 19.912,
    "text": "Woo-hoo!"
  },
  {
    "startTime": 19.3,
    "endTime": 25.28,
    "text": "Yeah!"
  },
  {
    "startTime": 25.28,
    "endTime": 28.0,
    "text": "What do you think?"
  },
  {
    "startTime": 28.2,
    "endTime": 29.4,
    "text": "[Expectation vs reality]"
  },
  {
    "startTime": 29.6,
    "endTime": 30.200000000000003,
    "text": "Did you get the right size?"
  },
  {
    "startTime": 30.4,
    "endTime": 31.4,
    "text": "Oh, yeah, man."
  },
  {
    "startTime": 31.6,
    "endTime": 32.0,
    "text": "Flex for me."
  },
  {
    "startTime": 32.2,
    "endTime": 33.900000000000006,
    "text": "Yeah, flex."
  },
  {
    "startTime": 34.0,
    "endTime": 34.1,
    "text": "Yeah."
  },
  {
    "startTime": 34.3,
    "endTime": 35.199999999999996,
    "text": "Ooh."
  },
  {
    "startTime": 35.35,
    "endTime": 36.32,
    "text": "Yeah, but flex though."
  },
  {
    "startTime": 36.32,
    "endTime": 37.5,
    "text": "Yeah, I'm flexing."
  },
  {
    "startTime": 37.7,
    "endTime": 38.2,
    "text": "Yeah, yeah."
  },
  {
    "startTime": 38.4,
    "endTime": 40.9,
    "text": "I think he looks great."
  },
  {
    "startTime": 41.03,
    "endTime": 42.0,
    "text": "Let's go boys."
  },
  {
    "startTime": 42.0,
    "endTime": 43.6,
    "text": "Hey, because you are?"
  },
  {
    "startTime": 43.8,
    "endTime": 44.3,
    "text": "Batman."
  },
  {
    "startTime": 44.5,
    "endTime": 47.5,
    "text": "Yeah, barely."
  },
  {
    "startTime": 47.7,
    "endTime": 50.18,
    "text": "Dude, we smoked it, bro."
  },
  {
    "startTime": 50.1,
    "endTime": 52.2,
    "text": "All right, candy buckets on the counter now."
  },
  {
    "startTime": 52.4,
    "endTime": 53.8,
    "text": "[The candy cop mom]"
  },
  {
    "startTime": 53.9,
    "endTime": 57.0,
    "text": "I'm sorry. Is this a non-wrapped homemade muffin?"
  },
  {
    "startTime": 57.2,
    "endTime": 59.300000000000004,
    "text": "That was from Susan's mom. We know her."
  },
  {
    "startTime": 59.48,
    "endTime": 61.19,
    "text": "Are these eggs?"
  },
  {
    "startTime": 61.19,
    "endTime": 62.4,
    "text": "They have a shell on them."
  },
  {
    "startTime": 62.6,
    "endTime": 65.7,
    "text": "We are not eating eggs from that house in this house."
  },
  {
    "startTime": 65.9,
    "endTime": 67.4,
    "text": "They have a chicken coop. - We're not doing this."
  },
  {
    "startTime": 67.6,
    "endTime": 68.24499999999999,
    "text": "Not the chocolate chip cookies!"
  },
  {
    "startTime": 69.0,
    "endTime": 72.6,
    "text": "They are gluten free!"
  },
  {
    "startTime": 72.6,
    "endTime": 73.5,
    "text": "No, no, no, no, no."
  },
  {
    "startTime": 73.7,
    "endTime": 75.60000000000001,
    "text": "Do you know how much sugar is in this?"
  },
  {
    "startTime": 75.8,
    "endTime": 79.7,
    "text": "I just want a new mom!"
  },
  {
    "startTime": 79.9,
    "endTime": 85.30000000000001,
    "text": "Have no fear. Just your friendly neighborhood Spiderman here."
  },
  {
    "startTime": 85.5,
    "endTime": 88.2,
    "text": "[The low-budget costume]"
  },
  {
    "startTime": 88.2,
    "endTime": 95.14,
    "text": "That's the worst Spiderman I've ever seen."
  },
  {
    "startTime": 95.14,
    "endTime": 97.7,
    "text": "Hey."
  },
  {
    "startTime": 97.8,
    "endTime": 101.1,
    "text": "Wow, yeah, well, I'm kind of freaking out."
  },
  {
    "startTime": 101.3,
    "endTime": 102.14999999999999,
    "text": "Because you look so good."
  },
  {
    "startTime": 102.15,
    "endTime": 113.5,
    "text": "You probably get this all the time. Are you the real Spiderman?"
  },
  {
    "startTime": 113.7,
    "endTime": 117.5,
    "text": "All right, guys. Dad's got a call. But I got a little pumpkin carving craft for you, OK?"
  },
  {
    "startTime": 117.7,
    "endTime": 120.0,
    "text": "You guys knock yourselves out, OK? I'll see you in a little bit."
  },
  {
    "startTime": 120.3,
    "endTime": 122.1,
    "text": "[\"Casual\" pumkin carving]"
  },
  {
    "startTime": 122.3,
    "endTime": 129.106,
    "text": "I'm almost done."
  },
  {
    "startTime": 129.106,
    "endTime": 132.5,
    "text": "No parents allowed!"
  },
  {
    "startTime": 132.7,
    "endTime": 134.2,
    "text": "Restroom is this way, right?"
  },
  {
    "startTime": 134.4,
    "endTime": 136.9,
    "text": "[Can't see costume]"
  },
  {
    "startTime": 137.1,
    "endTime": 138.29999999999998,
    "text": "Dude, seriously?"
  },
  {
    "startTime": 138.5,
    "endTime": 146.5,
    "text": "It could be light here. Look out!"
  },
  {
    "startTime": 146.7,
    "endTime": 147.89999999999998,
    "text": "Is that a trick-or-treater?"
  },
  {
    "startTime": 148.1,
    "endTime": 149.5,
    "text": "[The \"no one's home\"]"
  },
  {
    "startTime": 149.7,
    "endTime": 152.7,
    "text": "Get down. Get down."
  },
  {
    "startTime": 152.9,
    "endTime": 154.3,
    "text": "Trick-or-treat!"
  },
  {
    "startTime": 154.5,
    "endTime": 155.9,
    "text": "Do we have any candy?"
  },
  {
    "startTime": 156.0,
    "endTime": 158.2,
    "text": "I didn't buy candy."
  },
  {
    "startTime": 158.33,
    "endTime": 160.70000000000002,
    "text": "We've got to get the lights off."
  },
  {
    "startTime": 160.9,
    "endTime": 162.31,
    "text": "Trick-or-treat!"
  },
  {
    "startTime": 162.31,
    "endTime": 167.1,
    "text": "I mean, all the lights are on. They've got to be home."
  },
  {
    "startTime": 167.7,
    "endTime": 169.33999999999997,
    "text": "That literally did nothing."
  },
  {
    "startTime": 169.34,
    "endTime": 171.25,
    "text": "I got to get the entry light."
  },
  {
    "startTime": 171.25,
    "endTime": 172.8,
    "text": "Stay low. Stay low."
  },
  {
    "startTime": 173.0,
    "endTime": 173.1,
    "text": "I think I see something."
  },
  {
    "startTime": 173.3,
    "endTime": 176.4,
    "text": "I saw something move."
  },
  {
    "startTime": 176.6,
    "endTime": 177.79999999999998,
    "text": "I think they're flashing at us."
  },
  {
    "startTime": 177.9,
    "endTime": 178.1,
    "text": "Really?"
  },
  {
    "startTime": 178.4,
    "endTime": 181.407,
    "text": "Yeah, I think they're trying to tell us to come around to the side door."
  },
  {
    "startTime": 181.407,
    "endTime": 182.60000000000002,
    "text": "Oh, I'm in."
  },
  {
    "startTime": 182.8,
    "endTime": 186.05800000000002,
    "text": "Let's go."
  },
  {
    "startTime": 186.058,
    "endTime": 189.2,
    "text": "They're right there! They're right there! Stay down."
  },
  {
    "startTime": 189.31,
    "endTime": 192.6,
    "text": "We want candy. Hey."
  },
  {
    "startTime": 192.8,
    "endTime": 200.20000000000002,
    "text": "I think we should go back to the front door."
  },
  {
    "startTime": 200.4,
    "endTime": 202.3,
    "text": "The door's unlocked."
  },
  {
    "startTime": 202.6,
    "endTime": 203.4,
    "text": "Nobody's home."
  },
  {
    "startTime": 203.7,
    "endTime": 206.6,
    "text": "Huh, I guess we'll go to the next house."
  },
  {
    "startTime": 206.9,
    "endTime": 217.43,
    "text": "Trick-or-treat, trick-or-treat."
  },
  {
    "startTime": 217.43,
    "endTime": 220.3,
    "text": "Ahh, way too light orange. Not my style."
  },
  {
    "startTime": 220.5,
    "endTime": 221.42,
    "text": "[Mr. Picky pumpkin]"
  },
  {
    "startTime": 221.8,
    "endTime": 224.46,
    "text": "Do you get a free disease when you carve this one?"
  },
  {
    "startTime": 224.46,
    "endTime": 226.21,
    "text": "That makes me feel uncomfortable."
  },
  {
    "startTime": 226.4,
    "endTime": 228.5,
    "text": "What is this? A pancake pumpkin?"
  },
  {
    "startTime": 228.7,
    "endTime": 230.39999999999998,
    "text": "I did an oblong one last year."
  },
  {
    "startTime": 230.6,
    "endTime": 231.29999999999998,
    "text": "This is perfect."
  },
  {
    "startTime": 231.26,
    "endTime": 232.2,
    "text": "Wait, hold on. What?"
  },
  {
    "startTime": 232.4,
    "endTime": 235.3,
    "text": "Whoa, whoa, whoa, $100 right now. For the pumpkin."
  },
  {
    "startTime": 236.32,
    "endTime": 236.9,
    "text": "OK."
  },
  {
    "startTime": 237.1,
    "endTime": 238.45,
    "text": "I think that's the only good one here."
  },
  {
    "startTime": 238.45,
    "endTime": 239.39,
    "text": "Thank you."
  },
  {
    "startTime": 239.39,
    "endTime": 242.29999999999998,
    "text": "Ah! She's got scarring!"
  },
  {
    "startTime": 242.5,
    "endTime": 247.7,
    "text": "We can't tell if he's pregnant or he's just a really fat starfish."
  },
  {
    "startTime": 247.7,
    "endTime": 248.7,
    "text": "Help! Help! Help!"
  },
  {
    "startTime": 248.9,
    "endTime": 249.35,
    "text": "Oh my gosh."
  },
  {
    "startTime": 249.35,
    "endTime": 250.4,
    "text": "Oh!"
  },
  {
    "startTime": 250.6,
    "endTime": 252.6,
    "text": "[The way over the top]"
  },
  {
    "startTime": 252.6,
    "endTime": 256.3,
    "text": "I'm a pilot. I've skidded on the runway. This is classic."
  },
  {
    "startTime": 256.48,
    "endTime": 258.19,
    "text": "My grandmother's coming."
  },
  {
    "startTime": 258.19,
    "endTime": 260.11,
    "text": "There's going to be three-year-olds out there."
  },
  {
    "startTime": 260.11,
    "endTime": 263.5,
    "text": "You thought this is appropriate?"
  },
  {
    "startTime": 263.7,
    "endTime": 265.2,
    "text": "Hey, I'm ready."
  },
  {
    "startTime": 265.4,
    "endTime": 266.59999999999997,
    "text": "[The \"who are you\" costume]"
  },
  {
    "startTime": 266.6,
    "endTime": 267.8,
    "text": "What are you supposed to be?"
  },
  {
    "startTime": 268.0,
    "endTime": 269.4,
    "text": "I'm Peter Pan's shadow."
  },
  {
    "startTime": 269.6,
    "endTime": 273.1,
    "text": "No one's going to get that."
  },
  {
    "startTime": 273.3,
    "endTime": 278.8,
    "text": "My brother and I want to know if we can go trick-or-treating for Halloween for the first time this year."
  },
  {
    "startTime": 279.0,
    "endTime": 280.4,
    "text": "First of all, no."
  },
  {
    "startTime": 280.6,
    "endTime": 282.3,
    "text": "[Mr. Anti-Halloween]"
  },
  {
    "startTime": 281.9,
    "endTime": 283.2,
    "text": "Please. - Please."
  },
  {
    "startTime": 283.4,
    "endTime": 286.27,
    "text": "Under one condition would I let you go trick-or-treating."
  },
  {
    "startTime": 286.1,
    "endTime": 287.40000000000003,
    "text": "OK. - OK."
  },
  {
    "startTime": 287.6,
    "endTime": 296.1,
    "text": "I get to pick the costume."
  },
  {
    "startTime": 296.065,
    "endTime": 300.5,
    "text": "I can't believe he wouldn't even let me wear shoes."
  },
  {
    "startTime": 300.7,
    "endTime": 303.4,
    "text": "Or if you want really scary, we can go Brutal Chainsaw Mutilation 5."
  },
  {
    "startTime": 303.6,
    "endTime": 305.0,
    "text": "Dude, don't worry about us. Go as scary as you want."
  },
  {
    "startTime": 305.3,
    "endTime": 310.5,
    "text": "[Scary movie night]"
  },
  {
    "startTime": 310.7,
    "endTime": 311.59999999999997,
    "text": "Pretty special, huh?"
  },
  {
    "startTime": 311.8,
    "endTime": 313.0,
    "text": "Full sizies."
  },
  {
    "startTime": 313.2,
    "endTime": 315.2,
    "text": "Mr. Ferguson gives us king sized."
  },
  {
    "startTime": 315.4,
    "endTime": 316.4,
    "text": "He gives what?"
  },
  {
    "startTime": 316.7,
    "endTime": 321.7,
    "text": "Hey, Carl. King sized-- it's all the rage for the kids these days."
  },
  {
    "startTime": 322.0,
    "endTime": 323.8,
    "text": "[The candy wars]"
  },
  {
    "startTime": 323.8,
    "endTime": 328.0,
    "text": "Hate to do it to you, Mr. Ferguson. But it looks like the candy king has prevailed."
  },
  {
    "startTime": 328.2,
    "endTime": 332.4,
    "text": "How about a Colossal Kiss or a Reese's Cup the size of a cast iron skillet?"
  },
  {
    "startTime": 332.6,
    "endTime": 334.8,
    "text": "Not all heroes wear capes. I bid you adieu."
  },
  {
    "startTime": 335.0,
    "endTime": 335.7,
    "text": "Oh, have a good night though."
  },
  {
    "startTime": 335.9,
    "endTime": 342.09999999999997,
    "text": "Beep, beep, beep, beep."
  },
  {
    "startTime": 342.1,
    "endTime": 344.0,
    "text": "You're going to want to use your legs on this one, OK?"
  },
  {
    "startTime": 344.0,
    "endTime": 346.4,
    "text": "One, two, three."
  },
  {
    "startTime": 346.4,
    "endTime": 350.79999999999995,
    "text": "Don't hurt the back, boys. Have a great Halloween, OK?"
  },
  {
    "startTime": 351.0,
    "endTime": 354.014,
    "text": "Thank you, Mr. Ferguson."
  },
  {
    "startTime": 354.014,
    "endTime": 355.0,
    "text": "Hey, boys."
  },
  {
    "startTime": 355.0,
    "endTime": 355.5,
    "text": "Oh, wow!"
  },
  {
    "startTime": 355.7,
    "endTime": 358.5,
    "text": "In the Scary Larry Haunted Hayride."
  },
  {
    "startTime": 358.7,
    "endTime": 360.3,
    "text": "If you're excited give me a yippie."
  },
  {
    "startTime": 360.6,
    "endTime": 361.8,
    "text": "Yipee!"
  },
  {
    "startTime": 362.0,
    "endTime": 363.8,
    "text": "[The haunted hayride]"
  },
  {
    "startTime": 364.0,
    "endTime": 366.11,
    "text": "Larry, how much longer?"
  },
  {
    "startTime": 367.0,
    "endTime": 370.48,
    "text": "I think Larry might have oversold this a little."
  },
  {
    "startTime": 370.48,
    "endTime": 372.28000000000003,
    "text": "Oh, shucks."
  },
  {
    "startTime": 372.28,
    "endTime": 373.19699999999995,
    "text": "Should we walk back?"
  },
  {
    "startTime": 373.197,
    "endTime": 375.2,
    "text": "No, give me a couple of minutes. I'll get it."
  },
  {
    "startTime": 375.4,
    "endTime": 377.5,
    "text": "What is that, guys?"
  },
  {
    "startTime": 377.7,
    "endTime": 379.268,
    "text": "Larry, is that part of this?"
  },
  {
    "startTime": 379.268,
    "endTime": 381.5,
    "text": "I never seen that horse before! Come on!"
  },
  {
    "startTime": 381.7,
    "endTime": 383.2,
    "text": "What do you mean, it's not part of it?"
  },
  {
    "startTime": 383.4,
    "endTime": 383.9,
    "text": "Go rage on it."
  },
  {
    "startTime": 384.0,
    "endTime": 385.9,
    "text": "I can't just flip a switch and rage on it."
  },
  {
    "startTime": 386.0,
    "endTime": 387.1,
    "text": "What do you want me to do?"
  },
  {
    "startTime": 387.21,
    "endTime": 389.5,
    "text": "Oh!"
  },
  {
    "startTime": 388.9,
    "endTime": 390.01399999999995,
    "text": "I got you, buddy!"
  },
  {
    "startTime": 390.014,
    "endTime": 393.0,
    "text": "Oh!"
  },
  {
    "startTime": 399.0,
    "endTime": 401.0,
    "text": "Go, go, go, go!"
  },
  {
    "startTime": 401.0,
    "endTime": 402.88,
    "text": "Oh, this one's going to be good!"
  },
  {
    "startTime": 406.0,
    "endTime": 407.6,
    "text": "Ty, a clown!"
  },
  {
    "startTime": 407.8,
    "endTime": 413.90000000000003,
    "text": "There's a clown!"
  },
  {
    "startTime": 414.172,
    "endTime": 419.608,
    "text": "Wee!"
  },
  {
    "startTime": 419.608,
    "endTime": 421.068,
    "text": "Ahh!"
  },
  {
    "startTime": 421.068,
    "endTime": 424.02,
    "text": "Oh!"
  },
  {
    "startTime": 424.02,
    "endTime": 426.2,
    "text": "Vader!"
  },
  {
    "startTime": 426.3,
    "endTime": 431.0,
    "text": "You're not prepared for this!"
  },
  {
    "startTime": 431.2,
    "endTime": 437.134,
    "text": "He's using the force!"
  },
  {
    "startTime": 437.134,
    "endTime": 443.0,
    "text": "Get him!"
  },
  {
    "startTime": 443.3,
    "endTime": 445.0,
    "text": "This is unbelievable!"
  },
  {
    "startTime": 445.0,
    "endTime": 448.7,
    "text": "Oh, he's a jedi knight!"
  },
  {
    "startTime": 448.8,
    "endTime": 448.8,
    "text": "Rage Monster."
  },
  {
    "startTime": 449.0,
    "endTime": 465.48,
    "text": "Rage Monster."
  },
  {
    "startTime": 465.48,
    "endTime": 468.0,
    "text": "I would like to trade my black licorice for absolutely anything."
  },
  {
    "startTime": 468.2,
    "endTime": 470.0,
    "text": "[The candy trader]"
  },
  {
    "startTime": 470.0,
    "endTime": 471.1,
    "text": "I'm allergic to peanut butter."
  },
  {
    "startTime": 471.3,
    "endTime": 471.8,
    "text": "Who wants my Reese's?"
  },
  {
    "startTime": 472.0,
    "endTime": 473.4,
    "text": "Can't tell what I have."
  },
  {
    "startTime": 473.6,
    "endTime": 475.1,
    "text": "Ah, are you kidding me?"
  },
  {
    "startTime": 475.2,
    "endTime": 476.0,
    "text": "Dude!"
  },
  {
    "startTime": 476.0,
    "endTime": 479.0,
    "text": "Free game!"
  },
  {
    "startTime": 479.0,
    "endTime": 484.8,
    "text": "Hey, knock it off!"
  },
  {
    "startTime": 485.0,
    "endTime": 485.8,
    "text": "Who is that guy?"
  },
  {
    "startTime": 486.0,
    "endTime": 487.2,
    "text": "I don't know. I can't see anything."
  },
  {
    "startTime": 487.4,
    "endTime": 492.2,
    "text": "[The mystery guest]"
  },
  {
    "startTime": 492.1,
    "endTime": 493.40000000000003,
    "text": "Who's that guy in the baby mask?"
  },
  {
    "startTime": 493.6,
    "endTime": 495.20000000000005,
    "text": "I'm pretty sure that's Ty."
  },
  {
    "startTime": 495.2,
    "endTime": 497.08,
    "text": "What?"
  },
  {
    "startTime": 497.08,
    "endTime": 502.46,
    "text": "Wait, if you're Ty, who's that in the baby mask?"
  },
  {
    "startTime": 502.46,
    "endTime": 506.79999999999995,
    "text": "Oh, whoa, are we concerned that he's grabbing a knife right now?"
  },
  {
    "startTime": 507.0,
    "endTime": 509.4,
    "text": "You've been staring at that fly for 10 minutes."
  },
  {
    "startTime": 509.6,
    "endTime": 511.40000000000003,
    "text": "It's me. Chad."
  },
  {
    "startTime": 511.58,
    "endTime": 513.1,
    "text": "Oh, guys!"
  },
  {
    "startTime": 513.4,
    "endTime": 515.8,
    "text": "Oh!"
  },
  {
    "startTime": 516.0,
    "endTime": 519.5,
    "text": "Who is Chad?"
  },
  {
    "startTime": 519.7,
    "endTime": 521.0300000000001,
    "text": "Trick-or-treat."
  },
  {
    "startTime": 521.03,
    "endTime": 524.0,
    "text": "Oh, Patrick Mahomes and a chicken."
  },
  {
    "startTime": 524.0,
    "endTime": 525.38,
    "text": "Yeah, ran out of time."
  },
  {
    "startTime": 525.38,
    "endTime": 526.1899999999999,
    "text": "Fresh spinach?"
  },
  {
    "startTime": 526.19,
    "endTime": 527.4000000000001,
    "text": "Oh, I'm good."
  },
  {
    "startTime": 527.6,
    "endTime": 529.34,
    "text": "[The healthy treat lady]"
  },
  {
    "startTime": 529.34,
    "endTime": 531.2800000000001,
    "text": "Boys, that's just the trick."
  },
  {
    "startTime": 531.28,
    "endTime": 532.5,
    "text": "Let me get a real treat."
  },
  {
    "startTime": 532.7,
    "endTime": 534.32,
    "text": "Here you go, boys."
  },
  {
    "startTime": 534.32,
    "endTime": 535.5,
    "text": "OK."
  },
  {
    "startTime": 535.7,
    "endTime": 537.0,
    "text": "Toothbrushes."
  },
  {
    "startTime": 537.0,
    "endTime": 538.3,
    "text": "Is that dental floss? No."
  },
  {
    "startTime": 538.47,
    "endTime": 540.0,
    "text": "At least she has fireballs."
  },
  {
    "startTime": 540.0,
    "endTime": 541.9,
    "text": "Let me try that."
  },
  {
    "startTime": 542.1,
    "endTime": 546.5400000000001,
    "text": "Oh, that was a fresh cherry tomato straight from my garden."
  },
  {
    "startTime": 546.54,
    "endTime": 549.6999999999999,
    "text": "Yeah, it was delicious."
  },
  {
    "startTime": 549.9,
    "endTime": 557.3,
    "text": "Hey, Frank, we got about an hour until the fireworks show, you know, for the 4th of July."
  },
  {
    "startTime": 557.3,
    "endTime": 559.1769999999999,
    "text": "Sabrina's got Casper at soccer practice."
  },
  {
    "startTime": 559.177,
    "endTime": 562.5,
    "text": "And if I don't get this done before she gets home, she's going to turn me into a newt."
  },
  {
    "startTime": 562.7,
    "endTime": 564.8000000000001,
    "text": "Oh, OK."
  },
  {
    "startTime": 565.0,
    "endTime": 565.28,
    "text": "You know what?"
  },
  {
    "startTime": 565.28,
    "endTime": 567.0,
    "text": "Enjoy the Halloween spirit."
  },
  {
    "startTime": 567.0,
    "endTime": 572.0,
    "text": "We will be elsewhere."
  },
  {
    "startTime": 572.05,
    "endTime": 574.2099999999999,
    "text": "Oh, wow, he's a dinosaur."
  },
  {
    "startTime": 574.21,
    "endTime": 576.1220000000001,
    "text": "No, he's a chameleon."
  },
  {
    "startTime": 576.122,
    "endTime": 577.0,
    "text": "Oh, I know."
  },
  {
    "startTime": 577.0,
    "endTime": 578.36,
    "text": "That's what I meant to say! Chameleon!"
  },
  {
    "startTime": 578.4,
    "endTime": 579.8,
    "text": "I have to change it."
  },
  {
    "startTime": 580.0,
    "endTime": 584.4,
    "text": "[The mom who Amazon'd 40 costumes for their kid and can't decide a winner so she literally tries on all of them]"
  },
  {
    "startTime": 584.4,
    "endTime": 585.4599999999999,
    "text": "I'm a shark!"
  },
  {
    "startTime": 585.46,
    "endTime": 586.5,
    "text": "You are a shark!"
  },
  {
    "startTime": 586.7,
    "endTime": 587.2700000000001,
    "text": "You look awesome!"
  },
  {
    "startTime": 587.27,
    "endTime": 589.3149999999999,
    "text": "No, it's too baggy."
  },
  {
    "startTime": 589.315,
    "endTime": 590.47,
    "text": "Beep, beep!"
  },
  {
    "startTime": 590.47,
    "endTime": 592.36,
    "text": "Yes, trash truck."
  },
  {
    "startTime": 592.36,
    "endTime": 594.63,
    "text": "It didn't come with pants."
  },
  {
    "startTime": 593.5,
    "endTime": 595.9,
    "text": "That's fine. He never wears pants anyways."
  },
  {
    "startTime": 596.005,
    "endTime": 601.48,
    "text": "You know, it's going to be November in, like, four hours."
  },
  {
    "startTime": 601.48,
    "endTime": 602.4,
    "text": "Trick-or-treat."
  },
  {
    "startTime": 602.7,
    "endTime": 604.133,
    "text": "How's it going?"
  },
  {
    "startTime": 604.133,
    "endTime": 605.0,
    "text": "Good."
  },
  {
    "startTime": 605.0,
    "endTime": 606.0,
    "text": "Who are you guys?"
  },
  {
    "startTime": 605.9,
    "endTime": 607.4499999999999,
    "text": "We're Dude Perfect."
  },
  {
    "startTime": 607.2,
    "endTime": 608.6,
    "text": "Oh, never heard of them."
  },
  {
    "startTime": 608.8,
    "endTime": 610.38,
    "text": "[The Dude Perfect dress-up]"
  },
  {
    "startTime": 610.38,
    "endTime": 612.0,
    "text": "We're YouTubers. We do trick shots."
  },
  {
    "startTime": 612.12,
    "endTime": 613.5,
    "text": "Oh, yeah, those guys are still doing that."
  },
  {
    "startTime": 613.7,
    "endTime": 614.8000000000001,
    "text": "What are they? 60?"
  },
  {
    "startTime": 615.0,
    "endTime": 616.23,
    "text": "No, they're in their prime."
  },
  {
    "startTime": 616.23,
    "endTime": 616.7,
    "text": "Oh."
  },
  {
    "startTime": 617.0,
    "endTime": 618.8,
    "text": "Yeah, they even make their own beans."
  },
  {
    "startTime": 619.0,
    "endTime": 620.04,
    "text": "Good for them."
  },
  {
    "startTime": 620.0,
    "endTime": 621.54,
    "text": "Pound it. Noggin. See ya."
  },
  {
    "startTime": 624.0,
    "endTime": 624.5,
    "text": "Hi, thanks for watching."
  },
  {
    "startTime": 624.7,
    "endTime": 628.3000000000001,
    "text": "If you ain't a new, perfect subscriber, click down here so you don't miss out on any new videos."
  },
  {
    "startTime": 628.5,
    "endTime": 633.8,
    "text": "If you want to see the bonus video from this episode, they got the brand new Dude Perfect plus channel right over here."
  },
  {
    "startTime": 634.0,
    "endTime": 634.3,
    "text": "Check it out."
  },
  {
    "startTime": 634.5,
    "endTime": 638.375,
    "text": "And if you want a good gift for Christmas, Dude Perfect merchandise. Check them out."
  },
  {
    "startTime": 639.0,
    "endTime": 640.17,
    "text": "Sign off for now."
  },
  {
    "startTime": 640.17,
    "endTime": 641.9599999999999,
    "text": "Pound it. Noggin. See ya."
  },
  {
    "startTime": 642.08,
    "endTime": 644.23,
    "text": "Thank you. Thank you very much."
  }
]