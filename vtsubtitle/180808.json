    "endTime": 122.0,
    "text": "Gotcha!"
  },
  {
    "startTime": 123.0,
    "endTime": 124.0,
    "text": "That's it, big guy."
  },
  {
    "startTime": 124.0,
    "endTime": 125.0,
    "text": "Take deep breaths."
  },
  {
    "startTime": 126.0,
    "endTime": 130.0,
