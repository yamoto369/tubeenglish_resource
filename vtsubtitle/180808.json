  },
  {
    "startTime": 143.0,
    "endTime": 145.0,
    "text": "Oh, you must be the specialty surgeon."
  },
  {
    "startTime": 145.0,
    "endTime": 147.0,
    "text": "You're a surgeon!"
  },
  {
    "startTime": 147.0,
