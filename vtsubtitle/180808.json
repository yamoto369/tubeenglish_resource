[
  {
    "startTime": 0.0,
    "endTime": 0.0,
    "text": "Uh, fellas?"
  },
  {
    "startTime": 0.0,
    "endTime": 2.0,
    "text": "I'm getting the ol' heebie-jeebies here."
  },
  {
    "startTime": 2.0,
    "endTime": 3.0,
    "text": "I think we should skedaddle."
  },
  {
    "startTime": 4.0,
    "endTime": 5.0,
    "text": "Shouldn't we wait for the results?"
  },
  {
    "startTime": 5.0,
    "endTime": 5.0,
    "text": "No, no."
  },
  {
    "startTime": 5.0,
    "endTime": 6.0,
    "text": "I gotta get out of here."
  },
  {
    "startTime": 6.0,
    "endTime": 7.0,
    "text": "He knows something."
  },
  {
    "startTime": 7.0,
    "endTime": 8.0,
    "text": "I can feel it in my bones."
  },
  {
    "startTime": 8.0,
    "endTime": 8.0,
    "text": "Ah!"
  },
  {
    "startTime": 9.0,
    "endTime": 10.0,
    "text": "Clear all his surgeries."
  },
  {
    "startTime": 10.0,
    "endTime": 11.0,
    "text": "This is his top priority."
  },
  {
    "startTime": 11.0,
    "endTime": 12.0,
    "text": "Quick, get behind Bandit."
  },
  {
    "startTime": 12.0,
    "endTime": 15.0,
    "text": "Behind me, you dummy?"
  },
  {
    "startTime": 15.0,
    "endTime": 16.0,
    "text": "Oh, right, right."
  },
  {
    "startTime": 16.0,
    "endTime": 16.0,
    "text": "Okay, just like normal."
  },
  {
    "startTime": 18.0,
    "endTime": 21.0,
    "text": "Okay, good news is your test results are done."
  },
  {
    "startTime": 21.0,
    "endTime": 24.0,
    "text": "The bad news is that literally everything is wrong with you."
  },
  {
    "startTime": 24.0,
    "endTime": 26.0,
    "text": "We need to operate to find out more."
  },
  {
    "startTime": 26.0,
    "endTime": 27.0,
    "text": "Come get him, guys!"
  },
  {
    "startTime": 27.0,
    "endTime": 27.0,
    "text": "Wait, what?"
  },
  {
    "startTime": 27.0,
    "endTime": 29.0,
    "text": "Okay, uh, what's going on?"
  },
  {
    "startTime": 29.0,
    "endTime": 30.0,
    "text": "No, no, let go of me!"
  },
  {
    "startTime": 30.0,
    "endTime": 31.0,
    "text": "Panda, hey, Panda!"
  },
  {
    "startTime": 31.0,
    "endTime": 31.0,
    "text": "Hold it."
  },
  {
    "startTime": 31.0,
    "endTime": 33.0,
    "text": "We've never seen these results before."
  },
  {
    "startTime": 33.0,
    "endTime": 35.0,
    "text": "We need to find out if he's contagious to others."
  },
  {
    "startTime": 35.0,
    "endTime": 37.0,
    "text": "Plus, he signed this consent form."
  },
  {
    "startTime": 37.0,
    "endTime": 39.0,
    "text": "Trust me, it's for your brother's own good."
  },
  {
    "startTime": 39.0,
    "endTime": 41.0,
    "text": "If you try to interfere, I'm gonna have to call security."
  },
  {
    "startTime": 41.0,
    "endTime": 42.0,
    "text": "Doctor, wait!"
  },
  {
    "startTime": 42.0,
    "endTime": 42.0,
    "text": "No!"
  },
  {
    "startTime": 43.0,
    "endTime": 44.0,
    "text": "Despair."
  },
  {
    "startTime": 45.0,
    "endTime": 46.0,
    "text": "What'd I miss?"
  },
  {
    "startTime": 46.0,
    "endTime": 47.0,
    "text": "No, let me go!"
  },
  {
    "startTime": 48.0,
    "endTime": 49.0,
    "text": "Why am I strapped down?"
  },
  {
    "startTime": 49.0,
    "endTime": 51.0,
    "text": "What is going on?"
  },
  {
    "startTime": 51.0,
    "endTime": 51.0,
    "text": "Hey, Panda."
  },
  {
    "startTime": 52.0,
    "endTime": 53.0,
    "text": "Dr. Clark, what is happening?"
  },
  {
    "startTime": 54.0,
    "endTime": 55.0,
    "text": "We are taking you in for surgery right now."
  },
  {
    "startTime": 55.0,
    "endTime": 57.0,
    "text": "But I don't need surgery!"
  },
  {
    "startTime": 57.0,
    "endTime": 58.0,
    "text": "I'm fine, see?"
  },
  {
    "startTime": 59.0,
    "endTime": 61.0,
    "text": "Yeah, he's delirious."
  },
  {
    "startTime": 61.0,
    "endTime": 62.0,
    "text": "Take him to op room three."
  },
  {
    "startTime": 62.0,
    "endTime": 64.0,
    "text": "I'll send for the specialist surgeon right away."
  },
  {
    "startTime": 64.0,
    "endTime": 65.0,
    "text": "Yes, sir."
  },
  {
    "startTime": 65.0,
    "endTime": 66.0,
    "text": "I don't need surgery!"
  },
  {
    "startTime": 68.0,
    "endTime": 73.0,
    "text": "So this is the strange patient, huh?"
  },
  {
    "startTime": 73.0,
    "endTime": 74.0,
    "text": "He doesn't look so strange."
  },
  {
    "startTime": 74.0,
    "endTime": 75.0,
    "text": "He just looks like a panda."
  },
  {
    "startTime": 75.0,
    "endTime": 77.0,
    "text": "Yeah, but I heard he has blue blood."
  },
  {
    "startTime": 77.0,
    "endTime": 78.0,
    "text": "You guys are crazy!"
  },
  {
    "startTime": 78.0,
    "endTime": 79.0,
    "text": "Let me go!"
  },
  {
    "startTime": 79.0,
    "endTime": 79.0,
    "text": "Please help me!"
  },
  {
    "startTime": 80.0,
    "endTime": 80.0,
    "text": "Help!"
  },
  {
    "startTime": 80.0,
    "endTime": 82.0,
    "text": "No, let me go!"
  },
  {
    "startTime": 82.0,
    "endTime": 84.0,
    "text": "This is all Charlie's fault!"
  },
  {
    "startTime": 84.0,
    "endTime": 85.0,
    "text": "He's too hysterical!"
  },
  {
    "startTime": 85.0,
    "endTime": 86.0,
    "text": "Get the gas!"
  },
  {
    "startTime": 86.0,
    "endTime": 86.0,
    "text": "Gas!"
  },
  {
    "startTime": 88.0,
    "endTime": 90.0,
    "text": "What are we gonna do?"
  },
  {
    "startTime": 90.0,
    "endTime": 91.0,
    "text": "I heard they have a specialist surgeon."
  },
  {
    "startTime": 91.0,
    "endTime": 93.0,
    "text": "He could be surgiring him right now."
  },
  {
    "startTime": 93.0,
    "endTime": 94.0,
    "text": "This is my fault."
  },
  {
    "startTime": 94.0,
    "endTime": 95.0,
    "text": "Me and my dumb foot."
  },
  {
    "startTime": 95.0,
    "endTime": 97.0,
    "text": "Now my pan-pan's in danger."
  },
  {
    "startTime": 97.0,
    "endTime": 100.0,
    "text": "Don't give up, Charlie."
  },
  {
    "startTime": 100.0,
    "endTime": 102.0,
    "text": "We're gonna figure something out, man."
  },
  {
    "startTime": 102.0,
    "endTime": 102.0,
    "text": "Think, Chris."
  },
  {
    "startTime": 102.0,
    "endTime": 103.0,
    "text": "Think, Chris."
  },
  {
    "startTime": 103.0,
    "endTime": 103.0,
    "text": "Think."
  },
  {
    "startTime": 103.0,
    "endTime": 107.0,
    "text": "All of Ice Bear's ideas involve fireworks, blimp, catapult, bandages."
  },
  {
