  },
  {
    "startTime": 115.0,
    "endTime": 116.0,
    "text": "Oh, yeah."
  },
  {
    "startTime": 116.0,
    "endTime": 116.0,
    "text": "Ow!"
  },
  {
    "startTime": 116.0,
    "endTime": 117.0,
    "text": "No!"
  },
  {
    "startTime": 117.0,
    "endTime": 117.0,
    "text": "No!"
  },
  {
    "startTime": 117.0,
    "endTime": 118.0,
    "text": "I don't want it!"
  },
  {
    "startTime": 118.0,
    "endTime": 119.0,
    "text": "Sir, calm down."
  },
  {
    "startTime": 119.0,
    "endTime": 119.0,
    "text": "This will help."
