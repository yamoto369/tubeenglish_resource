[
  {
    "startTime": 1.2,
    "endTime": 2.3,
    "text": "An address."
  },
  {
    "startTime": 2.9,
    "endTime": 3.5999999999999996,
    "text": "What's that?"
  },
  {
    "startTime": 3.7,
    "endTime": 5.1,
    "text": "A safe house in Paris."
  },
  {
    "startTime": 5.2,
    "endTime": 6.88,
    "text": "Why would I need a safe house in Paris?"
  },
  {
    "startTime": 6.9,
    "endTime": 10.7,
    "text": "Should things, at some point, go terribly wrong, it's good to have a place to go."
  },
  {
    "startTime": 11.2,
    "endTime": 13.299999999999999,
    "text": "You know, for a cup of tea."
  },
  {
    "startTime": 14.8,
    "endTime": 16.0,
    "text": "My brothers."
  },
  {
    "startTime": 17.5,
    "endTime": 18.8,
    "text": "My sisters."
  },
  {
    "startTime": 19.3,
    "endTime": 21.6,
    "text": "The clock is ticking faster."
  },
  {
    "startTime": 23.1,
    "endTime": 24.3,
    "text": "My dream..."
  },
  {
    "startTime": 25.1,
    "endTime": 29.5,
    "text": "... we, who live for truth, for love..."
  },
  {
    "startTime": 29.8,
    "endTime": 30.900000000000002,
    "text": "Nagini."
  },
  {
    "startTime": 31.0,
    "endTime": 35.0,
    "text": "The moment has come to take our rightful place..."
  },
  {
    "startTime": 36.1,
    "endTime": 40.6,
    "text": "... in the world where we wizards are free."
  },
  {
    "startTime": 43.335,
    "endTime": 44.300000000000004,
    "text": "Join me..."
  },
  {
    "startTime": 47.5,
    "endTime": 48.5,
    "text": "... or die."
  },
  {
    "startTime": 50.1,
    "endTime": 53.7,
    "text": "The wizarding and non-wizarding worlds have been at peace for over a century."
  },
  {
    "startTime": 56.4,
    "endTime": 59.0,
    "text": "Grindelwald wants to see that peace destroyed."
  },
  {
    "startTime": 62.3,
    "endTime": 64.3,
    "text": "You want me to hunt him down?"
  },
  {
    "startTime": 65.6,
    "endTime": 66.6,
    "text": "To kill him?"
  },
  {
    "startTime": 70.2,
    "endTime": 72.5,
    "text": "Dumbledore, why can't you go?"
  },
  {
    "startTime": 73.2,
    "endTime": 75.0,
    "text": "I cannot move against Grindelwald."
  },
  {
    "startTime": 76.5,
    "endTime": 77.6,
    "text": "It has to be you."
  },
  {
    "startTime": 80.8,
    "endTime": 82.89999999999999,
    "text": "You don't suffer from motion sickness, do you?"
  },
  {
    "startTime": 83.0,
    "endTime": 84.2,
    "text": "I don't do well on boats."
  },
  {
    "startTime": 84.3,
    "endTime": 85.2,
    "text": "You'll be fine."
  },
  {
    "startTime": 90.3,
    "endTime": 92.0,
    "text": "Do you know why I admire you, Newt?"
  },
  {
    "startTime": 93.2,
    "endTime": 94.7,
    "text": "You do not seek power."
  },
  {
    "startTime": 95.9,
    "endTime": 97.80000000000001,
    "text": "You simply ask, \"Is a thing...\""
  },
  {
    "startTime": 98.5,
    "endTime": 99.4,
    "text": "\"... right?\""
  },
  {
    "startTime": 103.7,
    "endTime": 104.7,
    "text": "The time's coming..."
  },
  {
    "startTime": 105.9,
    "endTime": 107.60000000000001,
    "text": "... when you're gonna have to pick a side."
  },
  {
    "startTime": 108.7,
    "endTime": 110.60000000000001,
    "text": "No, I don't do sides."
  },
  {
    "startTime": 111.6,
    "endTime": 112.69999999999999,
    "text": "What are you gonna do?"
  },
  {
    "startTime": 114.5,
    "endTime": 115.5,
    "text": "I'll think of something."
  },
  {
    "startTime": 117.2,
    "endTime": 120.10000000000001,
    "text": "Newt, you never met a monster you couldn't love."
  },
  {
    "startTime": 120.8,
    "endTime": 121.8,
    "text": "Let's take him."
  },
  {
    "startTime": 135.6,
    "endTime": 136.6,
    "text": "That's your brother?"
  },
  {
    "startTime": 138.7,
    "endTime": 140.89999999999998,
    "text": "I think that might've been the best moment of my life."
  }
]