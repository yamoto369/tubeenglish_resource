[
  {
    "startTime": 4.212,
    "endTime": 5.212,
    "text": "I'm awesome."
  },
  {
    "startTime": 7.3,
    "endTime": 8.6,
    "text": "Boys, where have you been?"
  },
  {
    "startTime": 8.8,
    "endTime": 11.261000000000001,
    "text": "Woo!"
  },
  {
    "startTime": 11.261,
    "endTime": 12.6,
    "text": "We're just running errands."
  },
  {
    "startTime": 12.8,
    "endTime": 14.765,
    "text": "That's it?"
  },
  {
    "startTime": 16.2,
    "endTime": 17.308,
    "text": "Look, we're really sorry, Splinter."
  },
  {
    "startTime": 17.308,
    "endTime": 19.2,
    "text": "Some of the guys wanted to get pizza and I tried to talk them out of it."
  },
  {
    "startTime": 19.4,
    "endTime": 20.0,
    "text": "Leo!"
  },
  {
    "startTime": 20.103,
    "endTime": 20.900000000000002,
    "text": "You ratted us out!"
  },
  {
    "startTime": 21.062,
    "endTime": 22.704,
    "text": "Hey! Don't use that word that way."
  },
  {
    "startTime": 22.9,
    "endTime": 25.02,
    "text": "- I mean, it’s 2023, Mikey. - Sorry, Dad."
  },
  {
    "startTime": 26.5,
    "endTime": 28.0,
    "text": "Woo hoo!"
  },
  {
    "startTime": 27.905,
    "endTime": 29.029,
    "text": "Hey, guys."
  },
  {
    "startTime": 29.029,
    "endTime": 34.7,
    "text": "If we weren't monsters that were shunned by society and we could do what we wanted, what would you guys do?"
  },
  {
    "startTime": 34.801,
    "endTime": 35.2,
    "text": "Go to high school."
  },
  {
    "startTime": 35.41,
    "endTime": 37.077999999999996,
    "text": "Maybe get a girlfriend."
  },
  {
    "startTime": 37.078,
    "endTime": 37.900000000000006,
    "text": "Can you imagine that?"
  },
  {
    "startTime": 38.5,
    "endTime": 39.409,
    "text": "Not likely."
  },
  {
    "startTime": 43.0,
    "endTime": 44.156,
    "text": "This is insane."
  },
  {
    "startTime": 44.156,
    "endTime": 46.458,
    "text": "Turtle. Mutant. Karate. Teens."
  },
  {
    "startTime": 47.2,
    "endTime": 49.0,
    "text": "I want to know everything about you."
  },
  {
    "startTime": 49.1,
    "endTime": 51.617000000000004,
    "text": "Our dad is definitely not a giant rat."
  },
  {
    "startTime": 52.0,
    "endTime": 55.1,
    "text": "That makes me feel like he's a rat."
  },
  {
    "startTime": 55.5,
    "endTime": 59.644999999999996,
    "text": "Police are baffled by the recent crime wave led by Superfly."
  },
  {
    "startTime": 59.8,
    "endTime": 61.4,
    "text": "- Nobody's ever seen his face. - Why?"
  },
  {
    "startTime": 61.548,
    "endTime": 64.18900000000001,
    "text": "Because he kills everyone who does."
  },
  {
    "startTime": 64.189,
    "endTime": 65.52,
    "text": "Whoa."
  },
  {
    "startTime": 66.0,
    "endTime": 66.56,
    "text": "Cool."
  },
  {
    "startTime": 66.56,
    "endTime": 67.758,
    "text": "No. Not cool."
  },
  {
    "startTime": 67.758,
    "endTime": 69.6,
    "text": "Eh, a bit cool."
  },
  {
    "startTime": 69.8,
    "endTime": 72.707,
    "text": "We take out Superfly, and then everyone will think we're cool."
  },
  {
    "startTime": 72.707,
    "endTime": 74.6,
    "text": "They’ll accept us!"
  },
  {
    "startTime": 75.0,
    "endTime": 77.924,
    "text": "He’s making a deal tonight, under the Brooklyn Bridge."
  },
  {
    "startTime": 80.2,
    "endTime": 81.5,
    "text": "Whoa."
  },
  {
    "startTime": 82.7,
    "endTime": 85.09400000000001,
    "text": "What the?! Y’all some little tortises, huh?"
  },
  {
    "startTime": 85.001,
    "endTime": 87.03200000000001,
    "text": "I can't believe there are other mutants!"
  },
  {
    "startTime": 87.5,
    "endTime": 88.7,
    "text": "You wanna roll with us?"
  },
  {
    "startTime": 90.5,
    "endTime": 92.595,
    "text": "Humans are never gonna like us."
  },
  {
    "startTime": 94.3,
    "endTime": 97.02199999999999,
    "text": "So we gonna let the mutants rule the earth!"
  },
  {
    "startTime": 98.3,
    "endTime": 100.471,
    "text": "Peoples, zey got to go."
  },
  {
    "startTime": 100.471,
    "endTime": 102.658,
    "text": "Okay, um, sort of a twist."
  },
  {
    "startTime": 104.5,
    "endTime": 105.489,
    "text": "We can't stop him."
  },
  {
    "startTime": 105.489,
    "endTime": 106.546,
    "text": "We gotta try!"
  },
  {
    "startTime": 108.0,
    "endTime": 110.465,
    "text": "Six in the morning, police at my door."
  },
  {
    "startTime": 114.2,
    "endTime": 115.99000000000001,
    "text": "Go, go, go, go, go, go!"
  },
  {
    "startTime": 115.99,
    "endTime": 118.098,
    "text": "My son, Michelangelo."
  },
  {
    "startTime": 118.098,
    "endTime": 119.565,
    "text": "You have heart."
  },
  {
    "startTime": 119.565,
    "endTime": 121.792,
    "text": "Donatello, you have wisdom."
  },
  {
    "startTime": 121.792,
    "endTime": 124.169,
    "text": "Raphael, you have bravery."
  },
  {
    "startTime": 124.169,
    "endTime": 126.524,
    "text": "And Leonardo, honor."
  },
  {
    "startTime": 128.0,
    "endTime": 130.113,
    "text": "Enough talk! I dream about fighting every night!"
  },
  {
    "startTime": 130.113,
    "endTime": 131.701,
    "text": "- You've got a rage problem, Raph. - Oh, snap."
  },
  {
    "startTime": 131.701,
    "endTime": 138.096,
    "text": "It's not a problem!"
  },
  {
    "startTime": 138.4,
    "endTime": 140.348,
    "text": "Cowabunga!"
  }
]