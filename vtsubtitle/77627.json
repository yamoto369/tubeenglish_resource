  },
  {
    "startTime": 243.8,
    "endTime": 245.0,
    "text": "I'll be leaving soon."
  },
  {
    "startTime": 245.29,
    "endTime": 247.09,
    "text": "Don't worry because it's going to be a lot of..."
  },
  {
    "startTime": 247.09,
    "endTime": 251.5,
    "text": "There's internet there, so I get to Facetime you guys, or Facebook you guys everyday."
  },
  {
    "startTime": 251.73,
    "endTime": 253.5,
    "text": "Thank you for serving our country."
  },
  {
    "startTime": 253.71,
    "endTime": 254.5,
    "text": "You're welcome, sweetie."
  },
  {
    "startTime": 254.73,
    "endTime": 261.0,
    "text": "Thank you for taking care of all three of us while Dad's deployed."
  },
  {
    "startTime": 261.1,
