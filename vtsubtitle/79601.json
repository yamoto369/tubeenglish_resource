[
  {
    "startTime": 0.0,
    "endTime": 2.54,
    "text": "Hello, I'm Sam and in this lesson"
  },
  {
    "startTime": 2.54,
    "endTime": 5.32,
    "text": "we're going to look at the differences between"
  },
  {
    "startTime": 5.32,
    "endTime": 10.08,
    "text": "'at', 'in' and 'on' for location."
  },
  {
    "startTime": 10.08,
    "endTime": 16.72,
    "text": "'At' can be used to talk about a single specific location."
  },
  {
    "startTime": 16.72,
    "endTime": 18.48,
    "text": "I'm at work."
  },
  {
    "startTime": 18.48,
    "endTime": 22.0,
    "text": "Or: I'm at the BBC right now."
  },
  {
    "startTime": 22.0,
    "endTime": 25.92,
    "text": "'On' is used in relation to a surface."
  },
  {
    "startTime": 25.92,
    "endTime": 28.160000000000004,
    "text": "I'm sitting on a chair."
  },
  {
    "startTime": 28.16,
    "endTime": 33.08,
    "text": "And 'in' is used to talk about a three-dimensional space,"
  },
  {
    "startTime": 33.08,
    "endTime": 35.36,
    "text": "usually with four walls."
  },
  {
    "startTime": 35.36,
    "endTime": 38.4,
    "text": "It's similar to 'inside'."
  },
  {
    "startTime": 38.4,
    "endTime": 40.14,
    "text": "I'm in a room."
  },
  {
    "startTime": 40.14,
    "endTime": 42.980000000000004,
    "text": "So to help you remember these rules,"
  },
  {
    "startTime": 42.98,
    "endTime": 45.019,
    "text": "try to think of a concert:"
  },
  {
    "startTime": 45.02,
    "endTime": 47.02,
    "text": "I'm at the front."
  },
  {
    "startTime": 47.02,
    "endTime": 49.440000000000005,
    "text": "The band is on the stage."
  },
  {
    "startTime": 49.44,
    "endTime": 52.16,
    "text": "And my friends are in the crowd."
  },
  {
    "startTime": 52.16,
    "endTime": 53.86,
    "text": "And where are you right now?"
  }
]