[
  {
    "startTime": 0.0,
    "endTime": 2.0,
    "text": "Let me call you back."
  },
  {
    "startTime": 3.0,
    "endTime": 6.0,
    "text": "There's still one thing I need to take care of."
  },
  {
    "startTime": 34.0,
    "endTime": 36.0,
    "text": "Oh, I'm so excited."
  },
  {
    "startTime": 36.0,
    "endTime": 37.0,
    "text": "Our first day of filming."
  },
  {
    "startTime": 37.0,
    "endTime": 39.0,
    "text": "I hope it becomes a cult classic."
  },
  {
    "startTime": 40.0,
    "endTime": 40.0,
    "text": "Ice Bear..."
  },
  {
    "startTime": 40.0,
    "endTime": 42.0,
    "text": "Ice Bear is down here."
  },
  {
    "startTime": 42.0,
    "endTime": 43.0,
    "text": "Wait, did you hear something?"
  },
  {
    "startTime": 43.0,
    "endTime": 44.0,
    "text": "I didn't hear anything."
  },
  {
    "startTime": 44.0,
    "endTime": 48.0,
    "text": "We should get going."
  },
  {
    "startTime": 48.0,
    "endTime": 52.0,
    "text": "Well, here we are."
  },
  {
    "startTime": 53.0,
    "endTime": 54.0,
    "text": "Welcome to the movie set, boys."
  },
  {
    "startTime": 54.0,
    "endTime": 56.0,
    "text": "And everyone you see here is an extra in the movie."
  },
  {
    "startTime": 56.0,
    "endTime": 57.0,
    "text": "Wow!"
  },
  {
    "startTime": 57.0,
    "endTime": 59.0,
    "text": "Uh, where are the cameras?"
  },
  {
    "startTime": 59.0,
    "endTime": 60.0,
    "text": "Oh, they're hidden everywhere."
  },
  {
    "startTime": 60.0,
    "endTime": 61.0,
    "text": "It'll help with your acting."
  },
  {
    "startTime": 61.0,
    "endTime": 62.0,
    "text": "Wait, what?"
  },
  {
    "startTime": 62.0,
    "endTime": 63.0,
    "text": "We're acting?"
  },
  {
    "startTime": 63.0,
    "endTime": 64.0,
    "text": "What, we get to be in the movie?"
  },
  {
    "startTime": 64.0,
    "endTime": 66.0,
    "text": "Oops, did I forget to mention that?"
  },
  {
    "startTime": 66.0,
    "endTime": 67.0,
    "text": "Oh!"
  },
  {
    "startTime": 67.0,
    "endTime": 70.0,
    "text": "Hey, Nan, um, um, could we rehearse our lines first?"
  },
  {
    "startTime": 70.0,
    "endTime": 71.0,
    "text": "Nah, no time."
  },
  {
    "startTime": 71.0,
    "endTime": 72.0,
    "text": "All right, quick, take your rocks in the pool."
  },
  {
    "startTime": 72.0,
    "endTime": 74.0,
    "text": "And remember, your characters are in distress."
  },
  {
    "startTime": 75.0,
    "endTime": 76.0,
    "text": "Here's your costumes and props."
  },
  {
    "startTime": 76.0,
    "endTime": 77.0,
    "text": "Put them on and get in your places."
  },
  {
    "startTime": 78.0,
    "endTime": 78.0,
    "text": "Thanks, man."
  },
  {
    "startTime": 78.0,
    "endTime": 79.0,
    "text": "We won't let you down."
  },
  {
    "startTime": 79.0,
    "endTime": 80.0,
    "text": "All right, go get them."
  },
  {
    "startTime": 83.0,
    "endTime": 85.0,
    "text": "Aw, man, why is the slide closed?"
  },
  {
    "startTime": 85.0,
    "endTime": 85.0,
    "text": "Scram."
  },
  {
    "startTime": 86.0,
    "endTime": 87.0,
    "text": "Go swim in chlorine with your eyes open."
  },
  {
    "startTime": 90.0,
    "endTime": 94.0,
    "text": "Mailman, I have a package for a grizzly bear."
  },
  {
    "startTime": 94.0,
    "endTime": 95.0,
    "text": "Hello?"
  },
  {
    "startTime": 95.0,
    "endTime": 96.0,
    "text": "Anybody here?"
  },
  {
    "startTime": 97.0,
    "endTime": 97.0,
    "text": "Whoa!"
  },
  {
    "startTime": 98.0,
    "endTime": 98.0,
    "text": "Oh, my!"
  },
  {
    "startTime": 100.0,
    "endTime": 101.0,
    "text": "Package for grizzly bear?"
  },
  {
    "startTime": 102.0,
    "endTime": 102.0,
    "text": "Here, let me."
  },
  {
    "startTime": 102.0,
    "endTime": 103.0,
    "text": "Oops."
  },
  {
    "startTime": 103.0,
    "endTime": 104.0,
    "text": "Okay, then."
  },
  {
    "startTime": 106.0,
    "endTime": 107.0,
    "text": "Ooh."
  },
  {
    "startTime": 108.0,
    "endTime": 111.0,
    "text": "Okay, guys, ready?"
  },
  {
    "startTime": 111.0,
    "endTime": 112.0,
    "text": "And action!"
  },
  {
    "startTime": 112.0,
    "endTime": 114.0,
    "text": "Oh, no, the water is drowning us!"
  },
  {
    "startTime": 114.0,
    "endTime": 115.0,
    "text": "Attention, everyone."
  },
  {
    "startTime": 115.0,
    "endTime": 118.0,
    "text": "Can you all focus your attention on the drowning bears, please?"
  },
  {
    "startTime": 118.0,
    "endTime": 121.0,
    "text": "I have a water filling up my tummy."
  },
  {
    "startTime": 121.0,
    "endTime": 126.0,
    "text": "Flawless."
  },
  {
    "startTime": 126.0,
    "endTime": 128.0,
    "text": "And now to raise the stakes."
  },
  {
    "startTime": 130.0,
    "endTime": 134.0,
    "text": "Whoa, what's that?"
  },
  {
    "startTime": 135.0,
    "endTime": 136.0,
    "text": "It's a shark!"
  },
  {
    "startTime": 136.0,
    "endTime": 141.0,
    "text": "Everyone's playing their parts so well."
  },
  {
    "startTime": 142.0,
    "endTime": 144.0,
    "text": "Those bears are still in the water!"
  },
  {
    "startTime": 144.0,
    "endTime": 146.0,
    "text": "Oh, look, everyone, it's Nom Nom."
  },
  {
    "startTime": 152.0,
    "endTime": 154.0,
    "text": "Why are all the extras out of the pool?"
  },
  {
    "startTime": 154.0,
    "endTime": 155.0,
    "text": "Is that special effects?"
  },
  {
    "startTime": 156.0,
    "endTime": 159.0,
    "text": "Uh, that felt real."
  },
  {
    "startTime": 160.0,
    "endTime": 161.0,
    "text": "Help!"
  },
  {
    "startTime": 161.0,
    "endTime": 163.0,
    "text": "A giant shark!"
  },
  {
    "startTime": 165.0,
    "endTime": 168.0,
    "text": "Nom Nom is saving them!"
  },
  {
    "startTime": 168.0,
    "endTime": 169.0,
    "text": "He's a hero!"
  },
  {
    "startTime": 170.0,
    "endTime": 171.0,
    "text": "Bears, remain calm!"
  },
  {
    "startTime": 171.0,
    "endTime": 172.0,
    "text": "Nom Nom, get out of the pool, man!"
  },
  {
    "startTime": 172.0,
    "endTime": 173.0,
    "text": "There's real sharks!"
  },
  {
    "startTime": 173.0,
    "endTime": 175.0,
    "text": "What are you doing?"
  },
  {
    "startTime": 175.0,
    "endTime": 175.0,
    "text": "Stop!"
  },
  {
    "startTime": 180.0,
    "endTime": 181.0,
    "text": "Help!"
  },
  {
    "startTime": 180.0,
    "endTime": 183.0,
    "text": "Eat them first, I'm small and bony!"
  },
  {
    "startTime": 183.0,
    "endTime": 185.0,
    "text": "Whoa, what's that?"
  },
  {
    "startTime": 187.0,
    "endTime": 200.0,
    "text": "No, no, no, you ruined my video!"
  },
  {
    "startTime": 200.0,
    "endTime": 202.0,
    "text": "This was my shot, let me down!"
  },
  {
    "startTime": 203.0,
    "endTime": 204.0,
    "text": "Ah!"
  },
  {
    "startTime": 204.0,
    "endTime": 205.0,
    "text": "Ah!"
  },
  {
    "startTime": 208.0,
    "endTime": 209.0,
    "text": "Huh?"
  },
  {
    "startTime": 208.0,
    "endTime": 211.0,
    "text": "Hey, look, it's Nom Nom and he's being adorable!"
  },
  {
    "startTime": 211.0,
    "endTime": 224.0,
    "text": "Well, looks like Nom Nom is back where he belongs."
  },
  {
    "startTime": 225.0,
    "endTime": 225.0,
    "text": "On the internet."
  },
  {
    "startTime": 226.0,
    "endTime": 227.0,
    "text": "Bummer we didn't get to be in that movie, though."
  },
  {
    "startTime": 228.0,
    "endTime": 230.0,
    "text": "Yeah, but at least we weren't eaten alive by sharks."
  },
  {
    "startTime": 230.0,
    "endTime": 231.0,
    "text": "True that."
  },
  {
    "startTime": 232.0,
    "endTime": 233.0,
    "text": "Uh, catch up."
  },
  {
    "startTime": 235.0,
    "endTime": 236.0,
    "text": " Nom Nom."
  }
]