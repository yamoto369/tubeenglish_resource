[
  {
    "startTime": 0.0,
    "endTime": 1.25,
    "text": "Excuse me."
  },
  {
    "startTime": 1.25,
    "endTime": 3.125,
    "text": "Who are you?"
  },
  {
    "startTime": 3.166,
    "endTime": 4.667,
    "text": "Your grandma!"
  },
  {
    "startTime": 4.708,
    "endTime": 8.208,
    "text": "Don't let this psych you out, but magic is real."
  },
  {
    "startTime": 10.583,
    "endTime": 12.834,
    "text": "I'm not missing another chance to time-travel."
  },
  {
    "startTime": 12.875,
    "endTime": 14.5,
    "text": "We're in 1975."
  },
  {
    "startTime": 14.542,
    "endTime": 16.041,
    "text": "Ten-dollar vintage jeans?"
  },
  {
    "startTime": 16.082,
    "endTime": 17.916,
    "text": "Technically, they're not vintage yet."
  },
  {
    "startTime": 20.625,
    "endTime": 22.417,
    "text": "The night-blooming plants are gone."
  },
  {
    "startTime": 22.458,
    "endTime": 24.625,
    "text": "But we're the only ones who remember magic."
  },
  {
    "startTime": 24.667,
    "endTime": 26.25,
    "text": "There must be someone else out there."
  },
  {
    "startTime": 26.291,
    "endTime": 28.0,
    "text": "You're sure they don't know it was you?"
  },
  {
    "startTime": 28.1,
    "endTime": 29.083000000000002,
    "text": "Don't worry about the girls."
  },
  {
    "startTime": 29.125,
    "endTime": 30.083,
    "text": "I'll handle them."
  },
  {
    "startTime": 30.125,
    "endTime": 31.667,
    "text": "They can find a way to stop you."
  },
  {
    "startTime": 31.708,
    "endTime": 34.417,
    "text": "You said there'd be a downside from re-growing our magic garden."
  },
  {
    "startTime": 34.458,
    "endTime": 35.958,
    "text": "You think this is it?"
  },
  {
    "startTime": 36.0,
    "endTime": 37.0,
    "text": "We need your help."
  },
  {
    "startTime": 37.0,
    "endTime": 37.834,
    "text": "What else is new?"
  },
  {
    "startTime": 37.875,
    "endTime": 40.458,
    "text": "I came up with a recipe to unmask The Night Bandit."
  },
  {
    "startTime": 40.5,
    "endTime": 42.458,
    "text": "I'll get the ingredients."
  },
  {
    "startTime": 42.5,
    "endTime": 46.208,
    "text": "Parquinnien doesn't exist now, but we could go to a time when it did."
  },
  {
    "startTime": 46.25,
    "endTime": 48.0,
    "text": "1800s, here we come."
  },
  {
    "startTime": 48.041,
    "endTime": 50.875,
    "text": "Thought that description of the strange girls sounded familiar."
  },
  {
    "startTime": 50.917,
    "endTime": 51.708,
    "text": "Chuck."
  },
  {
    "startTime": 51.75,
    "endTime": 52.917,
    "text": "Help yourself to whatever you need."
  },
  {
    "startTime": 52.959,
    "endTime": 55.959,
    "text": "There's spices we've never even heard of."
  },
  {
    "startTime": 56.0,
    "endTime": 56.8,
    "text": "Hi!"
  },
  {
    "startTime": 56.8,
    "endTime": 59.375,
    "text": "We look so young!"
  },
  {
    "startTime": 59.417,
    "endTime": 60.7,
    "text": "Okay."
  },
  {
    "startTime": 60.7,
    "endTime": 63.083000000000006,
    "text": "This is a lot to process."
  },
  {
    "startTime": 63.125,
    "endTime": 67.667,
    "text": "The Night Bandit caused an earthquake and cursed us with a rot spell."
  },
  {
    "startTime": 67.708,
    "endTime": 69.75,
    "text": "Whoa, cool."
  },
  {
    "startTime": 69.792,
    "endTime": 71.708,
    "text": "But... not cool."
  },
  {
    "startTime": 71.75,
    "endTime": 74.291,
    "text": "Once we make this spell, it will all be over."
  },
  {
    "startTime": 74.333,
    "endTime": 76.667,
    "text": "Somebody wants to keep us seriously distracted."
  },
  {
    "startTime": 76.708,
    "endTime": 78.3,
    "text": "How did we not see it before?"
  },
  {
    "startTime": 78.3,
    "endTime": 80.0,
    "text": "You guys can solve anything."
  },
  {
    "startTime": 80.0,
    "endTime": 80.875,
    "text": "We better get cooking."
  },
  {
    "startTime": 80.917,
    "endTime": 83.0,
    "text": "One, two, three."
  },
  {
    "startTime": 89.583,
    "endTime": 90.959,
    "text": "Hannah, we need to focus."
  },
  {
    "startTime": 91.0,
    "endTime": 92.792,
    "text": "I'm totally focused."
  },
  {
    "startTime": 92.834,
    "endTime": 95.166,
    "text": "Look, a gorilla cuddling a kitten!"
  }
]