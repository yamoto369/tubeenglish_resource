[
  {
    "startTime": 11.22,
    "endTime": 17.630000000000003,
    "text": "I thought I saw a girl brought to life"
  },
  {
    "startTime": 17.63,
    "endTime": 23.34,
    "text": "She was warm, she came around and she was dignified"
  },
  {
    "startTime": 23.34,
    "endTime": 27.64,
    "text": "She showed me what it was to cry"
  },
  {
    "startTime": 27.64,
    "endTime": 32.71,
    "text": "Well, you couldn't be that girl I adored"
  },
  {
    "startTime": 32.71,
    "endTime": 34.660000000000004,
    "text": "You don't seem to know"
  },
  {
    "startTime": 34.66,
    "endTime": 38.778999999999996,
    "text": "Seem to care what your heart is for"
  },
  {
    "startTime": 38.78,
    "endTime": 41.160000000000004,
    "text": "No, I don't know her anymore"
  },
  {
    "startTime": 41.16,
    "endTime": 43.989,
    "text": "There's nothing where we used to lie"
  },
  {
    "startTime": 43.99,
    "endTime": 46.47,
    "text": "The conversation has run dry"
  },
  {
    "startTime": 46.47,
    "endTime": 49.5,
    "text": "That's what's going on"
  },
  {
    "startTime": 49.5,
    "endTime": 52.278999999999996,
    "text": "Nothing's fine, I'm torn"
  },
  {
    "startTime": 52.28,
    "endTime": 54.84,
    "text": "I'm all out of faith"
  },
  {
    "startTime": 54.84,
    "endTime": 57.120000000000005,
    "text": "This is how I feel"
  },
  {
    "startTime": 57.12,
    "endTime": 59.419,
    "text": "I'm cold and I am shamed"
  },
  {
    "startTime": 59.42,
    "endTime": 62.28,
    "text": "Lying naked on the floor"
  },
  {
    "startTime": 62.28,
    "endTime": 64.67,
    "text": "Illusion never changed"
  },
  {
    "startTime": 64.67,
    "endTime": 67.14,
    "text": "Into something real"
  },
  {
    "startTime": 67.14,
    "endTime": 69.56,
