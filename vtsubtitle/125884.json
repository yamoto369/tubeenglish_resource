  },
  {
    "startTime": 119.118,
    "endTime": 119.952,
    "text": ">> STEPHEN: I'M OKAY, ELMO."
  },
  {
    "startTime": 119.986,
    "endTime": 121.187,
    "text": "I'M VERY EXCITED TO WATCH YOUR NEW SHOW."
  },
  {
    "startTime": 121.22,
