  },
  {
    "startTime": 96.095,
    "endTime": 97.263,
    "text": ">> YEAH."
  },
  {
    "startTime": 97.296,
    "endTime": 100.5,
    "text": ">> Stephen: BY THE WAY, ELMO, I'VE NEVER SEEN YOU IN A SUIT"
