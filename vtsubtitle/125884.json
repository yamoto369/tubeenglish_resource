    "text": "FURRY TICKLISH HOST-- AND I'M NOT TALKING ABOUT JOHN"
  },
  {
    "startTime": 23.089,
    "endTime": 24.224,
    "text": "KRASINSKI."
  },
  {
    "startTime": 24.257,
    "endTime": 29.729000000000003,
    "text": "I MEAN ELMO, WHO IS ABOUT TO STAR IN \"THE NOT TOO LATE SHOW"
  },
  {
    "startTime": 29.762,
    "endTime": 30.63,
    "text": "WITH ELMO.\""
  },
  {
    "startTime": 30.663,
    "endTime": 32.832,
    "text": "WELL, I WANT TO WELCOME HIM TO LATE NIGHT."
  },
  {
    "startTime": 32.865,
    "endTime": 37.904,
    "text": "SO, HERE HE IS, THE MONSTER HIMSELF, ELMO!"
  },
  {
    "startTime": 37.937,
    "endTime": 40.54,
    "text": "HI, ELMO!"
  },
  {
    "startTime": 40.573,
    "endTime": 41.641,
    "text": "THANKS FOR JOINING ME."
  },
  {
    "startTime": 41.674,
    "endTime": 42.675,
    "text": ">> THANKS FOR HAVING ELMO ON YOUR SHOW, MISTER COLBERT."
  },
  {
    "startTime": 42.709,
    "endTime": 45.812000000000005,
    "text": ">> STEPHEN: OH, PLEASE, YOU CAN CALL ME \"STEPHEN.\""
  },
  {
    "startTime": 45.845,
    "endTime": 48.481,
    "text": ">> THAT'S GREAT, MISTER STEPHEN COLBERT!"
  },
  {
    "startTime": 48.514,
    "endTime": 49.882000000000005,
    "text": ">> STEPHEN: ELMO, FIRST OFF, HOW ARE YOU DOING WITH SOCIAL"
  },
  {
    "startTime": 49.915,
    "endTime": 56.823,
    "text": "DISTANCING?"
  },
  {
    "startTime": 56.856,
    "endTime": 59.192,
    "text": "THANKS FOR ASKING."
  },
  {
    "startTime": 59.225,
    "endTime": 60.0,
    "text": "ELMO IS OKAY."
  },
  {
    "startTime": 60.0,
    "endTime": 61.193,
    "text": "ELMO'S STAYING INSIDE WITH HIS MOMMY AND DADDY."
  },
  {
    "startTime": 61.227,
    "endTime": 62.061,
    "text": "EVERYONE ON SESAME STREET IS STAYING IN THEIR HOME."
  },
  {
    "startTime": 62.094,
    "endTime": 62.895,
    "text": "OR TRASHCAN."
  },
  {
    "startTime": 62.928,
    "endTime": 65.098,
    "text": ">> STEPHEN: OH, HOW IS OSCAR?"
  },
  {
    "startTime": 65.131,
    "endTime": 66.232,
    "text": "HE'S DOING GOOD."
  },
  {
    "startTime": 66.265,
    "endTime": 67.9,
