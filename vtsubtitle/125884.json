  {
    "startTime": 71.237,
    "endTime": 73.673,
    "text": "NOW."
  },
  {
    "startTime": 73.706,
    "endTime": 76.542,
    "text": ">> YEAH, THAT'S TRUE."
  },
  {
    "startTime": 76.575,
    "endTime": 77.977,
    "text": "ELMO HAS BEEN LUCKY BECAUSE IT HASN'T BEEN TOO BAD FOR ELMO!"
  },
  {
    "startTime": 78.01,
    "endTime": 81.34700000000001,
    "text": "ELMO LIKES USING HIS IMAGINATION TO GO PLACES, SPENDING EXTRA"
