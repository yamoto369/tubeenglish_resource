  },
  {
    "startTime": 170.102,
    "endTime": 171.304,
    "text": ">> DON'T WORRY MR. STEPHEN, \"THE NOT TOO LATE SHOW\" HAS A VERY"
  },
  {
    "startTime": 171.337,
