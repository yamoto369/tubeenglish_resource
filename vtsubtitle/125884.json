  },
  {
    "startTime": 152.151,
    "endTime": 154.32000000000002,
    "text": ">> STEPHEN: THOSE GUYS ARE GOOD."
  },
  {
    "startTime": 154.353,
    "endTime": 156.52200000000002,
    "text": "I JUST WANT TO SAY GOOD LUCK WITH YOUR SHOW."
  },
  {
    "startTime": 156.555,
    "endTime": 159.625,
