  },
  {
    "startTime": 43.35,
    "endTime": 47.870000000000005,
    "text": "And I won't save the day"
  },
  {
    "startTime": 47.87,
    "endTime": 51.919,
    "text": "But look in my eyes"
  },
  {
    "startTime": 51.92,
    "endTime": 56.61,
    "text": "And know I'll always stay"
  },
  {
    "startTime": 56.61,
    "endTime": 61.81,
    "text": "And I won't run away"
  },
  {
    "startTime": 61.81,
    "endTime": 73.64,
    "text": "I won't run away"
  },
  {
    "startTime": 73.64,
    "endTime": 76.57000000000001,
    "text": "Some years went by, they had a child"
  },
  {
    "startTime": 76.57,
    "endTime": 78.619,
    "text": "He was funny, strange, and mild"
  },
  {
    "startTime": 78.62,
    "endTime": 82.62,
    "text": "Their love for him ran deep"
  },
  {
    "startTime": 82.62,
    "endTime": 85.73,
    "text": "Some nights, his dreams would drive him wild"
  },
  {
    "startTime": 85.73,
    "endTime": 87.61,
    "text": "So into bed, she piled"
  },
  {
    "startTime": 87.61,
    "endTime": 92.27,
    "text": "To help him fall asleep"
  },
  {
    "startTime": 92.27,
    "endTime": 95.119,
    "text": "One night, he couldn't get to bed"
  },
  {
    "startTime": 95.12,
    "endTime": 97.23,
    "text": "So she kneeled on both knees"
  },
  {
