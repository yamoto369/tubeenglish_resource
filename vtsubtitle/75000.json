[
  {
    "startTime": 11.14,
    "endTime": 13.99,
    "text": "They met at school, that's how it goes"
  },
  {
    "startTime": 13.99,
    "endTime": 16.42,
    "text": "Some drinks and then a rose"
  },
  {
    "startTime": 16.42,
    "endTime": 20.340000000000003,
    "text": "Then plans to meet again"
  },
  {
    "startTime": 20.34,
    "endTime": 22.78,
    "text": "He wrote her poems, songs, and prose"
  },
  {
    "startTime": 22.78,
    "endTime": 24.85,
    "text": "She knew that he'd propose"
  },
  {
    "startTime": 24.85,
    "endTime": 29.53,
    "text": "She only wondered when"
  },
  {
    "startTime": 29.53,
    "endTime": 32.43,
    "text": "One night, before they went to bed"
  },
  {
    "startTime": 32.43,
    "endTime": 34.68,
    "text": "He kneeled on both knees"
  },
  {
    "startTime": 34.68,
    "endTime": 38.75,
    "text": "And this is what he said"
  },
  {
    "startTime": 38.75,
    "endTime": 43.35,
