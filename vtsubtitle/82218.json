[
  {
    "startTime": 0.0,
    "endTime": 2.94,
    "text": "Hello! I'm Sam from BBC Learning English"
  },
  {
    "startTime": 2.94,
    "endTime": 5.140000000000001,
    "text": "and in this episode, we're going to look at the"
  },
  {
    "startTime": 5.14,
    "endTime": 9.620000000000001,
    "text": "differences between 'see', 'watch' and 'look'."
  },
  {
    "startTime": 9.62,
    "endTime": 10.86,
    "text": "All three are verbs"
  },
  {
    "startTime": 10.86,
    "endTime": 13.879,
    "text": "and all three involve using your eyes."
  },
  {
    "startTime": 13.88,
    "endTime": 17.6,
    "text": "'See' can have many non-literal meanings,"
  },
  {
    "startTime": 17.6,
    "endTime": 19.66,
    "text": "but its basic meaning is"
  },
  {
    "startTime": 19.66,
    "endTime": 23.84,
    "text": "'to have the ability to use your eyes'."
  },
  {
    "startTime": 23.84,
    "endTime": 25.86,
    "text": "I can't see anything!"
  },
  {
    "startTime": 25.86,
    "endTime": 27.36,
    "text": "Or it can mean"
  },
  {
    "startTime": 27.36,
    "endTime": 30.28,
    "text": "'to notice something with your eyes'."
  },
  {
    "startTime": 30.28,
    "endTime": 32.56,
    "text": "Did you see the full moon last night?"
  },
  {
    "startTime": 32.56,
    "endTime": 33.88,
    "text": "It was huge!"
  },
  {
    "startTime": 33.89,
    "endTime": 35.38,
    "text": "To 'look' means"
  },
  {
    "startTime": 35.38,
    "endTime": 38.260000000000005,
    "text": "'to turn your eyes towards something"
  },
  {
    "startTime": 38.26,
    "endTime": 40.62,
    "text": "so that you can see it'."
  },
  {
    "startTime": 40.62,
    "endTime": 43.68,
    "text": "They said that if I look carefully at the painting,"
  },
  {
    "startTime": 43.68,
    "endTime": 45.8,
    "text": "I can see a flower."
  },
  {
    "startTime": 45.8,
    "endTime": 47.26,
    "text": "And 'watch'"
  },
  {
    "startTime": 47.26,
    "endTime": 50.9,
    "text": "is to 'look at something for a period of time'"
  },
  {
    "startTime": 50.9,
    "endTime": 52.82,
    "text": "- really looking carefully."
  },
  {
    "startTime": 52.82,
    "endTime": 56.480000000000004,
    "text": "Right now, you are watching this video"
  },
  {
    "startTime": 56.48,
    "endTime": 59.16,
    "text": "and paying very close attention, I'm sure."
  }
]