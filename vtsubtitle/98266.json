    "endTime": 36.745000000000005,
    "text": "I did it! I got the gig!"
  },
  {
    "startTime": 39.205,
    "endTime": 41.082,
    "text": "Must have been sudden for ya."
  },
  {
    "startTime": 43.585,
    "endTime": 44.627,
    "text": "Wah! Oh my goodness!"
  },
  {
    "startTime": 44.627,
    "endTime": 45.587,
    "text": "Oh my goodness!"
  },
  {
    "startTime": 45.587,
    "endTime": 47.047000000000004,
    "text": "Help! I'm not done!"
  },
  {
    "startTime": 47.047,
    "endTime": 48.006,
    "text": "Oh! Oh my goodness!"
  },
  {
    "startTime": 58.349,
    "endTime": 59.349,
    "text": "Huh?"
  },
  {
    "startTime": 61.102,
    "endTime": 62.102,
    "text": "Is this Heaven?"
  },
  {
    "startTime": 62.103,
    "endTime": 63.0,
    "text": "No."
  },
  {
    "startTime": 63.0,
    "endTime": 64.063,
    "text": "It's the Great Before."
  },
  {
    "startTime": 64.063,
    "endTime": 69.152,
    "text": "This is where new souls get their personalities, quirks, and interests before they go to Earth."
  },
  {
    "startTime": 69.152,
    "endTime": 70.153,
    "text": "Meet 22."
  },
  {
    "startTime": 70.153,
    "endTime": 71.738,
    "text": "I don't wanna go to Earth!"
  },
  {
    "startTime": 71.738,
    "endTime": 72.739,
    "text": "Stop fighting this!"
  },
  {
    "startTime": 72.739,
    "endTime": 73.74000000000001,
    "text": "I don't wanna!"
  },
  {
    "startTime": 73.74,
    "endTime": 74.5,
    "text": "Uhhh?"
  },
  {
    "startTime": 74.5,
    "endTime": 75.742,
    "text": "Hahaha!"
  },
  {
    "startTime": 76.326,
    "endTime": 80.58,
    "text": "Okay, look, I already know everything about Earth, and I don't want anything to do with it."
  },
  {
    "startTime": 80.58,
    "endTime": 83.958,
    "text": "You're missing out on the joys of life... like... uh.... pizza!"
  },
  {
    "startTime": 84.834,
    "endTime": 85.919,
    "text": "I can't smell!"
  },
  {
    "startTime": 86.461,
    "endTime": 86.92,
    "text": "We can't..."
  },
  {
    "startTime": 87.4,
    "endTime": 88.5,
    "text": "We can't taste either?"
  },
  {
    "startTime": 88.5,
    "endTime": 89.3,
    "text": "All that stuff is in your body."
  },
  {
    "startTime": 91.3,
    "endTime": 92.634,
    "text": "No smell! No taste!"
  },
  {
    "startTime": 92.634,
    "endTime": 93.635,
    "text": "Or touch."
  },
  {
    "startTime": 93.635,
    "endTime": 94.677,
    "text": "See?"
  },
  {
    "startTime": 97.097,
    "endTime": 98.473,
    "text": "Okay, I get it!"
  },
  {
    "startTime": 100.433,
    "endTime": 101.30000000000001,
    "text": "Wow!"
  },
  {
    "startTime": 101.3,
    "endTime": 102.477,
    "text": "It's my life."
  },
  {
    "startTime": 104.604,
    "endTime": 107.482,
    "text": "Is all this living really worth dying for?"
  },
  {
    "startTime": 110.318,
    "endTime": 111.361,
    "text": "You're still alive?"
  },
  {
    "startTime": 111.945,
    "endTime": 113.446,
    "text": "Can you help me get back?"
  },
  {
    "startTime": 113.446,
    "endTime": 114.447,
    "text": "No way!"
  },
  {
    "startTime": 114.906,
    "endTime": 115.5,
    "text": "There I am!"
  },
  {
    "startTime": 115.5,
    "endTime": 116.2,
    "text": "What are we waiting for?"
  },
  {
    "startTime": 116.2,
    "endTime": 118.07600000000001,
    "text": "No, no! Wait! Not me!"
  },
  {
    "startTime": 123.998,
    "endTime": 125.41600000000001,
    "text": "Hmm, that's weird."
  },
  {
    "startTime": 125.416,
    "endTime": 126.1,
    "text": "What is it?"
  },
  {
    "startTime": 126.1,
    "endTime": 131.756,
    "text": "151,000 souls go into the Great Beyond every day, and I count every single one of them."
  },
  {
    "startTime": 133.133,
    "endTime": 135.38500000000002,
    "text": "The count's off."
  },
  {
    "startTime": 136.344,
    "endTime": 137.345,
    "text": "Huh..."
  }
]