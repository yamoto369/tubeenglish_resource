[
  {
    "startTime": 7200.0,
    "endTime": 0.0,
    "text": "00:00:05,539 --> 00:00:07,789"
  },
  {
    "startTime": 10800.0,
    "endTime": 0.0,
    "text": "00:00:09,310 --> 00:00:10,660 Come on, Peter."
  },
  {
    "startTime": 10.66,
    "endTime": 11.51,
    "text": "Here's your suit."
  },
  {
    "startTime": 21600.0,
    "endTime": 0.0,
    "text": "00:00:18,600 --> 00:00:21,581 It's heartening to see so many strange new faces"
  },
  {
    "startTime": 21.581,
    "endTime": 22.419,
    "text": "here today."
  },
  {
    "startTime": 22.42,
    "endTime": 24.42,
    "text": "I know my mom would be very touched."
  },
  {
    "startTime": 24.42,
    "endTime": 26.240000000000002,
    "text": "And probably a little suspicious."
  },
  {
    "startTime": 27.99,
    "endTime": 31.47,
    "text": "My mother was a very secretive and private woman."
  },
  {
    "startTime": 35.71,
    "endTime": 37.02,
    "text": "That's grandma."
  },
  {
    "startTime": 37.02,
    "endTime": 39.290000000000006,
    "text": "You know you were her favorite, right?"
  },
  {
    "startTime": 39.29,
    "endTime": 40.85,
    "text": "Even when you were a little baby."
  },
  {
    "startTime": 40.85,
    "endTime": 43.61,
    "text": "She wouldn't let me feed you because she needed to feed you."
  },
  {
    "startTime": 44.659,
    "endTime": 45.94,
    "text": "But she was a very difficult woman,"
  },
  {
    "startTime": 45.94,
    "endTime": 47.53,
    "text": "which maybe explains me."
  },
  {
    "startTime": 48.51,
    "endTime": 50.87,
    "text": "I recognize you from your mother."
  },
  {
    "startTime": 50.87,
    "endTime": 51.97,
    "text": "What?"
  },
  {
    "startTime": 51.97,
    "endTime": 56.221,
    "text": "Sometimes, I swear I can feel her in the room."
  },
  {
    "startTime": 75600.0,
    "endTime": 0.0,
    "text": "00:01:02,610 --> 00:01:03,820 She isn't gone."
  },
  {
    "startTime": 69.76,
    "endTime": 72.61,
    "text": "She had private rituals. Private friends."
  },
  {
    "startTime": 75.89,
    "endTime": 77.24,
    "text": "Who's gonna take care of me?"
  },
  {
    "startTime": 77.24,
    "endTime": 79.72,
    "text": "You don't think I'm gonna take care of you?"
  },
  {
    "startTime": 79.72,
    "endTime": 80.81,
    "text": "But when you die."
  },
  {
    "startTime": 85.28,
    "endTime": 86.88,
    "text": "She wasn't all together there."
  },
  {
    "startTime": 88.44,
    "endTime": 89.39,
    "text": "At the end."
  },
  {
    "startTime": 104400.0,
    "endTime": 0.0,
    "text": "00:01:39,036 --> 00:01:39,869 Mom?"
  },
  {
    "startTime": 99.869,
    "endTime": 100.919,
    "text": "I don't like this."
  },
  {
    "startTime": 100.919,
    "endTime": 101.752,
    "text": "Dad, I don't like this."
  },
  {
    "startTime": 101.752,
    "endTime": 103.949,
    "text": "What's happening? Peter!"
  },
  {
    "startTime": 103.95,
    "endTime": 105.772,
    "text": "Don't you ever raise your voice at me."
  },
  {
    "startTime": 105.772,
    "endTime": 107.111,
    "text": "I am your mother!"
  },
  {
    "startTime": 107.111,
    "endTime": 108.551,
    "text": "Please stop!"
  },
  {
    "startTime": 108.551,
    "endTime": 109.974,
    "text": "Mom? What's happening?"
  },
  {
    "startTime": 109.974,
    "endTime": 112.327,
    "text": "Make it stop! Make it stop!"
  },
  {
    "startTime": 140400.0,
    "endTime": 0.0,
    "text": "00:01:55,164 --> 00:01:58,410 I just don't wanna put any more stress on my family."
  }
]