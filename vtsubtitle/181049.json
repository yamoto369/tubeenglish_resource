  },
  {
    "startTime": 413.0,
    "endTime": 414.0,
    "text": "I think we might have a lobster roll."
  },
  {
    "startTime": 415.0,
    "endTime": 416.0,
    "text": "We might have a lobster roll."
  },
  {
    "startTime": 416.0,
    "endTime": 417.0,
    "text": "So that might be next."
  },
  {
    "startTime": 418.0,
    "endTime": 419.0,
    "text": "So we're at our next location."
  },
  {
    "startTime": 419.0,
    "endTime": 424.0,
    "text": "We're gonna look at the lighthouse that you might be able to just see in the distance there."
