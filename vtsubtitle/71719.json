[
  {
    "startTime": 0.0,
    "endTime": 2.42,
    "text": "(Holiday music) Right before Christmas,"
  },
  {
    "startTime": 2.42,
    "endTime": 5.92,
    "text": "a good guy in red, is coming to theaters,"
  },
  {
    "startTime": 5.92,
