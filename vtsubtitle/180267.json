[
  {
    "startTime": 2.1,
    "endTime": 2.8,
    "text": "Adorable!"
  },
  {
    "startTime": 2.8,
    "endTime": 3.8,
    "text": "Oh, so cute!"
  },
  {
    "startTime": 3.8,
    "endTime": 4.7,
    "text": "Where'd you get these, Pan?"
  },
  {
    "startTime": 4.7,
    "endTime": 5.7,
    "text": "Oh, I found them online."
  },
  {
    "startTime": 5.9,
    "endTime": 9.0,
    "text": "Oh, they look just like little us!"
  },
  {
    "startTime": 9.6,
    "endTime": 10.7,
    "text": "What's the little heart for?"
  },
  {
    "startTime": 10.7,
    "endTime": 17.799999999999997,
    "text": "It says, \"Put your essence into the heart locket, and your oh-so-adorable will become berry special.\""
  },
  {
    "startTime": 18.0,
    "endTime": 20.1,
    "text": "Essence? Like our blood?"
  },
  {
    "startTime": 20.1,
    "endTime": 21.400000000000002,
    "text": "Eh, maybe just hair will work."
  },
  {
    "startTime": 21.4,
    "endTime": 21.9,
    "text": "Oh, yeah."
  },
  {
    "startTime": 21.9,
    "endTime": 23.9,
    "text": "So, we take a hair..."
  },
  {
    "startTime": 23.9,
    "endTime": 24.5,
    "text": "Ow!"
  },
  {
    "startTime": 24.5,
    "endTime": 26.2,
    "text": "Place it in the heart locket."
  },
  {
    "startTime": 26.2,
    "endTime": 28.0,
    "text": "Put locket of love inside."
  },
  {
    "startTime": 28.0,
    "endTime": 28.5,
    "text": "With care."
  },
  {
    "startTime": 28.5,
    "endTime": 31.2,
    "text": "Oh, I'm so plush and cute!"
  },
  {
    "startTime": 31.2,
    "endTime": 32.8,
    "text": "I love you, little panda."
  },
  {
    "startTime": 32.8,
    "endTime": 34.5,
    "text": "I love you, too."
  },
  {
    "startTime": 34.6,
    "endTime": 37.6,
    "text": "Whoa, the website didn't say anything about them talking."
  },
  {
    "startTime": 37.7,
    "endTime": 40.6,
    "text": "I love to make friends and eat snacks."
  },
  {
    "startTime": 40.7,
    "endTime": 44.400000000000006,
    "text": "Yeah, that's pretty accurate to my essence, I guess."
  },
  {
    "startTime": 44.4,
    "endTime": 45.4,
    "text": "Ice Bear loves hugs."
  },
  {
    "startTime": 45.4,
    "endTime": 46.5,
    "text": "Hug me."
  },
  {
    "startTime": 46.5,
    "endTime": 47.5,
    "text": "Ice Bear would not say that."
  },
  {
    "startTime": 47.5,
    "endTime": 49.0,
    "text": "This is not Ice Bear's essence."
  },
  {
    "startTime": 49.0,
    "endTime": 52.0,
    "text": "I love picking my nose!"
  },
  {
    "startTime": 52.0,
    "endTime": 53.6,
    "text": "I like dressing up as a cat."
  },
  {
    "startTime": 53.6,
    "endTime": 55.5,
    "text": "When no one is looking."
  },
  {
    "startTime": 55.5,
    "endTime": 57.6,
    "text": "Well, these are obviously defective."
  },
  {
    "startTime": 57.6,
    "endTime": 59.0,
    "text": "Oh, yeah, no, totally defective."
  },
  {
    "startTime": 59.0,
    "endTime": 61.6,
    "text": "Well, I guess we'll just send them back in the morning."
  },
  {
    "startTime": 61.6,
    "endTime": 62.6,
    "text": "How about some grub?"
  },
  {
    "startTime": 62.6,
    "endTime": 63.9,
    "text": "Ice Bear will make casserole."
  },
  {
    "startTime": 63.9,
    "endTime": 65.2,
    "text": "Oh, sweet, I'm down for that."
  },
  {
    "startTime": 65.2,
    "endTime": 67.60000000000001,
    "text": "Oh, hey, guys, this time, can we make it vegetarian?"
  },
  {
    "startTime": 67.6,
    "endTime": 72.1,
    "text": "I hate picking out all the chicken and..."
  },
  {
    "startTime": 72.1,
    "endTime": 73.89999999999999,
    "text": "Hoo, boy, smells so good."
  },
  {
    "startTime": 73.9,
    "endTime": 74.9,
    "text": "Thanks, brother."
  },
  {
    "startTime": 74.9,
    "endTime": 76.9,
    "text": "Mmm, huh, how'd I grab silverware?"
  },
  {
    "startTime": 77.0,
    "endTime": 78.6,
    "text": "Uh, could you grab me a fork, please?"
  },
  {
    "startTime": 78.6,
    "endTime": 80.0,
    "text": "Ice Bear got you covered."
  },
  {
    "startTime": 80.1,
    "endTime": 82.3,
    "text": "Huh?"
  },
  {
    "startTime": 82.4,
    "endTime": 83.7,
    "text": "Little panda?"
  },
  {
    "startTime": 83.6,
    "endTime": 84.5,
    "text": "That's weird."
  },
  {
    "startTime": 84.5,
    "endTime": 85.7,
    "text": "How'd you get out of the..."
  },
  {
    "startTime": 85.8,
    "endTime": 86.89999999999999,
    "text": "They're gone!"
  },
  {
    "startTime": 86.9,
    "endTime": 87.60000000000001,
    "text": "What the heck?"
  },
  {
    "startTime": 87.6,
    "endTime": 88.69999999999999,
    "text": "Where did the dolls go?"
  },
  {
    "startTime": 88.7,
    "endTime": 89.8,
    "text": "This doesn't make any sense."
  },
  {
    "startTime": 89.8,
    "endTime": 90.39999999999999,
    "text": "What's going on?"
  },
  {
    "startTime": 90.4,
    "endTime": 91.7,
    "text": "The other dolls are missing."
  },
  {
    "startTime": 91.7,
    "endTime": 92.60000000000001,
    "text": "What? We just put them away."
  },
  {
    "startTime": 92.7,
    "endTime": 95.0,
    "text": "Maybe they're under the table or something."
  },
  {
    "startTime": 95.0,
    "endTime": 96.4,
    "text": "Hmm, you find anything?"
  },
  {
    "startTime": 96.4,
    "endTime": 97.0,
    "text": "Nothing."
  },
  {
    "startTime": 97.0,
    "endTime": 98.5,
    "text": "Ice Bear found a lost controller."
  },
  {
    "startTime": 98.5,
    "endTime": 102.2,
    "text": "Ooh, been looking for that."
  },
  {
    "startTime": 102.3,
    "endTime": 104.39999999999999,
    "text": "Uh, wasn't Little Panda just sitting on this table?"
  },
  {
    "startTime": 104.4,
    "endTime": 106.0,
    "text": "Yes, yes, he was."
  },
  {
    "startTime": 106.0,
    "endTime": 107.0,
    "text": "Ice Bear leaving."
  },
  {
    "startTime": 107.0,
    "endTime": 107.9,
    "text": "Yep, I'm with him."
  },
  {
    "startTime": 107.9,
    "endTime": 108.80000000000001,
    "text": "I'm gonna give Tabes a call."
  },
  {
    "startTime": 108.9,
    "endTime": 113.0,
    "text": "She's good with this kind of creepy stuff."
  },
  {
    "startTime": 113.1,
    "endTime": 114.69999999999999,
    "text": "Speak, this is Ranger Tabes."
  },
  {
    "startTime": 114.8,
    "endTime": 117.0,
    "text": "Oh, never mind, Tabes."
  },
  {
    "startTime": 117.0,
    "endTime": 118.0,
    "text": "Talk to you later."
  },
  {
    "startTime": 118.0,
    "endTime": 119.5,
    "text": "I didn't know they could do that."
  },
  {
    "startTime": 119.5,
    "endTime": 122.6,
    "text": "It's kind of cute, but also creepy."
  },
  {
    "startTime": 122.6,
    "endTime": 123.69999999999999,
    "text": "It's time for dinner."
  },
  {
    "startTime": 123.7,
    "endTime": 124.4,
    "text": "Let's eat."
  },
  {
    "startTime": 124.4,
    "endTime": 126.0,
    "text": "Spoon full of sugar?"
  },
  {
    "startTime": 126.0,
    "endTime": 127.8,
    "text": "Let's spread some cheer."
  },
  {
    "startTime": 127.8,
    "endTime": 129.0,
    "text": "Not cute, not cute!"
  },
  {
    "startTime": 129.0,
    "endTime": 130.9,
    "text": "It's time for dinner."
  },
  {
    "startTime": 130.9,
    "endTime": 138.5,
    "text": "Let's eat."
  },
  {
    "startTime": 138.7,
    "endTime": 143.39999999999998,
    "text": "Sup, bro?"
  },
  {
    "startTime": 143.4,
    "endTime": 144.8,
    "text": "Ice Bear forgot his fork."
  },
  {
    "startTime": 145.0,
    "endTime": 154.8,
    "text": "Ice Bear hungry."
  },
  {
    "startTime": 154.8,
    "endTime": 158.4,
    "text": "Where are you?"
  },
  {
    "startTime": 158.4,
    "endTime": 159.4,
    "text": "I found you!"
  },
  {
    "startTime": 159.4,
    "endTime": 164.1,
    "text": "Mickey Chan, no!"
  },
  {
    "startTime": 164.1,
    "endTime": 169.7,
    "text": "I love playing hide and seek."
  },
  {
    "startTime": 169.8,
    "endTime": 172.20000000000002,
    "text": "Ice Bear thinks we got off on wrong foot."
  },
  {
    "startTime": 172.2,
    "endTime": 178.5,
    "text": "Ice Bear wants to break the ice."
  },
  {
    "startTime": 178.5,
    "endTime": 179.2,
    "text": "Stay away!"
  },
  {
    "startTime": 179.2,
    "endTime": 179.79999999999998,
    "text": "Stay back!"
  },
  {
    "startTime": 180.0,
    "endTime": 184.8,
    "text": "Ready or not, here I come!"
  },
  {
    "startTime": 184.8,
    "endTime": 185.8,
    "text": "You saved me."
  },
  {
    "startTime": 185.8,
    "endTime": 187.60000000000002,
    "text": "Is it dead?"
  },
  {
    "startTime": 187.6,
    "endTime": 188.79999999999998,
    "text": "That's cheating!"
  },
  {
    "startTime": 188.8,
    "endTime": 189.70000000000002,
    "text": "You're no fun!"
  },
  {
    "startTime": 189.7,
    "endTime": 191.0,
    "text": "Not dead."
  },
  {
    "startTime": 191.0,
    "endTime": 191.8,
    "text": "Hold on!"
  },
  {
    "startTime": 191.8,
    "endTime": 194.0,
    "text": "There's gotta be an off switch or something."
  },
  {
    "startTime": 194.0,
    "endTime": 195.3,
    "text": "Heart is off switch."
  },
  {
    "startTime": 195.4,
    "endTime": 196.0,
    "text": "What the?"
  },
  {
    "startTime": 198.6,
    "endTime": 199.4,
    "text": "No!"
  },
  {
    "startTime": 199.4,
    "endTime": 202.0,
    "text": "The heart!"
  },
  {
    "startTime": 202.0,
    "endTime": 206.0,
    "text": "Hug me! Hug me!"
  },
  {
    "startTime": 206.0,
    "endTime": 209.0,
    "text": "I think that did it!"
  },
  {
    "startTime": 209.1,
    "endTime": 210.7,
    "text": "Ice Bear not taking chances."
  },
  {
    "startTime": 210.8,
    "endTime": 212.0,
    "text": "Help! Help!"
  },
  {
    "startTime": 212.0,
    "endTime": 212.9,
    "text": "Grizz!"
  },
  {
    "startTime": 213.1,
    "endTime": 215.1,
    "text": "Guys! He's moving stronger!"
  },
  {
    "startTime": 215.3,
    "endTime": 218.70000000000002,
    "text": "Get off of him!"
  },
  {
    "startTime": 218.7,
    "endTime": 221.1,
    "text": "I thought we were froze a little, bro."
  },
  {
    "startTime": 221.1,
    "endTime": 221.9,
    "text": "I mean, I loved you."
  },
  {
    "startTime": 221.9,
    "endTime": 223.1,
    "text": "I do love you, bro."
  },
  {
    "startTime": 223.1,
    "endTime": 225.4,
    "text": "Two pieces."
  },
  {
    "startTime": 225.4,
    "endTime": 225.9,
    "text": "Ah!"
  },
  {
    "startTime": 225.9,
    "endTime": 227.4,
    "text": "I know karate, bro."
  },
  {
    "startTime": 227.4,
    "endTime": 228.8,
    "text": "I'll kick your face off."
  },
  {
    "startTime": 228.8,
    "endTime": 230.0,
    "text": "We can't hold him long!"
  },
  {
    "startTime": 230.1,
    "endTime": 232.2,
    "text": "Playtime is over!"
  },
  {
    "startTime": 232.2,
    "endTime": 233.29999999999998,
    "text": "Wait! No!"
  },
  {
    "startTime": 233.3,
    "endTime": 234.10000000000002,
    "text": "My essence!"
  },
  {
    "startTime": 234.1,
    "endTime": 245.29999999999998,
    "text": "Time to return the favor."
  },
  {
    "startTime": 245.3,
    "endTime": 246.20000000000002,
    "text": "Oh, man."
  },
  {
    "startTime": 246.3,
    "endTime": 248.3,
    "text": "I'm never buying anything off that website again."
  },
  {
    "startTime": 248.3,
    "endTime": 250.3,
    "text": "Oh, yeah, brother."
  },
  {
    "startTime": 250.4,
    "endTime": 251.3,
    "text": "Hey, fellas."
  },
  {
    "startTime": 251.3,
    "endTime": 252.0,
    "text": "I got your phone call."
  },
  {
    "startTime": 253.0,
    "endTime": 254.3,
    "text": "It's you, Tabes."
  },
  {
    "startTime": 254.4,
    "endTime": 258.0,
    "text": "Yeah, we had a little thing earlier, but everything's fine now."
  },
  {
    "startTime": 258.0,
    "endTime": 261.0,
    "text": "Well, I heard you talking about dolls, and I wanted to show you..."
  },
  {
    "startTime": 261.0,
    "endTime": 262.0,
    "text": "Little Tabes!"
  },
  {
    "startTime": 262.0,
    "endTime": 263.4,
    "text": "Let's serve some..."
  },
  {
    "startTime": 263.6,
    "endTime": 265.0,
    "text": "Justice!"
  }
]