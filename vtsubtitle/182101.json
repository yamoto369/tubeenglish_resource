  },
  {
    "startTime": 140.9,
    "endTime": 143.0,
    "text": "Very well done, you have a beautiful voice."
  },
  {
    "startTime": 143.0,
    "endTime": 145.0,
    "text": "Sofia."
  },
  {
    "startTime": 145.0,
    "endTime": 148.7,
    "text": "I think this season we have so many cool kids."
