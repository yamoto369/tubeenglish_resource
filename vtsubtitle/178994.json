[
  {
    "startTime": 0.0,
    "endTime": 2.38,
    "text": "Tomorrow, the entire country becomes infected."
  },
  {
    "startTime": 2.38,
    "endTime": 4.18,
    "text": "And the day after, the world."
  },
  {
    "startTime": 4.18,
    "endTime": 5.06,
    "text": "This is bad."
  },
  {
    "startTime": 5.06,
    "endTime": 6.02,
    "text": "Real bad."
  },
  {
    "startTime": 6.02,
    "endTime": 7.22,
    "text": "Make the necessary calls."
  },
  {
    "startTime": 7.22,
    "endTime": 8.26,
    "text": "We have to contain this."
  },
  {
    "startTime": 8.26,
    "endTime": 8.6,
    "text": "Yes, sir."
  },
  {
    "startTime": 8.6,
    "endTime": 9.6,
    "text": "Go, go, go, now!"
  },
  {
    "startTime": 9.7,
    "endTime": 10.86,
    "text": "Ah!"
  },
  {
    "startTime": 10.86,
    "endTime": 11.74,
    "text": "Thank you so much."
  },
  {
    "startTime": 11.74,
    "endTime": 13.14,
    "text": "I'll bring them to the office right now."
  },
  {
    "startTime": 13.14,
    "endTime": 13.940000000000001,
    "text": "See you soon."
  },
  {
    "startTime": 17.7,
    "endTime": 19.18,
    "text": "Go, go, go, go, let's go!"
  },
  {
    "startTime": 19.18,
    "endTime": 19.98,
    "text": "Hey!"
  },
  {
    "startTime": 19.98,
    "endTime": 20.400000000000002,
    "text": "What's going on?"
  },
  {
    "startTime": 20.5,
    "endTime": 21.58,
    "text": "Wait, stop!"
  },
  {
    "startTime": 21.58,
    "endTime": 22.5,
    "text": "What's happening?"
  },
  {
    "startTime": 22.5,
    "endTime": 23.459,
    "text": "Step away, citizen."
  },
  {
    "startTime": 23.459,
    "endTime": 25.419999999999998,
    "text": "This area has been quarantined due to the bear flu."
  },
  {
    "startTime": 25.42,
    "endTime": 26.299000000000003,
    "text": "Bear flu?"
  },
  {
    "startTime": 26.299,
    "endTime": 27.059,
    "text": "You're confused."
  },
  {
    "startTime": 27.059,
    "endTime": 28.139000000000003,
    "text": "There's no such thing."
  },
  {
    "startTime": 28.139,
    "endTime": 28.939999999999998,
    "text": "Are you a doctor?"
  },
  {
    "startTime": 28.94,
    "endTime": 29.740000000000002,
    "text": "What? No."
  },
  {
    "startTime": 29.82,
    "endTime": 30.379,
    "text": "Exactly."
  },
  {
    "startTime": 30.379,
    "endTime": 31.5,
    "text": "You don't know what you're talking about."
  },
  {
    "startTime": 31.5,
    "endTime": 34.7,
    "text": "Can someone escort this elderly Korean lady off the premises?"
  },
  {
    "startTime": 34.7,
    "endTime": 37.74,
    "text": "Dude, I'm 10!"
  },
  {
    "startTime": 37.74,
    "endTime": 39.099000000000004,
    "text": "Major, we're containing the cave."
  },
  {
    "startTime": 39.099,
    "endTime": 40.138999999999996,
    "text": "Nothing's getting in or out."
  },
  {
    "startTime": 40.139,
    "endTime": 40.86,
    "text": "Oh, no, no."
  },
  {
    "startTime": 47.5,
    "endTime": 48.82,
    "text": "Perfect."
  },
  {
    "startTime": 48.82,
    "endTime": 49.459,
    "text": "All clear."
  },
  {
    "startTime": 49.459,
    "endTime": 51.06,
    "text": "Be careful in there."
  },
  {
    "startTime": 51.06,
    "endTime": 52.619,
    "text": "Hey, who are you?"
  },
  {
    "startTime": 52.619,
    "endTime": 55.66,
    "text": "Um, I'm a hazmat guy."
  },
  {
    "startTime": 55.66,
    "endTime": 56.5,
    "text": "Oh, go right in."
  },
  {
    "startTime": 56.5,
    "endTime": 57.98,
    "text": "Be sure to use a decontamination chamber."
  },
  {
    "startTime": 61.7,
    "endTime": 62.660000000000004,
    "text": "What's their condition?"
  },
  {
    "startTime": 62.66,
    "endTime": 64.17999999999999,
    "text": "Decreased brain activity, sir."
  },
  {
    "startTime": 64.18,
    "endTime": 66.94000000000001,
    "text": "Patient two has lost his ability to distinguish reality."
  },
  {
    "startTime": 66.94,
    "endTime": 71.099,
    "text": "Life, candles, followers."
  },
  {
    "startTime": 71.099,
    "endTime": 73.26,
    "text": "And I'm afraid he's reached stage four."
  },
  {
    "startTime": 73.26,
    "endTime": 74.94000000000001,
    "text": "Ice Bear is ready for afterlife."
  },
  {
    "startTime": 74.94,
    "endTime": 76.339,
    "text": "And then after party."
  },
  {
    "startTime": 76.339,
    "endTime": 77.139,
    "text": "Oh."
  },
  {
    "startTime": 77.139,
    "endTime": 79.45899999999999,
    "text": "I heard they were going to ship him off to an island once we're all done here."
  },
  {
    "startTime": 79.459,
    "endTime": 82.019,
    "text": "I heard they're going to put him in a chamber 10,000 feet in the ground."
  },
  {
    "startTime": 82.019,
    "endTime": 83.099,
    "text": "Ah, you're both wrong."
  },
  {
    "startTime": 83.099,
    "endTime": 86.059,
    "text": "They're obviously going to have to be put into a rocket and shoot him into the sun."
  },
  {
    "startTime": 86.059,
    "endTime": 87.82,
    "text": "Hey, you, have you heard anything yet?"
  },
  {
    "startTime": 87.82,
    "endTime": 90.17999999999999,
    "text": "They're, uh, cutting our pension."
  },
  {
    "startTime": 90.4,
    "endTime": 90.80000000000001,
    "text": "What?"
  },
  {
    "startTime": 90.9,
    "endTime": 91.5,
    "text": "Huh?"
  },
  {
    "startTime": 91.6,
    "endTime": 92.58,
    "text": "This isn't fair."
  },
  {
    "startTime": 92.58,
    "endTime": 93.86,
    "text": "Oh, what are we supposed to do?"
  },
  {
    "startTime": 93.86,
    "endTime": 94.66,
    "text": "I mean."
  },
  {
    "startTime": 100.54,
    "endTime": 101.66000000000001,
    "text": "All righty, little guy."
  },
  {
    "startTime": 101.66,
    "endTime": 102.53999999999999,
    "text": "You're going to help me out."
  },
  {
    "startTime": 106.5,
    "endTime": 107.3,
    "text": "Oh, my gosh."
  },
  {
    "startTime": 107.3,
    "endTime": 108.099,
    "text": "Oh, my bad."
  },
  {
    "startTime": 108.099,
    "endTime": 110.059,
    "text": "There we go."
  },
  {
    "startTime": 110.059,
    "endTime": 112.37899999999999,
    "text": "Is that a caudula, glastula, or dorsalis?"
  },
  {
    "startTime": 112.379,
    "endTime": 114.26,
    "text": "I've got an inchworm."
  },
  {
    "startTime": 114.26,
    "endTime": 115.05900000000001,
    "text": "Breach!"
  },
  {
    "startTime": 118.62,
    "endTime": 119.41900000000001,
    "text": "Come on, guys."
  },
  {
    "startTime": 119.419,
    "endTime": 120.82,
    "text": "We've got to go to the doctors."
  },
  {
    "startTime": 120.82,
    "endTime": 121.61999999999999,
    "text": "Panda!"
  },
  {
    "startTime": 121.62,
    "endTime": 125.41900000000001,
    "text": "Is this heaven?"
  },
  {
    "startTime": 125.419,
    "endTime": 126.419,
    "text": "The atom!"
  },
  {
    "startTime": 126.419,
    "endTime": 127.459,
    "text": "I'm alive."
  },
  {
    "startTime": 127.459,
    "endTime": 128.46,
    "text": "We've got to get going."
  },
  {
    "startTime": 128.46,
    "endTime": 129.46,
    "text": "Get in the stack."
  },
  {
    "startTime": 129.46,
    "endTime": 131.139,
    "text": "Ice Bear will try."
  },
  {
    "startTime": 131.139,
    "endTime": 134.059,
    "text": "Is this heaven?"
  },
  {
    "startTime": 134.059,
    "endTime": 136.139,
    "text": "The atom!"
  },
  {
    "startTime": 136.139,
    "endTime": 138.82000000000002,
    "text": "How am I supposed to get three bears?"
  },
  {
    "startTime": 138.82,
    "endTime": 139.899,
    "text": "Aha!"
  },
  {
    "startTime": 139.899,
    "endTime": 140.74,
    "text": "We're working on it, sir."
  },
  {
    "startTime": 140.74,
    "endTime": 143.70000000000002,
    "text": "We have a situation contained. Everything is under control."
  },
  {
    "startTime": 143.94,
    "endTime": 145.85999999999999,
    "text": "Oh, just taking some samples back."
  },
  {
    "startTime": 145.86,
    "endTime": 146.66000000000003,
    "text": "Yeah."
  },
  {
    "startTime": 149.419,
    "endTime": 151.179,
    "text": "Panda, stop breathing."
  },
  {
    "startTime": 151.179,
    "endTime": 152.619,
    "text": "Premises have been resealed."
  },
  {
    "startTime": 152.619,
    "endTime": 155.419,
    "text": "Cave is clear."
  },
  {
    "startTime": 155.419,
    "endTime": 157.10000000000002,
    "text": "We should be able to put this to bed pretty soon."
  },
  {
    "startTime": 157.1,
    "endTime": 158.38,
    "text": "The bears are out of containment."
  },
  {
    "startTime": 158.38,
    "endTime": 159.179,
    "text": "They're gone."
  },
  {
    "startTime": 159.179,
    "endTime": 160.86,
    "text": "What?"
  },
  {
    "startTime": 160.86,
    "endTime": 161.979,
    "text": "No, I want my blanket."
  },
  {
    "startTime": 161.979,
    "endTime": 162.77900000000002,
    "text": "Give it back."
  },
  {
    "startTime": 162.779,
    "endTime": 163.57999999999998,
    "text": "They're escaping!"
  },
  {
    "startTime": 172.539,
    "endTime": 173.45999999999998,
    "text": "Requesting backup."
  },
  {
    "startTime": 173.46,
    "endTime": 174.94,
    "text": "They're heading towards the city."
  },
  {
    "startTime": 174.94,
    "endTime": 175.94,
    "text": "See you next week."
  },
  {
    "startTime": 176.02,
    "endTime": 177.3,
    "text": "All right, who's next?"
  },
  {
    "startTime": 178.4,
    "endTime": 180.3,
    "text": "Doctor! Doctor! Doctor, please hurry!"
  },
  {
    "startTime": 180.5,
    "endTime": 182.419,
    "text": "The bad guys are after us!"
  },
  {
    "startTime": 182.419,
    "endTime": 183.22,
    "text": "Bad guys?"
  },
  {
    "startTime": 183.22,
    "endTime": 185.899,
    "text": "Just bring them in."
  },
  {
    "startTime": 185.899,
    "endTime": 188.139,
    "text": "Well, from the looks of this, the fever's going down."
  },
  {
    "startTime": 188.139,
    "endTime": 189.699,
    "text": "I think you guys are going to be OK."
  },
  {
    "startTime": 189.699,
    "endTime": 191.3,
    "text": "Thanks again for seeing us so quickly."
  },
  {
    "startTime": 191.3,
    "endTime": 193.53900000000002,
    "text": "Well, better before blowing this whole thing out of proportion."
  },
  {
    "startTime": 193.539,
    "endTime": 195.1,
    "text": "Go! Go! Go!"
  },
  {
    "startTime": 195.3,
    "endTime": 197.86,
    "text": "Nobody moves. Step away from the bears."
  },
  {
    "startTime": 197.86,
    "endTime": 199.699,
    "text": "They are deathly ill and contagious."
  },
  {
    "startTime": 199.699,
    "endTime": 200.94000000000003,
    "text": "No more bear flu here."
  },
  {
    "startTime": 200.94,
    "endTime": 203.66,
    "text": "I was only exaggerating on the internet."
  },
  {
    "startTime": 203.66,
    "endTime": 204.46,
    "text": "Ice Bear innocent."
  },
  {
    "startTime": 204.46,
    "endTime": 205.0,
    "text": "Hang on."
  },
  {
    "startTime": 205.0,
    "endTime": 206.059,
    "text": "Bear flu?"
  },
  {
    "startTime": 206.059,
    "endTime": 207.059,
    "text": "This is out of control."
  },
  {
    "startTime": 207.059,
    "endTime": 208.139,
    "text": "These bears are fine."
  },
  {
    "startTime": 208.139,
    "endTime": 209.779,
    "text": "But what about the bear flu?"
  },
  {
    "startTime": 209.779,
    "endTime": 210.69899999999998,
    "text": "There's no such thing."
  },
  {
    "startTime": 210.699,
    "endTime": 211.899,
    "text": "It's fictitious."
  },
  {
    "startTime": 211.899,
    "endTime": 213.3,
    "text": "She is a doctor, sir."
  },
  {
    "startTime": 213.3,
    "endTime": 213.8,
    "text": "Code red."
  },
  {
    "startTime": 213.9,
    "endTime": 215.979,
    "text": "Possible outbreak of crop top syndrome in the Midwest."
  },
  {
    "startTime": 215.979,
    "endTime": 217.02,
    "text": "All right, we're done here."
  },
  {
    "startTime": 217.02,
    "endTime": 218.139,
    "text": "Let's hustle, people."
  },
  {
    "startTime": 218.139,
    "endTime": 219.74,
    "text": "Thank you for your cooperation, citizens."
  },
  {
    "startTime": 224.46,
    "endTime": 226.20000000000002,
    "text": "I'm sorry, you guys, for today's mess."
  },
  {
    "startTime": 226.3,
    "endTime": 228.66000000000003,
    "text": "I probably should have just brought you to the doctors."
  },
  {
    "startTime": 228.66,
    "endTime": 229.57999999999998,
    "text": "It's OK, Chloe."
  },
  {
    "startTime": 229.58,
    "endTime": 230.94000000000003,
    "text": "We're going to be OK now anyways."
  },
  {
    "startTime": 230.94,
    "endTime": 232.38,
    "text": "Thanks for trying to look out for us."
  },
  {
    "startTime": 232.38,
    "endTime": 235.0,
    "text": "Ice Bear gained life experience and lost a little weight."
  },
  {
    "startTime": 235.2,
    "endTime": 237.1,
    "text": "I'd say just grab some juice for them on the way back."
  },
  {
    "startTime": 237.3,
    "endTime": 239.38000000000002,
    "text": "Achoo!"
  }
]