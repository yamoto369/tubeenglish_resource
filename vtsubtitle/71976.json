    "text": "(theme music playing)"
  },
  {
    "startTime": 4.1,
    "endTime": 7.6,
    "text": "Fellas, I've gathered you here today because this is Minnie's new house."
  },
  {
    "startTime": 7.23,
    "endTime": 10.629000000000001,
