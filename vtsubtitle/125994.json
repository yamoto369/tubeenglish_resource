  },
  {
    "startTime": 39.21,
    "endTime": 41.7,
    "text": "It was pretty great."
  },
  {
    "startTime": 41.7,
    "endTime": 45.06,
    "text": "I was a favorite toy, actually."
  },
  {
    "startTime": 45.06,
    "endTime": 48.72,
    "text": "Running the room was my job, keeping all the toys in play."
  },
  {
    "startTime": 48.72,
    "endTime": 51.69,
