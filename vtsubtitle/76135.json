[
  {
    "startTime": 12.792,
    "endTime": 15.434,
    "text": "(Music: \\\"East Virginia\\\")"
  },
  {
    "startTime": 15.458,
    "endTime": 17.708,
    "text": "(Banjo)"
  },
  {
    "startTime": 52.958,
    "endTime": 56.643,
    "text": "(Singing) I'm from"
  },
  {
    "startTime": 56.667,
    "endTime": 62.667,
    "text": "old East Virginia."
  },
  {
    "startTime": 64.5,
    "endTime": 68.184,
    "text": "North Carolina"
  },
  {
    "startTime": 68.208,
    "endTime": 70.417,
    "text": "I did go."
  },
  {
    "startTime": 71.708,
    "endTime": 73.559,
    "text": "I met"
  },
  {
    "startTime": 73.583,
    "endTime": 79.833,
    "text": "a fair, young maiden."
  },
  {
    "startTime": 81.5,
    "endTime": 86.726,
    "text": "Her name I did not know."
  },
  {
    "startTime": 86.75,
    "endTime": 92.625,
    "text": "(Banjo)"
  },
  {
    "startTime": 125.125,
    "endTime": 128.643,
    "text": "Don't that road"
  },
  {
    "startTime": 128.667,
    "endTime": 133.792,
    "text": "look rough and rocky?"
  },
  {
    "startTime": 136.167,
    "endTime": 139.5,
    "text": "Don't that sea look wide and deep?"
  },
  {
    "startTime": 141.792,
    "endTime": 145.893,
    "text": "Don't my darlin'"
  },
  {
    "startTime": 145.917,
    "endTime": 149.268,
    "text": "look"
  },
  {
    "startTime": 149.292,
    "endTime": 150.833,
    "text": "the sweetest ..."
  },
  {
    "startTime": 153.417,
    "endTime": 156.351,
    "text": "When she's in my arms asleep?"
  },
  {
    "startTime": 156.375,
    "endTime": 161.125,
    "text": "(Banjo)"
  },
  {
    "startTime": 185.167,
    "endTime": 188.934,
    "text": "Her hair"
  },
  {
    "startTime": 188.958,
    "endTime": 194.708,
    "text": "was a dark-brown curly."
  },
  {
    "startTime": 196.958,
    "endTime": 201.167,
    "text": "Her cheeks were chestnut red."
  },
  {
    "startTime": 202.292,
    "endTime": 204.851,
    "text": "On her breast"
  },
  {
    "startTime": 204.875,
    "endTime": 210.458,
    "text": "she wore a white lilly."
  },
  {
    "startTime": 212.42,
    "endTime": 215.58999999999997,
    "text": "Through the night, the tears she shed."
  },
  {
    "startTime": 215.83,
    "endTime": 220.667,
    "text": "(Banjo)"
  },
  {
    "startTime": 246.833,
    "endTime": 250.434,
    "text": "Captain,"
  },
  {
    "startTime": 250.458,
    "endTime": 256.82,
    "text": "Captain, I am dyin'."
  },
  {
    "startTime": 257.958,
    "endTime": 262.91700000000003,
    "text": "Won't you take these words for me?"
  },
  {
    "startTime": 264.458,
    "endTime": 266.18,
    "text": "Take them back"
  },
  {
    "startTime": 266.42,
    "endTime": 271.457,
    "text": "to old East Virginia."
  },
  {
    "startTime": 273.83,
    "endTime": 278.393,
    "text": "Tell my darlin' she is free."
  },
  {
    "startTime": 278.417,
    "endTime": 281.351,
    "text": "(Banjo)"
  },
  {
    "startTime": 281.375,
    "endTime": 284.18,
    "text": "(Music ends)"
  },
  {
    "startTime": 284.42,
    "endTime": 290.457,
    "text": "(Applause and cheers)"
  },
  {
    "startTime": 292.25,
    "endTime": 294.851,
    "text": "That was a song called \\\"East Virginia\\\""
  },
  {
    "startTime": 294.875,
    "endTime": 296.809,
    "text": "I learned from a man named Clifton Hicks"
  },
  {
    "startTime": 296.833,
    "endTime": 298.375,
    "text": "who lives down in Georgia."
  },
  {
    "startTime": 299.333,
    "endTime": 300.833,
    "text": "The next song ..."
  },
  {
    "startTime": 302.417,
    "endTime": 305.351,
    "text": "I have for you"
  },
  {
    "startTime": 305.375,
    "endTime": 307.643,
    "text": "is called \\\"John Brown's Dream.\\\""
  },
  {
    "startTime": 307.667,
    "endTime": 309.683,
    "text": "It's an old dance tune."
  },
  {
    "startTime": 309.708,
    "endTime": 313.39300000000003,
    "text": "And you may notice that the banjo that I'm holding looks a little different"
  },
  {
    "startTime": 313.417,
    "endTime": 315.768,
    "text": "than banjos you might be used to seeing"
  },
  {
    "startTime": 315.792,
    "endTime": 318.933,
    "text": "or the one I just played, for example."
  },
  {
    "startTime": 318.958,
    "endTime": 324.18,
    "text": "And this banjo is sort of an earlier model."
  },
  {
    "startTime": 324.42,
    "endTime": 327.26800000000003,
    "text": "Banjos kind of evolved like a human has."
  },
  {
    "startTime": 327.292,
    "endTime": 331.351,
    "text": "And I like to say that the sound that comes out of this banjo"
  },
  {
    "startTime": 331.375,
    "endTime": 336.351,
    "text": "is a sound that was just a little closer to the source,"
  },
  {
    "startTime": 336.375,
    "endTime": 337.684,
    "text": "which is Africa,"
  },
  {
    "startTime": 337.708,
    "endTime": 339.14300000000003,
    "text": "and some people forget that,"
  },
  {
    "startTime": 339.167,
    "endTime": 340.933,
    "text": "so, yeah ..."
  },
  {
    "startTime": 340.958,
    "endTime": 346.375,
    "text": "(Banjo tuning)"
  },
  {
    "startTime": 351.792,
    "endTime": 354.101,
    "text": "(Music: \\\"John Brown's Dream\\\")"
  },
  {
    "startTime": 354.125,
    "endTime": 357.292,
    "text": "(Banjo)"
  },
  {
    "startTime": 414.125,
    "endTime": 416.875,
    "text": "(Banjo continues)"
  },
  {
    "startTime": 463.542,
    "endTime": 465.643,
    "text": "(Singing) John Brown's dream,"
  },
  {
    "startTime": 465.667,
    "endTime": 467.518,
    "text": "John Brown's dream the devil was dead."
  },
  {
    "startTime": 467.542,
    "endTime": 469.433,
    "text": "I'm gonna get that, get that, get that,"
  },
  {
    "startTime": 469.458,
    "endTime": 471.351,
    "text": "I'm gonna get that pretty little girl."
  },
  {
    "startTime": 471.375,
    "endTime": 474.875,
    "text": "(Banjo)"
  },
  {
    "startTime": 518.707,
    "endTime": 520.808,
    "text": "John Brown's dream,"
  },
  {
    "startTime": 520.832,
    "endTime": 522.933,
    "text": "John Brown's dream the devil was dead."
  },
  {
    "startTime": 522.957,
    "endTime": 526.308,
    "text": "(Banjo)"
  },
  {
    "startTime": 526.332,
    "endTime": 528.183,
    "text": "Come on, Liza, Liza, Liza."
  },
  {
    "startTime": 528.207,
    "endTime": 530.143,
    "text": "Come on, Liza we'll be pickin' it again."
  },
  {
    "startTime": 530.167,
    "endTime": 532.58,
    "text": "I'm gonna get that, get that, get that,"
  },
  {
    "startTime": 532.82,
    "endTime": 533.9330000000001,
    "text": "I'm gonna get that pretty little girl."
  },
  {
    "startTime": 533.957,
    "endTime": 540.101,
    "text": "(Banjo)"
  },
  {
    "startTime": 540.125,
    "endTime": 542.559,
    "text": "(Music ends)"
  },
  {
    "startTime": 542.583,
    "endTime": 545.875,
    "text": "(Applause and cheers)"
  },
  {
    "startTime": 548.83,
    "endTime": 549.2330000000001,
    "text": "Thank you very much."
  }
]