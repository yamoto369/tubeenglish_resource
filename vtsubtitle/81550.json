[
  {
    "startTime": 0.0,
    "endTime": 1.799,
    "text": "Hello, ladies and gentlemen!"
  },
  {
    "startTime": 1.8,
    "endTime": 4.14,
    "text": "Tom here for BBC Learning English."
  },
  {
    "startTime": 4.14,
    "endTime": 7.66,
    "text": "Today I'm going to explain the difference between"
  },
  {
    "startTime": 7.66,
    "endTime": 10.780000000000001,
    "text": "'everyone' and 'anyone'."
  },
  {
    "startTime": 10.78,
    "endTime": 13.76,
    "text": "When I say 'hello everyone',"
  },
  {
    "startTime": 13.76,
    "endTime": 17.06,
    "text": "I'm talking to all the people in a group"
  },
  {
    "startTime": 17.06,
    "endTime": 20.709,
    "text": "or all the people watching this video."
  },
  {
    "startTime": 20.71,
    "endTime": 26.380000000000003,
    "text": "'Anyone', however, relates to any one individual person"
  },
  {
    "startTime": 26.38,
    "endTime": 31.299,
    "text": "in a group, and we often use it to ask questions."
  },
  {
    "startTime": 31.3,
    "endTime": 32.619,
    "text": "For example:"
  },
  {
    "startTime": 32.619,
    "endTime": 35.18,
    "text": "Is anyone listening?"
  },
  {
    "startTime": 35.18,
    "endTime": 39.8,
    "text": "Or: Can anyone answer today's question?"
  },
  {
    "startTime": 39.8,
    "endTime": 44.22,
    "text": "Here I'm asking if any individuals in the group"
  },
  {
    "startTime": 44.22,
    "endTime": 45.16,
    "text": "are listening."
  },
  {
    "startTime": 45.16,
    "endTime": 48.739,
    "text": "If the whole group is listening, we can say:"
  },
  {
    "startTime": 48.74,
    "endTime": 51.82,
    "text": "Yes, everyone is listening!"
  },
  {
    "startTime": 51.82,
    "endTime": 56.18,
    "text": "- Which is something that English teachers love to hear."
  }
]