  },
  {
    "startTime": 423.12,
    "endTime": 423.8,
    "text": "Done."
  },
  {
    "startTime": 423.8,
    "endTime": 428.696,
    "text": "Ellen, what was the\nword you're thinking of?"
  },
  {
    "startTime": 428.696,
    "endTime": 429.57000000000005,
    "text": "I wasn't thinking it."
  },
  {
    "startTime": 429.57,
    "endTime": 429.65999999999997,
    "text": "Oh."
  },
  {
    "startTime": 429.66,
    "endTime": 430.56,
    "text": "But I read it from your book."
  },
  {
    "startTime": 430.56,
    "endTime": 431.06,
    "text": "Yeah."
  },
  {
    "startTime": 431.06,
    "endTime": 432.6,
    "text": "But Super Mario."
  },
  {
    "startTime": 432.6,
    "endTime": 433.389,
    "text": "Oh, yeah."
  },
  {
    "startTime": 433.389,
    "endTime": 434.43,
    "text": "I used to love that game."
  },
  {
    "startTime": 434.43,
    "endTime": 435.47,
    "text": "Yeah."
  },
  {
    "startTime": 435.47,
    "endTime": 438.15200000000004,
    "text": "See sometimes the image\nlooks a little crazy."
  },
  {
    "startTime": 438.152,
    "endTime": 439.86,
    "text": "When you really hone\nin on that thought--"
  },
  {
    "startTime": 439.86,
    "endTime": 440.75,
    "text": "Right."
  },
  {
    "startTime": 440.75,
    "endTime": 443.52,
    "text": "--you can actually\nmake Super Mario."
  },
  {
    "startTime": 443.52,
    "endTime": 444.41999999999996,
    "text": "[AUDIENCE GASPS]"
  },
  {
    "startTime": 444.42,
    "endTime": 446.22,
    "text": "[APPLAUSE]"
  },
  {
    "startTime": 447.42,
    "endTime": 448.02000000000004,
    "text": "Wow."
  },
  {
    "startTime": 448.02,
    "endTime": 449.21999999999997,
    "text": "[LAUGHS]"
  },
  {
    "startTime": 451.92,
    "endTime": 452.82,
    "text": "You're amazing."
  },
  {
    "startTime": 452.82,
    "endTime": 454.02,
    "text": "Thank you so much, Ellen."
  },
  {
    "startTime": 454.02,
    "endTime": 454.32,
    "text": "You're amazing."
  },
  {
    "startTime": 454.32,
    "endTime": 454.62,
    "text": "Awesome."
  },
  {
    "startTime": 454.62,
    "endTime": 454.92,
    "text": "Thank you."
  },
  {
    "startTime": 454.92,
    "endTime": 455.42,
    "text": "Thank you."
  },
  {
    "startTime": 455.42,
