[
  {
    "startTime": 1.335,
    "endTime": 4.213,
    "text": "Welcome to Ryme City."
  },
  {
    "startTime": 4.796,
    "endTime": 8.217,
    "text": "A celebration of the harmony between humans and Pokémon."
  },
  {
    "startTime": 8.342,
    "endTime": 12.93,
    "text": "♪  ♪"
  },
  {
    "startTime": 12.93,
    "endTime": 16.683,
    "text": "Tim, your dad was a legend in this precinct."
  },
  {
    "startTime": 17.559,
    "endTime": 18.852,
    "text": "- If you are anything like your dad--"
  },
  {
    "startTime": 18.852,
    "endTime": 20.729,
    "text": "- I'm not."
  },
  {
    "startTime": 22.773,
    "endTime": 26.485,
    "text": "I remember you wanted to be a Pokémon trainer"
  },
  {
    "startTime": 26.485,
    "endTime": 28.403,
    "text": "when you were young."
  },
  {
    "startTime": 29.321,
    "endTime": 31.907,
    "text": "- Yeah, that didn't really work out."
  },
  {
    "startTime": 36.245,
    "endTime": 37.62,
    "text": "Someone there?"
  },
  {
    "startTime": 40.332,
    "endTime": 43.126,
    "text": "Whoever you are, I know how to use this."
  },
  {
    "startTime": 44.878,
    "endTime": 46.4,
    "text": "Aw, jeez."
  },
  {
    "startTime": 46.4,
    "endTime": 47.4,
    "text": "Here we go."
  },
  {
    "startTime": 47.5,
    "endTime": 49.424,
    "text": "I know you can't understand me."
  },
  {
    "startTime": 49.424,
    "endTime": 51.9,
    "text": "But put down the stapler..."
  },
  {
    "startTime": 51.9,
    "endTime": 55.722,
    "text": "... or I will electrocute you."
  },
  {
    "startTime": 55.722,
    "endTime": 58.141,
    "text": "♪  ♪"
  },
  {
    "startTime": 58.141,
    "endTime": 59.434,
    "text": "Did you just talk?"
  },
  {
    "startTime": 59.434,
    "endTime": 60.561,
    "text": "Whoa."
  },
  {
    "startTime": 60.561,
    "endTime": 61.687,
    "text": "Did you just understand me?"
  },
  {
    "startTime": 61.687,
    "endTime": 62.437,
    "text": "- Oh, my God!"
  },
  {
    "startTime": 62.437,
    "endTime": 63.564,
    "text": "You can understand me!"
  },
  {
    "startTime": 63.564,
    "endTime": 64.188,
    "text": "- Stop!"
  },
  {
    "startTime": 64.188,
    "endTime": 65.648,
    "text": "I have been so lonely!"
  },
  {
    "startTime": 65.649,
    "endTime": 66.69200000000001,
    "text": "They try to talk to me all the time."
  },
  {
    "startTime": 66.692,
    "endTime": 67.943,
    "text": "All they hear is “Pika-Pika.”"
  },
  {
    "startTime": 67.943,
    "endTime": 69.152,
    "text": "You can hear him, right?"
  },
  {
    "startTime": 69.152,
    "endTime": 70.529,
    "text": "Pika-Pika."
  },
  {
    "startTime": 70.529,
    "endTime": 71.238,
    "text": "Yeah."
  },
  {
    "startTime": 71.238,
    "endTime": 72.489,
    "text": "Pika-Pika-Pika."
  },
  {
    "startTime": 72.489,
    "endTime": 73.74000000000001,
    "text": "He's adorable."
  },
  {
    "startTime": 73.74,
    "endTime": 74.741,
    "text": "You're adorable."
  },
  {
    "startTime": 74.741,
    "endTime": 75.826,
    "text": "They can't understand me, kid."
  },
  {
    "startTime": 75.826,
    "endTime": 77.35,
    "text": "- Can no one else hear him?!"
  },
  {
    "startTime": 77.35,
    "endTime": 79.36,
    "text": "♪  ♪"
  },
  {
    "startTime": 79.37,
    "endTime": 80.706,
    "text": "I don't need a Pokémon. Period."
  },
  {
    "startTime": 80.706,
    "endTime": 82.583,
    "text": "Then what about a world-class detective."
  },
  {
    "startTime": 82.583,
    "endTime": 84.96,
    "text": "Becase if you wanna find your pops..."
  },
  {
    "startTime": 84.96,
    "endTime": 87.86,
    "text": "... I'm your best bet."
  },
  {
    "startTime": 87.629,
    "endTime": 89.882,
    "text": "We're gonna do this, you and me."
  },
  {
    "startTime": 89.882,
    "endTime": 96.763,
    "text": "♪  I can't see me loving nobody but you for all my life  ♪"
  },
  {
    "startTime": 98.932,
    "endTime": 101.31,
    "text": "There's magic. It brought us together."
  },
  {
    "startTime": 101.31,
    "endTime": 103.729,
    "text": "And that magic is called hope."
  },
  {
    "startTime": 106.607,
    "endTime": 108.317,
    "text": "Listen up, we got ways to make you talk,"
  },
  {
    "startTime": 108.317,
    "endTime": 109.526,
    "text": "or mime... - Yeah."
  },
  {
    "startTime": 109.526,
    "endTime": 111.195,
    "text": "...So tell us what we wanna know."
  },
  {
    "startTime": 111.195,
    "endTime": 114.71,
    "text": "Pipe. Yes. Okay. A can."
  },
  {
    "startTime": 114.72,
    "endTime": 115.24,
    "text": "Shoving? Pushing."
  },
  {
    "startTime": 115.24,
    "endTime": 116.324,
    "text": "My problem is that I push people away and"
  },
  {
    "startTime": 116.325,
    "endTime": 117.70100000000001,
    "text": "then hate them for leaving."
  },
  {
    "startTime": 117.701,
    "endTime": 119.35,
    "text": "He's saying you can shove it."
  },
  {
    "startTime": 119.36,
    "endTime": 119.661,
    "text": "- What?"
  },
  {
    "startTime": 119.661,
    "endTime": 120.495,
    "text": "I can shove it?"
  },
  {
    "startTime": 120.495,
    "endTime": 121.455,
    "text": "Okay, that's it. No. We're switching roles."
  },
  {
    "startTime": 121.455,
    "endTime": 123.164,
    "text": "I'm bad cop, you're good cop."
  },
  {
    "startTime": 123.165,
    "endTime": 124.41600000000001,
    "text": "- No, we're not cops."
  },
  {
    "startTime": 126.71,
    "endTime": 128.29399999999998,
    "text": "In my head, I saw that differently."
  }
]