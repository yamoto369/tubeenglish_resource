  },
  {
    "startTime": 125.709,
    "endTime": 128.79500000000002,
    "text": "Are you sure this is what the kids are driving these days?"
  },
  {
    "startTime": 128.878,
    "endTime": 130.839,
    "text": "Only the cool kids."
  },
  {
    "startTime": 132.508,
    "endTime": 137.179,
    "text": "Hey, you guys must be lost! Dufus Drive is around the corner!"
  },
  {
    "startTime": 137.346,
