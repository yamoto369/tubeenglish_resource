  },
  {
    "startTime": 194.194,
    "endTime": 197.072,
    "text": "SpongeBob, aren't you two supposed to be camping?"
  },
  {
    "startTime": 197.155,
    "endTime": 198.365,
    "text": "We are camping."
  },
  {
    "startTime": 198.532,
    "endTime": 202.244,
    "text": "SpongeBob, it's not camping if you're ten feet from your house."
  },
  {
    "startTime": 202.327,
    "endTime": 205.914,
    "text": "Nah, it doesn't matter where you are as long as you're outdoors."
  },
  {
    "startTime": 206.039,
    "endTime": 213.881,
    "text": "While all those soft city folk are safe in their beds reading books, we're out here pitting ourselves against the formidable forces of nature!"
  },
  {
    "startTime": 213.964,
    "endTime": 215.924,
    "text": "-You wanna join us? -No!"
  },
  {
    "startTime": 216.008,
    "endTime": 218.46800000000002,
    "text": "Okay, have fun inside."
  },
  {
    "startTime": 229.521,
    "endTime": 231.648,
