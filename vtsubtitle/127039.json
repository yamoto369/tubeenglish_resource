  },
  {
    "startTime": 111.737,
    "endTime": 117.116,
    "text": "Nine hundred ninety-nine, one thousand. Ready or not, here I come."
  },
  {
    "startTime": 118.619,
    "endTime": 119.995,
    "text": "You found me!"
  },
  {
    "startTime": 122.539,
    "endTime": 124.374,
