  },
  {
    "startTime": 101.3,
    "endTime": 102.402,
    "text": "Kathryn Schmooze."
  },
  {
    "startTime": 104.537,
    "endTime": 109.60000000000001,
    "text": "She says, \"My old job had a phone in the restroom. Our boss would call it if he thought you'd been in there too long.\""
  },
  {
    "startTime": 109.975,
    "endTime": 111.69999999999999,
    "text": "Oh! Come on, man."
  },
  {
    "startTime": 111.845,
    "endTime": 113.746,
    "text": "That's not good. What? Come on, dude."
  },
  {
    "startTime": 113.746,
    "endTime": 115.115,
    "text": "Come on, man."
  },
  {
    "startTime": 118.217,
    "endTime": 120.185,
    "text": "This one's from @Johnathan_Young_."
  },
  {
    "startTime": 120.185,
    "endTime": 125.7,
    "text": "He said, \"My boss asked if I had a knife to open a box. I gave her one. I was later written up for having a knife at work.\""
  },
  {
    "startTime": 125.925,
    "endTime": 127.56,
    "text": "Come on. That's entrapment!"
  },
  {
    "startTime": 127.7,
    "endTime": 129.362,
    "text": "Come on, that's catch-22."
  },
  {
    "startTime": 131.531,
    "endTime": 132.70000000000002,
    "text": "Hey, Brain, you got a knife?"
  },
  {
    "startTime": 132.765,
    "endTime": 135.0,
    "text": "Yeah, yeah, Brain."
  },
  {
    "startTime": 134.9,
    "endTime": 137.905,
    "text": "This one's from @YZracer81."
  },
  {
    "startTime": 138.1,
    "endTime": 145.6,
    "text": "He says, \"I made a mistake at work and my boss called me up to chew me out. At the end of the conversation he made me say, 'I've been a bad boy.'\""
  },
  {
    "startTime": 146.212,
    "endTime": 149.07,
    "text": "I don't...I don't know."
  },
  {
    "startTime": 149.2,
    "endTime": 150.283,
    "text": "That wasn't about work."
  },
  {
    "startTime": 152.618,
    "endTime": 154.787,
    "text": "I don't know, man. Yeah."
  },
  {
    "startTime": 154.787,
    "endTime": 157.389,
    "text": "This one is from @CaptainHarris1."
  },
  {
    "startTime": 157.389,
    "endTime": 164.20000000000002,
    "text": "He says, \"I worked at a convenience store for one day. I quit when I saw the instructions for 'what to do when you get robbed.'  Not 'if' - 'WHEN.'\""
  },
  {
    "startTime": 164.964,
    "endTime": 167.399,
    "text": "This place gets robbed?"
  },
  {
    "startTime": 167.399,
