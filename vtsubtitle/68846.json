  },
  {
    "startTime": 131.463,
    "endTime": 132.665,
    "text": "You know what I'm saying?"
  },
  {
    "startTime": 132.665,
    "endTime": 133.733,
    "text": "Yeah, I think."
  },
  {
    "startTime": 133.733,
    "endTime": 135.167,
    "text": "But I'm a vampire, so I can't even --"
  },
  {
    "startTime": 135.167,
