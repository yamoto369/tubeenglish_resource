  {
    "startTime": 94.927,
    "endTime": 96.59500000000001,
    "text": "No, zero licensing. And it's filthy."
  },
  {
    "startTime": 96.595,
    "endTime": 98.464,
    "text": "Actually, it is a bar. It's a trampoline bar."
