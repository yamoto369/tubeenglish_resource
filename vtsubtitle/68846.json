    "startTime": 109.8,
    "endTime": 111.976,
    "text": "[ Laughter ]"
  },
  {
    "startTime": 112.077,
    "endTime": 113.312,
    "text": "I've always said that."
  },
  {
    "startTime": 113.312,
    "endTime": 114.847,
    "text": "Oh, you've always said that. You have that tattoo."
