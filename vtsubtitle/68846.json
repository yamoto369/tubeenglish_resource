  {
    "startTime": 98.464,
    "endTime": 99.199,
    "text": "Anyways."
  },
  {
    "startTime": 99.199,
    "endTime": 100.867,
    "text": "-Wait, it's a trampoline bar? -Anyways."
  },
  {
    "startTime": 100.867,
    "endTime": 103.63600000000001,
    "text": "Yes, and there's a 6-foot pool in there, as well."
  },
  {
    "startTime": 103.636,
    "endTime": 105.404,
    "text": "You could trampoline into the pool and drink."
  },
  {
    "startTime": 105.404,
    "endTime": 107.72999999999999,
    "text": "It's awful. They should close it down."
  },
  {
    "startTime": 107.33,
    "endTime": 109.8,
    "text": "I've been saying, \"Please close Mahuls.\""
