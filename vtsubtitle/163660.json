[
  {
    "startTime": 2.252,
    "endTime": 4.295,
    "text": "Um, hi."
  },
  {
    "startTime": 4.337,
    "endTime": 6.798,
    "text": "-Hi. -Is Monica around?"
  },
  {
    "startTime": 6.84,
    "endTime": 8.299,
    "text": "I-I have to ask her something."
  },
  {
    "startTime": 8.341,
    "endTime": 10.26,
    "text": "Doin' her laundry."
  },
  {
    "startTime": 10.301,
    "endTime": 12.262,
    "text": "What's that?"
  },
  {
    "startTime": 12.262,
    "endTime": 13.805,
    "text": "It came in the mail today."
  },
  {
    "startTime": 13.888,
    "endTime": 23.481,
    "text": "It's, uh, 72 long-stemmed red roses, one for each day that I've known and loved Emily cut up into mulch."
  },
  {
    "startTime": 25.483,
    "endTime": 27.36,
    "text": "Oh, honey, that's awful."
  },
  {
    "startTime": 27.36,
    "endTime": 29.738,
    "text": "Well, it's not so bad."
  },
  {
    "startTime": 29.738,
    "endTime": 31.781,
    "text": "Monica's gonna make Potpourri."
  },
  {
    "startTime": 35.368,
    "endTime": 39.247,
    "text": "I think I'm gonna ... go wander out in the rain for a while."
  },
  {
    "startTime": 39.998,
    "endTime": 41.291,
    "text": "But it-it's not raining."
  },
  {
    "startTime": 41.374,
    "endTime": 43.501000000000005,
    "text": "I can't catch a break."
  },
  {
    "startTime": 44.753,
    "endTime": 46.755,
    "text": "You know what, Ross? You're not going anywhere."
  },
  {
    "startTime": 46.755,
    "endTime": 48.506,
    "text": "You're gonna sit right here."
  },
  {
    "startTime": 48.59,
    "endTime": 52.010000000000005,
    "text": "I'm gonna make you a cup of tea, and we're gonna talk this whole thing out."
  },
  {
    "startTime": 52.01,
    "endTime": 52.76,
    "text": "All right."
  },
  {
    "startTime": 53.97,
    "endTime": 54.929,
    "text": "Okay."
  },
  {
    "startTime": 56.931,
    "endTime": 57.974,
    "text": "-Hey, Dave. -Yeah."
  },
  {
    "startTime": 57.974,
    "endTime": 60.634,
    "text": "Um, listen, I'm gonna need to take a rain check."
  },
  {
    "startTime": 60.634,
    "endTime": 62.687,
    "text": "My roommate is just really sick."
  },
  {
    "startTime": 62.687,
    "endTime": 64.188,
    "text": "Okay? Okay, bye."
  },
  {
    "startTime": 68.026,
    "endTime": 69.235,
    "text": "Honey, listen."
  },
  {
    "startTime": 70.153,
    "endTime": 74.32400000000001,
    "text": "I know, God, I know things seem so bad right now and that..."
  },
  {
    "startTime": 74.365,
    "endTime": 76.158,
    "text": "Rach?"
  },
  {
    "startTime": 76.201,
    "endTime": 78.202,
    "text": "Could I talk to you just for a minute?"
  },
  {
    "startTime": 79.329,
    "endTime": 80.788,
    "text": "I-I dropped some socks."
  },
  {
    "startTime": 82.04,
    "endTime": 83.37400000000001,
    "text": "Yeah, okay."
  },
  {
    "startTime": 90.59,
    "endTime": 91.75800000000001,
    "text": "What is the matter with you?"
  },
  {
    "startTime": 91.841,
    "endTime": 93.3,
    "text": "D-do you wanna fall into the trap?"
  },
  {
    "startTime": 93.384,
    "endTime": 94.886,
    "text": "Do you wanna fall into the trap?"
  },
  {
    "startTime": 95.371,
    "endTime": 97.597,
    "text": "You did not drop any socks!"
  },
  {
    "startTime": 98.556,
    "endTime": 100.767,
    "text": "I just ran into Dave, and he told me you blew him off."
  },
  {
    "startTime": 101.184,
    "endTime": 102.185,
    "text": "I mean, you listen to me."
  },
  {
    "startTime": 102.227,
    "endTime": 103.394,
    "text": "Now, I'm calling the shots."
  },
  {
    "startTime": 103.478,
    "endTime": 106.146,
    "text": "I say you leave Ross alone and go get Dave."
  },
  {
    "startTime": 106.231,
    "endTime": 107.607,
    "text": "What the hell are you trying to do?"
  },
  {
    "startTime": 107.607,
    "endTime": 114.405,
    "text": "Well, ultimately, I was trying, you know, I wan-wanted ... to tell him, you know, I was still in love with him."
  },
  {
    "startTime": 114.975,
    "endTime": 116.449,
    "text": "What?"
  },
  {
    "startTime": 116.616,
    "endTime": 118.743,
    "text": "You cannot tell him that."
  },
  {
    "startTime": 118.743,
    "endTime": 120.387,
    "text": "Why? Why not?"
  },
  {
    "startTime": 120.387,
    "endTime": 121.996,
    "text": "People love to hear that."
  },
  {
    "startTime": 123.832,
    "endTime": 126.25,
    "text": "I make the decisions, and I say no."
  },
  {
    "startTime": 126.334,
    "endTime": 127.043,
    "text": "Well, you know what?"
  },
  {
    "startTime": 127.043,
    "endTime": 131.047,
    "text": "No, you don't make my decisions because you're fired."
  },
  {
    "startTime": 132.048,
    "endTime": 133.758,
    "text": "You can't fire me."
  },
  {
    "startTime": 133.925,
    "endTime": 137.846,
    "text": "I make your decisions, and I say I'm not fired. Ha!"
  },
  {
    "startTime": 140.515,
    "endTime": 141.933,
    "text": "Well..."
  },
  {
    "startTime": 151.401,
    "endTime": 153.73600000000002,
    "text": "Rachel! Come on, let me in."
  },
  {
    "startTime": 153.778,
    "endTime": 155.113,
    "text": "Having some trouble?"
  },
  {
    "startTime": 156.364,
    "endTime": 157.824,
    "text": "Rachel locked the door."
  },
  {
    "startTime": 157.907,
    "endTime": 160.07600000000002,
    "text": "I'll kick that door in if you give me a little sugar."
  }
]