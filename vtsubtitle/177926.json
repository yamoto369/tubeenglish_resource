[
  {
    "startTime": 3.38,
    "endTime": 8.133,
    "text": "Mahito."
  },
  {
    "startTime": 8.133,
    "endTime": 11.0,
    "text": "So..."
  },
  {
    "startTime": 11.0,
    "endTime": 13.39,
    "text": "You made it."
  },
  {
    "startTime": 13.39,
    "endTime": 14.473,
    "text": "Mother."
  },
  {
    "startTime": 14.473,
    "endTime": 17.7,
    "text": "Have a seat."
  },
  {
    "startTime": 17.7,
    "endTime": 22.0,
    "text": "It's this way, Mahito."
  },
  {
    "startTime": 22.148,
    "endTime": 24.7,
    "text": "A lot of strange things happen in this place."
  },
  {
    "startTime": 24.7,
    "endTime": 26.36,
    "text": "Please join us!"
  },
  {
    "startTime": 26.36,
    "endTime": 30.0,
    "text": "I just hope he stays safe."
  },
  {
    "startTime": 30.0,
    "endTime": 31.073,
    "text": "Save me."
  },
  {
    "startTime": 31.073,
    "endTime": 33.7,
    "text": "Save me! Mahito!"
  },
  {
    "startTime": 33.7,
    "endTime": 37.080000000000005,
    "text": "What exactly are you?"
  },
  {
    "startTime": 37.08,
    "endTime": 39.0,
    "text": "Your mother..."
  },
  {
    "startTime": 39.0,
    "endTime": 42.293,
    "text": "She's awaiting your rescue."
  },
  {
    "startTime": 42.293,
    "endTime": 47.132,
    "text": "I'll be your guide."
  },
  {
    "startTime": 47.132,
    "endTime": 51.0,
    "text": "What is this place?"
  },
  {
    "startTime": 51.0,
    "endTime": 55.7,
    "text": "This world is filled with the dead."
  },
  {
    "startTime": 55.7,
    "endTime": 58.0,
    "text": "I know it's a lie...."
  },
  {
    "startTime": 58.0,
    "endTime": 62.0,
    "text": "But I have to see!"
  },
  {
    "startTime": 62.0,
    "endTime": 64.357,
    "text": "I'm looking for someone."
  },
  {
    "startTime": 64.357,
    "endTime": 68.0,
    "text": "Let's go."
  },
  {
    "startTime": 68.0,
    "endTime": 70.113,
    "text": "We must protect this world ourselves."
  },
  {
    "startTime": 70.113,
    "endTime": 72.0,
    "text": "Go back! Now!"
  },
  {
    "startTime": 72.0,
    "endTime": 73.0,
    "text": "Mahito!"
  },
  {
    "startTime": 73.0,
    "endTime": 75.0,
    "text": "Mahito!"
  },
  {
    "startTime": 75.0,
    "endTime": 79.8,
    "text": "You and I aren't friends or allies, kid."
  },
  {
    "startTime": 80.0,
    "endTime": 82.6,
    "text": "Don't let go. No matter what."
  },
  {
    "startTime": 82.6,
    "endTime": 90.258,
    "text": "Ready?"
  },
  {
    "startTime": 90.258,
    "endTime": 94.095,
    "text": "You see this world?"
  },
  {
    "startTime": 94.095,
    "endTime": 100.352,
    "text": "There's more work to be done."
  },
  {
    "startTime": 100.352,
    "endTime": 104.48,
    "text": "A gray heron once told me that all gray herons are liars."
  },
  {
    "startTime": 104.48,
    "endTime": 107.15,
    "text": "So, is that the truth or a lie?"
  },
  {
    "startTime": 107.15,
    "endTime": 109.0,
    "text": "- A lie. - The Truth."
  },
  {
    "startTime": 109.0,
    "endTime": 111.945,
    "text": "- That would have to be a lie too! - Except this lie is true!"
  }
]