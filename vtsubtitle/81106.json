[
  {
    "startTime": 9.4,
    "endTime": 18.78,
    "text": "How do you move on from a life you never got to live?"
  },
  {
    "startTime": 28.34,
    "endTime": 29.78,
    "text": "Yoo-hoo."
  },
  {
    "startTime": 29.95,
    "endTime": 31.54,
    "text": "Anyone home?"
  },
  {
    "startTime": 34.22,
    "endTime": 35.8,
    "text": "Jack is not coming back."
  },
  {
    "startTime": 35.8,
    "endTime": 37.919999999999995,
    "text": "There's nothing you could have done."
  },
  {
    "startTime": 37.92,
    "endTime": 42.08,
    "text": "There wasn't enough room on the door for both of you."
  },
  {
    "startTime": 46.86,
    "endTime": 50.4,
    "text": "We spent three weeks searching the Atlantic."
  },
  {
    "startTime": 50.4,
    "endTime": 52.98,
    "text": "For bodies from Titanic."
  },
  {
    "startTime": 52.98,
    "endTime": 55.459999999999994,
    "text": "And we found them all."
  },
  {
    "startTime": 55.46,
    "endTime": 59.46,
    "text": "Except one."
  },
  {
    "startTime": 68.18,
    "endTime": 72.12,
    "text": "His body was washed up on a beach in Ibiza."
  },
  {
    "startTime": 72.12,
    "endTime": 74.0,
    "text": "His wallet and ID were in his pocket."
  },
  {
    "startTime": 74.0,
    "endTime": 75.32,
    "text": "- Well, that's convenient. - Quite."
  },
  {
    "startTime": 75.45,
    "endTime": 77.82000000000001,
    "text": "But I thought he was dead."
  },
  {
    "startTime": 77.82,
    "endTime": 80.03999999999999,
    "text": "Didn't he drown on the Titanic?"
  },
  {
    "startTime": 80.04,
    "endTime": 83.88000000000001,
    "text": "Well, of course, it is what we all thought until now."
  },
  {
    "startTime": 83.88,
    "endTime": 86.0,
    "text": "They never found a body."
  },
  {
    "startTime": 88.7,
    "endTime": 91.44,
    "text": "Jack, Rose had to let you go."
  },
  {
    "startTime": 93.02,
    "endTime": 95.78,
    "text": "We all thought you were dead."
  },
  {
    "startTime": 95.78,
    "endTime": 98.6,
    "text": "Like a frozen popsicle."
  },
  {
    "startTime": 101.9,
    "endTime": 104.98,
    "text": "Jack, Rose deserves to know the truth."
  },
  {
    "startTime": 104.98,
    "endTime": 106.8,
    "text": "You need to go to her."
  },
  {
    "startTime": 106.8,
    "endTime": 109.08,
    "text": "You belong together."
  },
  {
    "startTime": 111.0,
    "endTime": 112.719,
    "text": "I'm not an idiot."
  },
  {
    "startTime": 112.719,
    "endTime": 114.04899999999999,
    "text": "I know how the world works."
  },
  {
    "startTime": 114.049,
    "endTime": 119.16000000000001,
    "text": "I've got 10 bucks in my pocket. I have nothing to offer you, and I know that."
  },
  {
    "startTime": 119.16,
    "endTime": 120.16,
    "text": "I understand."
  },
  {
    "startTime": 120.16,
    "endTime": 122.67999999999999,
    "text": "But I'm too involved now."
  },
  {
    "startTime": 123.26,
    "endTime": 125.02000000000001,
    "text": "You jump, I jump, remember?"
  },
  {
    "startTime": 125.02,
    "endTime": 127.94,
    "text": "I can't turn away without knowing you'll be alright."
  },
  {
    "startTime": 129.02,
    "endTime": 130.44,
    "text": "That's all that I want."
  },
  {
    "startTime": 132.3,
    "endTime": 133.24,
    "text": "Well, I'm fine."
  },
  {
    "startTime": 134.26,
    "endTime": 135.76,
    "text": "I'll be fine."
  },
  {
    "startTime": 135.82,
    "endTime": 136.9,
    "text": "Really."
  },
  {
    "startTime": 137.84,
    "endTime": 139.36,
    "text": "Really?"
  },
  {
    "startTime": 140.76,
    "endTime": 142.16,
    "text": "I don't think so."
  },
  {
    "startTime": 150.32,
    "endTime": 152.16,
    "text": "I'm sorry for everything."
  },
  {
    "startTime": 152.48,
    "endTime": 155.44,
    "text": "And I love you."
  }
]