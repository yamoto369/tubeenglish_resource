  },
  {
    "startTime": 37.621,
    "endTime": 40.499,
    "text": "He's beating up Squidward! Ha ha ha!"
  },
  {
    "startTime": 41.291,
    "endTime": 42.793,
    "text": "[moaning]"
  },
  {
    "startTime": 43.877,
    "endTime": 45.295,
    "text": "DoodleBob, stop!"
  },
  {
    "startTime": 45.379,
    "endTime": 47.256,
    "text": "Ah! Ow."
  },
  {
    "startTime": 47.506,
    "endTime": 48.799,
    "text": "[moaning]"
  },
  {
    "startTime": 54.304,
    "endTime": 55.973,
    "text": "He's got the pencil."
  },
  {
    "startTime": 56.056,
    "endTime": 58.559,
    "text": "What have I done? We've got to find him."
  },
  {
    "startTime": 58.725,
    "endTime": 62.104,
    "text": "This is great! You and me in school together."
  },
  {
    "startTime": 62.396,
    "endTime": 65.19,
    "text": "- So, where's the teacher? - You're looking at him."
  },
  {
    "startTime": 65.315,
    "endTime": 70.32,
    "text": "You are the teacher to my pupil?"
  },
  {
    "startTime": 70.696,
    "endTime": 73.615,
    "text": "This isn't art class, it's heaven."
  },
  {
    "startTime": 73.699,
    "endTime": 76.368,
    "text": "Alright SpongeBob, pay close attention."
  },
  {
    "startTime": 76.952,
    "endTime": 78.62,
    "text": "Look at your marble."
  },
  {
    "startTime": 78.996,
    "endTime": 81.747,
    "text": "Visualize the sculpture within."
  },
  {
    "startTime": 82.124,
    "endTime": 84.625,
    "text": "Then gently..."
  },
  {
    "startTime": 90.632,
    "endTime": 91.80000000000001,
    "text": "How's this, Squidward?"
  },
  {
    "startTime": 91.967,
    "endTime": 93.886,
    "text": "It's beautiful."
  },
  {
    "startTime": 94.887,
    "endTime": 98.14,
    "text": "I mean, this isn't a sculpture."
  },
  {
    "startTime": 98.223,
    "endTime": 101.727,
    "text": "A good sculpture takes... more time."
  },
  {
    "startTime": 101.852,
    "endTime": 106.14800000000001,
    "text": "You can't just sculpt willy nilly. You gotta go by the book."
  },
  {
    "startTime": 106.315,
    "endTime": 111.111,
    "text": "Follow the rules, otherwise you'll never get past amateur hour here."
  },
  {
    "startTime": 111.236,
    "endTime": 113.405,
    "text": "Besides, you got the nose wrong."
  },
  {
    "startTime": 115.365,
    "endTime": 118.702,
    "text": "There, now it's art."
  },
  {
    "startTime": 118.994,
    "endTime": 121.246,
    "text": "Oh, it's so obvious!"
  },
  {
    "startTime": 121.33,
    "endTime": 123.373,
    "text": "I would have never thought of that."
  },
  {
    "startTime": 124.458,
    "endTime": 127.878,
    "text": "Alright, Patrick. Gotta get started painting this wall,"
  },
  {
    "startTime": 128.044,
    "endTime": 131.048,
    "text": "with the permanent paint that we aren't allowed to get on anything,"
  },
  {
    "startTime": 131.131,
    "endTime": 132.132,
    "text": "but the wall."
  },
  {
    "startTime": 132.508,
    "endTime": 134.59300000000002,
    "text": "Well... here we go."
  },
  {
    "startTime": 136.845,
    "endTime": 140.182,
    "text": "Just a few more seconds of mental preparation and I'll be"
  },
  {
    "startTime": 140.265,
    "endTime": 141.517,
    "text": "painting this wall."
  },
  {
    "startTime": 143.644,
    "endTime": 145.89600000000002,
    "text": "I'm getting to the painting."
  },
  {
    "startTime": 148.315,
    "endTime": 150.984,
    "text": "Can you move it along? I'm all out of time cards."
  },
  {
    "startTime": 151.235,
    "endTime": 153.52900000000002,
    "text": "No problem, here I go."
  },
  {
    "startTime": 160.494,
    "endTime": 161.495,
    "text": "Huh?"
  },
  {
    "startTime": 162.12,
    "endTime": 163.288,
    "text": "[blowing]"
  },
  {
    "startTime": 178.095,
    "endTime": 180.0,
    "text": "Yeah. Huh?"
  },
  {
    "startTime": 181.723,
    "endTime": 185.227,
    "text": "Barnacles! What could be worse than a giant paint bubble?"
  },
  {
    "startTime": 185.435,
    "endTime": 186.478,
    "text": "Oh, I know."
  },
  {
    "startTime": 189.648,
    "endTime": 191.233,
    "text": "Two giant paint bubbles."
  },
  {
    "startTime": 191.4,
    "endTime": 192.943,
    "text": "No!"
  },
  {
    "startTime": 196.864,
    "endTime": 198.824,
    "text": "- Patrick? - Yeah, SpongeBob?"
  },
  {
    "startTime": 199.157,
    "endTime": 200.95100000000002,
    "text": "I don't think this bubble can get much bigger."
  },
  {
    "startTime": 201.034,
    "endTime": 202.119,
    "text": "Nonsense!"
  },
  {
    "startTime": 204.204,
    "endTime": 205.33,
    "text": "Pat, no!"
  },
  {
    "startTime": 216.049,
    "endTime": 218.76000000000002,
    "text": "And what has door knob number two been up to?"
  },
  {
    "startTime": 224.516,
    "endTime": 226.894,
    "text": "I've been making baskets too!"
  },
  {
    "startTime": 228.645,
    "endTime": 231.315,
    "text": "Darn! This hammer is defective."
  },
  {
    "startTime": 231.732,
    "endTime": 234.276,
    "text": "- Do you wanna make crafts too? - Crafts?"
  },
  {
    "startTime": 235.027,
    "endTime": 238.988,
    "text": "This isn't summer camp. I am a true artist."
  },
  {
    "startTime": 240.0,
    "endTime": 245.954,
    "text": "Oh man, I'll never make art like you and Squidward!"
  },
  {
    "startTime": 245.996,
    "endTime": 247.08,
    "text": "[sobbing]"
  },
  {
    "startTime": 247.164,
    "endTime": 250.291,
    "text": "Hey, don't be sad. You can be an artist too."
  },
  {
    "startTime": 250.417,
    "endTime": 254.004,
    "text": "I'll find something that will tap into your particular artistic skill set."
  },
  {
    "startTime": 254.087,
    "endTime": 255.797,
    "text": "Now, let me see."
  },
  {
    "startTime": 256.214,
    "endTime": 258.007,
    "text": "Oh, this'll be perfect!"
  },
  {
    "startTime": 258.382,
    "endTime": 261.594,
    "text": "Start with a rock, a little glue..."
  },
  {
    "startTime": 262.888,
    "endTime": 265.431,
    "text": "- Uh... - Stick on a couple of googly eyes."
  },
  {
    "startTime": 266.642,
    "endTime": 268.06,
    "text": "Whoa, slow down, SpongeBob."
  },
  {
    "startTime": 268.101,
    "endTime": 271.396,
    "text": "And presto! A rock with googly eyes!"
  },
  {
    "startTime": 271.522,
    "endTime": 274.65,
    "text": "Whoa! Ha, I did not see that coming!"
  },
  {
    "startTime": 274.691,
    "endTime": 276.902,
    "text": "- Now you try. - I'm scared."
  },
  {
    "startTime": 276.985,
    "endTime": 278.153,
    "text": "You can do this."
  },
  {
    "startTime": 278.237,
    "endTime": 280.23900000000003,
    "text": "I shall make the attempt!"
  },
  {
    "startTime": 281.949,
    "endTime": 283.534,
    "text": "- Privacy, please. - Sorry."
  },
  {
    "startTime": 285.244,
    "endTime": 286.32800000000003,
    "text": "[moaning]"
  },
  {
    "startTime": 289.122,
    "endTime": 291.5,
    "text": "- I did it! - Yeah! Let's take a look."
  },
  {
    "startTime": 291.708,
    "endTime": 292.87600000000003,
    "text": "Behold..."
  },
  {
    "startTime": 294.545,
    "endTime": 296.588,
    "text": "Ah! Oh!"
  },
  {
    "startTime": 296.88,
    "endTime": 299.091,
    "text": "Ooh, it's beautiful!"
  },
  {
    "startTime": 299.174,
    "endTime": 301.133,
    "text": "I'm an artist!"
  },
  {
    "startTime": 301.218,
    "endTime": 302.469,
    "text": "- Hooray! - Hooray!"
  }
