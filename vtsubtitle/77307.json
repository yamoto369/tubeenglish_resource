[
  {
    "startTime": 0.0,
    "endTime": 1.05,
    "text": "Welcome home."
  },
  {
    "startTime": 1.05,
    "endTime": 2.59,
    "text": "Welcome back."
  },
  {
    "startTime": 2.59,
    "endTime": 3.389,
    "text": "Good to have you."
  },
  {
    "startTime": 3.39,
    "endTime": 4.496,
    "text": "We missed you!"
  },
  {
    "startTime": 7.62,
    "endTime": 10.89,
    "text": "Thanks for sticking with us for more than 24 years of these characters."
  },
  {
    "startTime": 10.89,
    "endTime": 13.02,
    "text": "We're just so appreciative of you, the fans."
  },
  {
    "startTime": 13.02,
    "endTime": 13.92,
    "text": "Hey!"
  },
  {
    "startTime": 13.92,
    "endTime": 14.74,
    "text": "Watch it, buddy!"
  },
  {
    "startTime": 14.74,
    "endTime": 15.540000000000001,
    "text": "What do we do?"
  },
  {
    "startTime": 15.54,
    "endTime": 23.009999999999998,
    "text": "Thank you so much for your years of support and affection for these magnificent Pixar movies."
  },
  {
    "startTime": 23.01,
    "endTime": 24.41,
    "text": "We need to get back to our kid."
  },
  {
    "startTime": 24.41,
    "endTime": 27.75,
    "text": "Aww, Sheriff Woody always coming to the rescue."
  },
  {
    "startTime": 27.75,
    "endTime": 30.21,
    "text": "We missed you and you're going to love this."
  },
  {
    "startTime": 30.21,
    "endTime": 31.560000000000002,
    "text": "You're going to love it."
  },
  {
    "startTime": 31.56,
    "endTime": 32.46,
    "text": "Thanks for all the support."
  },
  {
    "startTime": 32.46,
    "endTime": 34.593,
    "text": "Aren't you supposed to say, we hope you're going to love this,"
  },
  {
    "startTime": 34.593,
    "endTime": 35.503,
    "text": "as opposed to-- - No, no."
  },
  {
    "startTime": 35.503,
    "endTime": 36.37,
    "text": "You're going to love this."
  },
  {
    "startTime": 36.37,
    "endTime": 37.236,
    "text": "I guess go, go."
  },
  {
    "startTime": 37.237,
    "endTime": 38.79,
    "text": "Follow your-- follow your heart."
  },
  {
    "startTime": 38.79,
    "endTime": 39.79,
    "text": "- Let's go. - Hey."
  },
  {
    "startTime": 39.79,
    "endTime": 41.04,
    "text": "If you got to go, you got to go."
  },
  {
    "startTime": 41.04,
    "endTime": 42.96,
    "text": "Thank you so much for being part of the \"Toy Story\" family for so many years."
  },
  {
    "startTime": 44.28,
    "endTime": 45.660000000000004,
    "text": "We love these characters so much"
  },
  {
    "startTime": 45.66,
    "endTime": 48.388999999999996,
    "text": "and we know you will enjoy this wonderful journey with them."
  }
]