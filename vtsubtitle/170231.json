[
  {
    "startTime": 5.7,
    "endTime": 6.396,
    "text": "I got him."
  },
  {
    "startTime": 24.9,
    "endTime": 27.36,
    "text": "Gotta move your foot here."
  },
  {
    "startTime": 27.36,
    "endTime": 29.38,
    "text": "Point your toe this way."
  },
  {
    "startTime": 29.38,
    "endTime": 30.799999999999997,
    "text": "Yes. Here."
  },
  {
    "startTime": 30.8,
    "endTime": 35.2,
    "text": "OK?"
  },
  {
    "startTime": 35.3,
    "endTime": 38.4,
    "text": "Mind your elbow."
  },
  {
    "startTime": 39.6,
    "endTime": 43.045,
    "text": "Good job, Hawkeye."
  },
  {
    "startTime": 55.27,
    "endTime": 58.300000000000004,
    "text": "(OFF-SCREEN) Cooper! Where are my headphones?"
  },
  {
    "startTime": 58.33,
    "endTime": 60.269999999999996,
    "text": "Lila?"
  },
  {
    "startTime": 60.27,
    "endTime": 61.24,
    "text": "Lila?"
  },
  {
    "startTime": 65.915,
    "endTime": 67.89500000000001,
    "text": "Lila!"
  },
  {
    "startTime": 71.8,
    "endTime": 75.334,
    "text": "Yeah, Dad?"
  },
  {
    "startTime": 78.7,
    "endTime": 79.4,
    "text": "It worked."
  },
  {
    "startTime": 87.7,
    "endTime": 89.9,
    "text": "Just like Budapest all over again."
  },
  {
    "startTime": 90.0,
    "endTime": 96.4,
    "text": "You and I remember Budapest very differently."
  },
  {
    "startTime": 96.6,
    "endTime": 99.6,
    "text": "You want me to slow him down, sir?"
  },
  {
    "startTime": 99.7,
    "endTime": 101.9,
    "text": "Or are you sending in more guys for him to beat up?"
  },
  {
    "startTime": 102.0,
    "endTime": 105.5,
    "text": "I'll let you know."
  },
  {
    "startTime": 105.5,
    "endTime": 108.455,
    "text": "You better call it, Coulson, because I'm starting to root for this guy."
  },
  {
    "startTime": 113.3,
    "endTime": 114.6,
    "text": "I guess I should have knocked."
  },
  {
    "startTime": 114.9,
    "endTime": 118.30000000000001,
    "text": "Oh, my God. What are you doing here?"
  },
  {
    "startTime": 118.5,
    "endTime": 124.4,
    "text": "Disappointing my kids."
  },
  {
    "startTime": 124.4,
    "endTime": 126.7,
    "text": "We're supposed to go water skiing."
  },
  {
    "startTime": 126.7,
    "endTime": 128.229,
    "text": "Cap needs our help. Come on."
  },
  {
    "startTime": 131.9,
    "endTime": 133.70000000000002,
    "text": "Clint, can you get him off me?"
  },
  {
    "startTime": 133.7,
    "endTime": 134.7,
    "text": "Buckled in?"
  },
  {
    "startTime": 134.7,
    "endTime": 137.7,
    "text": "Yeah. No, I'm good. I'm good, arrow guy. Let's go."
  },
  {
    "startTime": 138.0,
    "endTime": 140.715,
    "text": "Let's go!"
  },
  {
    "startTime": 155.2,
    "endTime": 157.76999999999998,
    "text": "Whatever it takes."
  },
  {
    "startTime": 160.9,
    "endTime": 168.70000000000002,
    "text": "If we don't get that stone, billions of people stay dead."
  },
  {
    "startTime": 168.9,
    "endTime": 171.4,
    "text": "Then I guess we both know who it's got to be."
  },
  {
    "startTime": 171.6,
    "endTime": 174.714,
    "text": "I guess we do."
  },
  {
    "startTime": 181.2,
    "endTime": 182.5,
    "text": "The city is flying."
  },
  {
    "startTime": 182.5,
    "endTime": 185.2,
    "text": "We're fighting an army of robots."
  },
  {
    "startTime": 185.3,
    "endTime": 186.4,
    "text": "And I have a bow and arrow."
  },
  {
    "startTime": 186.6,
    "endTime": 189.5,
    "text": "None of this makes sense."
  },
  {
    "startTime": 191.4,
    "endTime": 194.48000000000002,
    "text": "But I'm going back out there because it's my job."
  },
  {
    "startTime": 194.48,
    "endTime": 194.6,
    "text": "OK?"
  },
  {
    "startTime": 194.6,
    "endTime": 197.1,
    "text": "And I can't do my job and babysit."
  },
  {
    "startTime": 197.1,
    "endTime": 200.29999999999998,
    "text": "Doesn't matter what you did or what you were."
  },
  {
    "startTime": 200.3,
    "endTime": 203.60000000000002,
    "text": "If you go out there, you fight, and you fight to kill."
  },
  {
    "startTime": 203.6,
    "endTime": 205.29999999999998,
    "text": "Stay in here, you're good."
  },
  {
    "startTime": 205.3,
    "endTime": 207.28,
    "text": "I'll send your brother to come find you. But if you step out that door, you are an Avenger."
  },
  {
    "startTime": 233.9,
    "endTime": 239.4,
    "text": "Authorities are wondering if the masked vigilante who terrorized the city's underworld is back."
  },
  {
    "startTime": 239.5,
    "endTime": 244.4,
    "text": "When I wore this suit, I made a whole lot of enemies."
  },
  {
    "startTime": 244.4,
    "endTime": 245.3,
    "text": "You're Hawkeye!"
  },
  {
    "startTime": 245.3,
    "endTime": 246.8,
    "text": "Who the hell are you?"
  },
  {
    "startTime": 247.0,
    "endTime": 254.3,
    "text": "Some people actually call me the world's greatest archer."
  },
  {
    "startTime": 254.5,
    "endTime": 256.7,
    "text": "This is too dangerous."
  },
  {
    "startTime": 256.8,
    "endTime": 257.90000000000003,
    "text": "Definitely not this one."
  },
  {
    "startTime": 257.9,
    "endTime": 261.9,
    "text": "You don't have to say \"definitely\" like that."
  },
  {
    "startTime": 261.9,
    "endTime": 265.76,
    "text": "There are arrows more dangerous than that one?"
  }
]