[
  {
    "startTime": 0.1,
    "endTime": 1.0,
    "text": "Here we go."
  },
  {
    "startTime": 1.1,
    "endTime": 4.4,
    "text": "In three... two⏤whoa!⏤one."
  },
  {
    "startTime": 15.0,
    "endTime": 16.8,
    "text": "What do we have here?"
  },
  {
    "startTime": 16.9,
    "endTime": 18.4,
    "text": "And here, I thought we were special."
  },
  {
    "startTime": 18.5,
    "endTime": 20.0,
    "text": "Fellas, this here is Bagman."
  },
  {
    "startTime": 20.1,
    "endTime": 21.5,
    "text": "- Hangman.  - Whatever."
  },
  {
    "startTime": 21.6,
    "endTime": 22.900000000000002,
    "text": "What the hell kind of mission is this?"
  },
  {
    "startTime": 28.3,
    "endTime": 30.1,
    "text": "Everyone here is the best there is."
  },
  {
    "startTime": 30.2,
    "endTime": 32.6,
    "text": "Who the hell are they gonna get to teach us?"
  },
  {
    "startTime": 38.2,
    "endTime": 41.0,
    "text": "Captain Pete \"Maverick\" Mitchell."
  },
  {
    "startTime": 41.7,
    "endTime": 43.400000000000006,
    "text": "Let me be perfectly blunt."
  },
  {
    "startTime": 43.5,
    "endTime": 44.9,
    "text": "You are not my first choice."
  },
  {
    "startTime": 45.0,
    "endTime": 49.0,
    "text": "You are here at the request of Admiral Kazansky, a.k.a. Iceman."
  },
  {
    "startTime": 49.1,
    "endTime": 51.800000000000004,
    "text": "He seems to think that you have something left to offer the Navy."
  },
  {
    "startTime": 51.9,
    "endTime": 53.5,
    "text": "What that is, I can't imagine."
  },
  {
    "startTime": 56.4,
    "endTime": 58.8,
    "text": "With all due respect, sir, I'm not a teacher."
  },
  {
    "startTime": 60.1,
    "endTime": 62.0,
    "text": "Just want to manage expectations."
  },
  {
    "startTime": 64.9,
    "endTime": 66.0,
    "text": "What the hell?"
  },
  {
    "startTime": 66.6,
    "endTime": 68.39999999999999,
    "text": "Good morning, aviators."
  },
  {
    "startTime": 69.8,
    "endTime": 71.39999999999999,
    "text": "This is your captain speaking."
  },
  {
    "startTime": 74.4,
    "endTime": 75.7,
    "text": "And we're off."
  },
  {
    "startTime": 76.4,
    "endTime": 77.60000000000001,
    "text": "Here we go."
  },
  {
    "startTime": 77.7,
    "endTime": 83.3,
    "text": "In three... two... one."
  },
  {
    "startTime": 89.8,
    "endTime": 93.89999999999999,
    "text": "We're going into combat on a level no living pilot's ever seen."
  },
  {
    "startTime": 94.5,
    "endTime": 95.8,
    "text": "Not even him."
  },
  {
    "startTime": 96.6,
    "endTime": 98.3,
    "text": "You think up there, you're dead."
  },
  {
    "startTime": 98.4,
    "endTime": 99.5,
    "text": "Believe me."
  },
  {
    "startTime": 104.5,
    "endTime": 106.1,
    "text": "My dad believed in you."
  },
  {
    "startTime": 106.8,
    "endTime": 108.5,
    "text": "I'm not gonna make the same mistake."
  },
  {
    "startTime": 113.5,
    "endTime": 115.2,
    "text": "Someone's not coming back from this."
  },
  {
    "startTime": 116.3,
    "endTime": 118.2,
    "text": "Those are your pilots."
  },
  {
    "startTime": 118.3,
    "endTime": 120.0,
    "text": "Anything happens to them..."
  },
  {
    "startTime": 121.0,
    "endTime": 122.7,
    "text": "Smoke in the air! Smoke in the air!"
  },
  {
    "startTime": 125.2,
    "endTime": 127.2,
    "text": "... you'll never forgive yourself."
  },
  {
    "startTime": 129.5,
    "endTime": 131.1,
    "text": "No turning back now."
  },
  {
    "startTime": 131.2,
    "endTime": 132.2,
    "text": "Come on!"
  },
  {
    "startTime": 137.2,
    "endTime": 138.29999999999998,
    "text": "Having any fun yet?"
  }
]