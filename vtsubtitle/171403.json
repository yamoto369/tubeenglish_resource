[
  {
    "startTime": 5.3,
    "endTime": 10.0,
    "text": "There was a time when sea beasts would ravage our shores..."
  },
  {
    "startTime": 11.0,
    "endTime": 14.0,
    "text": "... and no ship was safe on the sea."
  },
  {
    "startTime": 16.0,
    "endTime": 18.0,
    "text": "But those days are over."
  },
  {
    "startTime": 20.4,
    "endTime": 25.0,
    "text": "Today, valiant warriors battle the beasts far beyond the horizon."
  },
  {
    "startTime": 29.3,
    "endTime": 33.1,
    "text": "You're Jacob Holland, a weapon against nature's darkest design."
  },
  {
    "startTime": 33.2,
    "endTime": 35.300000000000004,
    "text": "And I'm joining your crew."
  },
  {
    "startTime": 35.4,
    "endTime": 36.699999999999996,
    "text": "Oh, no, you ain't."
  },
  {
    "startTime": 37.2,
    "endTime": 39.5,
    "text": "Hey! Put me down; let me go!"
  },
  {
    "startTime": 43.4,
    "endTime": 46.5,
    "text": "We'll be off to kill a monster!"
  },
  {
    "startTime": 51.4,
    "endTime": 53.199999999999996,
    "text": "You stowed away?"
  },
  {
    "startTime": 53.3,
    "endTime": 54.3,
    "text": "I..."
  },
  {
    "startTime": 54.7,
    "endTime": 56.7,
    "text": "- Yeah.  - I like this kid."
  },
  {
    "startTime": 58.7,
    "endTime": 60.800000000000004,
    "text": "We're dropping you off at the nearest port."
  },
  {
    "startTime": 60.9,
    "endTime": 62.9,
    "text": "A hunting ship ain't no place for a kid."
  },
  {
    "startTime": 63.0,
    "endTime": 65.2,
    "text": "But you joined the ship when you were my age."
  },
  {
    "startTime": 65.3,
    "endTime": 67.1,
    "text": "Hold on, Maisie!"
  },
  {
    "startTime": 68.3,
    "endTime": 69.89999999999999,
    "text": "And look at you now."
  },
  {
    "startTime": 71.3,
    "endTime": 73.2,
    "text": "That's not the same thing."
  },
  {
    "startTime": 73.3,
    "endTime": 74.39999999999999,
    "text": "Isn't it?"
  },
  {
    "startTime": 74.5,
    "endTime": 75.5,
    "text": "No."
  },
  {
    "startTime": 75.6,
    "endTime": 76.6,
    "text": "It isn't."
  },
  {
    "startTime": 77.4,
    "endTime": 79.4,
    "text": "The Dregmorr is thick with monsters."
  },
  {
    "startTime": 79.5,
    "endTime": 81.2,
    "text": "Monsters that wanna eat us."
  },
  {
    "startTime": 81.3,
    "endTime": 83.0,
    "text": "We're not keeping it."
  },
  {
    "startTime": 83.1,
    "endTime": 84.5,
    "text": "But he's so cute."
  },
  {
    "startTime": 86.7,
    "endTime": 89.60000000000001,
    "text": "You and I have a different idea of cute."
  },
  {
    "startTime": 90.6,
    "endTime": 93.1,
    "text": "Just don't move."
  },
  {
    "startTime": 96.5,
    "endTime": 97.5,
    "text": "Best be going."
  },
  {
    "startTime": 105.7,
    "endTime": 107.5,
    "text": "I see a fire in her."
  },
  {
    "startTime": 107.9,
    "endTime": 109.80000000000001,
    "text": "Same fire I saw in you."
  },
  {
    "startTime": 110.4,
    "endTime": 112.4,
    "text": "The monsters I can handle."
  },
  {
    "startTime": 112.4,
    "endTime": 114.0,
    "text": "We got it right where we want it."
  },
  {
    "startTime": 114.1,
    "endTime": 115.5,
    "text": "- Wait, Jacob!  - That one..."
  },
  {
    "startTime": 117.5,
    "endTime": 118.9,
    "text": "She'll be the death of me."
  },
  {
    "startTime": 122.2,
    "endTime": 126.0,
    "text": "I swore I would do everything in my power to keep people safe."
  },
  {
    "startTime": 126.1,
    "endTime": 129.0,
    "text": "You can be a hero and still be wrong."
  },
  {
    "startTime": 131.2,
    "endTime": 133.39999999999998,
    "text": "The ocean has sent us its worst..."
  },
  {
    "startTime": 133.5,
    "endTime": 135.7,
    "text": "... then, we'll send it right back."
  },
  {
    "startTime": 138.3,
    "endTime": 139.3,
    "text": "Fire!"
  },
  {
    "startTime": 146.7,
    "endTime": 148.2,
    "text": "I've always wanted a pet."
  },
  {
    "startTime": 148.6,
    "endTime": 150.1,
    "text": "That's not a pet."
  },
  {
    "startTime": 150.2,
    "endTime": 151.7,
    "text": "But I already named it."
  },
  {
    "startTime": 151.9,
    "endTime": 153.0,
    "text": "Let me guess."
  },
  {
    "startTime": 153.3,
    "endTime": 154.3,
    "text": "Blue."
  }
]